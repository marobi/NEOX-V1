; ============================================================
; config.inc
; NEOX - kernel configuration
;
; Purpose:
; ============================================================

.ifndef __CONFIG_INC__
__CONFIG_INC__ = 1

; ------------------------------------------------------------
; Limits
; ------------------------------------------------------------

MAX_FDS     = 4          ; per-process descriptor count
OPEN_MAX    = 8          ; system-wide open object slots

; ------------------------------------------------------------
; Maximum simultaneously active processes
; ------------------------------------------------------------

MAX_PROCS   = 4

; ------------------------------------------------------------
; Maximum simultaneously active timer waits
; ------------------------------------------------------------

MAX_TIMER   = 8

; ============================================================
;
; ============================================================

USER_IMAGE_TABLE = $2000

; ------------------------------------------------------------
; Kernel
; ------------------------------------------------------------

KERNEL_BASE = $8000

; ------------------------------------------------------------
; Syscall table location
; ------------------------------------------------------------

SYSCALL_BASE = $C000

; ------------------------------------------------------------
; RP2350 mailbox control registers (MMIO)
;
; Layout:
;   Page D is shared I/O space
;   OS-owned mailbox control starts at $D010
; ------------------------------------------------------------

RP_DOORBELL  = $D010

; ------------------------------------------------------------
; Shared RAM request/result block
;
; mailbox request block.
; ------------------------------------------------------------

RP_REQ_BASE  = $E000

.endif
