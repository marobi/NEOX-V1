
BIOS:
F000  4C 2F F0 JMP @retry
F003  4C 3B F0 JMP _PUTCHAR
F006  4C 95 F0 JMP EMPTY
F009  4C 95 F0 JMP EMPTY
F00C  4C 60 F0 JMP SET_MMU_CONTEXT_AND_RTI
F00F  4C 78 F0 JMP SET_MMU_CONTEXT_AND_JUMP
F012  4C 55 F0 JMP ACK_IRQ
F015  4C 95 F0 JMP EMPTY
F018  4C 95 F0 JMP EMPTY
F01B  4C 95 F0 JMP EMPTY
F01E  4C 95 F0 JMP EMPTY
F021  4C 95 F0 JMP EMPTY
F024  4C 95 F0 JMP EMPTY
F027  4C 95 F0 JMP EMPTY
F02A  4C 95 F0 JMP EMPTY

bios_jmp_vec:
F02D  00       BRK
F02E  00       BRK

@retry:
F02F  AD 00 D0 LDA $D000
F032  F0 FB    BEQ @retry
F034  9C 00 D0 STZ $D000
F037  29 7F    AND #$7F
F039  18       CLC
F03A  60       RTS

_PUTCHAR:
F03B  48       PHA

@busy:
F03C  AD 01 D0 LDA $D001
F03F  D0 FB    BNE @busy
F041  68       PLA
F042  8D 01 D0 STA $D001
F045  18       CLC
F046  60       RTS

exec_cmd:
F047  48       PHA

@wait_cmd:
F048  AD 02 D0 LDA $D002
F04B  D0 FB    BNE @wait_cmd
F04D  8E 03 D0 STX $D003
F050  68       PLA
F051  8D 02 D0 STA $D002
F054  60       RTS

ACK_IRQ:
F055  48       PHA
F056  9C 0C E0 STZ $E00C

@wait_ack:
F059  AD 0F E0 LDA $E00F
F05C  D0 FB    BNE @wait_ack
F05E  68       PLA
F05F  60       RTS

SET_MMU_CONTEXT_AND_RTI:
F060  AA       TAX
F061  78       SEI

@wait_cmd:
F062  AD 02 D0 LDA $D002
F065  D0 FB    BNE @wait_cmd
F067  8E 03 D0 STX $D003
F06A  A9 02    LDA #$02
F06C  8D 02 D0 STA $D002

@wait_completion:
F06F  AD 02 D0 LDA $D002
F072  D0 FB    BNE @wait_completion
F074  7A       PLY
F075  FA       PLX
F076  68       PLA
F077  40       RTI

SET_MMU_CONTEXT_AND_JUMP:
F078  78       SEI
F079  8E 2D F0 STX bios_jmp_vec
F07C  8C 2E F0 STY $F02E
F07F  AA       TAX

@wait_cmd:
F080  AD 02 D0 LDA $D002
F083  D0 FB    BNE @wait_cmd
F085  8E 03 D0 STX $D003
F088  A9 02    LDA #$02
F08A  8D 02 D0 STA $D002

@wait_completion:
F08D  AD 02 D0 LDA $D002
F090  D0 FB    BNE @wait_completion
F092  6C 2D F0 JMP (bios_jmp_vec)

EMPTY:
F095  00       BRK
F096  EA       NOP
