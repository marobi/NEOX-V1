
BIOS:
F000  4C 32 F0 JMP @retry
F003  4C 3E F0 JMP _PUTCHAR
F006  4C 58 F0 JMP ACK_IRQ
F009  4C 63 F0 JMP EMPTY
F00C  4C 63 F0 JMP EMPTY
F00F  4C 63 F0 JMP EMPTY
F012  4C 63 F0 JMP EMPTY
F015  4C 63 F0 JMP EMPTY
F018  4C 63 F0 JMP EMPTY
F01B  4C 63 F0 JMP EMPTY
F01E  4C 63 F0 JMP EMPTY
F021  4C 63 F0 JMP EMPTY
F024  4C 63 F0 JMP EMPTY
F027  4C 63 F0 JMP EMPTY
F02A  4C 63 F0 JMP EMPTY
F02D  4C 63 F0 JMP EMPTY

bios_jmp_vec:
F030  00       BRK
F031  00       BRK

@retry:
F032  AD 00 D0 LDA $D000
F035  F0 FB    BEQ @retry
F037  9C 00 D0 STZ $D000
F03A  29 7F    AND #$7F
F03C  18       CLC
F03D  60       RTS

_PUTCHAR:
F03E  48       PHA

@busy:
F03F  AD 01 D0 LDA $D001
F042  D0 FB    BNE @busy
F044  68       PLA
F045  8D 01 D0 STA $D001
F048  18       CLC
F049  60       RTS

exec_cmd:
F04A  48       PHA

@wait_cmd:
F04B  AD 02 D0 LDA $D002
F04E  D0 FB    BNE @wait_cmd
F050  8E 03 D0 STX $D003
F053  68       PLA
F054  8D 02 D0 STA $D002
F057  60       RTS

ACK_IRQ:
F058  48       PHA
F059  9C 0C E0 STZ $E00C

@wait_ack:
F05C  AD 0F E0 LDA $E00F
F05F  D0 FB    BNE @wait_ack
F061  68       PLA
F062  60       RTS

EMPTY:
F063  00       BRK
F064  EA       NOP
