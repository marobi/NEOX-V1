
BIOS:
F000  4C 46 F0 JMP _GETCHAR
F003  4C 70 F0 JMP _PUTCHAR
F006  4C F1 F0 JMP EMPTY
F009  4C F1 F0 JMP EMPTY
F00C  4C BD F0 JMP SET_MMU_CONTEXT_AND_RTI
F00F  4C 8B F0 JMP _GETLINE
F012  4C B2 F0 JMP ACK_IRQ
F015  4C D4 F0 JMP SET_MMU_CONTEXT_AND_JUMP
F018  4C F1 F0 JMP EMPTY
F01B  4C F1 F0 JMP EMPTY
F01E  4C F1 F0 JMP EMPTY
F021  4C F1 F0 JMP EMPTY
F024  4C F1 F0 JMP EMPTY
F027  4C F1 F0 JMP EMPTY
F02A  4C F1 F0 JMP EMPTY
F02D  4C F1 F0 JMP EMPTY

ocharbuf:
F030  00       BRK

icharbuf:
F031  00       BRK

read_blk:
F032  00       BRK
F033  00       BRK
F034  00       BRK
F035  00       BRK
F036  01 00    ORA ($00,X)

readc_blk:
F038  00       BRK
F039  00       BRK
F03A  31 F0    AND ($F0),Y
F03C  01 00    ORA ($00,X)

write_blk:
F03E  01 00    ORA ($00,X)
F040  30 F0    BMI read_blk
F042  01 00    ORA ($00,X)

bios_jmp_vec:
F044  00       BRK
F045  00       BRK

_GETCHAR:
F046  DA       PHX
F047  5A       PHY
F048  A2 38    LDX #$38
F04A  A0 F0    LDY #$F0
F04C  20 09 C0 JSR LC009
F04F  B0 19    BCS @ic_error
F051  09 00    ORA #$00
F053  D0 07    BNE @got_char
F055  8A       TXA
F056  D0 04    BNE @got_char
F058  A9 00    LDA #$00
F05A  80 08    BRA @ok_exit

@got_char:
F05C  AD 31 F0 LDA icharbuf
F05F  29 7F    AND #$7F
F061  9C 31 F0 STZ icharbuf

@ok_exit:
F064  7A       PLY
F065  FA       PLX
F066  09 00    ORA #$00
F068  18       CLC
F069  60       RTS

@ic_error:
F06A  7A       PLY
F06B  FA       PLX
F06C  A9 00    LDA #$00
F06E  38       SEC
F06F  60       RTS

_PUTCHAR:
F070  48       PHA
F071  29 7F    AND #$7F
F073  F0 10    BEQ @pc_ok
F075  8D 30 F0 STA ocharbuf
F078  DA       PHX
F079  5A       PHY
F07A  A2 3E    LDX #$3E
F07C  A0 F0    LDY #$F0
F07E  20 0C C0 JSR LC00C
F081  7A       PLY
F082  FA       PLX
F083  B0 03    BCS @pc_error

@pc_ok:
F085  68       PLA
F086  18       CLC
F087  60       RTS

@pc_error:
F088  68       PLA
F089  38       SEC
F08A  60       RTS

_GETLINE:
F08B  8E 34 F0 STX $F034
F08E  8C 35 F0 STY $F035
F091  8D 36 F0 STA $F036
F094  9C 37 F0 STZ $F037
F097  A2 32    LDX #$32
F099  A0 F0    LDY #$F0
F09B  20 09 C0 JSR LC009
F09E  B0 02    BCS @gl_error
F0A0  18       CLC
F0A1  60       RTS

@gl_error:
F0A2  38       SEC
F0A3  60       RTS

exec_cmd:
F0A4  48       PHA

@wait_cmd:
F0A5  AD 02 D0 LDA $D002
F0A8  D0 FB    BNE @wait_cmd
F0AA  8E 03 D0 STX $D003
F0AD  68       PLA
F0AE  8D 02 D0 STA $D002
F0B1  60       RTS

ACK_IRQ:
F0B2  48       PHA
F0B3  9C 12 D0 STZ $D012
F0B6  A9 01    LDA #$01
F0B8  20 A4 F0 JSR exec_cmd
F0BB  68       PLA
F0BC  60       RTS

SET_MMU_CONTEXT_AND_RTI:
F0BD  AA       TAX

@wait_cmd:
F0BE  AD 02 D0 LDA $D002
F0C1  D0 FB    BNE @wait_cmd
F0C3  8E 03 D0 STX $D003
F0C6  A9 02    LDA #$02
F0C8  8D 02 D0 STA $D002

@wait_completion:
F0CB  AD 02 D0 LDA $D002
F0CE  D0 FB    BNE @wait_completion
F0D0  7A       PLY
F0D1  FA       PLX
F0D2  68       PLA
F0D3  40       RTI

SET_MMU_CONTEXT_AND_JUMP:
F0D4  8E 44 F0 STX bios_jmp_vec
F0D7  8C 45 F0 STY $F045
F0DA  AA       TAX

@wait_cmd:
F0DB  AD 02 D0 LDA $D002
F0DE  D0 FB    BNE @wait_cmd
F0E0  8E 03 D0 STX $D003
F0E3  A9 02    LDA #$02
F0E5  8D 02 D0 STA $D002

@wait_completion:
F0E8  AD 02 D0 LDA $D002
F0EB  D0 FB    BNE @wait_completion
F0ED  58       CLI
F0EE  6C 44 F0 JMP (bios_jmp_vec)

EMPTY:
F0F1  00       BRK
F0F2  EA       NOP
