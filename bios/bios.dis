
BIOS:
F000  4C 46 F0 JMP @retry
F003  4C 68 F0 JMP _PUTCHAR
F006  4C E3 F0 JMP EMPTY
F009  4C E3 F0 JMP EMPTY
F00C  4C AE F0 JMP SET_MMU_CONTEXT_AND_RTI
F00F  4C 83 F0 JMP _GETLINE
F012  4C AA F0 JMP ACK_IRQ
F015  4C C6 F0 JMP SET_MMU_CONTEXT_AND_JUMP
F018  4C E3 F0 JMP EMPTY
F01B  4C E3 F0 JMP EMPTY
F01E  4C E3 F0 JMP EMPTY
F021  4C E3 F0 JMP EMPTY
F024  4C E3 F0 JMP EMPTY
F027  4C E3 F0 JMP EMPTY
F02A  4C E3 F0 JMP EMPTY
F02D  4C E3 F0 JMP EMPTY

ocharbuf:
F030  00       BRK

icharbuf:
F031  00       BRK

read_blk:
F032  00       BRK
F033  00       BRK
F034  00       BRK
F035  00       BRK
F036  01 00    ORA ($00,X)

readc_blk:
F038  00       BRK
F039  00       BRK
F03A  31 F0    AND ($F0),Y
F03C  01 00    ORA ($00,X)

write_blk:
F03E  01 00    ORA ($00,X)
F040  30 F0    BMI read_blk
F042  01 00    ORA ($00,X)

bios_jmp_vec:
F044  00       BRK
F045  00       BRK

@retry:
F046  DA       PHX
F047  5A       PHY

@retry2:
F048  A2 38    LDX #$38
F04A  A0 F0    LDY #$F0
F04C  20 09 C0 JSR LC009
F04F  B0 F7    BCS @retry2
F051  09 00    ORA #$00
F053  D0 05    BNE @got_char
F055  8A       TXA
F056  D0 02    BNE @got_char
F058  80 EE    BRA @retry2

@got_char:
F05A  AD 31 F0 LDA icharbuf
F05D  29 7F    AND #$7F
F05F  9C 31 F0 STZ icharbuf
F062  7A       PLY
F063  FA       PLX
F064  09 00    ORA #$00
F066  18       CLC
F067  60       RTS

_PUTCHAR:
F068  48       PHA
F069  29 7F    AND #$7F
F06B  F0 10    BEQ @pc_ok
F06D  8D 30 F0 STA ocharbuf
F070  DA       PHX
F071  5A       PHY
F072  A2 3E    LDX #$3E
F074  A0 F0    LDY #$F0
F076  20 0C C0 JSR LC00C
F079  7A       PLY
F07A  FA       PLX
F07B  B0 03    BCS @pc_error

@pc_ok:
F07D  68       PLA
F07E  18       CLC
F07F  60       RTS

@pc_error:
F080  68       PLA
F081  38       SEC
F082  60       RTS

_GETLINE:
F083  8E 34 F0 STX $F034
F086  8C 35 F0 STY $F035
F089  8D 36 F0 STA $F036
F08C  9C 37 F0 STZ $F037
F08F  A2 32    LDX #$32
F091  A0 F0    LDY #$F0
F093  20 09 C0 JSR LC009
F096  B0 02    BCS @gl_error
F098  18       CLC
F099  60       RTS

@gl_error:
F09A  38       SEC
F09B  60       RTS

exec_cmd:
F09C  48       PHA

@wait_cmd:
F09D  AD 02 D0 LDA $D002
F0A0  D0 FB    BNE @wait_cmd
F0A2  8E 03 D0 STX $D003
F0A5  68       PLA
F0A6  8D 02 D0 STA $D002
F0A9  60       RTS

ACK_IRQ:
F0AA  9C 0C E0 STZ $E00C
F0AD  60       RTS

SET_MMU_CONTEXT_AND_RTI:
F0AE  AA       TAX
F0AF  78       SEI

@wait_cmd:
F0B0  AD 02 D0 LDA $D002
F0B3  D0 FB    BNE @wait_cmd
F0B5  8E 03 D0 STX $D003
F0B8  A9 02    LDA #$02
F0BA  8D 02 D0 STA $D002

@wait_completion:
F0BD  AD 02 D0 LDA $D002
F0C0  D0 FB    BNE @wait_completion
F0C2  7A       PLY
F0C3  FA       PLX
F0C4  68       PLA
F0C5  40       RTI

SET_MMU_CONTEXT_AND_JUMP:
F0C6  78       SEI
F0C7  8E 44 F0 STX bios_jmp_vec
F0CA  8C 45 F0 STY $F045
F0CD  AA       TAX

@wait_cmd:
F0CE  AD 02 D0 LDA $D002
F0D1  D0 FB    BNE @wait_cmd
F0D3  8E 03 D0 STX $D003
F0D6  A9 02    LDA #$02
F0D8  8D 02 D0 STA $D002

@wait_completion:
F0DB  AD 02 D0 LDA $D002
F0DE  D0 FB    BNE @wait_completion
F0E0  6C 44 F0 JMP (bios_jmp_vec)

EMPTY:
F0E3  00       BRK
F0E4  EA       NOP
