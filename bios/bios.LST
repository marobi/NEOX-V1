000000r 1               ; ********************************
000000r 1               ; * BIOS RIEN MATTHIJSSE         *
000000r 1               ; *        NEO6502_MMU           *
000000r 1               ; * V3.0   APRIL 2026            *
000000r 1               ; ********************************
000000r 1               ;
000000r 1               	.SETCPU "65C02"
000000r 1               
000000r 1               	.include "bios.inc"
000000r 2               ;
000000r 2               ; BIOS jumptable + ...
000000r 2               ;
000000r 2               .ifndef __BIOS_INC__
000000r 2               __BIOS_INC__ = 1
000000r 2               
000000r 2               BIOS_IRQ_SOURCE =   $E00C
000000r 2               BIOS_IRQ_STATE  =   $E00F
000000r 2               
000000r 2               BIOS_BASE         = $F000
000000r 2               
000000r 2               BIOS_GETCHAR      = BIOS_BASE
000000r 2               BIOS_PUTCHAR      = BIOS_BASE+3
000000r 2               BIOS_INKEY        = BIOS_BASE+6
000000r 2               BIOS_STPKEY		  =	BIOS_BASE+9
000000r 2               BIOS_CONTEXT_RTI  = BIOS_BASE+12
000000r 2               BIOS_CONTEXT_JUMP = BIOS_BASE+15
000000r 2               BIOS_ACK_IRQ      = BIOS_BASE+18
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               	.include "syscall.inc"
000000r 2               ; ============================================================
000000r 2               ; syscall.inc
000000r 2               ; NEOX - syscall definitions
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Defines syscall numbers, fixed syscall entry addresses,
000000r 2               ;   error codes, and common syscall argument structures.
000000r 2               ;
000000r 2               ; Architecture:
000000r 2               ;   - Syscall jump table is located in shared page C
000000r 2               ;   - Each syscall entry is a 3-byte JMP stub
000000r 2               ;   - User code calls fixed syscall entry addresses
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ;   SYS_MONITOR enters supervisor/MICMON context through the
000000r 2               ;   kernel-defined monitor entry path. It is a controlled
000000r 2               ;   privileged transfer, not direct user control of MMU/scheduler.
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __SYSCALL_INC__
000000r 2               __SYSCALL_INC__ = 1
000000r 2               
000000r 2               .include "config.inc"
000000r 3               ; ============================================================
000000r 3               ; config.inc
000000r 3               ; NEOX - kernel configuration
000000r 3               ;
000000r 3               ; Purpose:
000000r 3               ; ============================================================
000000r 3               
000000r 3               .ifndef __CONFIG_INC__
000000r 3               __CONFIG_INC__ = 1
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_FDS     = 6          ; per-process descriptor count
000000r 3               OPEN_MAX    = 8          ; system-wide open object slots
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active processes
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_PROCS   = 4
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active timer waits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_TIMER   = 8
000000r 3               
000000r 3               ;
000000r 3               ;
000000r 3               ;
000000r 3               
000000r 3               MAX_PIPES       = 8
000000r 3               PIPE_BUF_SIZE   = 64
000000r 3               ; ============================================================
000000r 3               ;
000000r 3               ; ============================================================
000000r 3               
000000r 3               USER_IMAGE_TABLE = $2000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Kernel
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               KERNEL_BASE = $8000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Syscall table location
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               SYSCALL_BASE = $C000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; RP2350 mailbox control registers (MMIO)
000000r 3               ;
000000r 3               ; Layout:
000000r 3               ;   Page D is shared I/O space
000000r 3               ;   OS-owned mailbox control starts at $D010
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_DOORBELL  = $D010
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Shared RAM request/result block
000000r 3               ;
000000r 3               ; mailbox request block.
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_REQ_BASE  = $E000
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               SYSCALL_ENTRY_SIZE  = 3
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Standard file descriptors
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               STDIN               = 0
000000r 2               STDOUT              = 1
000000r 2               STDERR              = 2
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Syscall numbers
000000r 2               ; ------------------------------------------------------------
000000r 2               SYS_EXIT			= $00
000000r 2               SYS_CLOSE			= $02
000000r 2               SYS_READ            = $03
000000r 2               SYS_WRITE           = $04
000000r 2               SYS_MONITOR         = $05
000000r 2               SYS_PIPE			= $0A
000000r 2               SYS_YIELD           = $0B
000000r 2               SYS_SLEEP           = $0E
000000r 2               SYS_DUP				= $0F
000000r 2               SYS_DUP2			= $10
000000r 2               SYS_TICKS           = $11
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Fixed syscall entry addresses
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               sys_exit            = SYSCALL_BASE + (SYS_EXIT    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_close           = SYSCALL_BASE + (SYS_CLOSE   * SYSCALL_ENTRY_SIZE)
000000r 2               sys_read            = SYSCALL_BASE + (SYS_READ    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_write           = SYSCALL_BASE + (SYS_WRITE   * SYSCALL_ENTRY_SIZE)
000000r 2               sys_monitor         = SYSCALL_BASE + (SYS_MONITOR * SYSCALL_ENTRY_SIZE)
000000r 2               sys_pipe            = SYSCALL_BASE + (SYS_PIPE    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_yield           = SYSCALL_BASE + (SYS_YIELD   * SYSCALL_ENTRY_SIZE)
000000r 2               sys_sleep           = SYSCALL_BASE + (SYS_SLEEP   * SYSCALL_ENTRY_SIZE)
000000r 2               sys_dup				= SYSCALL_BASE + (SYS_DUP     * SYSCALL_ENTRY_SIZE)
000000r 2               sys_dup2			= SYSCALL_BASE + (SYS_DUP2    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_ticks           = SYSCALL_BASE + (SYS_TICKS   * SYSCALL_ENTRY_SIZE)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Common errno values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               E_OK                = 0
000000r 2               EIO                 = 3
000000r 2               EINVAL              = 6
000000r 2               EMFILE              = 8        ; too many open file descriptors
000000r 2               EBADF               = 9
000000r 2               ENODEV              = 10
000000r 2               ENOSYS              = 11
000000r 2               EAGAIN              = 12       ; operation would block / try again
000000r 2               ENOMEM              = 13       ; no free kernel memory/object/table slot
000000r 2               EPIPE               = 14       ; write on pipe with no readers
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Common read/write argument block
000000r 2               ;
000000r 2               ; fd:
000000r 2               ;   STDIN / STDOUT / STDERR
000000r 2               ;
000000r 2               ; buf_ptr:
000000r 2               ;   Pointer to caller buffer in the current task context
000000r 2               ;
000000r 2               ; len:
000000r 2               ;   Requested transfer length
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct rw_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2                   buf_ptr         .word
000000r 2                   len             .word
000000r 2               .endstruct
000000r 2               
000000r 2               RW_ARGS_SIZE = .sizeof(rw_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; SYSCALL helper macro
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Load X/Y with the address of an argument block and call the
000000r 2               ;   fixed syscall entry.
000000r 2               ;
000000r 2               ; Example:
000000r 2               ;   SYSCALL my_args, sys_write
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .macro SYSCALL argblk, entry
000000r 2                   ldx #<argblk
000000r 2                   ldy #>argblk
000000r 2                   jsr entry
000000r 2               .endmacro
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               
000000r 1               KBD_PORT   = $D000
000000r 1               DSP_PORT   = KBD_PORT + 1
000000r 1               CMD_PORT   = KBD_PORT + 2
000000r 1               PARAM_PORT = KBD_PORT + 3
000000r 1               
000000r 1               ; -----------------------------------------------------------------------------
000000r 1               
000000r 1               ; commands
000000r 1               CMD_NONE           = 0
000000r 1               CMD_ACK_IRQ        = 1
000000r 1               CMD_CONTEXT_SWITCH = 2
000000r 1               
000000r 1               ; -----------------------------------------------------------------------------
000000r 1               ; set up origin
000000r 1               	.segment "BIOS"
000000r 1               
000000r 1               BIOS:					; jump table (16 cmds)
000000r 1  4C rr rr     	JMP _GETCHAR		; get char low level
000003r 1  4C rr rr     	JMP _PUTCHAR		; put char low level
000006r 1  4C rr rr     	JMP EMPTY			;
000009r 1  4C rr rr     	JMP EMPTY			;
00000Cr 1  4C rr rr     	JMP SET_MMU_CONTEXT_AND_RTI	    ; switch context and rti
00000Fr 1  4C rr rr     	JMP SET_MMU_CONTEXT_AND_JUMP	; switch context and jump
000012r 1  4C rr rr     	JMP ACK_IRQ			; acknowledge IRQ
000015r 1  4C rr rr     	JMP EMPTY			; empty slot
000018r 1  4C rr rr     	JMP EMPTY			; empty slot
00001Br 1  4C rr rr     	JMP EMPTY			; empty slot
00001Er 1  4C rr rr     	JMP EMPTY			; empty slot
000021r 1  4C rr rr     	JMP EMPTY			; empty slot
000024r 1  4C rr rr     	JMP EMPTY			; empty slot
000027r 1  4C rr rr     	JMP EMPTY			; empty slot
00002Ar 1  4C rr rr     	JMP EMPTY			; empty slot
00002Dr 1               
00002Dr 1               ; -----------------------------------------------------------------------------
00002Dr 1               
00002Dr 1               bios_jmp_vec:
00002Dr 1  xx xx        	.res 2
00002Fr 1               
00002Fr 1               ; -----------------------------------------------------------------------------
00002Fr 1               ; read a key from input, only a-reg is used
00002Fr 1               ;
00002Fr 1               .proc _GETCHAR
00002Fr 1               @retry:
00002Fr 1  AD 00 D0     	lda KBD_PORT
000032r 1  F0 FB        	beq @retry
000034r 1  9C 00 D0     	stz KBD_PORT
000037r 1  29 7F        	and #$7F
000039r 1  18               clc
00003Ar 1  60               rts
00003Br 1               .endproc
00003Br 1               
00003Br 1               ; -----------------------------------------------------------------------------
00003Br 1               ; write a char to output, only a-reg is used
00003Br 1               ;
00003Br 1               .proc _PUTCHAR
00003Br 1  48           	pha
00003Cr 1               @busy:
00003Cr 1  AD 01 D0     	lda DSP_PORT
00003Fr 1  D0 FB        	bne @busy
000041r 1  68           	pla
000042r 1  8D 01 D0     	sta DSP_PORT
000045r 1  18           	clc
000046r 1  60               rts
000047r 1               .endproc
000047r 1               
000047r 1               ; exec command  A=cmd, X=param (optional)
000047r 1               ; wait for cmd == 0
000047r 1               ; set new cmd
000047r 1               ;
000047r 1               .proc exec_cmd
000047r 1  48           	pha
000048r 1               
000048r 1               @wait_cmd:
000048r 1  AD 02 D0     	lda CMD_PORT
00004Br 1  D0 FB        	bne @wait_cmd
00004Dr 1  8E 03 D0     	stx PARAM_PORT
000050r 1  68           	pla
000051r 1  8D 02 D0     	sta CMD_PORT
000054r 1               
000054r 1  60           	rts
000055r 1               .endproc
000055r 1               
000055r 1               ;
000055r 1               ; ack IRQ
000055r 1               ; registers preserved
000055r 1               ;
000055r 1               .proc ACK_IRQ
000055r 1  48           	pha
000056r 1  9C 0C E0     	stz BIOS_IRQ_SOURCE
000059r 1               
000059r 1               @wait_ack:
000059r 1  AD 0F E0     	lda BIOS_IRQ_STATE
00005Cr 1  D0 FB        	bne @wait_ack
00005Er 1  68           	pla
00005Fr 1  60           	rts
000060r 1               .endproc
000060r 1               
000060r 1               ;
000060r 1               ; switch context
000060r 1               ; A = context
000060r 1               ;
000060r 1               .proc SET_MMU_CONTEXT_AND_RTI
000060r 1  AA           	tax						; context
000061r 1  78           	sei
000062r 1               @wait_cmd:
000062r 1  AD 02 D0     	lda CMD_PORT
000065r 1  D0 FB        	bne @wait_cmd
000067r 1  8E 03 D0     	stx PARAM_PORT
00006Ar 1  A9 02        	lda #CMD_CONTEXT_SWITCH
00006Cr 1  8D 02 D0     	sta CMD_PORT			; context switch
00006Fr 1               
00006Fr 1               @wait_completion:
00006Fr 1  AD 02 D0     	lda CMD_PORT
000072r 1  D0 FB        	bne @wait_completion
000074r 1               
000074r 1  7A           	ply
000075r 1  FA           	plx
000076r 1  68           	pla
000077r 1  40           	rti
000078r 1               .endproc
000078r 1               
000078r 1               ; A = context
000078r 1               ; X = target low
000078r 1               ; Y = target high
000078r 1               .proc SET_MMU_CONTEXT_AND_JUMP
000078r 1  78           	sei
000079r 1                   ; save jump target
000079r 1  8E rr rr         stx bios_jmp_vec
00007Cr 1  8C rr rr         sty bios_jmp_vec+1
00007Fr 1               
00007Fr 1  AA           	tax				; context
000080r 1               @wait_cmd:
000080r 1  AD 02 D0     	lda CMD_PORT
000083r 1  D0 FB        	bne @wait_cmd
000085r 1  8E 03 D0     	stx PARAM_PORT
000088r 1  A9 02        	lda #CMD_CONTEXT_SWITCH
00008Ar 1  8D 02 D0     	sta CMD_PORT
00008Dr 1               @wait_completion:
00008Dr 1  AD 02 D0     	lda CMD_PORT
000090r 1  D0 FB        	bne @wait_completion
000092r 1               
000092r 1  58           	cli
000093r 1  6C rr rr         jmp (bios_jmp_vec)
000096r 1               .endproc
000096r 1               
000096r 1               ; -----------------------------------------------------------------------------
000096r 1               ; empty
000096r 1               ;
000096r 1               .proc EMPTY
000096r 1  00           	BRK
000097r 1  EA           	NOP
000098r 1               .endproc
000098r 1               
