#!/bin/sh
#
# Get load and run addresses from label file and output in hex in format
# to be used as arguments to the bintomon program.

LOAD=`grep ".syscall_table" ./out/neox_syscall.lbl |  awk '{ print $2 }' | head -1`
#RESET=`grep ".reset" micmonneo6502_syscalllbl | awk '{ print $2 }' | head -1`
#IRQ=`grep ".irq_entry" neo6502_syscall.lbl | awk '{ print $2 }' | head -1`
#NMI=`grep ".nmi_entry" neo6502_syscall.lbl | awk '{ print $2 }' | head -1`
echo "-l 0x${LOAD}"
