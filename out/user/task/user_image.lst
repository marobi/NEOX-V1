000020r 4               SPAWN_FD_CLOSED = $FF
000020r 4               
000020r 4               ; Maximum process-private launch-line storage including its terminating NUL.
000020r 4               ; The public length excludes the NUL and must be less than SPAWN_LINE_MAX.
000020r 4               SPAWN_LINE_MAX = 64
000020r 4               
000020r 4               ; ------------------------------------------------------------
000020r 4               ; spawn_resident_args
000020r 4               ;
000020r 4               ; The parent transfers one opaque argument line to the child. The kernel
000020r 4               ; does not tokenize, count, quote, or otherwise interpret argument bytes.
000020r 4               ; arg_line_len excludes the terminating NUL.
000020r 4               ; ------------------------------------------------------------
000020r 4               .struct spawn_resident_args
000020r 4                   entry           .word
000020r 4                   launch_id       .byte
000020r 4                   arg_line_ptr    .word
000020r 4                   arg_line_len    .byte
000020r 4                   stdin_fd        .byte
000020r 4                   stdout_fd       .byte
000020r 4                   stderr_fd       .byte
000020r 4                   flags           .byte   ; initial child proc_flags
000020r 4                   result_pid      .byte
000020r 4               .endstruct
000020r 4               
000020r 4               SPAWN_RESIDENT_ARGS_SIZE = .sizeof(spawn_resident_args)
000020r 4               
000020r 4               ; ------------------------------------------------------------
000020r 4               ; spawn_get_line_args
000020r 4               ;
000020r 4               ; Child-side retrieval of the opaque launch argument line.
000020r 4               ; buffer_size includes space for the terminating NUL.
000020r 4               ; result_len excludes the terminating NUL.
000020r 4               ; ------------------------------------------------------------
000020r 4               .struct spawn_get_line_args
000020r 4                   buffer_ptr      .word
000020r 4                   buffer_size     .byte
000020r 4                   result_len      .byte
000020r 4               .endstruct
000020r 4               
000020r 4               SPAWN_GET_LINE_ARGS_SIZE = .sizeof(spawn_get_line_args)
000020r 4               
000020r 4               .endif
000020r 4               
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Common open argument block
000020r 3               ;
000020r 3               ; path_ptr:
000020r 3               ;   Pointer to a NUL-terminated 8.3 filename in the current task
000020r 3               ;   context. The RP-side FS_OPEN command scans at most max_len bytes.
000020r 3               ;
000020r 3               ; max_len:
000020r 3               ;   Maximum filename scan length. Use a small bounded value such as 64.
000020r 3               ;
000020r 3               ; flags:
000020r 3               ;   Open mode. V32 supports read-only, write/truncate, write-existing,
000020r 3               ;   read/write-existing, and read/write-create.
000020r 3               ;
000020r 3               ; device:
000020r 3               ;   RP filesystem device/FatFs drive number: 0..3.
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               .struct open_args
000020r 3                   path_ptr        .word
000020r 3                   max_len         .word
000020r 3                   flags           .byte
000020r 3                   device          .byte
000020r 3               .endstruct
000020r 3               
000020r 3               OPEN_ARGS_SIZE = .sizeof(open_args)
000020r 3               
000020r 3               OPEN_READ           = $00    ; read existing
000020r 3               OPEN_WRITE_TRUNC    = $01    ; write create/truncate
000020r 3               OPEN_WRITE_EXISTING = $02    ; write existing, no truncate
000020r 3               OPEN_RW_EXISTING    = $03    ; read/write existing, no truncate
000020r 3               OPEN_RW_CREATE      = $04    ; read/write create if missing, no truncate if existing
000020r 3               
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Bulk filesystem argument blocks
000020r 3               ;
000020r 3               ; Names and paths use NEOX 8.3 path components. The path string is
000020r 3               ; NUL-terminated and is validated by the RP side.
000020r 3               ;
000020r 3               ; max_bytes / byte_count:
000020r 3               ;   $0000 means 65536 bytes.
000020r 3               ;
000020r 3               ; flags:
000020r 3               ;   Reserved for now. Must be 0.
000020r 3               ;
000020r 3               ; Context rule:
000020r 3               ;   User code never supplies a context. The kernel derives the caller
000020r 3               ;   context and passes it separately to the RP mailbox in ARG2L.
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               .struct fs_load_args
000020r 3                   path_ptr        .word
000020r 3                   dest_ptr        .word
000020r 3                   max_bytes       .word
000020r 3                   device          .byte
000020r 3                   flags           .byte
000020r 3               .endstruct
000020r 3               
000020r 3               FS_LOAD_ARGS_SIZE = .sizeof(fs_load_args)
000020r 3               
000020r 3               .struct fs_save_args
000020r 3                   path_ptr        .word
000020r 3                   src_ptr         .word
000020r 3                   byte_count      .word
000020r 3                   device          .byte
000020r 3                   flags           .byte
000020r 3               .endstruct
000020r 3               
000020r 3               FS_SAVE_ARGS_SIZE = .sizeof(fs_save_args)
000020r 3               
000020r 3               FS_BULK_FLAGS_NONE = $00
000020r 3               
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Seek/tell filesystem argument blocks
000020r 3               ;
000020r 3               ; offset_lo/offset_hi:
000020r 3               ;   Signed 32-bit offset split into low/high words.  SEEK_SET
000020r 3               ;   requires a non-negative final target; SEEK_CUR and SEEK_END
000020r 3               ;   allow negative offsets.
000020r 3               ;
000020r 3               ; result_lo/result_hi:
000020r 3               ;   Kernel writes the resulting unsigned 32-bit file position here.
000020r 3               ;   A/X also return result_lo for convenience.
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               SEEK_SET            = $00
000020r 3               SEEK_CUR            = $01
000020r 3               SEEK_END            = $02
000020r 3               
000020r 3               .struct seek_args
000020r 3                   fd              .byte
000020r 3                   whence          .byte
000020r 3                   offset_lo       .word
000020r 3                   offset_hi       .word
000020r 3                   result_lo       .word
000020r 3                   result_hi       .word
000020r 3               .endstruct
000020r 3               
000020r 3               SEEK_ARGS_SIZE = .sizeof(seek_args)
000020r 3               
000020r 3               .struct tell_args
000020r 3                   fd              .byte
000020r 3                   reserved        .byte
000020r 3                   result_lo       .word
000020r 3                   result_hi       .word
000020r 3               .endstruct
000020r 3               
000020r 3               TELL_ARGS_SIZE = .sizeof(tell_args)
000020r 3               
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Delete/rename filesystem argument blocks
000020r 3               ;
000020r 3               ; V34 path handling uses the same RP-side 8.3 validator as open.
000020r 3               ; flags is reserved and must be 0.
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               FS_PATH_FLAGS_NONE  = $00
000020r 3               
000020r 3               .struct delete_args
000020r 3                   path_ptr        .word
000020r 3                   max_len         .word
000020r 3                   device          .byte
000020r 3                   flags           .byte
000020r 3               .endstruct
000020r 3               
000020r 3               DELETE_ARGS_SIZE = .sizeof(delete_args)
000020r 3               
000020r 3               .struct rename_args
000020r 3                   old_path_ptr    .word
000020r 3                   new_path_ptr    .word
000020r 3                   max_len         .word
000020r 3                   device          .byte
000020r 3                   flags           .byte
000020r 3               .endstruct
000020r 3               
000020r 3               RENAME_ARGS_SIZE = .sizeof(rename_args)
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Common read/write argument block
000020r 3               ;
000020r 3               ; fd:
000020r 3               ;   STDIN / STDOUT / STDERR
000020r 3               ;
000020r 3               ; buf_ptr:
000020r 3               ;   Pointer to caller buffer in the current task context
000020r 3               ;
000020r 3               ; len:
000020r 3               ;   Requested transfer length
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               .struct rw_args
000020r 3                   fd              .byte
000020r 3                   reserved        .byte
000020r 3                   buf_ptr         .word
000020r 3                   len             .word
000020r 3               .endstruct
000020r 3               
000020r 3               RW_ARGS_SIZE = .sizeof(rw_args)
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; SYSCALL helper macro
000020r 3               ;
000020r 3               ; Purpose:
000020r 3               ;   Load X/Y with the address of an argument block and call the
000020r 3               ;   fixed syscall entry.
000020r 3               ;
000020r 3               ; Example:
000020r 3               ;   SYSCALL my_args, sys_write
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               .macro SYSCALL argblk, entry
000020r 3                   ; Keep the register argument pointer stable across the tiny user-side
000020r 3                   ; setup window. The kernel snapshots the process-private pointer before
000020r 3                   ; taking file_io_gate and decodes the block after the owner resumes.
000020r 3                   sei
000020r 3                   ldx #<argblk
000020r 3                   ldy #>argblk
000020r 3                   jsr entry
000020r 3               .endmacro
000020r 3               
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Directory control argument blocks
000020r 3               ;
000020r 3               ; V35 exposes directory handles as normal NEOX fd numbers. The RP
000020r 3               ; directory handle remains kernel-private in the FD/open-object table.
000020r 3               ;
000020r 3               ; dir_entry layout matches the RP serialized directory entry:
000020r 3               ;   name[13] = NUL-terminated 8.3 name
000020r 3               ;   attr     = FatFs attribute byte
000020r 3               ;   size     = unsigned 32-bit byte size
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               DIR_ENTRY_NAME_SIZE = 13
000020r 3               DIR_ENTRY_SIZE      = 18
000020r 3               
000020r 3               .struct dir_entry
000020r 3                   name            .res 13
000020r 3                   attr            .byte
000020r 3                   size_lo         .word
000020r 3                   size_hi         .word
000020r 3               .endstruct
000020r 3               
000020r 3               .struct opendir_args
000020r 3                   path_ptr        .word
000020r 3                   max_len         .word
000020r 3                   device          .byte
000020r 3                   flags           .byte
000020r 3               .endstruct
000020r 3               
000020r 3               OPENDIR_ARGS_SIZE = .sizeof(opendir_args)
000020r 3               
000020r 3               .struct readdir_args
000020r 3                   fd              .byte
000020r 3                   reserved        .byte
000020r 3                   entry_ptr       .word
000020r 3                   entry_size      .word
000020r 3               .endstruct
000020r 3               
000020r 3               READDIR_ARGS_SIZE = .sizeof(readdir_args)
000020r 3               
000020r 3               .struct closedir_args
000020r 3                   fd              .byte
000020r 3                   reserved        .byte
000020r 3               .endstruct
000020r 3               
000020r 3               CLOSEDIR_ARGS_SIZE = .sizeof(closedir_args)
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Current directory argument blocks
000020r 3               ;
000020r 3               ; V36 stores current directory per process as drive + absolute path.
000020r 3               ; User-visible getcwd form is D:/PATH.
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               NEOX_PATH_FLAGS_NONE = $00
000020r 3               
000020r 3               .struct chdir_args
000020r 3                   path_ptr        .word
000020r 3                   max_len         .word
000020r 3                   device          .byte
000020r 3                   flags           .byte
000020r 3               .endstruct
000020r 3               
000020r 3               CHDIR_ARGS_SIZE = .sizeof(chdir_args)
000020r 3               
000020r 3               .struct getcwd_args
000020r 3                   buffer_ptr      .word
000020r 3                   buffer_size     .word
000020r 3                   result_len      .word
000020r 3                   flags           .byte
000020r 3                   reserved        .byte
000020r 3               .endstruct
000020r 3               
000020r 3               GETCWD_ARGS_SIZE = .sizeof(getcwd_args)
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Directory create/remove argument blocks
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               .struct mkdir_args
000020r 3                   path_ptr        .word
000020r 3                   max_len         .word
000020r 3                   device          .byte
000020r 3                   flags           .byte
000020r 3               .endstruct
000020r 3               
000020r 3               MKDIR_ARGS_SIZE = .sizeof(mkdir_args)
000020r 3               
000020r 3               .struct rmdir_args
000020r 3                   path_ptr        .word
000020r 3                   max_len         .word
000020r 3                   device          .byte
000020r 3                   flags           .byte
000020r 3               .endstruct
000020r 3               
000020r 3               RMDIR_ARGS_SIZE = .sizeof(rmdir_args)
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Process information argument block
000020r 3               ;
000020r 3               ; SYS_GETPROCINFO copies one compact process-table snapshot record
000020r 3               ; into caller memory.  The record is deliberately binary; user-space
000020r 3               ; commands such as PS own all text formatting.
000020r 3               ;
000020r 3               ; Record layout:
000020r 3               ;   +0 pid
000020r 3               ;   +1 ppid
000020r 3               ;   +2 state
000020r 3               ;   +3 wait_reason
000020r 3               ;   +4 signal_pending
000020r 3               ;   +5 wait_object
000020r 3               ;   +6 held_gate_mask (PROC_HOLD_*)
000020r 3               ;
000020r 3               ; Kernels accepting the extended record remain compatible with callers
000020r 3               ; that provide the original five-byte buffer.
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               PROCINFO_RECORD_MIN_SIZE = 5
000020r 3               PROCINFO_RECORD_SIZE     = 7
000020r 3               
000020r 3               .struct procinfo_args
000020r 3                   pid             .byte
000020r 3                   reserved        .byte
000020r 3                   buffer_ptr      .word
000020r 3                   buffer_size     .word
000020r 3               .endstruct
000020r 3               
000020r 3               PROCINFO_ARGS_SIZE = .sizeof(procinfo_args)
000020r 3               
000020r 3               .endif
000020r 3               
000020r 2               
000020r 2               .export user_task1_entry
000020r 2               
000020r 2               T1_TX_FD          = 3          ; Task 1 -> Task 2
000020r 2               T1_RX_FD          = 4          ; Task 2 -> Task 1
000020r 2               T1_SAMPLE_TICKS   = 100        ; TIMER 100 = 10 ms, 1000 ticks = 10 sec
000020r 2               
000020r 2               .segment "USER_DATA"
000000r 2               
000000r 2               t1_ping_byte:
000000r 2  50               .byte "P"
000001r 2               
000001r 2               t1_rx_byte:
000001r 2  xx               .res 1
000002r 2               
000002r 2               ; Total completed ping-pong loops.
000002r 2               t1_loop_lo:
000002r 2  00               .byte 0
000003r 2               
000003r 2               t1_loop_hi:
000003r 2  00               .byte 0
000004r 2               
000004r 2               ; Previous loop count sample.
000004r 2               t1_last_loop_lo:
000004r 2  00               .byte 0
000005r 2               
000005r 2               t1_last_loop_hi:
000005r 2  00               .byte 0
000006r 2               
000006r 2               ; Tick sample start.
000006r 2               t1_start_tick_lo:
000006r 2  00               .byte 0
000007r 2               
000007r 2               t1_start_tick_hi:
000007r 2  00               .byte 0
000008r 2               
000008r 2               ; Current sys_ticks sample.
000008r 2               t1_now_tick_lo:
000008r 2  00               .byte 0
000009r 2               
000009r 2               t1_now_tick_hi:
000009r 2  00               .byte 0
00000Ar 2               
00000Ar 2               ; Delta loops during the last measured second.
00000Ar 2               t1_delta_loop_lo:
00000Ar 2  00               .byte 0
00000Br 2               
00000Br 2               t1_delta_loop_hi:
00000Br 2  00               .byte 0
00000Cr 2               
00000Cr 2               t1_msg_start:
00000Cr 2  54 31 20 50      .byte "T1 PINGPONG TICKS", 13
000010r 2  49 4E 47 50  
000014r 2  4F 4E 47 20  
00001Er 2               
00001Er 2               t1_msg_rate:
00001Er 2  54 31 20 6C      .byte "T1 lps=$0000", 13
000022r 2  70 73 3D 24  
000026r 2  30 30 30 30  
00002Br 2               
00002Br 2               t1_msg_fail:
00002Br 2  54 31 20 50      .byte "T1 PINGPONG FAIL", 13
00002Fr 2  49 4E 47 50  
000033r 2  4F 4E 47 20  
00003Cr 2               
00003Cr 2               t1_wr_stdout_args:
00003Cr 2  01               .byte STDOUT
00003Dr 2  00               .byte 0
00003Er 2  00 00            .word 0
000040r 2  00 00            .word 0
000042r 2               
000042r 2               t1_write_args:
000042r 2  03               .byte T1_TX_FD
000043r 2  00               .byte 0
000044r 2  rr rr            .word t1_ping_byte
000046r 2  01 00            .word 1
000048r 2               
000048r 2               t1_read_args:
000048r 2  04               .byte T1_RX_FD
000049r 2  00               .byte 0
00004Ar 2  rr rr            .word t1_rx_byte
00004Cr 2  01 00            .word 1
00004Er 2               
00004Er 2               .segment "USER_TEXT"
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; t1_print_msg
000000r 2               ;
000000r 2               ; Input:
000000r 2               ;   A/X = string pointer
000000r 2               ;   Y   = length including CR
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .proc t1_print_msg
000000r 2  8D rr rr         sta t1_wr_stdout_args + rw_args::buf_ptr
000003r 2  8E rr rr         stx t1_wr_stdout_args + rw_args::buf_ptr + 1
000006r 2               
000006r 2  98               tya
000007r 2  8D rr rr         sta t1_wr_stdout_args + rw_args::len
00000Ar 2  9C rr rr         stz t1_wr_stdout_args + rw_args::len + 1
00000Dr 2               
00000Dr 2  78 A2 rr A0      SYSCALL t1_wr_stdout_args, sys_write
000011r 2  rr 20 0C F1  
000015r 2  60               rts
000016r 2               .endproc
000016r 2               
000016r 2               .proc t1_print_start
000016r 2  A9 rr            lda #<t1_msg_start
000018r 2  A2 rr            ldx #>t1_msg_start
00001Ar 2  A0 12            ldy #18
00001Cr 2  4C rr rr         jmp t1_print_msg
00001Fr 2               .endproc
00001Fr 2               
00001Fr 2               .proc t1_print_fail
00001Fr 2  A9 rr            lda #<t1_msg_fail
000021r 2  A2 rr            ldx #>t1_msg_fail
000023r 2  A0 11            ldy #17
000025r 2  4C rr rr         jmp t1_print_msg
000028r 2               .endproc
000028r 2               
000028r 2               ; ------------------------------------------------------------
000028r 2               ; t1_hex_nibble
000028r 2               ;
000028r 2               ; Input:
000028r 2               ;   A = low nibble value
000028r 2               ;
000028r 2               ; Output:
000028r 2               ;   A = ASCII hex digit
000028r 2               ; ------------------------------------------------------------
000028r 2               
000028r 2               .proc t1_hex_nibble
000028r 2  29 0F            and #$0F
00002Ar 2  C9 0A            cmp #10
00002Cr 2  90 04            bcc @digit
00002Er 2               
00002Er 2  18               clc
00002Fr 2  69 37            adc #'A' - 10
000031r 2  60               rts
000032r 2               
000032r 2               @digit:
000032r 2  18               clc
000033r 2  69 30            adc #'0'
000035r 2  60               rts
000036r 2               .endproc
000036r 2               
000036r 2               ; ------------------------------------------------------------
000036r 2               ; t1_store_hex_byte
000036r 2               ;
000036r 2               ; Input:
000036r 2               ;   A = byte
000036r 2               ;   Y = offset in t1_msg_rate
000036r 2               ; ------------------------------------------------------------
000036r 2               
000036r 2               .proc t1_store_hex_byte
000036r 2  48               pha
000037r 2               
000037r 2  4A               lsr
000038r 2  4A               lsr
000039r 2  4A               lsr
00003Ar 2  4A               lsr
00003Br 2  20 rr rr         jsr t1_hex_nibble
00003Er 2  99 rr rr         sta t1_msg_rate,y
000041r 2               
000041r 2  C8               iny
000042r 2  68               pla
000043r 2  20 rr rr         jsr t1_hex_nibble
000046r 2  99 rr rr         sta t1_msg_rate,y
000049r 2               
000049r 2  60               rts
00004Ar 2               .endproc
00004Ar 2               
00004Ar 2               ; ------------------------------------------------------------
00004Ar 2               ; t1_print_rate
00004Ar 2               ;
00004Ar 2               ; Prints:
00004Ar 2               ;   T1 lps=$hhhh
00004Ar 2               ;
00004Ar 2               ; Value printed is loops completed during the last 50 ticks.
00004Ar 2               ; At TIMER 50 this equals loops/sec.
00004Ar 2               ; ------------------------------------------------------------
00004Ar 2               
00004Ar 2               .proc t1_print_rate
00004Ar 2  AD rr rr         lda t1_delta_loop_hi
00004Dr 2  A0 08            ldy #8
00004Fr 2  20 rr rr         jsr t1_store_hex_byte
000052r 2               
000052r 2  AD rr rr         lda t1_delta_loop_lo
000055r 2  A0 0A            ldy #10
000057r 2  20 rr rr         jsr t1_store_hex_byte
00005Ar 2               
00005Ar 2  A9 rr            lda #<t1_msg_rate
00005Cr 2  A2 rr            ldx #>t1_msg_rate
00005Er 2  A0 0D            ldy #13
000060r 2  4C rr rr         jmp t1_print_msg
000063r 2               .endproc
000063r 2               
000063r 2               ; ------------------------------------------------------------
000063r 2               ; t1_sample_ticks
000063r 2               ;
000063r 2               ; Output:
000063r 2               ;   t1_now_tick_lo/hi updated
000063r 2               ; ------------------------------------------------------------
000063r 2               
000063r 2               .proc t1_sample_ticks
000063r 2  20 33 F1         jsr sys_ticks
000066r 2  8D rr rr         sta t1_now_tick_lo
000069r 2  8E rr rr         stx t1_now_tick_hi
00006Cr 2  60               rts
00006Dr 2               .endproc
00006Dr 2               
00006Dr 2               ; ------------------------------------------------------------
00006Dr 2               ; t1_reset_sample
00006Dr 2               ;
00006Dr 2               ; Sets:
00006Dr 2               ;   start_tick = sys_ticks()
00006Dr 2               ;   last_loop  = current loop count
00006Dr 2               ; ------------------------------------------------------------
00006Dr 2               
00006Dr 2               .proc t1_reset_sample
00006Dr 2  20 rr rr         jsr t1_sample_ticks
000070r 2               
000070r 2  AD rr rr         lda t1_now_tick_lo
000073r 2  8D rr rr         sta t1_start_tick_lo
000076r 2               
000076r 2  AD rr rr         lda t1_now_tick_hi
000079r 2  8D rr rr         sta t1_start_tick_hi
00007Cr 2               
00007Cr 2  AD rr rr         lda t1_loop_lo
00007Fr 2  8D rr rr         sta t1_last_loop_lo
000082r 2               
000082r 2  AD rr rr         lda t1_loop_hi
000085r 2  8D rr rr         sta t1_last_loop_hi
000088r 2               
000088r 2  60               rts
000089r 2               .endproc
000089r 2               
000089r 2               ; ------------------------------------------------------------
000089r 2               ; t1_tick_elapsed_sample
000089r 2               ;
000089r 2               ; Output:
000089r 2               ;   C clear = at least T1_SAMPLE_TICKS elapsed
000089r 2               ;   C set   = not yet elapsed
000089r 2               ;
000089r 2               ; Uses wrap-safe 16-bit unsigned subtraction:
000089r 2               ;   now - start >= 500
000089r 2               ; ------------------------------------------------------------
000089r 2               
000089r 2               .proc t1_tick_elapsed_1s
000089r 2  20 rr rr         jsr t1_sample_ticks
00008Cr 2               
00008Cr 2  38               sec
00008Dr 2  AD rr rr         lda t1_now_tick_lo
000090r 2  ED rr rr         sbc t1_start_tick_lo
000093r 2  A8               tay                         ; Y = delta low
000094r 2               
000094r 2  AD rr rr         lda t1_now_tick_hi
000097r 2  ED rr rr         sbc t1_start_tick_hi        ; A = delta high
00009Ar 2               
00009Ar 2                   ; Compare delta >= 500 ($01F4)
00009Ar 2  C9 00            cmp #>T1_SAMPLE_TICKS
00009Cr 2  90 09            bcc @not_elapsed
00009Er 2  D0 05            bne @elapsed
0000A0r 2               
0000A0r 2  98               tya
0000A1r 2  C9 64            cmp #<T1_SAMPLE_TICKS
0000A3r 2  90 02            bcc @not_elapsed
0000A5r 2               
0000A5r 2               @elapsed:
0000A5r 2  18               clc
0000A6r 2  60               rts
0000A7r 2               
0000A7r 2               @not_elapsed:
0000A7r 2  38               sec
0000A8r 2  60               rts
0000A9r 2               .endproc
0000A9r 2               
0000A9r 2               ; ------------------------------------------------------------
0000A9r 2               ; t1_update_rate
0000A9r 2               ;
0000A9r 2               ; If one scheduler-second elapsed:
0000A9r 2               ;   delta_loop = loop_count - last_loop
0000A9r 2               ;   print delta_loop
0000A9r 2               ;   reset sample
0000A9r 2               ;
0000A9r 2               ; Called only every 16 completed loops to reduce measurement
0000A9r 2               ; overhead in the hot path.
0000A9r 2               ; ------------------------------------------------------------
0000A9r 2               
0000A9r 2               .proc t1_update_rate
0000A9r 2  20 rr rr         jsr t1_tick_elapsed_1s
0000ACr 2  90 01            bcc :+
0000AEr 2  60               rts
0000AFr 2               :
0000AFr 2  38               sec
0000B0r 2  AD rr rr         lda t1_loop_lo
0000B3r 2  ED rr rr         sbc t1_last_loop_lo
0000B6r 2  8D rr rr         sta t1_delta_loop_lo
0000B9r 2               
0000B9r 2  AD rr rr         lda t1_loop_hi
0000BCr 2  ED rr rr         sbc t1_last_loop_hi
0000BFr 2  8D rr rr         sta t1_delta_loop_hi
0000C2r 2               
0000C2r 2                   ; V38: keep pipe ping/pong task active, but suppress periodic console spam
0000C2r 2                   ; so the interactive nbox task remains usable.
0000C2r 2                   ; jsr t1_print_rate
0000C2r 2  20 rr rr         jsr t1_reset_sample
0000C5r 2  60               rts
0000C6r 2               .endproc
0000C6r 2               
0000C6r 2               ; ------------------------------------------------------------
0000C6r 2               ; t1_write_ping
0000C6r 2               ;
0000C6r 2               ; Blocking pipe write. The kernel handles EAGAIN by blocking
0000C6r 2               ; and retrying the syscall; task code only handles real errors.
0000C6r 2               ; ------------------------------------------------------------
0000C6r 2               
0000C6r 2               .proc t1_write_ping
0000C6r 2  78 A2 rr A0      SYSCALL t1_write_args, sys_write
0000CAr 2  rr 20 0C F1  
0000CEr 2  90 02            bcc @ok
0000D0r 2               
0000D0r 2  38               sec
0000D1r 2  60               rts
0000D2r 2               
0000D2r 2               @ok:
0000D2r 2  C9 01            cmp #1
0000D4r 2  F0 02            beq :+
0000D6r 2  38               sec
0000D7r 2  60               rts
0000D8r 2               :
0000D8r 2  E0 00            cpx #0
0000DAr 2  F0 02            beq :+
0000DCr 2  38               sec
0000DDr 2  60               rts
0000DEr 2               :
0000DEr 2  18               clc
0000DFr 2  60               rts
0000E0r 2               .endproc
0000E0r 2               
0000E0r 2               ; ------------------------------------------------------------
0000E0r 2               ; t1_read_pong
0000E0r 2               ;
0000E0r 2               ; Blocking pipe read. The kernel handles EAGAIN by blocking
0000E0r 2               ; and retrying the syscall; task code only handles EOF/real errors.
0000E0r 2               ; ------------------------------------------------------------
0000E0r 2               
0000E0r 2               .proc t1_read_pong
0000E0r 2  78 A2 rr A0      SYSCALL t1_read_args, sys_read
0000E4r 2  rr 20 09 F1  
0000E8r 2  90 02            bcc @ok
0000EAr 2               
0000EAr 2  38               sec
0000EBr 2  60               rts
0000ECr 2               
0000ECr 2               @ok:
0000ECr 2  C9 01            cmp #1
0000EEr 2  F0 02            beq :+
0000F0r 2  38               sec
0000F1r 2  60               rts
0000F2r 2               :
0000F2r 2  E0 00            cpx #0
0000F4r 2  F0 02            beq :+
0000F6r 2  38               sec
0000F7r 2  60               rts
0000F8r 2               :
0000F8r 2  AD rr rr         lda t1_rx_byte
0000FBr 2  C9 51            cmp #'Q'
0000FDr 2  F0 02            beq :+
0000FFr 2  38               sec
000100r 2  60               rts
000101r 2               :
000101r 2  18               clc
000102r 2  60               rts
000103r 2               .endproc
000103r 2               
000103r 2               ; ------------------------------------------------------------
000103r 2               ; t1_count_loop
000103r 2               ;
000103r 2               ; Increment loop counter.
000103r 2               ; Only sample ticks every 16 loops:
000103r 2               ;   loop_lo & $0F == 0
000103r 2               ; ------------------------------------------------------------
000103r 2               
000103r 2               .proc t1_count_loop
000103r 2  EE rr rr         inc t1_loop_lo
000106r 2  D0 03            bne @check_sample
000108r 2               
000108r 2  EE rr rr         inc t1_loop_hi
00010Br 2               
00010Br 2               @check_sample:
00010Br 2  AD rr rr         lda t1_loop_lo
00010Er 2  29 0F            and #$0F
000110r 2  D0 03            bne @done
000112r 2               
000112r 2  20 rr rr         jsr t1_update_rate
000115r 2               
000115r 2               @done:
000115r 2  60               rts
000116r 2               .endproc
000116r 2               
000116r 2               ; ------------------------------------------------------------
000116r 2               ; user_task1_entry
000116r 2               ; ------------------------------------------------------------
000116r 2               
000116r 2               .proc user_task1_entry
000116r 2  20 rr rr         jsr t1_print_start
000119r 2               
000119r 2  9C rr rr         stz t1_loop_lo
00011Cr 2  9C rr rr         stz t1_loop_hi
00011Fr 2  9C rr rr         stz t1_last_loop_lo
000122r 2  9C rr rr         stz t1_last_loop_hi
000125r 2  9C rr rr         stz t1_delta_loop_lo
000128r 2  9C rr rr         stz t1_delta_loop_hi
00012Br 2               
00012Br 2  20 rr rr         jsr t1_reset_sample
00012Er 2               
00012Er 2               @loop:
00012Er 2  20 rr rr         jsr t1_write_ping
000131r 2  90 03            bcc :+
000133r 2  4C rr rr         jmp @fail
000136r 2               :
000136r 2  20 rr rr         jsr t1_read_pong
000139r 2  90 03            bcc :+
00013Br 2  4C rr rr         jmp @fail
00013Er 2               :
00013Er 2  20 rr rr         jsr t1_count_loop
000141r 2               
000141r 2  A9 01        	lda #$01
000143r 2  20 2A F1     	jsr sys_sleep
000146r 2  80 E6            bra @loop
000148r 2               
000148r 2               @fail:
000148r 2  20 rr rr         jsr t1_print_fail
00014Br 2               
00014Br 2               @idle:
00014Br 2                   ; Failure stop loop.
00014Br 2  A9 10        	lda #$10
00014Dr 2  20 2A F1     	jsr sys_sleep
000150r 2  80 F9            bra @idle
000152r 2               .endproc
000152r 2               
000152r 1               .include "task/task2.asm"
000152r 2               ; ============================================================
000152r 2               ; task2.asm
000152r 2               ; NEOX - inter-process pipe ping/pong responder
000152r 2               ; ca65 / W65C02
000152r 2               ; ============================================================
000152r 2               
000152r 2               .setcpu "65C02"
000152r 2               
000152r 2               .include "syscall.inc"
000152r 3               ; ============================================================
000152r 3               ; syscall.inc
000152r 3               ; NEOX - syscall definitions
000152r 3               ;
000152r 3               ; Purpose:
000152r 3               ;   Defines syscall numbers, fixed syscall entry addresses,
000152r 3               ;   error codes, and common syscall argument structures.
000152r 3               ;
000152r 3               ; Architecture:
000152r 3               ;   - Syscall jump table is located in the shared BIOS page at $F100
000152r 3               ;   - Each syscall entry is a 3-byte JMP stub
000152r 3               ;   - User code calls fixed syscall entry addresses
000152r 3               ;
000152r 3               ; Notes:
000152r 3               ;   SYS_MONITOR enters supervisor/MICMON context through the
000152r 3               ;   kernel-defined monitor entry path. It is a controlled
000152r 3               ;   privileged transfer, not direct user control of MMU/scheduler.
000152r 3               ; ============================================================
000152r 3               
000152r 3               .ifndef __SYSCALL_INC__
000152r 3               __SYSCALL_INC__ = 1
000152r 3               
000152r 3               .include "config.inc"
000152r 3               
000152r 3               SYSCALL_ENTRY_SIZE  = 3
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Standard file descriptors
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               STDIN               = 0
000152r 3               STDOUT              = 1
000152r 3               STDERR              = 2
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Syscall numbers
000152r 3               ; ------------------------------------------------------------
000152r 3               SYS_EXIT			= $00
000152r 3               SYS_OPEN            = $01
000152r 3               SYS_CLOSE			= $02
000152r 3               SYS_READ            = $03
000152r 3               SYS_WRITE           = $04
000152r 3               SYS_MONITOR         = $05
000152r 3               SYS_LOAD_FILE_TO_MEMORY = $06
000152r 3               SYS_SAVE_MEMORY_TO_FILE = $07
000152r 3               SYS_SEEK            = $08
000152r 3               SYS_TELL            = $09
000152r 3               SYS_PIPE			= $0A
000152r 3               SYS_DELETE          = $0C
000152r 3               SYS_RENAME          = $0D
000152r 3               SYS_YIELD           = $0B
000152r 3               SYS_SLEEP           = $0E
000152r 3               SYS_DUP				= $0F
000152r 3               SYS_DUP2			= $10
000152r 3               SYS_TICKS           = $11
000152r 3               SYS_SIGNAL          = $12
000152r 3               SYS_OPENDIR         = $13
000152r 3               SYS_READDIR         = $14
000152r 3               SYS_CLOSEDIR        = $15
000152r 3               SYS_CHDIR           = $16
000152r 3               SYS_GETCWD          = $17
000152r 3               SYS_MKDIR           = $18
000152r 3               SYS_RMDIR           = $19
000152r 3               SYS_GETPROCINFO      = $1A
000152r 3               SYS_WAITPID           = $1B
000152r 3               SYS_GET_LAUNCH_ID     = $1C
000152r 3               SYS_GET_LAUNCH_LINE   = $1D
000152r 3               SYS_SPAWN_RESIDENT    = $1E
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Fixed syscall entry addresses
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               sys_exit            = SYSCALL_BASE + (SYS_EXIT    * SYSCALL_ENTRY_SIZE)
000152r 3               sys_open            = SYSCALL_BASE + (SYS_OPEN    * SYSCALL_ENTRY_SIZE)
000152r 3               sys_close           = SYSCALL_BASE + (SYS_CLOSE   * SYSCALL_ENTRY_SIZE)
000152r 3               sys_read            = SYSCALL_BASE + (SYS_READ    * SYSCALL_ENTRY_SIZE)
000152r 3               sys_write           = SYSCALL_BASE + (SYS_WRITE   * SYSCALL_ENTRY_SIZE)
000152r 3               sys_monitor         = SYSCALL_BASE + (SYS_MONITOR * SYSCALL_ENTRY_SIZE)
000152r 3               sys_load_file_to_memory = SYSCALL_BASE + (SYS_LOAD_FILE_TO_MEMORY * SYSCALL_ENTRY_SIZE)
000152r 3               sys_save_memory_to_file = SYSCALL_BASE + (SYS_SAVE_MEMORY_TO_FILE * SYSCALL_ENTRY_SIZE)
000152r 3               sys_seek            = SYSCALL_BASE + (SYS_SEEK    * SYSCALL_ENTRY_SIZE)
000152r 3               sys_tell            = SYSCALL_BASE + (SYS_TELL    * SYSCALL_ENTRY_SIZE)
000152r 3               sys_delete          = SYSCALL_BASE + (SYS_DELETE  * SYSCALL_ENTRY_SIZE)
000152r 3               sys_rename          = SYSCALL_BASE + (SYS_RENAME  * SYSCALL_ENTRY_SIZE)
000152r 3               sys_pipe            = SYSCALL_BASE + (SYS_PIPE    * SYSCALL_ENTRY_SIZE)
000152r 3               sys_yield           = SYSCALL_BASE + (SYS_YIELD   * SYSCALL_ENTRY_SIZE)
000152r 3               sys_sleep           = SYSCALL_BASE + (SYS_SLEEP   * SYSCALL_ENTRY_SIZE)
000152r 3               sys_dup				= SYSCALL_BASE + (SYS_DUP     * SYSCALL_ENTRY_SIZE)
000152r 3               sys_dup2			= SYSCALL_BASE + (SYS_DUP2    * SYSCALL_ENTRY_SIZE)
000152r 3               sys_ticks           = SYSCALL_BASE + (SYS_TICKS   * SYSCALL_ENTRY_SIZE)
000152r 3               sys_signal          = SYSCALL_BASE + (SYS_SIGNAL  * SYSCALL_ENTRY_SIZE)
000152r 3               sys_opendir         = SYSCALL_BASE + (SYS_OPENDIR * SYSCALL_ENTRY_SIZE)
000152r 3               sys_readdir         = SYSCALL_BASE + (SYS_READDIR * SYSCALL_ENTRY_SIZE)
000152r 3               sys_closedir        = SYSCALL_BASE + (SYS_CLOSEDIR * SYSCALL_ENTRY_SIZE)
000152r 3               sys_chdir           = SYSCALL_BASE + (SYS_CHDIR * SYSCALL_ENTRY_SIZE)
000152r 3               sys_getcwd          = SYSCALL_BASE + (SYS_GETCWD * SYSCALL_ENTRY_SIZE)
000152r 3               sys_mkdir           = SYSCALL_BASE + (SYS_MKDIR * SYSCALL_ENTRY_SIZE)
000152r 3               sys_rmdir           = SYSCALL_BASE + (SYS_RMDIR * SYSCALL_ENTRY_SIZE)
000152r 3               sys_getprocinfo      = SYSCALL_BASE + (SYS_GETPROCINFO * SYSCALL_ENTRY_SIZE)
000152r 3               sys_waitpid          = SYSCALL_BASE + (SYS_WAITPID * SYSCALL_ENTRY_SIZE)
000152r 3               sys_get_launch_id    = SYSCALL_BASE + (SYS_GET_LAUNCH_ID * SYSCALL_ENTRY_SIZE)
000152r 3               sys_get_launch_line  = SYSCALL_BASE + (SYS_GET_LAUNCH_LINE * SYSCALL_ENTRY_SIZE)
000152r 3               sys_spawn_resident   = SYSCALL_BASE + (SYS_SPAWN_RESIDENT * SYSCALL_ENTRY_SIZE)
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Common errno values
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               E_OK                = 0
000152r 3               EIO                 = 3
000152r 3               EINVAL              = 6
000152r 3               EMFILE              = 8        ; too many open file descriptors
000152r 3               EBADF               = 9
000152r 3               ENODEV              = 10
000152r 3               ENOSYS              = 11
000152r 3               EINTR               = 4        ; interrupted system call
000152r 3               EAGAIN              = 12       ; operation would block / try again
000152r 3               ENOMEM              = 13       ; no free kernel memory/object/table slot
000152r 3               EPIPE               = 14       ; write on pipe with no readers
000152r 3               
000152r 3               .include "spawn.inc"
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Common open argument block
000152r 3               ;
000152r 3               ; path_ptr:
000152r 3               ;   Pointer to a NUL-terminated 8.3 filename in the current task
000152r 3               ;   context. The RP-side FS_OPEN command scans at most max_len bytes.
000152r 3               ;
000152r 3               ; max_len:
000152r 3               ;   Maximum filename scan length. Use a small bounded value such as 64.
000152r 3               ;
000152r 3               ; flags:
000152r 3               ;   Open mode. V32 supports read-only, write/truncate, write-existing,
000152r 3               ;   read/write-existing, and read/write-create.
000152r 3               ;
000152r 3               ; device:
000152r 3               ;   RP filesystem device/FatFs drive number: 0..3.
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               .struct open_args
000152r 3                   path_ptr        .word
000152r 3                   max_len         .word
000152r 3                   flags           .byte
000152r 3                   device          .byte
000152r 3               .endstruct
000152r 3               
000152r 3               OPEN_ARGS_SIZE = .sizeof(open_args)
000152r 3               
000152r 3               OPEN_READ           = $00    ; read existing
000152r 3               OPEN_WRITE_TRUNC    = $01    ; write create/truncate
000152r 3               OPEN_WRITE_EXISTING = $02    ; write existing, no truncate
000152r 3               OPEN_RW_EXISTING    = $03    ; read/write existing, no truncate
000152r 3               OPEN_RW_CREATE      = $04    ; read/write create if missing, no truncate if existing
000152r 3               
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Bulk filesystem argument blocks
000152r 3               ;
000152r 3               ; Names and paths use NEOX 8.3 path components. The path string is
000152r 3               ; NUL-terminated and is validated by the RP side.
000152r 3               ;
000152r 3               ; max_bytes / byte_count:
000152r 3               ;   $0000 means 65536 bytes.
000152r 3               ;
000152r 3               ; flags:
000152r 3               ;   Reserved for now. Must be 0.
000152r 3               ;
000152r 3               ; Context rule:
000152r 3               ;   User code never supplies a context. The kernel derives the caller
000152r 3               ;   context and passes it separately to the RP mailbox in ARG2L.
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               .struct fs_load_args
000152r 3                   path_ptr        .word
000152r 3                   dest_ptr        .word
000152r 3                   max_bytes       .word
000152r 3                   device          .byte
000152r 3                   flags           .byte
000152r 3               .endstruct
000152r 3               
000152r 3               FS_LOAD_ARGS_SIZE = .sizeof(fs_load_args)
000152r 3               
000152r 3               .struct fs_save_args
000152r 3                   path_ptr        .word
000152r 3                   src_ptr         .word
000152r 3                   byte_count      .word
000152r 3                   device          .byte
000152r 3                   flags           .byte
000152r 3               .endstruct
000152r 3               
000152r 3               FS_SAVE_ARGS_SIZE = .sizeof(fs_save_args)
000152r 3               
000152r 3               FS_BULK_FLAGS_NONE = $00
000152r 3               
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Seek/tell filesystem argument blocks
000152r 3               ;
000152r 3               ; offset_lo/offset_hi:
000152r 3               ;   Signed 32-bit offset split into low/high words.  SEEK_SET
000152r 3               ;   requires a non-negative final target; SEEK_CUR and SEEK_END
000152r 3               ;   allow negative offsets.
000152r 3               ;
000152r 3               ; result_lo/result_hi:
000152r 3               ;   Kernel writes the resulting unsigned 32-bit file position here.
000152r 3               ;   A/X also return result_lo for convenience.
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               SEEK_SET            = $00
000152r 3               SEEK_CUR            = $01
000152r 3               SEEK_END            = $02
000152r 3               
000152r 3               .struct seek_args
000152r 3                   fd              .byte
000152r 3                   whence          .byte
000152r 3                   offset_lo       .word
000152r 3                   offset_hi       .word
000152r 3                   result_lo       .word
000152r 3                   result_hi       .word
000152r 3               .endstruct
000152r 3               
000152r 3               SEEK_ARGS_SIZE = .sizeof(seek_args)
000152r 3               
000152r 3               .struct tell_args
000152r 3                   fd              .byte
000152r 3                   reserved        .byte
000152r 3                   result_lo       .word
000152r 3                   result_hi       .word
000152r 3               .endstruct
000152r 3               
000152r 3               TELL_ARGS_SIZE = .sizeof(tell_args)
000152r 3               
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Delete/rename filesystem argument blocks
000152r 3               ;
000152r 3               ; V34 path handling uses the same RP-side 8.3 validator as open.
000152r 3               ; flags is reserved and must be 0.
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               FS_PATH_FLAGS_NONE  = $00
000152r 3               
000152r 3               .struct delete_args
000152r 3                   path_ptr        .word
000152r 3                   max_len         .word
000152r 3                   device          .byte
000152r 3                   flags           .byte
000152r 3               .endstruct
000152r 3               
000152r 3               DELETE_ARGS_SIZE = .sizeof(delete_args)
000152r 3               
000152r 3               .struct rename_args
000152r 3                   old_path_ptr    .word
000152r 3                   new_path_ptr    .word
000152r 3                   max_len         .word
000152r 3                   device          .byte
000152r 3                   flags           .byte
000152r 3               .endstruct
000152r 3               
000152r 3               RENAME_ARGS_SIZE = .sizeof(rename_args)
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Common read/write argument block
000152r 3               ;
000152r 3               ; fd:
000152r 3               ;   STDIN / STDOUT / STDERR
000152r 3               ;
000152r 3               ; buf_ptr:
000152r 3               ;   Pointer to caller buffer in the current task context
000152r 3               ;
000152r 3               ; len:
000152r 3               ;   Requested transfer length
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               .struct rw_args
000152r 3                   fd              .byte
000152r 3                   reserved        .byte
000152r 3                   buf_ptr         .word
000152r 3                   len             .word
000152r 3               .endstruct
000152r 3               
000152r 3               RW_ARGS_SIZE = .sizeof(rw_args)
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; SYSCALL helper macro
000152r 3               ;
000152r 3               ; Purpose:
000152r 3               ;   Load X/Y with the address of an argument block and call the
000152r 3               ;   fixed syscall entry.
000152r 3               ;
000152r 3               ; Example:
000152r 3               ;   SYSCALL my_args, sys_write
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               .macro SYSCALL argblk, entry
000152r 3                   ; Keep the register argument pointer stable across the tiny user-side
000152r 3                   ; setup window. The kernel snapshots the process-private pointer before
000152r 3                   ; taking file_io_gate and decodes the block after the owner resumes.
000152r 3                   sei
000152r 3                   ldx #<argblk
000152r 3                   ldy #>argblk
000152r 3                   jsr entry
000152r 3               .endmacro
000152r 3               
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Directory control argument blocks
000152r 3               ;
000152r 3               ; V35 exposes directory handles as normal NEOX fd numbers. The RP
000152r 3               ; directory handle remains kernel-private in the FD/open-object table.
000152r 3               ;
000152r 3               ; dir_entry layout matches the RP serialized directory entry:
000152r 3               ;   name[13] = NUL-terminated 8.3 name
000152r 3               ;   attr     = FatFs attribute byte
000152r 3               ;   size     = unsigned 32-bit byte size
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               DIR_ENTRY_NAME_SIZE = 13
000152r 3               DIR_ENTRY_SIZE      = 18
000152r 3               
000152r 3               .struct dir_entry
000152r 3                   name            .res 13
000152r 3                   attr            .byte
000152r 3                   size_lo         .word
000152r 3                   size_hi         .word
000152r 3               .endstruct
000152r 3               
000152r 3               .struct opendir_args
000152r 3                   path_ptr        .word
000152r 3                   max_len         .word
000152r 3                   device          .byte
000152r 3                   flags           .byte
000152r 3               .endstruct
000152r 3               
000152r 3               OPENDIR_ARGS_SIZE = .sizeof(opendir_args)
000152r 3               
000152r 3               .struct readdir_args
000152r 3                   fd              .byte
000152r 3                   reserved        .byte
000152r 3                   entry_ptr       .word
000152r 3                   entry_size      .word
000152r 3               .endstruct
000152r 3               
000152r 3               READDIR_ARGS_SIZE = .sizeof(readdir_args)
000152r 3               
000152r 3               .struct closedir_args
000152r 3                   fd              .byte
000152r 3                   reserved        .byte
000152r 3               .endstruct
000152r 3               
000152r 3               CLOSEDIR_ARGS_SIZE = .sizeof(closedir_args)
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Current directory argument blocks
000152r 3               ;
000152r 3               ; V36 stores current directory per process as drive + absolute path.
000152r 3               ; User-visible getcwd form is D:/PATH.
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               NEOX_PATH_FLAGS_NONE = $00
000152r 3               
000152r 3               .struct chdir_args
000152r 3                   path_ptr        .word
000152r 3                   max_len         .word
000152r 3                   device          .byte
000152r 3                   flags           .byte
000152r 3               .endstruct
000152r 3               
000152r 3               CHDIR_ARGS_SIZE = .sizeof(chdir_args)
000152r 3               
000152r 3               .struct getcwd_args
000152r 3                   buffer_ptr      .word
000152r 3                   buffer_size     .word
000152r 3                   result_len      .word
000152r 3                   flags           .byte
000152r 3                   reserved        .byte
000152r 3               .endstruct
000152r 3               
000152r 3               GETCWD_ARGS_SIZE = .sizeof(getcwd_args)
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Directory create/remove argument blocks
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               .struct mkdir_args
000152r 3                   path_ptr        .word
000152r 3                   max_len         .word
000152r 3                   device          .byte
000152r 3                   flags           .byte
000152r 3               .endstruct
000152r 3               
000152r 3               MKDIR_ARGS_SIZE = .sizeof(mkdir_args)
000152r 3               
000152r 3               .struct rmdir_args
000152r 3                   path_ptr        .word
000152r 3                   max_len         .word
000152r 3                   device          .byte
000152r 3                   flags           .byte
000152r 3               .endstruct
000152r 3               
000152r 3               RMDIR_ARGS_SIZE = .sizeof(rmdir_args)
000152r 3               
000152r 3               ; ------------------------------------------------------------
000152r 3               ; Process information argument block
000152r 3               ;
000152r 3               ; SYS_GETPROCINFO copies one compact process-table snapshot record
000152r 3               ; into caller memory.  The record is deliberately binary; user-space
000152r 3               ; commands such as PS own all text formatting.
000152r 3               ;
000152r 3               ; Record layout:
000152r 3               ;   +0 pid
000152r 3               ;   +1 ppid
000152r 3               ;   +2 state
000152r 3               ;   +3 wait_reason
000152r 3               ;   +4 signal_pending
000152r 3               ;   +5 wait_object
000152r 3               ;   +6 held_gate_mask (PROC_HOLD_*)
000152r 3               ;
000152r 3               ; Kernels accepting the extended record remain compatible with callers
000152r 3               ; that provide the original five-byte buffer.
000152r 3               ; ------------------------------------------------------------
000152r 3               
000152r 3               PROCINFO_RECORD_MIN_SIZE = 5
000152r 3               PROCINFO_RECORD_SIZE     = 7
000152r 3               
000152r 3               .struct procinfo_args
000152r 3                   pid             .byte
000152r 3                   reserved        .byte
000152r 3                   buffer_ptr      .word
000152r 3                   buffer_size     .word
000152r 3               .endstruct
000152r 3               
000152r 3               PROCINFO_ARGS_SIZE = .sizeof(procinfo_args)
000152r 3               
000152r 3               .endif
000152r 3               
000152r 2               
000152r 2               .export user_task2_entry
000152r 2               
000152r 2               T2_RX_FD = 3          ; Task 1 -> Task 2
000152r 2               T2_TX_FD = 4          ; Task 2 -> Task 1
000152r 2               
000152r 2               .segment "USER_DATA"
00004Er 2               
00004Er 2               t2_pong_byte:
00004Er 2  51               .byte "Q"
00004Fr 2               
00004Fr 2               t2_rx_byte:
00004Fr 2  xx               .res 1
000050r 2               
000050r 2               t2_msg_start:
000050r 2  54 32 20 50      .byte "T2 PINGPONG START", 13
000054r 2  49 4E 47 50  
000058r 2  4F 4E 47 20  
000062r 2               
000062r 2               ; Failure message layout:
000062r 2               ;   "T2 PINGPONG FAIL " + one diagnostic code + CR
000062r 2               ;
000062r 2               ; Codes:
000062r 2               ;   R = sys_read returned real error
000062r 2               ;   A = sys_read returned low byte count != 1
000062r 2               ;   X = sys_read returned high byte count != 0
000062r 2               ;   B = sys_read returned byte other than 'P'
000062r 2               ;   W = sys_write returned real error
000062r 2               ;   C = sys_write returned low byte count != 1
000062r 2               ;   H = sys_write returned high byte count != 0
000062r 2               
000062r 2               t2_msg_fail:
000062r 2  54 32 20 50      .byte "T2 PINGPONG FAIL "
000066r 2  49 4E 47 50  
00006Ar 2  4F 4E 47 20  
000073r 2               
000073r 2               t2_fail_code:
000073r 2  3F               .byte "?"
000074r 2               
000074r 2  0D               .byte 13
000075r 2               
000075r 2               t2_wr_stdout_args:
000075r 2  01               .byte STDOUT
000076r 2  00               .byte 0
000077r 2  00 00            .word 0
000079r 2  00 00            .word 0
00007Br 2               
00007Br 2               t2_read_args:
00007Br 2  03               .byte T2_RX_FD
00007Cr 2  00               .byte 0
00007Dr 2  rr rr            .word t2_rx_byte
00007Fr 2  01 00            .word 1
000081r 2               
000081r 2               t2_write_args:
000081r 2  04               .byte T2_TX_FD
000082r 2  00               .byte 0
000083r 2  rr rr            .word t2_pong_byte
000085r 2  01 00            .word 1
000087r 2               
000087r 2               .segment "USER_TEXT"
000152r 2               
000152r 2               ; ------------------------------------------------------------
000152r 2               ; t2_print_msg
000152r 2               ;
000152r 2               ; Input:
000152r 2               ;   A/X = string pointer
000152r 2               ;   Y   = length including CR
000152r 2               ; ------------------------------------------------------------
000152r 2               
000152r 2               .proc t2_print_msg
000152r 2  8D rr rr         sta t2_wr_stdout_args + rw_args::buf_ptr
000155r 2  8E rr rr         stx t2_wr_stdout_args + rw_args::buf_ptr + 1
000158r 2               
000158r 2  98               tya
000159r 2  8D rr rr         sta t2_wr_stdout_args + rw_args::len
00015Cr 2  9C rr rr         stz t2_wr_stdout_args + rw_args::len + 1
00015Fr 2               
00015Fr 2  78 A2 rr A0      SYSCALL t2_wr_stdout_args, sys_write
000163r 2  rr 20 0C F1  
000167r 2  60               rts
000168r 2               .endproc
000168r 2               
000168r 2               .proc t2_print_start
000168r 2  A9 rr            lda #<t2_msg_start
00016Ar 2  A2 rr            ldx #>t2_msg_start
00016Cr 2  A0 12            ldy #18
00016Er 2  4C rr rr         jmp t2_print_msg
000171r 2               .endproc
000171r 2               
000171r 2               .proc t2_print_fail
000171r 2  A9 rr            lda #<t2_msg_fail
000173r 2  A2 rr            ldx #>t2_msg_fail
000175r 2  A0 13            ldy #19
000177r 2  4C rr rr         jmp t2_print_msg
00017Ar 2               .endproc
00017Ar 2               
00017Ar 2               ; ------------------------------------------------------------
00017Ar 2               ; t2_read_ping
00017Ar 2               ;
00017Ar 2               ; Blocking pipe read. The kernel handles EAGAIN by blocking
00017Ar 2               ; and retrying the syscall; task code only handles EOF/real errors.
00017Ar 2               ; ------------------------------------------------------------
00017Ar 2               
00017Ar 2               .proc t2_read_ping
00017Ar 2  78 A2 rr A0      SYSCALL t2_read_args, sys_read
00017Er 2  rr 20 09 F1  
000182r 2  90 07            bcc @ok
000184r 2               
000184r 2  A9 52            lda #'R'                ; read returned real error
000186r 2  8D rr rr         sta t2_fail_code
000189r 2  38               sec
00018Ar 2  60               rts
00018Br 2               
00018Br 2               @ok:
00018Br 2  C9 01            cmp #1
00018Dr 2  F0 07            beq :+
00018Fr 2  A9 41            lda #'A'                ; read low byte count was not 1
000191r 2  8D rr rr         sta t2_fail_code
000194r 2  38               sec
000195r 2  60               rts
000196r 2               :
000196r 2  E0 00            cpx #0
000198r 2  F0 07            beq :+
00019Ar 2  A9 58            lda #'X'                ; read high byte count was not 0
00019Cr 2  8D rr rr         sta t2_fail_code
00019Fr 2  38               sec
0001A0r 2  60               rts
0001A1r 2               :
0001A1r 2  AD rr rr         lda t2_rx_byte
0001A4r 2  C9 50            cmp #'P'
0001A6r 2  F0 07            beq :+
0001A8r 2  A9 42            lda #'B'                ; read byte was not 'P'
0001AAr 2  8D rr rr         sta t2_fail_code
0001ADr 2  38               sec
0001AEr 2  60               rts
0001AFr 2               :
0001AFr 2  18               clc
0001B0r 2  60               rts
0001B1r 2               .endproc
0001B1r 2               
0001B1r 2               ; ------------------------------------------------------------
0001B1r 2               ; t2_write_pong
0001B1r 2               ;
0001B1r 2               ; Blocking pipe write. The kernel handles EAGAIN by blocking
0001B1r 2               ; and retrying the syscall; task code only handles real errors.
0001B1r 2               ; ------------------------------------------------------------
0001B1r 2               
0001B1r 2               .proc t2_write_pong
0001B1r 2  78 A2 rr A0      SYSCALL t2_write_args, sys_write
0001B5r 2  rr 20 0C F1  
0001B9r 2  90 07            bcc @ok
0001BBr 2               
0001BBr 2  A9 57            lda #'W'                ; write returned real error
0001BDr 2  8D rr rr         sta t2_fail_code
0001C0r 2  38               sec
0001C1r 2  60               rts
0001C2r 2               
0001C2r 2               @ok:
0001C2r 2  C9 01            cmp #1
0001C4r 2  F0 07            beq :+
0001C6r 2  A9 43            lda #'C'                ; write low byte count was not 1
0001C8r 2  8D rr rr         sta t2_fail_code
0001CBr 2  38               sec
0001CCr 2  60               rts
0001CDr 2               :
0001CDr 2  E0 00            cpx #0
0001CFr 2  F0 07            beq :+
0001D1r 2  A9 48            lda #'H'                ; write high byte count was not 0
0001D3r 2  8D rr rr         sta t2_fail_code
0001D6r 2  38               sec
0001D7r 2  60               rts
0001D8r 2               :
0001D8r 2  18               clc
0001D9r 2  60               rts
0001DAr 2               .endproc
0001DAr 2               
0001DAr 2               ; ------------------------------------------------------------
0001DAr 2               ; user_task2_entry
0001DAr 2               ; ------------------------------------------------------------
0001DAr 2               
0001DAr 2               .proc user_task2_entry
0001DAr 2  20 rr rr         jsr t2_print_start
0001DDr 2               
0001DDr 2               @loop:
0001DDr 2  20 rr rr         jsr t2_read_ping
0001E0r 2  90 03            bcc :+
0001E2r 2  4C rr rr         jmp @fail
0001E5r 2               :
0001E5r 2  20 rr rr         jsr t2_write_pong
0001E8r 2  90 03            bcc :+
0001EAr 2  4C rr rr         jmp @fail
0001EDr 2               :
0001EDr 2  A9 01        	lda #$01
0001EFr 2  20 2A F1     	jsr sys_sleep
0001F2r 2  80 E9            bra @loop
0001F4r 2               
0001F4r 2               @fail:
0001F4r 2  20 rr rr         jsr t2_print_fail
0001F7r 2               
0001F7r 2               @idle:
0001F7r 2                   ; Failure stop loop.
0001F7r 2  A9 10        	lda #$10
0001F9r 2  20 2A F1     	jsr sys_sleep
0001FCr 2  80 F9            bra @idle
0001FEr 2               .endproc
0001FEr 2               
0001FEr 1               .include "task/task3.asm"
0001FEr 2               ; ============================================================
0001FEr 2               ; task3.asm
0001FEr 2               ; NEOX console echo task
0001FEr 2               ;
0001FEr 2               ; Policy:
0001FEr 2               ;   User tasks must use the normal syscall console path.
0001FEr 2               ;
0001FEr 2               ; Behavior:
0001FEr 2               ;   - read one byte from STDIN
0001FEr 2               ;   - echo it to STDOUT
0001FEr 2               ;   - exit when the byte is 'Q'
0001FEr 2               ;   - blocking console read/write are handled by the kernel
0001FEr 2               ;   - exit on read/write error or short transfer
0001FEr 2               ; ============================================================
0001FEr 2               
0001FEr 2               .setcpu "65C02"
0001FEr 2               
0001FEr 2               .include "syscall.inc"
0001FEr 3               ; ============================================================
0001FEr 3               ; syscall.inc
0001FEr 3               ; NEOX - syscall definitions
0001FEr 3               ;
0001FEr 3               ; Purpose:
0001FEr 3               ;   Defines syscall numbers, fixed syscall entry addresses,
0001FEr 3               ;   error codes, and common syscall argument structures.
0001FEr 3               ;
0001FEr 3               ; Architecture:
0001FEr 3               ;   - Syscall jump table is located in the shared BIOS page at $F100
0001FEr 3               ;   - Each syscall entry is a 3-byte JMP stub
0001FEr 3               ;   - User code calls fixed syscall entry addresses
0001FEr 3               ;
0001FEr 3               ; Notes:
0001FEr 3               ;   SYS_MONITOR enters supervisor/MICMON context through the
0001FEr 3               ;   kernel-defined monitor entry path. It is a controlled
0001FEr 3               ;   privileged transfer, not direct user control of MMU/scheduler.
0001FEr 3               ; ============================================================
0001FEr 3               
0001FEr 3               .ifndef __SYSCALL_INC__
0001FEr 3               __SYSCALL_INC__ = 1
0001FEr 3               
0001FEr 3               .include "config.inc"
0001FEr 3               
0001FEr 3               SYSCALL_ENTRY_SIZE  = 3
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Standard file descriptors
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               STDIN               = 0
0001FEr 3               STDOUT              = 1
0001FEr 3               STDERR              = 2
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Syscall numbers
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               SYS_EXIT			= $00
0001FEr 3               SYS_OPEN            = $01
0001FEr 3               SYS_CLOSE			= $02
0001FEr 3               SYS_READ            = $03
0001FEr 3               SYS_WRITE           = $04
0001FEr 3               SYS_MONITOR         = $05
0001FEr 3               SYS_LOAD_FILE_TO_MEMORY = $06
0001FEr 3               SYS_SAVE_MEMORY_TO_FILE = $07
0001FEr 3               SYS_SEEK            = $08
0001FEr 3               SYS_TELL            = $09
0001FEr 3               SYS_PIPE			= $0A
0001FEr 3               SYS_DELETE          = $0C
0001FEr 3               SYS_RENAME          = $0D
0001FEr 3               SYS_YIELD           = $0B
0001FEr 3               SYS_SLEEP           = $0E
0001FEr 3               SYS_DUP				= $0F
0001FEr 3               SYS_DUP2			= $10
0001FEr 3               SYS_TICKS           = $11
0001FEr 3               SYS_SIGNAL          = $12
0001FEr 3               SYS_OPENDIR         = $13
0001FEr 3               SYS_READDIR         = $14
0001FEr 3               SYS_CLOSEDIR        = $15
0001FEr 3               SYS_CHDIR           = $16
0001FEr 3               SYS_GETCWD          = $17
0001FEr 3               SYS_MKDIR           = $18
0001FEr 3               SYS_RMDIR           = $19
0001FEr 3               SYS_GETPROCINFO      = $1A
0001FEr 3               SYS_WAITPID           = $1B
0001FEr 3               SYS_GET_LAUNCH_ID     = $1C
0001FEr 3               SYS_GET_LAUNCH_LINE   = $1D
0001FEr 3               SYS_SPAWN_RESIDENT    = $1E
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Fixed syscall entry addresses
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               sys_exit            = SYSCALL_BASE + (SYS_EXIT    * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_open            = SYSCALL_BASE + (SYS_OPEN    * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_close           = SYSCALL_BASE + (SYS_CLOSE   * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_read            = SYSCALL_BASE + (SYS_READ    * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_write           = SYSCALL_BASE + (SYS_WRITE   * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_monitor         = SYSCALL_BASE + (SYS_MONITOR * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_load_file_to_memory = SYSCALL_BASE + (SYS_LOAD_FILE_TO_MEMORY * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_save_memory_to_file = SYSCALL_BASE + (SYS_SAVE_MEMORY_TO_FILE * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_seek            = SYSCALL_BASE + (SYS_SEEK    * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_tell            = SYSCALL_BASE + (SYS_TELL    * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_delete          = SYSCALL_BASE + (SYS_DELETE  * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_rename          = SYSCALL_BASE + (SYS_RENAME  * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_pipe            = SYSCALL_BASE + (SYS_PIPE    * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_yield           = SYSCALL_BASE + (SYS_YIELD   * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_sleep           = SYSCALL_BASE + (SYS_SLEEP   * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_dup				= SYSCALL_BASE + (SYS_DUP     * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_dup2			= SYSCALL_BASE + (SYS_DUP2    * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_ticks           = SYSCALL_BASE + (SYS_TICKS   * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_signal          = SYSCALL_BASE + (SYS_SIGNAL  * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_opendir         = SYSCALL_BASE + (SYS_OPENDIR * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_readdir         = SYSCALL_BASE + (SYS_READDIR * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_closedir        = SYSCALL_BASE + (SYS_CLOSEDIR * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_chdir           = SYSCALL_BASE + (SYS_CHDIR * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_getcwd          = SYSCALL_BASE + (SYS_GETCWD * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_mkdir           = SYSCALL_BASE + (SYS_MKDIR * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_rmdir           = SYSCALL_BASE + (SYS_RMDIR * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_getprocinfo      = SYSCALL_BASE + (SYS_GETPROCINFO * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_waitpid          = SYSCALL_BASE + (SYS_WAITPID * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_get_launch_id    = SYSCALL_BASE + (SYS_GET_LAUNCH_ID * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_get_launch_line  = SYSCALL_BASE + (SYS_GET_LAUNCH_LINE * SYSCALL_ENTRY_SIZE)
0001FEr 3               sys_spawn_resident   = SYSCALL_BASE + (SYS_SPAWN_RESIDENT * SYSCALL_ENTRY_SIZE)
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Common errno values
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               E_OK                = 0
0001FEr 3               EIO                 = 3
0001FEr 3               EINVAL              = 6
0001FEr 3               EMFILE              = 8        ; too many open file descriptors
0001FEr 3               EBADF               = 9
0001FEr 3               ENODEV              = 10
0001FEr 3               ENOSYS              = 11
0001FEr 3               EINTR               = 4        ; interrupted system call
0001FEr 3               EAGAIN              = 12       ; operation would block / try again
0001FEr 3               ENOMEM              = 13       ; no free kernel memory/object/table slot
0001FEr 3               EPIPE               = 14       ; write on pipe with no readers
0001FEr 3               
0001FEr 3               .include "spawn.inc"
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Common open argument block
0001FEr 3               ;
0001FEr 3               ; path_ptr:
0001FEr 3               ;   Pointer to a NUL-terminated 8.3 filename in the current task
0001FEr 3               ;   context. The RP-side FS_OPEN command scans at most max_len bytes.
0001FEr 3               ;
0001FEr 3               ; max_len:
0001FEr 3               ;   Maximum filename scan length. Use a small bounded value such as 64.
0001FEr 3               ;
0001FEr 3               ; flags:
0001FEr 3               ;   Open mode. V32 supports read-only, write/truncate, write-existing,
0001FEr 3               ;   read/write-existing, and read/write-create.
0001FEr 3               ;
0001FEr 3               ; device:
0001FEr 3               ;   RP filesystem device/FatFs drive number: 0..3.
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               .struct open_args
0001FEr 3                   path_ptr        .word
0001FEr 3                   max_len         .word
0001FEr 3                   flags           .byte
0001FEr 3                   device          .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               OPEN_ARGS_SIZE = .sizeof(open_args)
0001FEr 3               
0001FEr 3               OPEN_READ           = $00    ; read existing
0001FEr 3               OPEN_WRITE_TRUNC    = $01    ; write create/truncate
0001FEr 3               OPEN_WRITE_EXISTING = $02    ; write existing, no truncate
0001FEr 3               OPEN_RW_EXISTING    = $03    ; read/write existing, no truncate
0001FEr 3               OPEN_RW_CREATE      = $04    ; read/write create if missing, no truncate if existing
0001FEr 3               
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Bulk filesystem argument blocks
0001FEr 3               ;
0001FEr 3               ; Names and paths use NEOX 8.3 path components. The path string is
0001FEr 3               ; NUL-terminated and is validated by the RP side.
0001FEr 3               ;
0001FEr 3               ; max_bytes / byte_count:
0001FEr 3               ;   $0000 means 65536 bytes.
0001FEr 3               ;
0001FEr 3               ; flags:
0001FEr 3               ;   Reserved for now. Must be 0.
0001FEr 3               ;
0001FEr 3               ; Context rule:
0001FEr 3               ;   User code never supplies a context. The kernel derives the caller
0001FEr 3               ;   context and passes it separately to the RP mailbox in ARG2L.
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               .struct fs_load_args
0001FEr 3                   path_ptr        .word
0001FEr 3                   dest_ptr        .word
0001FEr 3                   max_bytes       .word
0001FEr 3                   device          .byte
0001FEr 3                   flags           .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               FS_LOAD_ARGS_SIZE = .sizeof(fs_load_args)
0001FEr 3               
0001FEr 3               .struct fs_save_args
0001FEr 3                   path_ptr        .word
0001FEr 3                   src_ptr         .word
0001FEr 3                   byte_count      .word
0001FEr 3                   device          .byte
0001FEr 3                   flags           .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               FS_SAVE_ARGS_SIZE = .sizeof(fs_save_args)
0001FEr 3               
0001FEr 3               FS_BULK_FLAGS_NONE = $00
0001FEr 3               
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Seek/tell filesystem argument blocks
0001FEr 3               ;
0001FEr 3               ; offset_lo/offset_hi:
0001FEr 3               ;   Signed 32-bit offset split into low/high words.  SEEK_SET
0001FEr 3               ;   requires a non-negative final target; SEEK_CUR and SEEK_END
0001FEr 3               ;   allow negative offsets.
0001FEr 3               ;
0001FEr 3               ; result_lo/result_hi:
0001FEr 3               ;   Kernel writes the resulting unsigned 32-bit file position here.
0001FEr 3               ;   A/X also return result_lo for convenience.
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               SEEK_SET            = $00
0001FEr 3               SEEK_CUR            = $01
0001FEr 3               SEEK_END            = $02
0001FEr 3               
0001FEr 3               .struct seek_args
0001FEr 3                   fd              .byte
0001FEr 3                   whence          .byte
0001FEr 3                   offset_lo       .word
0001FEr 3                   offset_hi       .word
0001FEr 3                   result_lo       .word
0001FEr 3                   result_hi       .word
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               SEEK_ARGS_SIZE = .sizeof(seek_args)
0001FEr 3               
0001FEr 3               .struct tell_args
0001FEr 3                   fd              .byte
0001FEr 3                   reserved        .byte
0001FEr 3                   result_lo       .word
0001FEr 3                   result_hi       .word
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               TELL_ARGS_SIZE = .sizeof(tell_args)
0001FEr 3               
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Delete/rename filesystem argument blocks
0001FEr 3               ;
0001FEr 3               ; V34 path handling uses the same RP-side 8.3 validator as open.
0001FEr 3               ; flags is reserved and must be 0.
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               FS_PATH_FLAGS_NONE  = $00
0001FEr 3               
0001FEr 3               .struct delete_args
0001FEr 3                   path_ptr        .word
0001FEr 3                   max_len         .word
0001FEr 3                   device          .byte
0001FEr 3                   flags           .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               DELETE_ARGS_SIZE = .sizeof(delete_args)
0001FEr 3               
0001FEr 3               .struct rename_args
0001FEr 3                   old_path_ptr    .word
0001FEr 3                   new_path_ptr    .word
0001FEr 3                   max_len         .word
0001FEr 3                   device          .byte
0001FEr 3                   flags           .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               RENAME_ARGS_SIZE = .sizeof(rename_args)
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Common read/write argument block
0001FEr 3               ;
0001FEr 3               ; fd:
0001FEr 3               ;   STDIN / STDOUT / STDERR
0001FEr 3               ;
0001FEr 3               ; buf_ptr:
0001FEr 3               ;   Pointer to caller buffer in the current task context
0001FEr 3               ;
0001FEr 3               ; len:
0001FEr 3               ;   Requested transfer length
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               .struct rw_args
0001FEr 3                   fd              .byte
0001FEr 3                   reserved        .byte
0001FEr 3                   buf_ptr         .word
0001FEr 3                   len             .word
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               RW_ARGS_SIZE = .sizeof(rw_args)
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; SYSCALL helper macro
0001FEr 3               ;
0001FEr 3               ; Purpose:
0001FEr 3               ;   Load X/Y with the address of an argument block and call the
0001FEr 3               ;   fixed syscall entry.
0001FEr 3               ;
0001FEr 3               ; Example:
0001FEr 3               ;   SYSCALL my_args, sys_write
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               .macro SYSCALL argblk, entry
0001FEr 3                   ; Keep the register argument pointer stable across the tiny user-side
0001FEr 3                   ; setup window. The kernel snapshots the process-private pointer before
0001FEr 3                   ; taking file_io_gate and decodes the block after the owner resumes.
0001FEr 3                   sei
0001FEr 3                   ldx #<argblk
0001FEr 3                   ldy #>argblk
0001FEr 3                   jsr entry
0001FEr 3               .endmacro
0001FEr 3               
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Directory control argument blocks
0001FEr 3               ;
0001FEr 3               ; V35 exposes directory handles as normal NEOX fd numbers. The RP
0001FEr 3               ; directory handle remains kernel-private in the FD/open-object table.
0001FEr 3               ;
0001FEr 3               ; dir_entry layout matches the RP serialized directory entry:
0001FEr 3               ;   name[13] = NUL-terminated 8.3 name
0001FEr 3               ;   attr     = FatFs attribute byte
0001FEr 3               ;   size     = unsigned 32-bit byte size
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               DIR_ENTRY_NAME_SIZE = 13
0001FEr 3               DIR_ENTRY_SIZE      = 18
0001FEr 3               
0001FEr 3               .struct dir_entry
0001FEr 3                   name            .res 13
0001FEr 3                   attr            .byte
0001FEr 3                   size_lo         .word
0001FEr 3                   size_hi         .word
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               .struct opendir_args
0001FEr 3                   path_ptr        .word
0001FEr 3                   max_len         .word
0001FEr 3                   device          .byte
0001FEr 3                   flags           .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               OPENDIR_ARGS_SIZE = .sizeof(opendir_args)
0001FEr 3               
0001FEr 3               .struct readdir_args
0001FEr 3                   fd              .byte
0001FEr 3                   reserved        .byte
0001FEr 3                   entry_ptr       .word
0001FEr 3                   entry_size      .word
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               READDIR_ARGS_SIZE = .sizeof(readdir_args)
0001FEr 3               
0001FEr 3               .struct closedir_args
0001FEr 3                   fd              .byte
0001FEr 3                   reserved        .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               CLOSEDIR_ARGS_SIZE = .sizeof(closedir_args)
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Current directory argument blocks
0001FEr 3               ;
0001FEr 3               ; V36 stores current directory per process as drive + absolute path.
0001FEr 3               ; User-visible getcwd form is D:/PATH.
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               NEOX_PATH_FLAGS_NONE = $00
0001FEr 3               
0001FEr 3               .struct chdir_args
0001FEr 3                   path_ptr        .word
0001FEr 3                   max_len         .word
0001FEr 3                   device          .byte
0001FEr 3                   flags           .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               CHDIR_ARGS_SIZE = .sizeof(chdir_args)
0001FEr 3               
0001FEr 3               .struct getcwd_args
0001FEr 3                   buffer_ptr      .word
0001FEr 3                   buffer_size     .word
0001FEr 3                   result_len      .word
0001FEr 3                   flags           .byte
0001FEr 3                   reserved        .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               GETCWD_ARGS_SIZE = .sizeof(getcwd_args)
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Directory create/remove argument blocks
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               .struct mkdir_args
0001FEr 3                   path_ptr        .word
0001FEr 3                   max_len         .word
0001FEr 3                   device          .byte
0001FEr 3                   flags           .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               MKDIR_ARGS_SIZE = .sizeof(mkdir_args)
0001FEr 3               
0001FEr 3               .struct rmdir_args
0001FEr 3                   path_ptr        .word
0001FEr 3                   max_len         .word
0001FEr 3                   device          .byte
0001FEr 3                   flags           .byte
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               RMDIR_ARGS_SIZE = .sizeof(rmdir_args)
0001FEr 3               
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               ; Process information argument block
0001FEr 3               ;
0001FEr 3               ; SYS_GETPROCINFO copies one compact process-table snapshot record
0001FEr 3               ; into caller memory.  The record is deliberately binary; user-space
0001FEr 3               ; commands such as PS own all text formatting.
0001FEr 3               ;
0001FEr 3               ; Record layout:
0001FEr 3               ;   +0 pid
0001FEr 3               ;   +1 ppid
0001FEr 3               ;   +2 state
0001FEr 3               ;   +3 wait_reason
0001FEr 3               ;   +4 signal_pending
0001FEr 3               ;   +5 wait_object
0001FEr 3               ;   +6 held_gate_mask (PROC_HOLD_*)
0001FEr 3               ;
0001FEr 3               ; Kernels accepting the extended record remain compatible with callers
0001FEr 3               ; that provide the original five-byte buffer.
0001FEr 3               ; ------------------------------------------------------------
0001FEr 3               
0001FEr 3               PROCINFO_RECORD_MIN_SIZE = 5
0001FEr 3               PROCINFO_RECORD_SIZE     = 7
0001FEr 3               
0001FEr 3               .struct procinfo_args
0001FEr 3                   pid             .byte
0001FEr 3                   reserved        .byte
0001FEr 3                   buffer_ptr      .word
0001FEr 3                   buffer_size     .word
0001FEr 3               .endstruct
0001FEr 3               
0001FEr 3               PROCINFO_ARGS_SIZE = .sizeof(procinfo_args)
0001FEr 3               
0001FEr 3               .endif
0001FEr 3               
0001FEr 2               
0001FEr 2               T3_RX_FD          = STDIN
0001FEr 2               T3_TX_FD          = STDOUT
0001FEr 2               
0001FEr 2               .export user_task3_entry
0001FEr 2               
0001FEr 2               .segment "USER_DATA"
000087r 2               
000087r 2               t3_byte:
000087r 2  xx               .res 1
000088r 2               
000088r 2               t3_read_args:
000088r 2  00               .byte T3_RX_FD
000089r 2  00               .byte 0
00008Ar 2  rr rr            .word t3_byte
00008Cr 2  01 00            .word 1
00008Er 2               
00008Er 2               t3_write_args:
00008Er 2  01               .byte T3_TX_FD
00008Fr 2  00               .byte 0
000090r 2  rr rr            .word t3_byte
000092r 2  01 00            .word 1
000094r 2               
000094r 2               .segment "USER_TEXT"
0001FEr 2               
0001FEr 2               ; ------------------------------------------------------------
0001FEr 2               ; t3_read_char
0001FEr 2               ;
0001FEr 2               ; Return:
0001FEr 2               ;   C clear = one byte read into t3_byte
0001FEr 2               ;   C set   = read error or short transfer
0001FEr 2               ; ------------------------------------------------------------
0001FEr 2               
0001FEr 2               .proc t3_read_char
0001FEr 2  78 A2 rr A0      SYSCALL t3_read_args, sys_read
000202r 2  rr 20 09 F1  
000206r 2  90 02            bcc @ok
000208r 2               
000208r 2  38               sec
000209r 2  60               rts
00020Ar 2               
00020Ar 2               @ok:
00020Ar 2  C9 01            cmp #1
00020Cr 2  D0 06            bne @bad_count
00020Er 2               
00020Er 2  E0 00            cpx #0
000210r 2  D0 02            bne @bad_count
000212r 2               
000212r 2  18               clc
000213r 2  60               rts
000214r 2               
000214r 2               @bad_count:
000214r 2  38               sec
000215r 2  60               rts
000216r 2               .endproc
000216r 2               
000216r 2               ; ------------------------------------------------------------
000216r 2               ; t3_write_char
000216r 2               ;
000216r 2               ; Return:
000216r 2               ;   C clear = one byte written from t3_byte
000216r 2               ;   C set   = write error or short transfer
000216r 2               ; ------------------------------------------------------------
000216r 2               
000216r 2               .proc t3_write_char
000216r 2  78 A2 rr A0      SYSCALL t3_write_args, sys_write
00021Ar 2  rr 20 0C F1  
00021Er 2  90 02            bcc @ok
000220r 2               
000220r 2  38               sec
000221r 2  60               rts
000222r 2               
000222r 2               @ok:
000222r 2  C9 01            cmp #1
000224r 2  D0 06            bne @bad_count
000226r 2               
000226r 2  E0 00            cpx #0
000228r 2  D0 02            bne @bad_count
00022Ar 2               
00022Ar 2  18               clc
00022Br 2  60               rts
00022Cr 2               
00022Cr 2               @bad_count:
00022Cr 2  38               sec
00022Dr 2  60               rts
00022Er 2               .endproc
00022Er 2               
00022Er 2               ; ------------------------------------------------------------
00022Er 2               ; user_task3_entry
00022Er 2               ; ------------------------------------------------------------
00022Er 2               
00022Er 2               .proc user_task3_entry
00022Er 2               @loop:
00022Er 2  20 rr rr         jsr t3_read_char
000231r 2  B0 0C            bcs @exit
000233r 2               
000233r 2  20 rr rr         jsr t3_write_char
000236r 2  B0 07            bcs @exit
000238r 2               
000238r 2  AD rr rr         lda t3_byte
00023Br 2  C9 51            cmp #'Q'
00023Dr 2  D0 EF            bne @loop
00023Fr 2               
00023Fr 2               @exit:
00023Fr 2  4C 00 F1         jmp sys_exit
000242r 2               .endproc
000242r 2               
000242r 1               .include "task/task4.asm"
000242r 2               ; ============================================================
000242r 2               ; task4.asm
000242r 2               ; NEOX - RP filesystem read-only syscall smoke test
000242r 2               ;
000242r 2               ; Purpose:
000242r 2               ;   Exercises the new SYS_OPEN -> RP FS -> sys_read -> sys_close path
000242r 2               ;   from a normal user task.
000242r 2               ;
000242r 2               ; Behavior:
000242r 2               ;   - open TEST.TXT on RP filesystem device 0
000242r 2               ;   - read up to 64 bytes
000242r 2               ;   - write the bytes to STDOUT followed by CR
000242r 2               ;   - print a short failure marker if open/read/write fails
000242r 2               ;   - exit after one pass
000242r 2               ; ============================================================
000242r 2               
000242r 2               .setcpu "65C02"
000242r 2               
000242r 2               .include "syscall.inc"
000242r 3               ; ============================================================
000242r 3               ; syscall.inc
000242r 3               ; NEOX - syscall definitions
000242r 3               ;
000242r 3               ; Purpose:
000242r 3               ;   Defines syscall numbers, fixed syscall entry addresses,
000242r 3               ;   error codes, and common syscall argument structures.
000242r 3               ;
000242r 3               ; Architecture:
000242r 3               ;   - Syscall jump table is located in the shared BIOS page at $F100
000242r 3               ;   - Each syscall entry is a 3-byte JMP stub
000242r 3               ;   - User code calls fixed syscall entry addresses
000242r 3               ;
000242r 3               ; Notes:
000242r 3               ;   SYS_MONITOR enters supervisor/MICMON context through the
000242r 3               ;   kernel-defined monitor entry path. It is a controlled
000242r 3               ;   privileged transfer, not direct user control of MMU/scheduler.
000242r 3               ; ============================================================
000242r 3               
000242r 3               .ifndef __SYSCALL_INC__
000242r 3               __SYSCALL_INC__ = 1
000242r 3               
000242r 3               .include "config.inc"
000242r 3               
000242r 3               SYSCALL_ENTRY_SIZE  = 3
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Standard file descriptors
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               STDIN               = 0
000242r 3               STDOUT              = 1
000242r 3               STDERR              = 2
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Syscall numbers
000242r 3               ; ------------------------------------------------------------
000242r 3               SYS_EXIT			= $00
000242r 3               SYS_OPEN            = $01
000242r 3               SYS_CLOSE			= $02
000242r 3               SYS_READ            = $03
000242r 3               SYS_WRITE           = $04
000242r 3               SYS_MONITOR         = $05
000242r 3               SYS_LOAD_FILE_TO_MEMORY = $06
000242r 3               SYS_SAVE_MEMORY_TO_FILE = $07
000242r 3               SYS_SEEK            = $08
000242r 3               SYS_TELL            = $09
000242r 3               SYS_PIPE			= $0A
000242r 3               SYS_DELETE          = $0C
000242r 3               SYS_RENAME          = $0D
000242r 3               SYS_YIELD           = $0B
000242r 3               SYS_SLEEP           = $0E
000242r 3               SYS_DUP				= $0F
000242r 3               SYS_DUP2			= $10
000242r 3               SYS_TICKS           = $11
000242r 3               SYS_SIGNAL          = $12
000242r 3               SYS_OPENDIR         = $13
000242r 3               SYS_READDIR         = $14
000242r 3               SYS_CLOSEDIR        = $15
000242r 3               SYS_CHDIR           = $16
000242r 3               SYS_GETCWD          = $17
000242r 3               SYS_MKDIR           = $18
000242r 3               SYS_RMDIR           = $19
000242r 3               SYS_GETPROCINFO      = $1A
000242r 3               SYS_WAITPID           = $1B
000242r 3               SYS_GET_LAUNCH_ID     = $1C
000242r 3               SYS_GET_LAUNCH_LINE   = $1D
000242r 3               SYS_SPAWN_RESIDENT    = $1E
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Fixed syscall entry addresses
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               sys_exit            = SYSCALL_BASE + (SYS_EXIT    * SYSCALL_ENTRY_SIZE)
000242r 3               sys_open            = SYSCALL_BASE + (SYS_OPEN    * SYSCALL_ENTRY_SIZE)
000242r 3               sys_close           = SYSCALL_BASE + (SYS_CLOSE   * SYSCALL_ENTRY_SIZE)
000242r 3               sys_read            = SYSCALL_BASE + (SYS_READ    * SYSCALL_ENTRY_SIZE)
000242r 3               sys_write           = SYSCALL_BASE + (SYS_WRITE   * SYSCALL_ENTRY_SIZE)
000242r 3               sys_monitor         = SYSCALL_BASE + (SYS_MONITOR * SYSCALL_ENTRY_SIZE)
000242r 3               sys_load_file_to_memory = SYSCALL_BASE + (SYS_LOAD_FILE_TO_MEMORY * SYSCALL_ENTRY_SIZE)
000242r 3               sys_save_memory_to_file = SYSCALL_BASE + (SYS_SAVE_MEMORY_TO_FILE * SYSCALL_ENTRY_SIZE)
000242r 3               sys_seek            = SYSCALL_BASE + (SYS_SEEK    * SYSCALL_ENTRY_SIZE)
000242r 3               sys_tell            = SYSCALL_BASE + (SYS_TELL    * SYSCALL_ENTRY_SIZE)
000242r 3               sys_delete          = SYSCALL_BASE + (SYS_DELETE  * SYSCALL_ENTRY_SIZE)
000242r 3               sys_rename          = SYSCALL_BASE + (SYS_RENAME  * SYSCALL_ENTRY_SIZE)
000242r 3               sys_pipe            = SYSCALL_BASE + (SYS_PIPE    * SYSCALL_ENTRY_SIZE)
000242r 3               sys_yield           = SYSCALL_BASE + (SYS_YIELD   * SYSCALL_ENTRY_SIZE)
000242r 3               sys_sleep           = SYSCALL_BASE + (SYS_SLEEP   * SYSCALL_ENTRY_SIZE)
000242r 3               sys_dup				= SYSCALL_BASE + (SYS_DUP     * SYSCALL_ENTRY_SIZE)
000242r 3               sys_dup2			= SYSCALL_BASE + (SYS_DUP2    * SYSCALL_ENTRY_SIZE)
000242r 3               sys_ticks           = SYSCALL_BASE + (SYS_TICKS   * SYSCALL_ENTRY_SIZE)
000242r 3               sys_signal          = SYSCALL_BASE + (SYS_SIGNAL  * SYSCALL_ENTRY_SIZE)
000242r 3               sys_opendir         = SYSCALL_BASE + (SYS_OPENDIR * SYSCALL_ENTRY_SIZE)
000242r 3               sys_readdir         = SYSCALL_BASE + (SYS_READDIR * SYSCALL_ENTRY_SIZE)
000242r 3               sys_closedir        = SYSCALL_BASE + (SYS_CLOSEDIR * SYSCALL_ENTRY_SIZE)
000242r 3               sys_chdir           = SYSCALL_BASE + (SYS_CHDIR * SYSCALL_ENTRY_SIZE)
000242r 3               sys_getcwd          = SYSCALL_BASE + (SYS_GETCWD * SYSCALL_ENTRY_SIZE)
000242r 3               sys_mkdir           = SYSCALL_BASE + (SYS_MKDIR * SYSCALL_ENTRY_SIZE)
000242r 3               sys_rmdir           = SYSCALL_BASE + (SYS_RMDIR * SYSCALL_ENTRY_SIZE)
000242r 3               sys_getprocinfo      = SYSCALL_BASE + (SYS_GETPROCINFO * SYSCALL_ENTRY_SIZE)
000242r 3               sys_waitpid          = SYSCALL_BASE + (SYS_WAITPID * SYSCALL_ENTRY_SIZE)
000242r 3               sys_get_launch_id    = SYSCALL_BASE + (SYS_GET_LAUNCH_ID * SYSCALL_ENTRY_SIZE)
000242r 3               sys_get_launch_line  = SYSCALL_BASE + (SYS_GET_LAUNCH_LINE * SYSCALL_ENTRY_SIZE)
000242r 3               sys_spawn_resident   = SYSCALL_BASE + (SYS_SPAWN_RESIDENT * SYSCALL_ENTRY_SIZE)
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Common errno values
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               E_OK                = 0
000242r 3               EIO                 = 3
000242r 3               EINVAL              = 6
000242r 3               EMFILE              = 8        ; too many open file descriptors
000242r 3               EBADF               = 9
000242r 3               ENODEV              = 10
000242r 3               ENOSYS              = 11
000242r 3               EINTR               = 4        ; interrupted system call
000242r 3               EAGAIN              = 12       ; operation would block / try again
000242r 3               ENOMEM              = 13       ; no free kernel memory/object/table slot
000242r 3               EPIPE               = 14       ; write on pipe with no readers
000242r 3               
000242r 3               .include "spawn.inc"
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Common open argument block
000242r 3               ;
000242r 3               ; path_ptr:
000242r 3               ;   Pointer to a NUL-terminated 8.3 filename in the current task
000242r 3               ;   context. The RP-side FS_OPEN command scans at most max_len bytes.
000242r 3               ;
000242r 3               ; max_len:
000242r 3               ;   Maximum filename scan length. Use a small bounded value such as 64.
000242r 3               ;
000242r 3               ; flags:
000242r 3               ;   Open mode. V32 supports read-only, write/truncate, write-existing,
000242r 3               ;   read/write-existing, and read/write-create.
000242r 3               ;
000242r 3               ; device:
000242r 3               ;   RP filesystem device/FatFs drive number: 0..3.
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               .struct open_args
000242r 3                   path_ptr        .word
000242r 3                   max_len         .word
000242r 3                   flags           .byte
000242r 3                   device          .byte
000242r 3               .endstruct
000242r 3               
000242r 3               OPEN_ARGS_SIZE = .sizeof(open_args)
000242r 3               
000242r 3               OPEN_READ           = $00    ; read existing
000242r 3               OPEN_WRITE_TRUNC    = $01    ; write create/truncate
000242r 3               OPEN_WRITE_EXISTING = $02    ; write existing, no truncate
000242r 3               OPEN_RW_EXISTING    = $03    ; read/write existing, no truncate
000242r 3               OPEN_RW_CREATE      = $04    ; read/write create if missing, no truncate if existing
000242r 3               
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Bulk filesystem argument blocks
000242r 3               ;
000242r 3               ; Names and paths use NEOX 8.3 path components. The path string is
000242r 3               ; NUL-terminated and is validated by the RP side.
000242r 3               ;
000242r 3               ; max_bytes / byte_count:
000242r 3               ;   $0000 means 65536 bytes.
000242r 3               ;
000242r 3               ; flags:
000242r 3               ;   Reserved for now. Must be 0.
000242r 3               ;
000242r 3               ; Context rule:
000242r 3               ;   User code never supplies a context. The kernel derives the caller
000242r 3               ;   context and passes it separately to the RP mailbox in ARG2L.
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               .struct fs_load_args
000242r 3                   path_ptr        .word
000242r 3                   dest_ptr        .word
000242r 3                   max_bytes       .word
000242r 3                   device          .byte
000242r 3                   flags           .byte
000242r 3               .endstruct
000242r 3               
000242r 3               FS_LOAD_ARGS_SIZE = .sizeof(fs_load_args)
000242r 3               
000242r 3               .struct fs_save_args
000242r 3                   path_ptr        .word
000242r 3                   src_ptr         .word
000242r 3                   byte_count      .word
000242r 3                   device          .byte
000242r 3                   flags           .byte
000242r 3               .endstruct
000242r 3               
000242r 3               FS_SAVE_ARGS_SIZE = .sizeof(fs_save_args)
000242r 3               
000242r 3               FS_BULK_FLAGS_NONE = $00
000242r 3               
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Seek/tell filesystem argument blocks
000242r 3               ;
000242r 3               ; offset_lo/offset_hi:
000242r 3               ;   Signed 32-bit offset split into low/high words.  SEEK_SET
000242r 3               ;   requires a non-negative final target; SEEK_CUR and SEEK_END
000242r 3               ;   allow negative offsets.
000242r 3               ;
000242r 3               ; result_lo/result_hi:
000242r 3               ;   Kernel writes the resulting unsigned 32-bit file position here.
000242r 3               ;   A/X also return result_lo for convenience.
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               SEEK_SET            = $00
000242r 3               SEEK_CUR            = $01
000242r 3               SEEK_END            = $02
000242r 3               
000242r 3               .struct seek_args
000242r 3                   fd              .byte
000242r 3                   whence          .byte
000242r 3                   offset_lo       .word
000242r 3                   offset_hi       .word
000242r 3                   result_lo       .word
000242r 3                   result_hi       .word
000242r 3               .endstruct
000242r 3               
000242r 3               SEEK_ARGS_SIZE = .sizeof(seek_args)
000242r 3               
000242r 3               .struct tell_args
000242r 3                   fd              .byte
000242r 3                   reserved        .byte
000242r 3                   result_lo       .word
000242r 3                   result_hi       .word
000242r 3               .endstruct
000242r 3               
000242r 3               TELL_ARGS_SIZE = .sizeof(tell_args)
000242r 3               
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Delete/rename filesystem argument blocks
000242r 3               ;
000242r 3               ; V34 path handling uses the same RP-side 8.3 validator as open.
000242r 3               ; flags is reserved and must be 0.
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               FS_PATH_FLAGS_NONE  = $00
000242r 3               
000242r 3               .struct delete_args
000242r 3                   path_ptr        .word
000242r 3                   max_len         .word
000242r 3                   device          .byte
000242r 3                   flags           .byte
000242r 3               .endstruct
000242r 3               
000242r 3               DELETE_ARGS_SIZE = .sizeof(delete_args)
000242r 3               
000242r 3               .struct rename_args
000242r 3                   old_path_ptr    .word
000242r 3                   new_path_ptr    .word
000242r 3                   max_len         .word
000242r 3                   device          .byte
000242r 3                   flags           .byte
000242r 3               .endstruct
000242r 3               
000242r 3               RENAME_ARGS_SIZE = .sizeof(rename_args)
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Common read/write argument block
000242r 3               ;
000242r 3               ; fd:
000242r 3               ;   STDIN / STDOUT / STDERR
000242r 3               ;
000242r 3               ; buf_ptr:
000242r 3               ;   Pointer to caller buffer in the current task context
000242r 3               ;
000242r 3               ; len:
000242r 3               ;   Requested transfer length
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               .struct rw_args
000242r 3                   fd              .byte
000242r 3                   reserved        .byte
000242r 3                   buf_ptr         .word
000242r 3                   len             .word
000242r 3               .endstruct
000242r 3               
000242r 3               RW_ARGS_SIZE = .sizeof(rw_args)
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; SYSCALL helper macro
000242r 3               ;
000242r 3               ; Purpose:
000242r 3               ;   Load X/Y with the address of an argument block and call the
000242r 3               ;   fixed syscall entry.
000242r 3               ;
000242r 3               ; Example:
000242r 3               ;   SYSCALL my_args, sys_write
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               .macro SYSCALL argblk, entry
000242r 3                   ; Keep the register argument pointer stable across the tiny user-side
000242r 3                   ; setup window. The kernel snapshots the process-private pointer before
000242r 3                   ; taking file_io_gate and decodes the block after the owner resumes.
000242r 3                   sei
000242r 3                   ldx #<argblk
000242r 3                   ldy #>argblk
000242r 3                   jsr entry
000242r 3               .endmacro
000242r 3               
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Directory control argument blocks
000242r 3               ;
000242r 3               ; V35 exposes directory handles as normal NEOX fd numbers. The RP
000242r 3               ; directory handle remains kernel-private in the FD/open-object table.
000242r 3               ;
000242r 3               ; dir_entry layout matches the RP serialized directory entry:
000242r 3               ;   name[13] = NUL-terminated 8.3 name
000242r 3               ;   attr     = FatFs attribute byte
000242r 3               ;   size     = unsigned 32-bit byte size
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               DIR_ENTRY_NAME_SIZE = 13
000242r 3               DIR_ENTRY_SIZE      = 18
000242r 3               
000242r 3               .struct dir_entry
000242r 3                   name            .res 13
000242r 3                   attr            .byte
000242r 3                   size_lo         .word
000242r 3                   size_hi         .word
000242r 3               .endstruct
000242r 3               
000242r 3               .struct opendir_args
000242r 3                   path_ptr        .word
000242r 3                   max_len         .word
000242r 3                   device          .byte
000242r 3                   flags           .byte
000242r 3               .endstruct
000242r 3               
000242r 3               OPENDIR_ARGS_SIZE = .sizeof(opendir_args)
000242r 3               
000242r 3               .struct readdir_args
000242r 3                   fd              .byte
000242r 3                   reserved        .byte
000242r 3                   entry_ptr       .word
000242r 3                   entry_size      .word
000242r 3               .endstruct
000242r 3               
000242r 3               READDIR_ARGS_SIZE = .sizeof(readdir_args)
000242r 3               
000242r 3               .struct closedir_args
000242r 3                   fd              .byte
000242r 3                   reserved        .byte
000242r 3               .endstruct
000242r 3               
000242r 3               CLOSEDIR_ARGS_SIZE = .sizeof(closedir_args)
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Current directory argument blocks
000242r 3               ;
000242r 3               ; V36 stores current directory per process as drive + absolute path.
000242r 3               ; User-visible getcwd form is D:/PATH.
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               NEOX_PATH_FLAGS_NONE = $00
000242r 3               
000242r 3               .struct chdir_args
000242r 3                   path_ptr        .word
000242r 3                   max_len         .word
000242r 3                   device          .byte
000242r 3                   flags           .byte
000242r 3               .endstruct
000242r 3               
000242r 3               CHDIR_ARGS_SIZE = .sizeof(chdir_args)
000242r 3               
000242r 3               .struct getcwd_args
000242r 3                   buffer_ptr      .word
000242r 3                   buffer_size     .word
000242r 3                   result_len      .word
000242r 3                   flags           .byte
000242r 3                   reserved        .byte
000242r 3               .endstruct
000242r 3               
000242r 3               GETCWD_ARGS_SIZE = .sizeof(getcwd_args)
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Directory create/remove argument blocks
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               .struct mkdir_args
000242r 3                   path_ptr        .word
000242r 3                   max_len         .word
000242r 3                   device          .byte
000242r 3                   flags           .byte
000242r 3               .endstruct
000242r 3               
000242r 3               MKDIR_ARGS_SIZE = .sizeof(mkdir_args)
000242r 3               
000242r 3               .struct rmdir_args
000242r 3                   path_ptr        .word
000242r 3                   max_len         .word
000242r 3                   device          .byte
000242r 3                   flags           .byte
000242r 3               .endstruct
000242r 3               
000242r 3               RMDIR_ARGS_SIZE = .sizeof(rmdir_args)
000242r 3               
000242r 3               ; ------------------------------------------------------------
000242r 3               ; Process information argument block
000242r 3               ;
000242r 3               ; SYS_GETPROCINFO copies one compact process-table snapshot record
000242r 3               ; into caller memory.  The record is deliberately binary; user-space
000242r 3               ; commands such as PS own all text formatting.
000242r 3               ;
000242r 3               ; Record layout:
000242r 3               ;   +0 pid
000242r 3               ;   +1 ppid
000242r 3               ;   +2 state
000242r 3               ;   +3 wait_reason
000242r 3               ;   +4 signal_pending
000242r 3               ;   +5 wait_object
000242r 3               ;   +6 held_gate_mask (PROC_HOLD_*)
000242r 3               ;
000242r 3               ; Kernels accepting the extended record remain compatible with callers
000242r 3               ; that provide the original five-byte buffer.
000242r 3               ; ------------------------------------------------------------
000242r 3               
000242r 3               PROCINFO_RECORD_MIN_SIZE = 5
000242r 3               PROCINFO_RECORD_SIZE     = 7
000242r 3               
000242r 3               .struct procinfo_args
000242r 3                   pid             .byte
000242r 3                   reserved        .byte
000242r 3                   buffer_ptr      .word
000242r 3                   buffer_size     .word
000242r 3               .endstruct
000242r 3               
000242r 3               PROCINFO_ARGS_SIZE = .sizeof(procinfo_args)
000242r 3               
000242r 3               .endif
000242r 3               
000242r 2               
000242r 2               .export user_task4_entry
000242r 2               
000242r 2               T4_DEVICE          = 0
000242r 2               T4_READ_MAX        = 64
000242r 2               T4_FD_NONE        = $FF
000242r 2               
000242r 2               .segment "USER_DATA"
000094r 2               
000094r 2               t4_path:
000094r 2  54 45 53 54      .byte "TEST.TXT", 0
000098r 2  2E 54 58 54  
00009Cr 2  00           
00009Dr 2               
00009Dr 2               t4_read_buf:
00009Dr 2  xx xx xx xx      .res T4_READ_MAX
0000A1r 2  xx xx xx xx  
0000A5r 2  xx xx xx xx  
0000DDr 2               
0000DDr 2               t4_file_fd:
0000DDr 2  FF               .byte T4_FD_NONE
0000DEr 2               
0000DEr 2               t4_msg_start:
0000DEr 2  54 34 20 46      .byte "T4 FS START", 13
0000E2r 2  53 20 53 54  
0000E6r 2  41 52 54 0D  
0000EAr 2               
0000EAr 2               t4_msg_open_fail:
0000EAr 2  54 34 20 4F      .byte "T4 OPEN FAIL", 13
0000EEr 2  50 45 4E 20  
0000F2r 2  46 41 49 4C  
0000F7r 2               
0000F7r 2               t4_msg_read_fail:
0000F7r 2  54 34 20 52      .byte "T4 READ FAIL", 13
0000FBr 2  45 41 44 20  
0000FFr 2  46 41 49 4C  
000104r 2               
000104r 2               t4_msg_write_fail:
000104r 2  54 34 20 57      .byte "T4 WRITE FAIL", 13
000108r 2  52 49 54 45  
00010Cr 2  20 46 41 49  
000112r 2               
000112r 2               t4_msg_empty:
000112r 2  54 34 20 45      .byte "T4 EMPTY", 13
000116r 2  4D 50 54 59  
00011Ar 2  0D           
00011Br 2               
00011Br 2               t4_cr:
00011Br 2  0D               .byte 13
00011Cr 2               
00011Cr 2               t4_stdout_args:
00011Cr 2  01               .byte STDOUT
00011Dr 2  00               .byte 0
00011Er 2  00 00            .word 0
000120r 2  00 00            .word 0
000122r 2               
000122r 2               t4_open_args:
000122r 2  rr rr            .word t4_path
000124r 2  40 00            .word 64
000126r 2  00               .byte 0
000127r 2  00               .byte T4_DEVICE
000128r 2               
000128r 2               t4_read_args:
000128r 2  FF               .byte T4_FD_NONE
000129r 2  00               .byte 0
00012Ar 2  rr rr            .word t4_read_buf
00012Cr 2  40 00            .word T4_READ_MAX
00012Er 2               
00012Er 2               .segment "USER_TEXT"
000242r 2               
000242r 2               ; ------------------------------------------------------------
000242r 2               ; t4_print_msg
000242r 2               ;
000242r 2               ; Input:
000242r 2               ;   A/X = string pointer
000242r 2               ;   Y   = byte length including CR when present
000242r 2               ; ------------------------------------------------------------
000242r 2               
000242r 2               .proc t4_print_msg
000242r 2  8D rr rr         sta t4_stdout_args + rw_args::buf_ptr
000245r 2  8E rr rr         stx t4_stdout_args + rw_args::buf_ptr + 1
000248r 2               
000248r 2  98               tya
000249r 2  8D rr rr         sta t4_stdout_args + rw_args::len
00024Cr 2  9C rr rr         stz t4_stdout_args + rw_args::len + 1
00024Fr 2               
00024Fr 2  78 A2 rr A0      SYSCALL t4_stdout_args, sys_write
000253r 2  rr 20 0C F1  
000257r 2  60               rts
000258r 2               .endproc
000258r 2               
000258r 2               .proc t4_print_start
000258r 2  A9 rr            lda #<t4_msg_start
00025Ar 2  A2 rr            ldx #>t4_msg_start
00025Cr 2  A0 0C            ldy #12
00025Er 2  4C rr rr         jmp t4_print_msg
000261r 2               .endproc
000261r 2               
000261r 2               .proc t4_print_open_fail
000261r 2  A9 rr            lda #<t4_msg_open_fail
000263r 2  A2 rr            ldx #>t4_msg_open_fail
000265r 2  A0 0D            ldy #13
000267r 2  4C rr rr         jmp t4_print_msg
00026Ar 2               .endproc
00026Ar 2               
00026Ar 2               .proc t4_print_read_fail
00026Ar 2  A9 rr            lda #<t4_msg_read_fail
00026Cr 2  A2 rr            ldx #>t4_msg_read_fail
00026Er 2  A0 0D            ldy #13
000270r 2  4C rr rr         jmp t4_print_msg
000273r 2               .endproc
000273r 2               
000273r 2               .proc t4_print_write_fail
000273r 2  A9 rr            lda #<t4_msg_write_fail
000275r 2  A2 rr            ldx #>t4_msg_write_fail
000277r 2  A0 0E            ldy #14
000279r 2  4C rr rr         jmp t4_print_msg
00027Cr 2               .endproc
00027Cr 2               
00027Cr 2               .proc t4_print_empty
00027Cr 2  A9 rr            lda #<t4_msg_empty
00027Er 2  A2 rr            ldx #>t4_msg_empty
000280r 2  A0 09            ldy #9
000282r 2  4C rr rr         jmp t4_print_msg
000285r 2               .endproc
000285r 2               
000285r 2               ; ------------------------------------------------------------
000285r 2               ; t4_close_file
000285r 2               ;
000285r 2               ; Closes t4_file_fd if it contains an open descriptor.
000285r 2               ; ------------------------------------------------------------
000285r 2               
000285r 2               .proc t4_close_file
000285r 2  AD rr rr         lda t4_file_fd
000288r 2  C9 FF            cmp #T4_FD_NONE
00028Ar 2  F0 0A            beq @done
00028Cr 2               
00028Cr 2  48               pha
00028Dr 2  A9 FF            lda #T4_FD_NONE
00028Fr 2  8D rr rr         sta t4_file_fd
000292r 2  68               pla
000293r 2  20 06 F1         jsr sys_close
000296r 2               
000296r 2               @done:
000296r 2  60               rts
000297r 2               .endproc
000297r 2               
000297r 2               ; ------------------------------------------------------------
000297r 2               ; t4_open_file
000297r 2               ;
000297r 2               ; Return:
000297r 2               ;   C clear = t4_file_fd contains the opened FD
000297r 2               ;   C set   = open failed
000297r 2               ; ------------------------------------------------------------
000297r 2               
000297r 2               .proc t4_open_file
000297r 2  78 A2 rr A0      SYSCALL t4_open_args, sys_open
00029Br 2  rr 20 03 F1  
00029Fr 2  90 02            bcc @ok
0002A1r 2               
0002A1r 2  38               sec
0002A2r 2  60               rts
0002A3r 2               
0002A3r 2               @ok:
0002A3r 2  8D rr rr         sta t4_file_fd
0002A6r 2  8D rr rr         sta t4_read_args + rw_args::fd
0002A9r 2  18               clc
0002AAr 2  60               rts
0002ABr 2               .endproc
0002ABr 2               
0002ABr 2               ; ------------------------------------------------------------
0002ABr 2               ; t4_read_file
0002ABr 2               ;
0002ABr 2               ; Return:
0002ABr 2               ;   C clear = A/X contains bytes read
0002ABr 2               ;   C set   = read failed
0002ABr 2               ; ------------------------------------------------------------
0002ABr 2               
0002ABr 2               .proc t4_read_file
0002ABr 2  78 A2 rr A0      SYSCALL t4_read_args, sys_read
0002AFr 2  rr 20 09 F1  
0002B3r 2  60               rts
0002B4r 2               .endproc
0002B4r 2               
0002B4r 2               ; ------------------------------------------------------------
0002B4r 2               ; t4_write_file_text
0002B4r 2               ;
0002B4r 2               ; Input:
0002B4r 2               ;   A/X = byte count to write from t4_read_buf
0002B4r 2               ;
0002B4r 2               ; Return:
0002B4r 2               ;   C clear = write succeeded
0002B4r 2               ;   C set   = write failed or short transfer
0002B4r 2               ; ------------------------------------------------------------
0002B4r 2               
0002B4r 2               .proc t4_write_file_text
0002B4r 2  8D rr rr         sta t4_stdout_args + rw_args::len
0002B7r 2  8E rr rr         stx t4_stdout_args + rw_args::len + 1
0002BAr 2               
0002BAr 2  0D rr rr         ora t4_stdout_args + rw_args::len + 1
0002BDr 2  D0 05            bne @non_empty
0002BFr 2               
0002BFr 2  20 rr rr         jsr t4_print_empty
0002C2r 2  18               clc
0002C3r 2  60               rts
0002C4r 2               
0002C4r 2               @non_empty:
0002C4r 2  A9 rr            lda #<t4_read_buf
0002C6r 2  8D rr rr         sta t4_stdout_args + rw_args::buf_ptr
0002C9r 2  A9 rr            lda #>t4_read_buf
0002CBr 2  8D rr rr         sta t4_stdout_args + rw_args::buf_ptr + 1
0002CEr 2               
0002CEr 2  78 A2 rr A0      SYSCALL t4_stdout_args, sys_write
0002D2r 2  rr 20 0C F1  
0002D6r 2  B0 15            bcs @fail
0002D8r 2               
0002D8r 2                   ; For the smoke test the read count is at most 64, so high byte is zero.
0002D8r 2  CD rr rr         cmp t4_stdout_args + rw_args::len
0002DBr 2  D0 10            bne @fail
0002DDr 2  EC rr rr         cpx t4_stdout_args + rw_args::len + 1
0002E0r 2  D0 0B            bne @fail
0002E2r 2               
0002E2r 2  A9 rr            lda #<t4_cr
0002E4r 2  A2 rr            ldx #>t4_cr
0002E6r 2  A0 01            ldy #1
0002E8r 2  20 rr rr         jsr t4_print_msg
0002EBr 2               
0002EBr 2  18               clc
0002ECr 2  60               rts
0002EDr 2               
0002EDr 2               @fail:
0002EDr 2  38               sec
0002EEr 2  60               rts
0002EFr 2               .endproc
0002EFr 2               
0002EFr 2               ; ------------------------------------------------------------
0002EFr 2               ; user_task4_entry
0002EFr 2               ; ------------------------------------------------------------
0002EFr 2               
0002EFr 2               .proc user_task4_entry
0002EFr 2  20 rr rr         jsr t4_print_start
0002F2r 2               
0002F2r 2  20 rr rr         jsr t4_open_file
0002F5r 2  90 06            bcc :+
0002F7r 2  20 rr rr         jsr t4_print_open_fail
0002FAr 2  4C rr rr         jmp @exit
0002FDr 2               :
0002FDr 2  20 rr rr         jsr t4_read_file
000300r 2  90 09            bcc :+
000302r 2  20 rr rr         jsr t4_print_read_fail
000305r 2  20 rr rr         jsr t4_close_file
000308r 2  4C rr rr         jmp @exit
00030Br 2               :
00030Br 2  20 rr rr         jsr t4_write_file_text
00030Er 2  90 03            bcc :+
000310r 2  20 rr rr         jsr t4_print_write_fail
000313r 2               :
000313r 2  20 rr rr         jsr t4_close_file
000316r 2               
000316r 2               @exit:
000316r 2  4C 00 F1         jmp sys_exit
000319r 2               .endproc
000319r 2               
000319r 1               .include "task/task5.asm"
000319r 2               ; ============================================================
000319r 2               ; task5.asm
000319r 2               ; NEOX - RP filesystem V31-V37 regression test
000319r 2               ;
000319r 2               ; Purpose:
000319r 2               ;   Exercises SYS_SAVE_MEMORY_TO_FILE / SYS_LOAD_FILE_TO_MEMORY, the
000319r 2               ;   V32 SYS_OPEN modes, V33 SYS_SEEK / SYS_TELL, and V34 SYS_DELETE /
000319r 2               ;   SYS_RENAME and V35 SYS_OPENDIR / SYS_READDIR / SYS_CLOSEDIR and V37 SYS_MKDIR / SYS_RMDIR through the normal user syscall path.
000319r 2               ;
000319r 2               ; V33 scenario:
000319r 2               ;   - create V33TEST.TXT as ABCDE
000319r 2               ;   - tell start position = 0
000319r 2               ;   - seek EOF, append !, verify ABCDE!
000319r 2               ;   - seek END -2, overwrite E with Q, verify ABCDQ!
000319r 2               ;   - seek SET 1, then seek CUR +2, overwrite D with R, verify ABCRQ!
000319r 2               ;
000319r 2               ; V34 scenario:
000319r 2               ;   - create V34TEST.TXT as ABCDE
000319r 2               ;   - rename V34TEST.TXT to V34REN.TXT
000319r 2               ;   - verify renamed file content
000319r 2               ;   - delete V34REN.TXT
000319r 2               ;   - verify deleted file no longer opens
000319r 2               ;
000319r 2               ; V35 scenario:
000319r 2               ;   - opendir root twice
000319r 2               ;   - readdir both handles
000319r 2               ;   - verify both independent scans return the same first entry
000319r 2               ;   - closedir both handles
000319r 2               ;
000319r 2               ; V37 scenario:
000319r 2               ;   - cleanup stale V37DIR/A.TXT and V37DIR
000319r 2               ;   - mkdir V37DIR
000319r 2               ;   - chdir V37DIR
000319r 2               ;   - create A.TXT through relative cwd
000319r 2               ;   - chdir 0:/
000319r 2               ;   - verify V37DIR/A.TXT
000319r 2               ;   - delete V37DIR/A.TXT
000319r 2               ;   - rmdir V37DIR
000319r 2               ;   - verify opendir V37DIR fails
000319r 2               ; ============================================================
000319r 2               
000319r 2               .setcpu "65C02"
000319r 2               
000319r 2               .include "syscall.inc"
000319r 3               ; ============================================================
000319r 3               ; syscall.inc
000319r 3               ; NEOX - syscall definitions
000319r 3               ;
000319r 3               ; Purpose:
000319r 3               ;   Defines syscall numbers, fixed syscall entry addresses,
000319r 3               ;   error codes, and common syscall argument structures.
000319r 3               ;
000319r 3               ; Architecture:
000319r 3               ;   - Syscall jump table is located in the shared BIOS page at $F100
000319r 3               ;   - Each syscall entry is a 3-byte JMP stub
000319r 3               ;   - User code calls fixed syscall entry addresses
000319r 3               ;
000319r 3               ; Notes:
000319r 3               ;   SYS_MONITOR enters supervisor/MICMON context through the
000319r 3               ;   kernel-defined monitor entry path. It is a controlled
000319r 3               ;   privileged transfer, not direct user control of MMU/scheduler.
000319r 3               ; ============================================================
000319r 3               
000319r 3               .ifndef __SYSCALL_INC__
000319r 3               __SYSCALL_INC__ = 1
000319r 3               
000319r 3               .include "config.inc"
000319r 3               
000319r 3               SYSCALL_ENTRY_SIZE  = 3
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Standard file descriptors
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               STDIN               = 0
000319r 3               STDOUT              = 1
000319r 3               STDERR              = 2
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Syscall numbers
000319r 3               ; ------------------------------------------------------------
000319r 3               SYS_EXIT			= $00
000319r 3               SYS_OPEN            = $01
000319r 3               SYS_CLOSE			= $02
000319r 3               SYS_READ            = $03
000319r 3               SYS_WRITE           = $04
000319r 3               SYS_MONITOR         = $05
000319r 3               SYS_LOAD_FILE_TO_MEMORY = $06
000319r 3               SYS_SAVE_MEMORY_TO_FILE = $07
000319r 3               SYS_SEEK            = $08
000319r 3               SYS_TELL            = $09
000319r 3               SYS_PIPE			= $0A
000319r 3               SYS_DELETE          = $0C
000319r 3               SYS_RENAME          = $0D
000319r 3               SYS_YIELD           = $0B
000319r 3               SYS_SLEEP           = $0E
000319r 3               SYS_DUP				= $0F
000319r 3               SYS_DUP2			= $10
000319r 3               SYS_TICKS           = $11
000319r 3               SYS_SIGNAL          = $12
000319r 3               SYS_OPENDIR         = $13
000319r 3               SYS_READDIR         = $14
000319r 3               SYS_CLOSEDIR        = $15
000319r 3               SYS_CHDIR           = $16
000319r 3               SYS_GETCWD          = $17
000319r 3               SYS_MKDIR           = $18
000319r 3               SYS_RMDIR           = $19
000319r 3               SYS_GETPROCINFO      = $1A
000319r 3               SYS_WAITPID           = $1B
000319r 3               SYS_GET_LAUNCH_ID     = $1C
000319r 3               SYS_GET_LAUNCH_LINE   = $1D
000319r 3               SYS_SPAWN_RESIDENT    = $1E
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Fixed syscall entry addresses
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               sys_exit            = SYSCALL_BASE + (SYS_EXIT    * SYSCALL_ENTRY_SIZE)
000319r 3               sys_open            = SYSCALL_BASE + (SYS_OPEN    * SYSCALL_ENTRY_SIZE)
000319r 3               sys_close           = SYSCALL_BASE + (SYS_CLOSE   * SYSCALL_ENTRY_SIZE)
000319r 3               sys_read            = SYSCALL_BASE + (SYS_READ    * SYSCALL_ENTRY_SIZE)
000319r 3               sys_write           = SYSCALL_BASE + (SYS_WRITE   * SYSCALL_ENTRY_SIZE)
000319r 3               sys_monitor         = SYSCALL_BASE + (SYS_MONITOR * SYSCALL_ENTRY_SIZE)
000319r 3               sys_load_file_to_memory = SYSCALL_BASE + (SYS_LOAD_FILE_TO_MEMORY * SYSCALL_ENTRY_SIZE)
000319r 3               sys_save_memory_to_file = SYSCALL_BASE + (SYS_SAVE_MEMORY_TO_FILE * SYSCALL_ENTRY_SIZE)
000319r 3               sys_seek            = SYSCALL_BASE + (SYS_SEEK    * SYSCALL_ENTRY_SIZE)
000319r 3               sys_tell            = SYSCALL_BASE + (SYS_TELL    * SYSCALL_ENTRY_SIZE)
000319r 3               sys_delete          = SYSCALL_BASE + (SYS_DELETE  * SYSCALL_ENTRY_SIZE)
000319r 3               sys_rename          = SYSCALL_BASE + (SYS_RENAME  * SYSCALL_ENTRY_SIZE)
000319r 3               sys_pipe            = SYSCALL_BASE + (SYS_PIPE    * SYSCALL_ENTRY_SIZE)
000319r 3               sys_yield           = SYSCALL_BASE + (SYS_YIELD   * SYSCALL_ENTRY_SIZE)
000319r 3               sys_sleep           = SYSCALL_BASE + (SYS_SLEEP   * SYSCALL_ENTRY_SIZE)
000319r 3               sys_dup				= SYSCALL_BASE + (SYS_DUP     * SYSCALL_ENTRY_SIZE)
000319r 3               sys_dup2			= SYSCALL_BASE + (SYS_DUP2    * SYSCALL_ENTRY_SIZE)
000319r 3               sys_ticks           = SYSCALL_BASE + (SYS_TICKS   * SYSCALL_ENTRY_SIZE)
000319r 3               sys_signal          = SYSCALL_BASE + (SYS_SIGNAL  * SYSCALL_ENTRY_SIZE)
000319r 3               sys_opendir         = SYSCALL_BASE + (SYS_OPENDIR * SYSCALL_ENTRY_SIZE)
000319r 3               sys_readdir         = SYSCALL_BASE + (SYS_READDIR * SYSCALL_ENTRY_SIZE)
000319r 3               sys_closedir        = SYSCALL_BASE + (SYS_CLOSEDIR * SYSCALL_ENTRY_SIZE)
000319r 3               sys_chdir           = SYSCALL_BASE + (SYS_CHDIR * SYSCALL_ENTRY_SIZE)
000319r 3               sys_getcwd          = SYSCALL_BASE + (SYS_GETCWD * SYSCALL_ENTRY_SIZE)
000319r 3               sys_mkdir           = SYSCALL_BASE + (SYS_MKDIR * SYSCALL_ENTRY_SIZE)
000319r 3               sys_rmdir           = SYSCALL_BASE + (SYS_RMDIR * SYSCALL_ENTRY_SIZE)
000319r 3               sys_getprocinfo      = SYSCALL_BASE + (SYS_GETPROCINFO * SYSCALL_ENTRY_SIZE)
000319r 3               sys_waitpid          = SYSCALL_BASE + (SYS_WAITPID * SYSCALL_ENTRY_SIZE)
000319r 3               sys_get_launch_id    = SYSCALL_BASE + (SYS_GET_LAUNCH_ID * SYSCALL_ENTRY_SIZE)
000319r 3               sys_get_launch_line  = SYSCALL_BASE + (SYS_GET_LAUNCH_LINE * SYSCALL_ENTRY_SIZE)
000319r 3               sys_spawn_resident   = SYSCALL_BASE + (SYS_SPAWN_RESIDENT * SYSCALL_ENTRY_SIZE)
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Common errno values
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               E_OK                = 0
000319r 3               EIO                 = 3
000319r 3               EINVAL              = 6
000319r 3               EMFILE              = 8        ; too many open file descriptors
000319r 3               EBADF               = 9
000319r 3               ENODEV              = 10
000319r 3               ENOSYS              = 11
000319r 3               EINTR               = 4        ; interrupted system call
000319r 3               EAGAIN              = 12       ; operation would block / try again
000319r 3               ENOMEM              = 13       ; no free kernel memory/object/table slot
000319r 3               EPIPE               = 14       ; write on pipe with no readers
000319r 3               
000319r 3               .include "spawn.inc"
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Common open argument block
000319r 3               ;
000319r 3               ; path_ptr:
000319r 3               ;   Pointer to a NUL-terminated 8.3 filename in the current task
000319r 3               ;   context. The RP-side FS_OPEN command scans at most max_len bytes.
000319r 3               ;
000319r 3               ; max_len:
000319r 3               ;   Maximum filename scan length. Use a small bounded value such as 64.
000319r 3               ;
000319r 3               ; flags:
000319r 3               ;   Open mode. V32 supports read-only, write/truncate, write-existing,
000319r 3               ;   read/write-existing, and read/write-create.
000319r 3               ;
000319r 3               ; device:
000319r 3               ;   RP filesystem device/FatFs drive number: 0..3.
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               .struct open_args
000319r 3                   path_ptr        .word
000319r 3                   max_len         .word
000319r 3                   flags           .byte
000319r 3                   device          .byte
000319r 3               .endstruct
000319r 3               
000319r 3               OPEN_ARGS_SIZE = .sizeof(open_args)
000319r 3               
000319r 3               OPEN_READ           = $00    ; read existing
000319r 3               OPEN_WRITE_TRUNC    = $01    ; write create/truncate
000319r 3               OPEN_WRITE_EXISTING = $02    ; write existing, no truncate
000319r 3               OPEN_RW_EXISTING    = $03    ; read/write existing, no truncate
000319r 3               OPEN_RW_CREATE      = $04    ; read/write create if missing, no truncate if existing
000319r 3               
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Bulk filesystem argument blocks
000319r 3               ;
000319r 3               ; Names and paths use NEOX 8.3 path components. The path string is
000319r 3               ; NUL-terminated and is validated by the RP side.
000319r 3               ;
000319r 3               ; max_bytes / byte_count:
000319r 3               ;   $0000 means 65536 bytes.
000319r 3               ;
000319r 3               ; flags:
000319r 3               ;   Reserved for now. Must be 0.
000319r 3               ;
000319r 3               ; Context rule:
000319r 3               ;   User code never supplies a context. The kernel derives the caller
000319r 3               ;   context and passes it separately to the RP mailbox in ARG2L.
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               .struct fs_load_args
000319r 3                   path_ptr        .word
000319r 3                   dest_ptr        .word
000319r 3                   max_bytes       .word
000319r 3                   device          .byte
000319r 3                   flags           .byte
000319r 3               .endstruct
000319r 3               
000319r 3               FS_LOAD_ARGS_SIZE = .sizeof(fs_load_args)
000319r 3               
000319r 3               .struct fs_save_args
000319r 3                   path_ptr        .word
000319r 3                   src_ptr         .word
000319r 3                   byte_count      .word
000319r 3                   device          .byte
000319r 3                   flags           .byte
000319r 3               .endstruct
000319r 3               
000319r 3               FS_SAVE_ARGS_SIZE = .sizeof(fs_save_args)
000319r 3               
000319r 3               FS_BULK_FLAGS_NONE = $00
000319r 3               
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Seek/tell filesystem argument blocks
000319r 3               ;
000319r 3               ; offset_lo/offset_hi:
000319r 3               ;   Signed 32-bit offset split into low/high words.  SEEK_SET
000319r 3               ;   requires a non-negative final target; SEEK_CUR and SEEK_END
000319r 3               ;   allow negative offsets.
000319r 3               ;
000319r 3               ; result_lo/result_hi:
000319r 3               ;   Kernel writes the resulting unsigned 32-bit file position here.
000319r 3               ;   A/X also return result_lo for convenience.
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               SEEK_SET            = $00
000319r 3               SEEK_CUR            = $01
000319r 3               SEEK_END            = $02
000319r 3               
000319r 3               .struct seek_args
000319r 3                   fd              .byte
000319r 3                   whence          .byte
000319r 3                   offset_lo       .word
000319r 3                   offset_hi       .word
000319r 3                   result_lo       .word
000319r 3                   result_hi       .word
000319r 3               .endstruct
000319r 3               
000319r 3               SEEK_ARGS_SIZE = .sizeof(seek_args)
000319r 3               
000319r 3               .struct tell_args
000319r 3                   fd              .byte
000319r 3                   reserved        .byte
000319r 3                   result_lo       .word
000319r 3                   result_hi       .word
000319r 3               .endstruct
000319r 3               
000319r 3               TELL_ARGS_SIZE = .sizeof(tell_args)
000319r 3               
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Delete/rename filesystem argument blocks
000319r 3               ;
000319r 3               ; V34 path handling uses the same RP-side 8.3 validator as open.
000319r 3               ; flags is reserved and must be 0.
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               FS_PATH_FLAGS_NONE  = $00
000319r 3               
000319r 3               .struct delete_args
000319r 3                   path_ptr        .word
000319r 3                   max_len         .word
000319r 3                   device          .byte
000319r 3                   flags           .byte
000319r 3               .endstruct
000319r 3               
000319r 3               DELETE_ARGS_SIZE = .sizeof(delete_args)
000319r 3               
000319r 3               .struct rename_args
000319r 3                   old_path_ptr    .word
000319r 3                   new_path_ptr    .word
000319r 3                   max_len         .word
000319r 3                   device          .byte
000319r 3                   flags           .byte
000319r 3               .endstruct
000319r 3               
000319r 3               RENAME_ARGS_SIZE = .sizeof(rename_args)
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Common read/write argument block
000319r 3               ;
000319r 3               ; fd:
000319r 3               ;   STDIN / STDOUT / STDERR
000319r 3               ;
000319r 3               ; buf_ptr:
000319r 3               ;   Pointer to caller buffer in the current task context
000319r 3               ;
000319r 3               ; len:
000319r 3               ;   Requested transfer length
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               .struct rw_args
000319r 3                   fd              .byte
000319r 3                   reserved        .byte
000319r 3                   buf_ptr         .word
000319r 3                   len             .word
000319r 3               .endstruct
000319r 3               
000319r 3               RW_ARGS_SIZE = .sizeof(rw_args)
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; SYSCALL helper macro
000319r 3               ;
000319r 3               ; Purpose:
000319r 3               ;   Load X/Y with the address of an argument block and call the
000319r 3               ;   fixed syscall entry.
000319r 3               ;
000319r 3               ; Example:
000319r 3               ;   SYSCALL my_args, sys_write
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               .macro SYSCALL argblk, entry
000319r 3                   ; Keep the register argument pointer stable across the tiny user-side
000319r 3                   ; setup window. The kernel snapshots the process-private pointer before
000319r 3                   ; taking file_io_gate and decodes the block after the owner resumes.
000319r 3                   sei
000319r 3                   ldx #<argblk
000319r 3                   ldy #>argblk
000319r 3                   jsr entry
000319r 3               .endmacro
000319r 3               
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Directory control argument blocks
000319r 3               ;
000319r 3               ; V35 exposes directory handles as normal NEOX fd numbers. The RP
000319r 3               ; directory handle remains kernel-private in the FD/open-object table.
000319r 3               ;
000319r 3               ; dir_entry layout matches the RP serialized directory entry:
000319r 3               ;   name[13] = NUL-terminated 8.3 name
000319r 3               ;   attr     = FatFs attribute byte
000319r 3               ;   size     = unsigned 32-bit byte size
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               DIR_ENTRY_NAME_SIZE = 13
000319r 3               DIR_ENTRY_SIZE      = 18
000319r 3               
000319r 3               .struct dir_entry
000319r 3                   name            .res 13
000319r 3                   attr            .byte
000319r 3                   size_lo         .word
000319r 3                   size_hi         .word
000319r 3               .endstruct
000319r 3               
000319r 3               .struct opendir_args
000319r 3                   path_ptr        .word
000319r 3                   max_len         .word
000319r 3                   device          .byte
000319r 3                   flags           .byte
000319r 3               .endstruct
000319r 3               
000319r 3               OPENDIR_ARGS_SIZE = .sizeof(opendir_args)
000319r 3               
000319r 3               .struct readdir_args
000319r 3                   fd              .byte
000319r 3                   reserved        .byte
000319r 3                   entry_ptr       .word
000319r 3                   entry_size      .word
000319r 3               .endstruct
000319r 3               
000319r 3               READDIR_ARGS_SIZE = .sizeof(readdir_args)
000319r 3               
000319r 3               .struct closedir_args
000319r 3                   fd              .byte
000319r 3                   reserved        .byte
000319r 3               .endstruct
000319r 3               
000319r 3               CLOSEDIR_ARGS_SIZE = .sizeof(closedir_args)
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Current directory argument blocks
000319r 3               ;
000319r 3               ; V36 stores current directory per process as drive + absolute path.
000319r 3               ; User-visible getcwd form is D:/PATH.
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               NEOX_PATH_FLAGS_NONE = $00
000319r 3               
000319r 3               .struct chdir_args
000319r 3                   path_ptr        .word
000319r 3                   max_len         .word
000319r 3                   device          .byte
000319r 3                   flags           .byte
000319r 3               .endstruct
000319r 3               
000319r 3               CHDIR_ARGS_SIZE = .sizeof(chdir_args)
000319r 3               
000319r 3               .struct getcwd_args
000319r 3                   buffer_ptr      .word
000319r 3                   buffer_size     .word
000319r 3                   result_len      .word
000319r 3                   flags           .byte
000319r 3                   reserved        .byte
000319r 3               .endstruct
000319r 3               
000319r 3               GETCWD_ARGS_SIZE = .sizeof(getcwd_args)
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Directory create/remove argument blocks
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               .struct mkdir_args
000319r 3                   path_ptr        .word
000319r 3                   max_len         .word
000319r 3                   device          .byte
000319r 3                   flags           .byte
000319r 3               .endstruct
000319r 3               
000319r 3               MKDIR_ARGS_SIZE = .sizeof(mkdir_args)
000319r 3               
000319r 3               .struct rmdir_args
000319r 3                   path_ptr        .word
000319r 3                   max_len         .word
000319r 3                   device          .byte
000319r 3                   flags           .byte
000319r 3               .endstruct
000319r 3               
000319r 3               RMDIR_ARGS_SIZE = .sizeof(rmdir_args)
000319r 3               
000319r 3               ; ------------------------------------------------------------
000319r 3               ; Process information argument block
000319r 3               ;
000319r 3               ; SYS_GETPROCINFO copies one compact process-table snapshot record
000319r 3               ; into caller memory.  The record is deliberately binary; user-space
000319r 3               ; commands such as PS own all text formatting.
000319r 3               ;
000319r 3               ; Record layout:
000319r 3               ;   +0 pid
000319r 3               ;   +1 ppid
000319r 3               ;   +2 state
000319r 3               ;   +3 wait_reason
000319r 3               ;   +4 signal_pending
000319r 3               ;   +5 wait_object
000319r 3               ;   +6 held_gate_mask (PROC_HOLD_*)
000319r 3               ;
000319r 3               ; Kernels accepting the extended record remain compatible with callers
000319r 3               ; that provide the original five-byte buffer.
000319r 3               ; ------------------------------------------------------------
000319r 3               
000319r 3               PROCINFO_RECORD_MIN_SIZE = 5
000319r 3               PROCINFO_RECORD_SIZE     = 7
000319r 3               
000319r 3               .struct procinfo_args
000319r 3                   pid             .byte
000319r 3                   reserved        .byte
000319r 3                   buffer_ptr      .word
000319r 3                   buffer_size     .word
000319r 3               .endstruct
000319r 3               
000319r 3               PROCINFO_ARGS_SIZE = .sizeof(procinfo_args)
000319r 3               
000319r 3               .endif
000319r 3               
