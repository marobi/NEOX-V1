000020r 3               EBADF               = 9
000020r 3               ENODEV              = 10
000020r 3               ENOSYS              = 11
000020r 3               EINTR               = 4        ; interrupted system call
000020r 3               EAGAIN              = 12       ; operation would block / try again
000020r 3               ENOMEM              = 13       ; no free kernel memory/object/table slot
000020r 3               EPIPE               = 14       ; write on pipe with no readers
