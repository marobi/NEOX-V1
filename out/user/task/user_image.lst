000319r 2               ; ------------------------------------------------------------
000319r 2               ; user_task5_disabled_entry
000319r 2               ;
000319r 2               ; Silent boot-table placeholder used when the regression test body
000319r 2               ; must remain linked into the image but must not auto-run at boot.
000319r 2               ; ------------------------------------------------------------
000319r 2               
000319r 2               .proc user_task5_disabled_entry
000319r 2  A9 00            lda #0
00031Br 2  4C 00 F1         jmp sys_exit
00031Er 2               .endproc
