000000r 1               ; ============================================================
000000r 1               ; user/task/user_image.asm
000000r 1               ; NEOX static user task image
000000r 1               ; ============================================================
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .include "task/user_entry.asm"
000000r 2               ; ============================================================
000000r 2               ; user_entry.asm
000000r 2               ; NEOX static user image entry table
000000r 2               ; ============================================================
000000r 2               
000000r 2               .setcpu "65C02"
000000r 2               
000000r 2               .include "process.inc"
000000r 3               .ifndef __PROCESS_INC__
000000r 3               __PROCESS_INC__ = 1
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Process states
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               PROC_EMPTY      = $00
000000r 3               PROC_NEW        = $01
000000r 3               PROC_READY      = $02
000000r 3               PROC_RUNNING    = $03
000000r 3               PROC_BLOCKED    = $04
000000r 3               PROC_STOPPED    = $05
000000r 3               PROC_ZOMBIE     = $06
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Flags byte bit definitions
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               PROC_FLAG_NONE              = $00
000000r 3               PROC_FLAG_IDLE              = $01
000000r 3               PROC_FLAG_ATTACHED_CON      = $02
000000r 3               PROC_FLAG_FOREGROUND        = $04
000000r 3               PROC_FLAG_SIGINT_INTERRUPT  = $08
000000r 3               
000000r 3               ; Flags that may be supplied as initial process characteristics by a
000000r 3               ; boot-task record or resident spawn request. PROC_FLAG_IDLE remains
000000r 3               ; kernel-owned and cannot be requested through these creation interfaces.
000000r 3               PROC_FLAGS_CREATE_MASK = PROC_FLAG_ATTACHED_CON | PROC_FLAG_FOREGROUND | PROC_FLAG_SIGINT_INTERRUPT
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Process frame format
000000r 3               ;
000000r 3               ; All saved runnable process stacks use the IRQ-compatible
000000r 3               ; extended RTI frame:
000000r 3               ;     Y, X, A, P, PCL, PCH
000000r 3               ; The scheduler has no per-process resume mode; normal task
000000r 3               ; resume is always RTI.
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Process wait reasons
000000r 3               ;
000000r 3               ; WAIT_NONE means the process is not blocked on a known wait object.
000000r 3               ; Other values describe why a PROC_BLOCKED process is blocked.
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               WAIT_NONE       = $00
000000r 3               WAIT_CONSOLE    = $01
000000r 3               WAIT_DEVICE     = $02
000000r 3               WAIT_PIPE_READ  = $03        ; pipe read wait on empty pipe
000000r 3               WAIT_PIPE       = WAIT_PIPE_READ ; compatibility alias
000000r 3               WAIT_TIMER      = $04
000000r 3               WAIT_PROC       = $05
000000r 3               
000000r 3               ; Generic sleepable gate wait.
000000r 3               ;
000000r 3               ; wait_object identifies the gate object:
000000r 3               ;   LOCK_ID_FILE_IO = FD/open-object/pipe/console syscall gate
000000r 3               ;   LOCK_ID_PROC    = future process-management syscall gate
000000r 3               WAIT_LOCK       = $06
000000r 3               
000000r 3               ; Pipe write wait on a full pipe. Kept separate from WAIT_PIPE_READ so
000000r 3               ; readers and writers can be woken by the correct readiness event.
000000r 3               WAIT_PIPE_WRITE = $07
000000r 3               
000000r 3               ; Blocked while retaining FILE_IO ownership until the RP2350 completes
000000r 3               ; the single active generic filesystem request. wait_object contains the
000000r 3               ; filesystem operation code.
000000r 3               WAIT_RP         = $08
000000r 3               
000000r 3               LOCK_ID_FILE_IO = $00
000000r 3               LOCK_ID_PROC    = $01
000000r 3               
000000r 3               ; Diagnostic gate-hold mask returned by SYS_GETPROCINFO.
000000r 3               PROC_HOLD_NONE     = $00
000000r 3               PROC_HOLD_FILE_IO  = $01
000000r 3               PROC_HOLD_PROC     = $02
000000r 3               
000000r 3               ; Sentinel used for free gate owners and empty gate wait queues.
000000r 3               GATE_OWNER_NONE = $FF
000000r 3               
000000r 3               EXIT_OK         = $00
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               .export user_image_header
000000r 2               
000000r 2               .segment "USER_ENTRY"
000000r 2               
000000r 2               user_image_header:
000000r 2  4E 58            .byte "N", "X"         ; magic: NEOX User
000002r 2  01               .byte $01              ; version
000003r 2  06               .byte $06              ; number of boot tasks
000004r 2               
000004r 2                   ; task 1
000004r 2  00               .byte $00              ; flags
000005r 2  00               .byte $00              ; reserved
000006r 2  rr rr            .word user_task1_entry
000008r 2               
000008r 2                   ; task 2
000008r 2  00               .byte $00
000009r 2  00               .byte $00
00000Ar 2  rr rr            .word user_task2_entry
00000Cr 2               
00000Cr 2                   ; task 3
00000Cr 2  00               .byte $00
00000Dr 2  00               .byte $00
00000Er 2  rr rr            .word user_task3_entry
000010r 2               
000010r 2               
000010r 2                   ; task 4
000010r 2  00               .byte $00
000011r 2  00               .byte $00
000012r 2  rr rr            .word user_task4_entry
000014r 2               
000014r 2                   ; task 5
000014r 2  00               .byte $00
000015r 2  00               .byte $00
000016r 2  rr rr            .word user_task5_disabled_entry
000018r 2               
000018r 2               
000018r 2                   ; task 6: interactive shell survives SIG_INT and treats it as
000018r 2                   ; an interrupted console read/current-line cancellation.
000018r 2  08               .byte PROC_FLAG_SIGINT_INTERRUPT
000019r 2  00               .byte $00
00001Ar 2  rr rr            .word user_task6_entry
00001Cr 2               
00001Cr 2                   ; terminator, optional
00001Cr 2  FF               .byte $ff
00001Dr 2  00               .byte $00
00001Er 2  00 00            .word $0000
000020r 2               
000020r 1               
000020r 1               .include "task/task1.asm"
000020r 2               ; ============================================================
000020r 2               ; task1.asm
000020r 2               ; NEOX - inter-process pipe ping/pong initiator with sys_ticks
000020r 2               ; ca65 / W65C02
000020r 2               ; ============================================================
000020r 2               
000020r 2               .setcpu "65C02"
000020r 2               
000020r 2               .include "syscall.inc"
000020r 3               ; ============================================================
000020r 3               ; syscall.inc
000020r 3               ; NEOX - syscall definitions
000020r 3               ;
000020r 3               ; Purpose:
000020r 3               ;   Defines syscall numbers, fixed syscall entry addresses,
000020r 3               ;   error codes, and common syscall argument structures.
000020r 3               ;
000020r 3               ; Architecture:
000020r 3               ;   - Syscall jump table is located in the shared BIOS page at $F100
000020r 3               ;   - Each syscall entry is a 3-byte JMP stub
000020r 3               ;   - User code calls fixed syscall entry addresses
000020r 3               ;
000020r 3               ; Notes:
000020r 3               ;   SYS_MONITOR enters supervisor/MICMON context through the
000020r 3               ;   kernel-defined monitor entry path. It is a controlled
000020r 3               ;   privileged transfer, not direct user control of MMU/scheduler.
000020r 3               ; ============================================================
000020r 3               
000020r 3               .ifndef __SYSCALL_INC__
000020r 3               __SYSCALL_INC__ = 1
000020r 3               
000020r 3               .include "config.inc"
000020r 4               ; ============================================================
000020r 4               ; config.inc
000020r 4               ; NEOX - kernel configuration
000020r 4               ;
000020r 4               ; Purpose:
000020r 4               ; ============================================================
000020r 4               
000020r 4               .ifndef __CONFIG_INC__
000020r 4               __CONFIG_INC__ = 1
000020r 4               
000020r 4               ; ------------------------------------------------------------
000020r 4               ; Limits
000020r 4               ; ------------------------------------------------------------
000020r 4               
000020r 4               MAX_FDS     = 6          ; per-process descriptor count
000020r 4               OPEN_MAX    = 16         ; system-wide open object slots
000020r 4               
000020r 4               ; ------------------------------------------------------------
000020r 4               ; Maximum simultaneously active processes
000020r 4               ; ------------------------------------------------------------
000020r 4               
000020r 4               MAX_PROCS   = 8
000020r 4               
000020r 4               ; ------------------------------------------------------------
000020r 4               ; Maximum simultaneously active timer waits
000020r 4               ; ------------------------------------------------------------
000020r 4               
000020r 4               MAX_TIMER   = 8
000020r 4               
000020r 4               ;
000020r 4               ;
000020r 4               ;
000020r 4               
000020r 4               MAX_PIPES       = 8
000020r 4               PIPE_BUF_SIZE   = 64
000020r 4               
000020r 4               ; ------------------------------------------------------------
000020r 4               ; Filesystem path limits
000020r 4               ; ------------------------------------------------------------
000020r 4               
000020r 4               NEOX_CWD_MAX  = 32        ; process-private current-directory path bytes
000020r 4               NEOX_PATH_MAX = 64        ; kernel path resolver buffer bytes
000020r 4               ; ============================================================
000020r 4               ;
000020r 4               ; ============================================================
000020r 4               
000020r 4               USER_IMAGE_TABLE = $1000
000020r 4               
000020r 4               ; Final 32/32 virtual-memory split.
000020r 4               USER_SPACE_LIMIT = $8000
000020r 4               KERNEL_SHARED_BASE = $B020
000020r 4               KERNEL_OVERFLOW_BASE = $C000
000020r 4               MICMON_BASE = $D000
000020r 4               IO_PAGE_BASE = $E000
000020r 4               BIOS_BASE = $F000
000020r 4               
000020r 4               ; ------------------------------------------------------------
000020r 4               ; Kernel
000020r 4               ; ------------------------------------------------------------
000020r 4               
000020r 4               KERNEL_BASE = $8000
000020r 4               
000020r 4               ; ------------------------------------------------------------
000020r 4               ; Syscall table location
000020r 4               ; ------------------------------------------------------------
000020r 4               
000020r 4               SYSCALL_BASE = $F100
000020r 4               
000020r 4               ; ------------------------------------------------------------
000020r 4               ; RP2350 mailbox control registers (MMIO)
000020r 4               ;
000020r 4               ; Layout:
000020r 4               ;   Page E is shared I/O space
000020r 4               ;   OS-owned mailbox doorbell starts at $E010
000020r 4               ; ------------------------------------------------------------
000020r 4               
000020r 4               RP_DOORBELL  = $E010
000020r 4               
000020r 4               ; ------------------------------------------------------------
000020r 4               ; Shared RAM request/result block (ordinary shared RAM, not I/O)
000020r 4               ;
000020r 4               ; mailbox request block.
000020r 4               ; ------------------------------------------------------------
000020r 4               
000020r 4               RP_REQ_BASE  = $B000
000020r 4               
000020r 4               .endif
000020r 4               
000020r 3               
000020r 3               SYSCALL_ENTRY_SIZE  = 3
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Standard file descriptors
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               STDIN               = 0
000020r 3               STDOUT              = 1
000020r 3               STDERR              = 2
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Syscall numbers
000020r 3               ; ------------------------------------------------------------
000020r 3               SYS_EXIT			= $00
000020r 3               SYS_OPEN            = $01
000020r 3               SYS_CLOSE			= $02
000020r 3               SYS_READ            = $03
000020r 3               SYS_WRITE           = $04
000020r 3               SYS_MONITOR         = $05
000020r 3               SYS_LOAD_FILE_TO_MEMORY = $06
000020r 3               SYS_SAVE_MEMORY_TO_FILE = $07
000020r 3               SYS_SEEK            = $08
000020r 3               SYS_TELL            = $09
000020r 3               SYS_PIPE			= $0A
000020r 3               SYS_DELETE          = $0C
000020r 3               SYS_RENAME          = $0D
000020r 3               SYS_YIELD           = $0B
000020r 3               SYS_SLEEP           = $0E
000020r 3               SYS_DUP				= $0F
000020r 3               SYS_DUP2			= $10
000020r 3               SYS_TICKS           = $11
000020r 3               SYS_SIGNAL          = $12
000020r 3               SYS_OPENDIR         = $13
000020r 3               SYS_READDIR         = $14
000020r 3               SYS_CLOSEDIR        = $15
000020r 3               SYS_CHDIR           = $16
000020r 3               SYS_GETCWD          = $17
000020r 3               SYS_MKDIR           = $18
000020r 3               SYS_RMDIR           = $19
000020r 3               SYS_GETPROCINFO      = $1A
000020r 3               SYS_WAITPID           = $1B
000020r 3               SYS_GET_LAUNCH_ID     = $1C
000020r 3               SYS_GET_LAUNCH_LINE   = $1D
000020r 3               SYS_SPAWN_RESIDENT    = $1E
000020r 3               
000020r 3               ; ------------------------------------------------------------
000020r 3               ; Fixed syscall entry addresses
000020r 3               ; ------------------------------------------------------------
000020r 3               
000020r 3               sys_exit            = SYSCALL_BASE + (SYS_EXIT    * SYSCALL_ENTRY_SIZE)
000020r 3               sys_open            = SYSCALL_BASE + (SYS_OPEN    * SYSCALL_ENTRY_SIZE)
000020r 3               sys_close           = SYSCALL_BASE + (SYS_CLOSE   * SYSCALL_ENTRY_SIZE)
000020r 3               sys_read            = SYSCALL_BASE + (SYS_READ    * SYSCALL_ENTRY_SIZE)
000020r 3               sys_write           = SYSCALL_BASE + (SYS_WRITE   * SYSCALL_ENTRY_SIZE)
000020r 3               sys_monitor         = SYSCALL_BASE + (SYS_MONITOR * SYSCALL_ENTRY_SIZE)
000020r 3               sys_load_file_to_memory = SYSCALL_BASE + (SYS_LOAD_FILE_TO_MEMORY * SYSCALL_ENTRY_SIZE)
000020r 3               sys_save_memory_to_file = SYSCALL_BASE + (SYS_SAVE_MEMORY_TO_FILE * SYSCALL_ENTRY_SIZE)
000020r 3               sys_seek            = SYSCALL_BASE + (SYS_SEEK    * SYSCALL_ENTRY_SIZE)
000020r 3               sys_tell            = SYSCALL_BASE + (SYS_TELL    * SYSCALL_ENTRY_SIZE)
000020r 3               sys_delete          = SYSCALL_BASE + (SYS_DELETE  * SYSCALL_ENTRY_SIZE)
000020r 3               sys_rename          = SYSCALL_BASE + (SYS_RENAME  * SYSCALL_ENTRY_SIZE)
000020r 3               sys_pipe            = SYSCALL_BASE + (SYS_PIPE    * SYSCALL_ENTRY_SIZE)
000020r 3               sys_yield           = SYSCALL_BASE + (SYS_YIELD   * SYSCALL_ENTRY_SIZE)
000020r 3               sys_sleep           = SYSCALL_BASE + (SYS_SLEEP   * SYSCALL_ENTRY_SIZE)
000020r 3               sys_dup				= SYSCALL_BASE + (SYS_DUP     * SYSCALL_ENTRY_SIZE)
000020r 3               sys_dup2			= SYSCALL_BASE + (SYS_DUP2    * SYSCALL_ENTRY_SIZE)
000020r 3               sys_ticks           = SYSCALL_BASE + (SYS_TICKS   * SYSCALL_ENTRY_SIZE)
000020r 3               sys_signal          = SYSCALL_BASE + (SYS_SIGNAL  * SYSCALL_ENTRY_SIZE)
000020r 3               sys_opendir         = SYSCALL_BASE + (SYS_OPENDIR * SYSCALL_ENTRY_SIZE)
000020r 3               sys_readdir         = SYSCALL_BASE + (SYS_READDIR * SYSCALL_ENTRY_SIZE)
000020r 3               sys_closedir        = SYSCALL_BASE + (SYS_CLOSEDIR * SYSCALL_ENTRY_SIZE)
000020r 3               sys_chdir           = SYSCALL_BASE + (SYS_CHDIR * SYSCALL_ENTRY_SIZE)
000020r 3               sys_getcwd          = SYSCALL_BASE + (SYS_GETCWD * SYSCALL_ENTRY_SIZE)
000020r 3               sys_mkdir           = SYSCALL_BASE + (SYS_MKDIR * SYSCALL_ENTRY_SIZE)
000020r 3               sys_rmdir           = SYSCALL_BASE + (SYS_RMDIR * SYSCALL_ENTRY_SIZE)
000020r 3               sys_getprocinfo      = SYSCALL_BASE + (SYS_GETPROCINFO * SYSCALL_ENTRY_SIZE)
000020r 3               sys_waitpid          = SYSCALL_BASE + (SYS_WAITPID * SYSCALL_ENTRY_SIZE)
000020r 3               sys_get_launch_id    = SYSCALL_BASE + (SYS_GET_LAUNCH_ID * SYSCALL_ENTRY_SIZE)
000020r 3               sys_get_launch_line  = SYSCALL_BASE + (SYS_GET_LAUNCH_LINE * SYSCALL_ENTRY_SIZE)
000020r 3               sys_spawn_resident   = SYSCALL_BASE + (SYS_SPAWN_RESIDENT * SYSCALL_ENTRY_SIZE)
000020r 3               
000020r 3               ; ------------------------------------------------------------
