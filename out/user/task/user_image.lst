000DDFr 1               .include "task/task6.asm"
000DDFr 2               ; ============================================================
000DDFr 2               ; user/task/task6.asm
000DDFr 2               ; NEOX - task 6 shell wrapper
000DDFr 2               ;
000DDFr 2               ; Purpose:
000DDFr 2               ;   Minimal task-6 bootstrap. Initializes the process-private cc65
000DDFr 2               ;   runtime and transfers control to the interactive shell.
000DDFr 2               ;
000DDFr 2               ; Policy:
000DDFr 2               ;   Task 6 never uses BIOS/simple I/O. All userland I/O goes through
000DDFr 2               ;   inherited descriptors and NEOX syscalls.
000DDFr 2               ; ============================================================
000DDFr 2               
000DDFr 2               .setcpu "65C02"
000DDFr 2               
000DDFr 2               .export user_task6_entry
000DDFr 2               
000DDFr 2               .import neosh_main
000DDFr 2               .import neox_cc65_runtime_init
000DDFr 2               
000DDFr 2               .segment "USER_TEXT"
000DDFr 2               
000DDFr 2               ; ------------------------------------------------------------
000DDFr 2               ; user_task6_entry
000DDFr 2               ;
000DDFr 2               ; Purpose:
000DDFr 2               ;   Initializes the cc65 software stack and C BSS, then enters neosh.
000DDFr 2               ;
000DDFr 2               ; Input:
000DDFr 2               ;   None.
000DDFr 2               ;
000DDFr 2               ; Return:
000DDFr 2               ;   Does not return during normal shell execution.
000DDFr 2               ; ------------------------------------------------------------
000DDFr 2               .proc user_task6_entry
000DDFr 2  20 rr rr         jsr neox_cc65_runtime_init
000DE2r 2  4C rr rr         jmp neosh_main
000DE5r 2               .endproc
000DE5r 2               
000DE5r 1               
