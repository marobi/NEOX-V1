000000r 3               .include "process.inc"
000000r 4               .ifndef __PROCESS_INC__
000000r 4               __PROCESS_INC__ = 1
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Process states
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               PROC_EMPTY      = $00
000000r 4               PROC_NEW        = $01
000000r 4               PROC_READY      = $02
000000r 4               PROC_RUNNING    = $03
000000r 4               PROC_BLOCKED    = $04
000000r 4               PROC_STOPPED    = $05
000000r 4               PROC_ZOMBIE     = $06
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Flags byte bit definitions
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               PROC_FLAG_NONE              = $00
000000r 4               PROC_FLAG_IDLE              = $01
000000r 4               PROC_FLAG_ATTACHED_CON      = $02
000000r 4               PROC_FLAG_FOREGROUND        = $04
000000r 4               PROC_FLAG_SIGINT_INTERRUPT  = $08
000000r 4               
000000r 4               ; Flags that may be supplied as initial process characteristics by a
000000r 4               ; boot-task record or resident spawn request. PROC_FLAG_IDLE remains
000000r 4               ; kernel-owned and cannot be requested through these creation interfaces.
000000r 4               PROC_FLAGS_CREATE_MASK = PROC_FLAG_ATTACHED_CON | PROC_FLAG_FOREGROUND | PROC_FLAG_SIGINT_INTERRUPT
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Process frame format
000000r 4               ;
000000r 4               ; All saved runnable process stacks use the IRQ-compatible
000000r 4               ; extended RTI frame:
000000r 4               ;     Y, X, A, P, PCL, PCH
000000r 4               ; The scheduler has no per-process resume mode; normal task
000000r 4               ; resume is always RTI.
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Process wait reasons
000000r 4               ;
000000r 4               ; WAIT_NONE means the process is not blocked on a known wait object.
000000r 4               ; Other values describe why a PROC_BLOCKED process is blocked.
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               WAIT_NONE       = $00
000000r 4               WAIT_CONSOLE    = $01
000000r 4               WAIT_DEVICE     = $02
000000r 4               WAIT_PIPE_READ  = $03        ; pipe read wait on empty pipe
000000r 4               WAIT_PIPE       = WAIT_PIPE_READ ; compatibility alias
000000r 4               WAIT_TIMER      = $04
000000r 4               WAIT_PROC       = $05
000000r 4               
000000r 4               ; Generic sleepable gate wait.
000000r 4               ;
000000r 4               ; wait_object identifies the gate object:
000000r 4               ;   LOCK_ID_FILE_IO = FD/open-object/pipe/console syscall gate
000000r 4               ;   LOCK_ID_PROC    = future process-management syscall gate
000000r 4               WAIT_LOCK       = $06
000000r 4               
000000r 4               ; Pipe write wait on a full pipe. Kept separate from WAIT_PIPE_READ so
000000r 4               ; readers and writers can be woken by the correct readiness event.
000000r 4               WAIT_PIPE_WRITE = $07
000000r 4               
000000r 4               ; Blocked while retaining FILE_IO ownership until the RP2350 completes
000000r 4               ; the single active generic filesystem request. wait_object contains the
000000r 4               ; filesystem operation code.
000000r 4               WAIT_RP         = $08
000000r 4               
000000r 4               LOCK_ID_FILE_IO = $00
000000r 4               LOCK_ID_PROC    = $01
000000r 4               
000000r 4               ; Diagnostic gate-hold mask returned by SYS_GETPROCINFO.
000000r 4               PROC_HOLD_NONE     = $00
000000r 4               PROC_HOLD_FILE_IO  = $01
000000r 4               PROC_HOLD_PROC     = $02
000000r 4               
000000r 4               ; Sentinel used for free gate owners and empty gate wait queues.
000000r 4               GATE_OWNER_NONE = $FF
000000r 4               
000000r 4               EXIT_OK         = $00
000000r 4               
000000r 4               .endif
000000r 4               
000000r 3               
000000r 3               SPAWN_FLAGS_NONE = PROC_FLAG_NONE
000000r 3               SPAWN_FLAGS_VALID = PROC_FLAGS_CREATE_MASK
000000r 3               SPAWN_LAUNCH_NONE = $FF
000000r 3               SPAWN_FD_CLOSED = $FF
000000r 3               
000000r 3               ; Maximum process-private launch-line storage including its terminating NUL.
000000r 3               ; The public length excludes the NUL and must be less than SPAWN_LINE_MAX.
000000r 3               SPAWN_LINE_MAX = 64
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; spawn_resident_args
000000r 3               ;
000000r 3               ; The parent transfers one opaque argument line to the child. The kernel
000000r 3               ; does not tokenize, count, quote, or otherwise interpret argument bytes.
000000r 3               ; arg_line_len excludes the terminating NUL.
000000r 3               ; ------------------------------------------------------------
000000r 3               .struct spawn_resident_args
000000r 3                   entry           .word
000000r 3                   launch_id       .byte
000000r 3                   arg_line_ptr    .word
000000r 3                   arg_line_len    .byte
000000r 3                   stdin_fd        .byte
000000r 3                   stdout_fd       .byte
000000r 3                   stderr_fd       .byte
000000r 3                   flags           .byte   ; initial child proc_flags
000000r 3                   result_pid      .byte
000000r 3               .endstruct
000000r 3               
000000r 3               SPAWN_RESIDENT_ARGS_SIZE = .sizeof(spawn_resident_args)
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; spawn_get_line_args
000000r 3               ;
000000r 3               ; Child-side retrieval of the opaque launch argument line.
000000r 3               ; buffer_size includes space for the terminating NUL.
000000r 3               ; result_len excludes the terminating NUL.
000000r 3               ; ------------------------------------------------------------
000000r 3               .struct spawn_get_line_args
000000r 3                   buffer_ptr      .word
000000r 3                   buffer_size     .byte
000000r 3                   result_len      .byte
000000r 3               .endstruct
000000r 3               
000000r 3               SPAWN_GET_LINE_ARGS_SIZE = .sizeof(spawn_get_line_args)
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Common open argument block
000000r 2               ;
000000r 2               ; path_ptr:
000000r 2               ;   Pointer to a NUL-terminated 8.3 filename in the current task
000000r 2               ;   context. The RP-side FS_OPEN command scans at most max_len bytes.
000000r 2               ;
000000r 2               ; max_len:
000000r 2               ;   Maximum filename scan length. Use a small bounded value such as 64.
000000r 2               ;
000000r 2               ; flags:
000000r 2               ;   Open mode. V32 supports read-only, write/truncate, write-existing,
000000r 2               ;   read/write-existing, and read/write-create.
000000r 2               ;
000000r 2               ; device:
000000r 2               ;   RP filesystem device/FatFs drive number: 0..3.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct open_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   flags           .byte
000000r 2                   device          .byte
000000r 2               .endstruct
000000r 2               
000000r 2               OPEN_ARGS_SIZE = .sizeof(open_args)
000000r 2               
000000r 2               OPEN_READ           = $00    ; read existing
000000r 2               OPEN_WRITE_TRUNC    = $01    ; write create/truncate
000000r 2               OPEN_WRITE_EXISTING = $02    ; write existing, no truncate
000000r 2               OPEN_RW_EXISTING    = $03    ; read/write existing, no truncate
000000r 2               OPEN_RW_CREATE      = $04    ; read/write create if missing, no truncate if existing
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Bulk filesystem argument blocks
000000r 2               ;
000000r 2               ; Names and paths use NEOX 8.3 path components. The path string is
000000r 2               ; NUL-terminated and is validated by the RP side.
000000r 2               ;
000000r 2               ; max_bytes / byte_count:
000000r 2               ;   $0000 means 65536 bytes.
000000r 2               ;
000000r 2               ; flags:
000000r 2               ;   Reserved for now. Must be 0.
000000r 2               ;
000000r 2               ; Context rule:
000000r 2               ;   User code never supplies a context. The kernel derives the caller
000000r 2               ;   context and passes it separately to the RP mailbox in ARG2L.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct fs_load_args
000000r 2                   path_ptr        .word
000000r 2                   dest_ptr        .word
000000r 2                   max_bytes       .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               FS_LOAD_ARGS_SIZE = .sizeof(fs_load_args)
000000r 2               
000000r 2               .struct fs_save_args
000000r 2                   path_ptr        .word
000000r 2                   src_ptr         .word
000000r 2                   byte_count      .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               FS_SAVE_ARGS_SIZE = .sizeof(fs_save_args)
000000r 2               
000000r 2               FS_BULK_FLAGS_NONE = $00
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Seek/tell filesystem argument blocks
000000r 2               ;
000000r 2               ; offset_lo/offset_hi:
000000r 2               ;   Signed 32-bit offset split into low/high words.  SEEK_SET
000000r 2               ;   requires a non-negative final target; SEEK_CUR and SEEK_END
000000r 2               ;   allow negative offsets.
000000r 2               ;
000000r 2               ; result_lo/result_hi:
000000r 2               ;   Kernel writes the resulting unsigned 32-bit file position here.
000000r 2               ;   A/X also return result_lo for convenience.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               SEEK_SET            = $00
000000r 2               SEEK_CUR            = $01
000000r 2               SEEK_END            = $02
000000r 2               
000000r 2               .struct seek_args
000000r 2                   fd              .byte
000000r 2                   whence          .byte
000000r 2                   offset_lo       .word
000000r 2                   offset_hi       .word
000000r 2                   result_lo       .word
000000r 2                   result_hi       .word
000000r 2               .endstruct
000000r 2               
000000r 2               SEEK_ARGS_SIZE = .sizeof(seek_args)
000000r 2               
000000r 2               .struct tell_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2                   result_lo       .word
000000r 2                   result_hi       .word
000000r 2               .endstruct
000000r 2               
000000r 2               TELL_ARGS_SIZE = .sizeof(tell_args)
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Delete/rename filesystem argument blocks
000000r 2               ;
000000r 2               ; V34 path handling uses the same RP-side 8.3 validator as open.
000000r 2               ; flags is reserved and must be 0.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               FS_PATH_FLAGS_NONE  = $00
000000r 2               
000000r 2               .struct delete_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               DELETE_ARGS_SIZE = .sizeof(delete_args)
000000r 2               
000000r 2               .struct rename_args
000000r 2                   old_path_ptr    .word
000000r 2                   new_path_ptr    .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               RENAME_ARGS_SIZE = .sizeof(rename_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Common read/write argument block
000000r 2               ;
000000r 2               ; fd:
000000r 2               ;   STDIN / STDOUT / STDERR
000000r 2               ;
000000r 2               ; buf_ptr:
000000r 2               ;   Pointer to caller buffer in the current task context
000000r 2               ;
000000r 2               ; len:
000000r 2               ;   Requested transfer length
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct rw_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2                   buf_ptr         .word
000000r 2                   len             .word
000000r 2               .endstruct
000000r 2               
000000r 2               RW_ARGS_SIZE = .sizeof(rw_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; SYSCALL helper macro
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Load X/Y with the address of an argument block and call the
000000r 2               ;   fixed syscall entry.
000000r 2               ;
000000r 2               ; Example:
000000r 2               ;   SYSCALL my_args, sys_write
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .macro SYSCALL argblk, entry
000000r 2                   ; Keep the register argument pointer stable across the tiny user-side
000000r 2                   ; setup window. The kernel snapshots the process-private pointer before
000000r 2                   ; taking file_io_gate and decodes the block after the owner resumes.
000000r 2                   sei
000000r 2                   ldx #<argblk
000000r 2                   ldy #>argblk
000000r 2                   jsr entry
000000r 2               .endmacro
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Directory control argument blocks
000000r 2               ;
000000r 2               ; V35 exposes directory handles as normal NEOX fd numbers. The RP
000000r 2               ; directory handle remains kernel-private in the FD/open-object table.
000000r 2               ;
000000r 2               ; dir_entry layout matches the RP serialized directory entry:
000000r 2               ;   name[13] = NUL-terminated 8.3 name
000000r 2               ;   attr     = FatFs attribute byte
000000r 2               ;   size     = unsigned 32-bit byte size
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               DIR_ENTRY_NAME_SIZE = 13
000000r 2               DIR_ENTRY_SIZE      = 18
000000r 2               
000000r 2               .struct dir_entry
000000r 2                   name            .res 13
000000r 2                   attr            .byte
000000r 2                   size_lo         .word
000000r 2                   size_hi         .word
000000r 2               .endstruct
000000r 2               
000000r 2               .struct opendir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               OPENDIR_ARGS_SIZE = .sizeof(opendir_args)
000000r 2               
000000r 2               .struct readdir_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2                   entry_ptr       .word
000000r 2                   entry_size      .word
000000r 2               .endstruct
000000r 2               
000000r 2               READDIR_ARGS_SIZE = .sizeof(readdir_args)
000000r 2               
000000r 2               .struct closedir_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2               .endstruct
000000r 2               
000000r 2               CLOSEDIR_ARGS_SIZE = .sizeof(closedir_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Current directory argument blocks
000000r 2               ;
000000r 2               ; V36 stores current directory per process as drive + absolute path.
000000r 2               ; User-visible getcwd form is D:/PATH.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               NEOX_PATH_FLAGS_NONE = $00
000000r 2               
000000r 2               .struct chdir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               CHDIR_ARGS_SIZE = .sizeof(chdir_args)
000000r 2               
000000r 2               .struct getcwd_args
000000r 2                   buffer_ptr      .word
000000r 2                   buffer_size     .word
000000r 2                   result_len      .word
000000r 2                   flags           .byte
000000r 2                   reserved        .byte
000000r 2               .endstruct
000000r 2               
000000r 2               GETCWD_ARGS_SIZE = .sizeof(getcwd_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Directory create/remove argument blocks
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct mkdir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               MKDIR_ARGS_SIZE = .sizeof(mkdir_args)
000000r 2               
000000r 2               .struct rmdir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               RMDIR_ARGS_SIZE = .sizeof(rmdir_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Process information argument block
000000r 2               ;
000000r 2               ; SYS_GETPROCINFO copies one compact process-table snapshot record
000000r 2               ; into caller memory.  The record is deliberately binary; user-space
000000r 2               ; commands such as PS own all text formatting.
000000r 2               ;
000000r 2               ; Record layout:
000000r 2               ;   +0 pid
000000r 2               ;   +1 ppid
000000r 2               ;   +2 state
000000r 2               ;   +3 wait_reason
000000r 2               ;   +4 signal_pending
000000r 2               ;   +5 wait_object
000000r 2               ;   +6 held_gate_mask (PROC_HOLD_*)
000000r 2               ;
000000r 2               ; Kernels accepting the extended record remain compatible with callers
000000r 2               ; that provide the original five-byte buffer.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               PROCINFO_RECORD_MIN_SIZE = 5
000000r 2               PROCINFO_RECORD_SIZE     = 7
000000r 2               
000000r 2               .struct procinfo_args
000000r 2                   pid             .byte
000000r 2                   reserved        .byte
000000r 2                   buffer_ptr      .word
000000r 2                   buffer_size     .word
000000r 2               .endstruct
000000r 2               
000000r 2               PROCINFO_ARGS_SIZE = .sizeof(procinfo_args)
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               .include "neox_path_call.inc"
000000r 2               ; ============================================================
000000r 2               ; neox_path_call.inc
000000r 2               ; Shared cc65 helper macro for one-path filesystem syscalls.
000000r 2               ; ============================================================
000000r 2               
000000r 2               .macro NEOX_DEFINE_ONE_PATH_CALL public_symbol, syscall_symbol, args_label
000000r 2               .export public_symbol
000000r 2               
000000r 2               .segment "C_BSS"
000000r 2               
000000r 2               args_label:
000000r 2                   .res 6
000000r 2               
000000r 2               .segment "C_CODE"
000000r 2               
000000r 2               .proc public_symbol
000000r 2                   sta args_label+0
000000r 2                   stx args_label+1
000000r 2               
000000r 2                   lda #64
000000r 2                   sta args_label+2
000000r 2                   stz args_label+3
000000r 2               
000000r 2                   stz args_label+4
000000r 2                   stz args_label+5
000000r 2               
000000r 2                   sei
000000r 2                   ldx #<args_label
000000r 2                   ldy #>args_label
000000r 2                   jsr syscall_symbol
000000r 2                   bcs @failed
000000r 2               
000000r 2                   lda #0
000000r 2                   tax
000000r 2                   rts
000000r 2               
000000r 2               @failed:
000000r 2                   tya
000000r 2                   ldx #0
000000r 2                   rts
000000r 2               .endproc
000000r 2               .endmacro
000000r 2               
000000r 1               
000000r 1  xx xx xx xx  NEOX_DEFINE_ONE_PATH_CALL _neox_delete, sys_delete, neox_delete_args
000004r 1  xx xx 8D rr  
000008r 1  rr 8E rr rr  
000000r 1               
