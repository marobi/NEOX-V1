000000r 1               ; ============================================================
000000r 1               ; runtime.asm
000000r 1               ; NEOX libneox - minimal cc65 runtime initialization
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Initializes the cc65 software stack and clears the C BSS before
000000r 1               ;   any C function executes in the shell process.
000000r 1               ;
000000r 1               ; Provides:
000000r 1               ;   neox_cc65_runtime_init
000000r 1               ;
000000r 1               ; Input:
000000r 1               ;   None.
000000r 1               ;
000000r 1               ; Return:
000000r 1               ;   None.
000000r 1               ;
000000r 1               ; Clobbers:
000000r 1               ;   A, X, Y, ptr1, tmp1, tmp2.
000000r 1               ;
000000r 1               ; Notes:
000000r 1               ;   - Constructors, destructors, initialized writable DATA, heap,
000000r 1               ;     and standard cc65 startup are intentionally not supported.
000000r 1               ;   - The software stack grows downward from $8000 into the reserved
000000r 1               ;     $7C00-$7FFF C stack area.
000000r 1               ; ============================================================
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .export neox_cc65_runtime_init
000000r 1               
000000r 1               .importzp c_sp
000000r 1               .importzp ptr1
000000r 1               .importzp tmp1
000000r 1               .importzp tmp2
000000r 1               
000000r 1               .import __C_STACK_START__
000000r 1               .import __C_STACK_SIZE__
000000r 1               .import __C_BSS_RUN__
000000r 1               .import __C_BSS_SIZE__
000000r 1               
000000r 1               .segment "USER_TEXT"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; neox_cc65_runtime_init
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Initializes the cc65 software-stack pointer and clears C BSS.
000000r 1               ;
000000r 1               ; Input:
000000r 1               ;   None.
000000r 1               ;
000000r 1               ; Return:
000000r 1               ;   None.
000000r 1               ;
000000r 1               ; Clobbers:
000000r 1               ;   A, X, Y, ptr1, tmp1, tmp2.
000000r 1               ; ------------------------------------------------------------
000000r 1               .proc neox_cc65_runtime_init
000000r 1  A9 rr            lda #<(__C_STACK_START__ + __C_STACK_SIZE__)
000002r 1  85 rr            sta c_sp
000004r 1  A9 rr            lda #>(__C_STACK_START__ + __C_STACK_SIZE__)
000006r 1  85 rr            sta c_sp+1
000008r 1               
000008r 1  A9 rr            lda #<__C_BSS_RUN__
00000Ar 1  85 rr            sta ptr1
00000Cr 1  A9 rr            lda #>__C_BSS_RUN__
00000Er 1  85 rr            sta ptr1+1
000010r 1               
000010r 1  A9 rr            lda #<__C_BSS_SIZE__
000012r 1  85 rr            sta tmp1
000014r 1  A9 rr            lda #>__C_BSS_SIZE__
000016r 1  85 rr            sta tmp2
000018r 1               
000018r 1  A5 rr            lda tmp1
00001Ar 1  05 rr            ora tmp2
00001Cr 1  F0 20            beq @done
00001Er 1               
00001Er 1  A9 00            lda #$00
000020r 1  A0 00            ldy #$00
000022r 1               
000022r 1               @clear_byte:
000022r 1  91 rr            sta (ptr1),y
000024r 1               
000024r 1  E6 rr            inc ptr1
000026r 1  D0 02            bne @pointer_ready
000028r 1  E6 rr            inc ptr1+1
00002Ar 1               
00002Ar 1               @pointer_ready:
00002Ar 1  A5 rr            lda tmp1
00002Cr 1  D0 02            bne @decrement_low
00002Er 1  C6 rr            dec tmp2
000030r 1               
000030r 1               @decrement_low:
000030r 1  C6 rr            dec tmp1
000032r 1               
000032r 1  A5 rr            lda tmp1
000034r 1  05 rr            ora tmp2
000036r 1  D0 02            bne @load_zero
000038r 1  80 04            bra @done
00003Ar 1               
00003Ar 1               @load_zero:
00003Ar 1  A9 00            lda #$00
00003Cr 1  80 E4            bra @clear_byte
00003Er 1               
00003Er 1               @done:
00003Er 1  60               rts
00003Fr 1               .endproc
00003Fr 1               
