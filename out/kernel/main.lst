0000A4r 1                   ; --------------------------------------------------------
0000A4r 1  A2 00            ldx #IDLE_PID
0000A6r 1  8E rr rr         stx active_pid
0000A9r 1  8E rr rr         stx sched_cursor_pid
0000ACr 1               
0000ACr 1  A9 03            lda #PROC_RUNNING
0000AEr 1  9D rr rr         sta proc_state,x
0000B1r 1               
0000B1r 1  A9 FF        	lda #$FF
0000B3r 1  8D rr rr         sta console_owner_pid
0000B6r 1               
0000B6r 1  A9 00            lda #$00
0000B8r 1  20 rr rr         jsr scheduler_set_current_context
0000BBr 1               
0000BBr 1  A9 rr 85 rr      KLOG_OK msg_klog_ready
0000BFr 1  A9 rr 85 rr  
0000C3r 1  20 rr rr     
0000C6r 1               
0000C6r 1               	; enable interrupts
0000C6r 1  58           	cli
0000C7r 1               
0000C7r 1  4C rr rr     	jmp idle_loop
0000CAr 1               .endproc
