000000r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; kernel_main
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Perform kernel-side bootstrap after BIOS transfers control.
000000r 1               ;
000000r 1               ; Inputs:
000000r 1               ;   None explicitly.
000000r 1               ;
000000r 1               ; Outputs:
000000r 1               ;   Does not return.
000000r 1               ;
000000r 1               ; Clobbers:
000000r 1               ;   A, X
000000r 1               ;
000000r 1               ; Notes:
000000r 1               ;   - Remains in supervisor context 0 after setup.
000000r 1               ;   - Normal task execution begins only when timer IRQ arrives.
000000r 1               ;   - Shared communication/mailbox state is initialized here.
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               .proc kernel_main
000000r 1                   ; --------------------------------------------------------
000000r 1                   ; Basic CPU setup for supervisor entry.
000000r 1                   ; --------------------------------------------------------
000000r 1  78               sei                     ; no interrupts during bootstrap
000001r 1  D8               cld
000002r 1  A2 FF            ldx #$FF
000004r 1  9A               txs                     ; initialize supervisor stack
000005r 1               
000005r 1  20 rr rr         KLOG_CLEAR
000008r 1  A9 rr 85 rr      KLOG_BOOT msg_klog_start
00000Cr 1  A9 rr 85 rr  
000010r 1  20 rr rr     
000013r 1               
000013r 1  A9 rr        	lda #<irq_restore
000015r 1  8D rr rr     	sta brk_vector
000018r 1  A9 rr        	lda #>irq_restore
00001Ar 1  8D rr rr     	sta brk_vector+1
00001Dr 1               
00001Dr 1  20 rr rr     	jsr rp_init
000020r 1  A9 rr 85 rr      KLOG_OK msg_klog_rp_init
000024r 1  A9 rr 85 rr  
000028r 1  20 rr rr     
00002Br 1               
00002Br 1                   ; --------------------------------------------------------
00002Br 1               	; set the version of the kernel
00002Br 1                   ; --------------------------------------------------------
00002Br 1  A9 0B        	lda #$0B				; shared-state ABI 0x020B: Linux-compatible signal numbers
00002Dr 1  8D rr rr     	sta kernel_version
000030r 1  A9 02        	Lda #$02				; major
000032r 1  8D rr rr     	sta kernel_version+1
000035r 1  A9 rr 85 rr      KLOG_OK msg_klog_version
000039r 1  A9 rr 85 rr  
00003Dr 1  20 rr rr     
000040r 1               
000040r 1               
000040r 1                   ; --------------------------------------------------------
000040r 1                   ; Initialize scheduler tables and mark current execution as
000040r 1                   ; supervisor context 0.
000040r 1                   ; --------------------------------------------------------
000040r 1  20 rr rr         jsr scheduler_init
000043r 1  A9 rr 85 rr      KLOG_OK msg_klog_scheduler_init
000047r 1  A9 rr 85 rr  
00004Br 1  20 rr rr     
00004Er 1               
00004Er 1                   ; --------------------------------------------------------
00004Er 1                   ; Initialize kernel-owned context slot state.
00004Er 1                   ; RP/boot has already created and preloaded the physical
00004Er 1                   ; MMU contexts; NEOX only owns allocation status.
00004Er 1                   ; --------------------------------------------------------
00004Er 1  20 rr rr         jsr ctx_init_table
000051r 1  A9 rr 85 rr      KLOG_OK msg_klog_ctx_init
000055r 1  A9 rr 85 rr  
000059r 1  20 rr rr     
00005Cr 1               
00005Cr 1                   ; --------------------------------------------------------
00005Cr 1                   ; Initialize ksys/fd/pipe
00005Cr 1                   ; --------------------------------------------------------
