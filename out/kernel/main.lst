000000r 1               .import brk_vector
000000r 1               .import irq_restore
000000r 1               
000000r 1               
000000r 1               .import scheduler_init
000000r 1               .import scheduler_set_current_context
000000r 1               .import ctx_init_table
000000r 1               
000000r 1               .import fd_init_tables
000000r 1               .import fd_init_process
000000r 1               
000000r 1               .import pipe_init_tables
000000r 1               
