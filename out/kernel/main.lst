000179r 1               .proc rp_init
000179r 1                   ; --------------------------------------------------------
000179r 1                   ; Initialize shared RP2350 communication state.
000179r 1                   ;
000179r 1                   ; These registers/state bytes are shared resources and
000179r 1                   ; must start from a known idle state before tasks begin.
000179r 1                   ; --------------------------------------------------------
000179r 1  9C rr rr         stz rp_lock
00017Cr 1               
00017Cr 1  A2 00        	ldx #0
00017Er 1               @rp_clear:
00017Er 1  9E 00 B0         stz RP_GROUP,x
000181r 1  E8           	inx
000182r 1  E0 14        	cpx #$14
000184r 1  D0 F8        	bne @rp_clear
000186r 1               
000186r 1  9C 10 E0         stz RP_DOORBELL
000189r 1  60           	rts
00018Ar 1               .endproc
00018Ar 1               
00018Ar 1               ;
00018Ar 1               ;  provide a vector for BREAK processing
00018Ar 1               ;
00018Ar 1               .proc set_brk_vector
00018Ar 1  8D rr rr     	sta brk_vector
00018Dr 1  8E rr rr     	stx brk_vector+1
000190r 1  60           	rts
