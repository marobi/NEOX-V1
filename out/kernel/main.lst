000000r 1               .include "klog.inc"
000000r 2               ; ============================================================
000000r 2               ; klog.inc
000000r 2               ; NEOX - boot/init logging interface
000000r 2               ;
000000r 2               ; Model:
000000r 2               ;   - BIOS_PUTCHAR-backed character output
000000r 2               ;   - boot/init use only for now
000000r 2               ;   - no FD/syscall/RP mailbox dependency
000000r 2               ;   - uses dedicated zero page pointer klog_ptr
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __KLOG_INC__
000000r 2               __KLOG_INC__ = 1
000000r 2               
000000r 2               .importzp klog_ptr
000000r 2               
000000r 2               .import klog_putc
000000r 2               .import klog_puts
000000r 2               .import klog_crlf
000000r 2               .import klog_clear
000000r 2               .import klog_boot
000000r 2               .import klog_ok
000000r 2               .import klog_fail
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; KLOG_LOAD msg
000000r 2               ;
000000r 2               ; Load klog_ptr with address of a zero-terminated string.
000000r 2               ; ------------------------------------------------------------
000000r 2               .macro KLOG_LOAD msg
000000r 2                   lda #<msg
000000r 2                   sta klog_ptr
000000r 2                   lda #>msg
000000r 2                   sta klog_ptr+1
000000r 2               .endmacro
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; KLOG_PUTS msg
000000r 2               ; ------------------------------------------------------------
000000r 2               .macro KLOG_PUTS msg
000000r 2                   KLOG_LOAD msg
000000r 2                   jsr klog_puts
000000r 2               .endmacro
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; KLOG_CLEAR
000000r 2               ; ------------------------------------------------------------
000000r 2               .macro KLOG_CLEAR
000000r 2                   jsr klog_clear
000000r 2               .endmacro
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; KLOG_BOOT msg
000000r 2               ; KLOG_OK msg
000000r 2               ; KLOG_FAIL msg
000000r 2               ; ------------------------------------------------------------
000000r 2               .macro KLOG_BOOT msg
000000r 2                   KLOG_LOAD msg
000000r 2                   jsr klog_boot
000000r 2               .endmacro
000000r 2               
000000r 2               .macro KLOG_OK msg
000000r 2                   KLOG_LOAD msg
000000r 2                   jsr klog_ok
000000r 2               .endmacro
000000r 2               
000000r 2               .macro KLOG_FAIL msg
000000r 2                   KLOG_LOAD msg
000000r 2                   jsr klog_fail
000000r 2               .endmacro
000000r 2               
000000r 2               .endif
000000r 2               
