000000r 2               NEOX_VERSION_MINOR  = 98
000000r 2               NEOX_VERSION_BUILD  = 156
000000r 2               
000000r 2               .macro NEOX_VERSION_BYTES
000000r 2                   .byte "0.98.156"
000000r 2               .endmacro
000000r 2               
000000r 2               .endif
