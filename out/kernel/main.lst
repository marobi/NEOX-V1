000093r 1  20 rr rr     
000096r 1               
000096r 1               	; --------------------------------------------------------
000096r 1                   ; Create initial runnable tasks.
000096r 1                   ; tasks_init creates processes from the user entry table.
000096r 1                   ; proc_create allocates both PID and preloaded context.
000096r 1                   ; --------------------------------------------------------
000096r 1  20 rr rr         jsr tasks_init
000099r 1  A9 rr 85 rr      KLOG_OK msg_klog_tasks_init
00009Dr 1  A9 rr 85 rr  
0000A1r 1  20 rr rr     
0000A4r 1               
