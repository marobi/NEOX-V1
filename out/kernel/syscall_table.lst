000015r 1  4C 36 80         jmp KERN_ENTRY_KSYS_SAVE_MEMORY_TO_FILE
000018r 1               .endproc
000018r 1               
000018r 1               .proc k_seek
000018r 1  4C 39 80         jmp KERN_ENTRY_KSYS_SEEK
00001Br 1               .endproc
00001Br 1               
00001Br 1               .proc k_tell
00001Br 1  4C 3C 80         jmp KERN_ENTRY_KSYS_TELL
00001Er 1               .endproc
00001Er 1               
00001Er 1               .proc k_pipe
00001Er 1  4C 24 80         jmp KERN_ENTRY_KSYS_PIPE
000021r 1               .endproc
000021r 1               
000021r 1               .proc k_yield
000021r 1                   ; Enter cooperative scheduler path with IRQs disabled.
000021r 1                   ;
000021r 1                   ; This closes the race where a timer IRQ arrives after the
000021r 1                   ; user has entered sys_yield but before sched_yield executes
000021r 1                   ; its own SEI.
000021r 1  78               sei
000022r 1               
000022r 1  20 15 80         jsr KERN_ENTRY_KSYS_YIELD
000025r 1               
000025r 1  18               clc
000026r 1  60               rts
000027r 1               .endproc
000027r 1               
000027r 1               .proc k_delete
000027r 1  4C 3F 80         jmp KERN_ENTRY_KSYS_DELETE
00002Ar 1               .endproc
00002Ar 1               
00002Ar 1               .proc k_rename
00002Ar 1  4C 42 80         jmp KERN_ENTRY_KSYS_RENAME
00002Dr 1               .endproc
00002Dr 1               
00002Dr 1               .proc k_sleep
00002Dr 1  4C 18 80     	jmp KERN_ENTRY_KSYS_SLEEP
000030r 1               .endproc
000030r 1               
000030r 1               .proc k_dup
000030r 1  4C 1E 80         jmp KERN_ENTRY_KSYS_DUP
000033r 1               .endproc
000033r 1               
000033r 1               .proc k_dup2
000033r 1  4C 21 80         jmp KERN_ENTRY_KSYS_DUP2
000036r 1               .endproc
000036r 1               
000036r 1               .proc k_ticks
000036r 1  4C 2A 80         jmp KERN_ENTRY_KSYS_TICKS
000039r 1               .endproc
000039r 1               
000039r 1               .proc k_signal
000039r 1  4C 2D 80         jmp KERN_ENTRY_KSYS_SIGNAL
00003Cr 1               .endproc
00003Cr 1               
00003Cr 1               .proc k_opendir
00003Cr 1  4C 45 80         jmp KERN_ENTRY_KSYS_OPENDIR
00003Fr 1               .endproc
00003Fr 1               
00003Fr 1               .proc k_readdir
00003Fr 1  4C 48 80         jmp KERN_ENTRY_KSYS_READDIR
000042r 1               .endproc
000042r 1               
000042r 1               .proc k_closedir
000042r 1  4C 4B 80         jmp KERN_ENTRY_KSYS_CLOSEDIR
000045r 1               .endproc
000045r 1               
000045r 1               .proc k_chdir
000045r 1  4C 4E 80         jmp KERN_ENTRY_KSYS_CHDIR
000048r 1               .endproc
000048r 1               
000048r 1               .proc k_getcwd
000048r 1  4C 51 80         jmp KERN_ENTRY_KSYS_GETCWD
00004Br 1               .endproc
00004Br 1               
00004Br 1               .proc k_mkdir
00004Br 1  4C 54 80         jmp KERN_ENTRY_KSYS_MKDIR
00004Er 1               .endproc
00004Er 1               
00004Er 1               .proc k_rmdir
00004Er 1  4C 57 80         jmp KERN_ENTRY_KSYS_RMDIR
000051r 1               .endproc
000051r 1               
000051r 1               .proc k_getprocinfo
000051r 1  4C 5A 80         jmp KERN_ENTRY_KSYS_GETPROCINFO
000054r 1               .endproc
000054r 1               
000054r 1               
000054r 1               
000054r 1               
000054r 1               
000054r 1               
000054r 1               
000054r 1               .proc k_waitpid
000054r 1  4C 5D 80         jmp KERN_ENTRY_KSYS_WAITPID
000057r 1               .endproc
000057r 1               
000057r 1               
000057r 1               .proc k_get_launch_id
000057r 1  4C 60 80         jmp KERN_ENTRY_KSYS_GET_LAUNCH_ID
00005Ar 1               .endproc
00005Ar 1               
00005Ar 1               
00005Ar 1               .proc k_get_launch_line
00005Ar 1  4C 63 80         jmp KERN_ENTRY_KSYS_GET_LAUNCH_LINE
00005Dr 1               .endproc
00005Dr 1               
00005Dr 1               .proc k_spawn_resident
00005Dr 1  4C 66 80         jmp KERN_ENTRY_KSYS_SPAWN_RESIDENT
000060r 1               .endproc
000060r 1               
000060r 1               
