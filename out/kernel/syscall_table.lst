000000r 1               ; ------------------------------------------------------------
000000r 1               ; syscall_table
000000r 1               ;
000000r 1               ; Entry index must match syscall number exactly:
000000r 1               ;   0  -> k_exit
000000r 1               ;   1  -> k_open
000000r 1               ;   2  -> k_close
000000r 1               ;   3  -> k_read
000000r 1               ;   4  -> k_write
000000r 1               ;   5  -> k_monitor
000000r 1               ;   6  -> k_load_file_to_memory
000000r 1               ;   7  -> k_save_memory_to_file
000000r 1               ;   8  -> k_seek
000000r 1               ;   9  -> k_tell
000000r 1               ;   10 -> k_pipe
000000r 1               ;   11 -> k_yield
000000r 1               ;   12 -> k_delete
000000r 1               ;   13 -> k_rename
000000r 1               ;	14 -> k_sleep
000000r 1               ;	15 -> k_dup
000000r 1               ;	16 -> k_dup2
000000r 1               ;   17 -> k_ticks
000000r 1               ;   18 -> k_signal
000000r 1               ;   19 -> k_opendir
000000r 1               ;   20 -> k_readdir
000000r 1               ;   21 -> k_closedir
000000r 1               ;   22 -> k_chdir
000000r 1               ;   23 -> k_getcwd
000000r 1               ;   24 -> k_mkdir
000000r 1               ;   25 -> k_rmdir
000000r 1               ;   26 -> k_getprocinfo
000000r 1               ;   27 -> k_waitpid
000000r 1               ;   28 -> k_get_launch_id
000000r 1               ;   29 -> k_get_launch_line
000000r 1               ;   30 -> k_spawn_resident
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               syscall_table:
000000r 1  4C rr rr         jmp k_exit
000003r 1  4C rr rr         jmp k_open
000006r 1  4C rr rr         jmp k_close
000009r 1  4C rr rr         jmp k_read
00000Cr 1  4C rr rr         jmp k_write
00000Fr 1  4C rr rr         jmp k_monitor
000012r 1  4C rr rr         jmp k_load_file_to_memory
000015r 1  4C rr rr         jmp k_save_memory_to_file
000018r 1  4C rr rr         jmp k_seek
00001Br 1  4C rr rr         jmp k_tell
00001Er 1  4C rr rr         jmp k_pipe
000021r 1  4C rr rr         jmp k_yield
000024r 1  4C rr rr         jmp k_delete
000027r 1  4C rr rr         jmp k_rename
00002Ar 1  4C rr rr     	jmp k_sleep
00002Dr 1  4C rr rr         jmp k_dup
000030r 1  4C rr rr         jmp k_dup2
000033r 1  4C rr rr     	jmp k_ticks
000036r 1  4C rr rr     	jmp k_signal
000039r 1  4C rr rr         jmp k_opendir
00003Cr 1  4C rr rr         jmp k_readdir
00003Fr 1  4C rr rr         jmp k_closedir
000042r 1  4C rr rr         jmp k_chdir
000045r 1  4C rr rr         jmp k_getcwd
000048r 1  4C rr rr         jmp k_mkdir
00004Br 1  4C rr rr         jmp k_rmdir
00004Er 1  4C rr rr         jmp k_getprocinfo
000051r 1  4C rr rr         jmp k_waitpid
000054r 1  4C rr rr         jmp k_get_launch_id
000057r 1  4C rr rr         jmp k_get_launch_line
00005Ar 1  4C rr rr         jmp k_spawn_resident
00005Dr 1               
00005Dr 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               
000000r 1               
000000r 1               .proc k_exit
000000r 1  4C 12 80         jmp KERN_ENTRY_KSYS_EXIT
000003r 1               .endproc
000003r 1               
000003r 1               .proc k_open
000003r 1  4C 30 80         jmp KERN_ENTRY_KSYS_OPEN
000006r 1               .endproc
000006r 1               
