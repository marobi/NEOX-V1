00000Cr 1  4C 0F 80     	jmp KERN_ENTRY_KSYS_WRITE
00000Fr 1               .endproc
00000Fr 1               
00000Fr 1               .proc k_monitor
00000Fr 1  4C 03 80         jmp KERN_ENTRY_MONITOR
000012r 1               .endproc
000012r 1               
000012r 1               .proc k_load_file_to_memory
000012r 1  4C 33 80         jmp KERN_ENTRY_KSYS_LOAD_FILE_TO_MEMORY
000015r 1               .endproc
000015r 1               
