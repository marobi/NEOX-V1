000000r 1               .export fd_init_process
000000r 1               .export fd_close_process
000000r 1               .export fd_read
000000r 1               .export fd_write
000000r 1               .export fd_close
000000r 1               .export fd_dup
000000r 1               .export fd_dup2
000000r 1               .export fd_clone_between
000000r 1               .export fd_close_pid
000000r 1               .export fd_clear_process_slots
000000r 1               
