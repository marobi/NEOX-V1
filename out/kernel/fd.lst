000000r 1               ; ============================================================
000000r 1               ; fd.asm
000000r 1               ; NEOX - file descriptor / open object handling
000000r 1               ;
000000r 1               ; Model:
000000r 1               ;   process fd table -> open object table -> backend device
000000r 1               ;
000000r 1               ; This file provides:
000000r 1               ;   - global open-object initialization
000000r 1               ;   - per-process fd initialization
000000r 1               ;   - fd_attach primitive (core building block)
000000r 1               ;
000000r 1               ; Design rules:
000000r 1               ;   - FD table is per-process
000000r 1               ;   - open objects are system-wide and reference counted
000000r 1               ;   - fd_attach is the only place that increments refcount
000000r 1               ; ============================================================
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .include "fd.inc"
000000r 2               ; ============================================================
000000r 2               ; fd.inc
000000r 2               ; NEOX - file descriptor and open object definitions
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   devices/files.
000000r 2               ;   This forms the FD/open-object/device layer
000000r 2               ;   used by read/write/close/dup/dup2.;
000000r 2               ; Model:
000000r 2               ;   process fd table → open object table → device/file backend
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __FD_INC__
000000r 2               __FD_INC__ = 1
000000r 2               
000000r 2               .include "config.inc"
000000r 3               ; ============================================================
000000r 3               ; config.inc
000000r 3               ; NEOX - kernel configuration
000000r 3               ;
000000r 3               ; Purpose:
000000r 3               ; ============================================================
000000r 3               
000000r 3               .ifndef __CONFIG_INC__
000000r 3               __CONFIG_INC__ = 1
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_FDS     = 6          ; per-process descriptor count
000000r 3               OPEN_MAX    = 16         ; system-wide open object slots
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active processes
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_PROCS   = 8
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active timer waits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_TIMER   = 8
000000r 3               
000000r 3               ;
000000r 3               ;
000000r 3               ;
000000r 3               
000000r 3               MAX_PIPES       = 8
000000r 3               PIPE_BUF_SIZE   = 64
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Filesystem path limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               NEOX_CWD_MAX  = 32        ; process-private current-directory path bytes
000000r 3               NEOX_PATH_MAX = 64        ; kernel path resolver buffer bytes
000000r 3               ; ============================================================
000000r 3               ;
000000r 3               ; ============================================================
000000r 3               
000000r 3               USER_IMAGE_TABLE = $1000
000000r 3               
000000r 3               ; Final 32/32 virtual-memory split.
000000r 3               USER_SPACE_LIMIT = $8000
000000r 3               KERNEL_SHARED_BASE = $B020
000000r 3               KERNEL_OVERFLOW_BASE = $C000
000000r 3               MICMON_BASE = $D000
000000r 3               IO_PAGE_BASE = $E000
000000r 3               BIOS_BASE = $F000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Kernel
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               KERNEL_BASE = $8000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Syscall table location
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               SYSCALL_BASE = $F100
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; RP2350 mailbox control registers (MMIO)
000000r 3               ;
000000r 3               ; Layout:
000000r 3               ;   Page E is shared I/O space
000000r 3               ;   OS-owned mailbox doorbell starts at $E010
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_DOORBELL  = $E010
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Shared RAM request/result block (ordinary shared RAM, not I/O)
000000r 3               ;
000000r 3               ; mailbox request block.
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_REQ_BASE  = $B000
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; FD values
000000r 2               ; ------------------------------------------------------------
000000r 2               FD_NONE     = $FF        ; invalid / unused descriptor
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; FD flags (per process)
000000r 2               ;
000000r 2               ; These describe how the process uses the descriptor.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               FD_FLAG_READ    = $01
000000r 2               FD_FLAG_WRITE   = $02
000000r 2               FD_FLAG_CLOEXEC = $80    ; reserved for later exec() support
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Open object types (system-wide)
000000r 2               ;
000000r 2               ; Each open object represents a shared resource. Multiple
000000r 2               ; processes may reference the same object.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               OBJ_NONE    = $00
000000r 2               OBJ_DEVICE  = $01        ; console for now
000000r 2               OBJ_FILE    = $02        ; RP filesystem file handle
000000r 2               OBJ_PIPE    = $03        ; reserved
000000r 2               OBJ_DIR     = $04        ; RP filesystem directory handle
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; FD clone argument block
000000r 2               ;
000000r 2               ; Used by kernel-internal cross-process descriptor cloning.
000000r 2               ; The source descriptor is resolved in source_pid/source_fd and
000000r 2               ; attached to target_pid/target_fd with the same per-FD flags.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct fd_clone_args
000000r 2                   source_pid      .byte
000000r 2                   source_fd       .byte
000000r 2                   target_pid      .byte
000000r 2                   target_fd       .byte
000000r 2               .endstruct
000000r 2               
000000r 2               FD_CLONE_ARGS_SIZE = .sizeof(fd_clone_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Device identifiers
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               DEV_NONE        = $00
000000r 2               DEV_CONSOLE     = $01
000000r 2               
000000r 2               DEV_MAX         = $02
000000r 2               
000000r 2               ; Each dev_ops entry is one 16-bit operation-table pointer.
000000r 2               DEV_OPS_ENTRY_SIZE = 2
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Device operation offsets
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               DEVOP_READ      = 0
000000r 2               DEVOP_WRITE     = 2
000000r 2               DEVOP_IOCTL     = 4
000000r 2               DEVOP_CLOSE     = 6
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               .include "lock.inc"
000000r 2               ; ============================================================
000000r 2               ; lock.inc
000000r 2               ; NEOX - generic 65C02 lock primitives
000000r 2               ; ============================================================
000000r 2               ;
000000r 2               ; Locks are byte variables.
000000r 2               ; Bit 0 is the ownership bit.
000000r 2               ;
000000r 2               ; These are macros, not subroutines, because W65C02 TSB/TRB
000000r 2               ; require a fixed memory operand.
000000r 2               ;
000000r 2               ; Rules:
000000r 2               ;   - Do not hold short subsystem locks across sched_yield.
000000r 2               ;   - Sleepable gates are implemented as routines, not with these
000000r 2               ;     spinning macros.
000000r 2               ;   - Use byte locks only for short, non-sleeping ownership.
000000r 2               ;   - Use php/sei/plp only for true IRQ-critical sections.
000000r 2               ;
000000r 2               ; Lock convention:
000000r 2               ;   C set   = success / acquired / released
000000r 2               ;   C clear = busy
000000r 2               ;
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __LOCK_INC__
000000r 2               __LOCK_INC__ = 1
000000r 2               
000000r 2               LOCK_BIT = $01
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; LOCK_TRY_ACQUIRE lock
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Try to acquire lock bit 0.
000000r 2               ;
000000r 2               ; Output:
000000r 2               ;   C set   = acquired
000000r 2               ;   C clear = busy
000000r 2               ;
000000r 2               ; Clobbers:
000000r 2               ;   A
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .macro LOCK_TRY_ACQUIRE lock
000000r 2                   lda #LOCK_BIT
000000r 2                   tsb lock
000000r 2                   beq :+
000000r 2                   clc
000000r 2                   bra :++
000000r 2               :
000000r 2                   sec
000000r 2               :
000000r 2               .endmacro
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; LOCK_ACQUIRE lock
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Spin until lock bit 0 is acquired.
000000r 2               ;
000000r 2               ; Output:
000000r 2               ;   C set
000000r 2               ;
000000r 2               ; Clobbers:
000000r 2               ;   A
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ;   This spins with IRQs enabled.
000000r 2               ;   The lock holder must not block/yield while holding the lock.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .macro LOCK_ACQUIRE lock
000000r 2               :
000000r 2                   lda #LOCK_BIT
000000r 2                   tsb lock
000000r 2                   beq :+
000000r 2                   bra :-
000000r 2               :
000000r 2                   sec
000000r 2               .endmacro
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; LOCK_RELEASE lock
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Release lock bit 0.
000000r 2               ;
000000r 2               ; Output:
000000r 2               ;   C set
000000r 2               ;
000000r 2               ; Clobbers:
000000r 2               ;   A
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .macro LOCK_RELEASE lock
000000r 2                   lda #LOCK_BIT
000000r 2                   trb lock
000000r 2                   sec
000000r 2               .endmacro
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; LOCK_IS_HELD lock
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Test whether lock bit 0 is held.
000000r 2               ;
000000r 2               ; Output:
000000r 2               ;   Z set   = not held
000000r 2               ;   Z clear = held
000000r 2               ;
000000r 2               ; Clobbers:
000000r 2               ;   A
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .macro LOCK_IS_HELD lock
000000r 2                   lda lock
000000r 2                   and #LOCK_BIT
000000r 2               .endmacro
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; LOCK_ASSERT_FREE lock
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Debug trap if lock is already held.
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ;   This intentionally loops forever on failure.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .macro LOCK_ASSERT_FREE lock
000000r 2                   lda lock
000000r 2                   and #LOCK_BIT
000000r 2                   beq :+
000000r 2               :
000000r 2                   bra :-
000000r 2               :
000000r 2               .endmacro
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; LOCK_ASSERT_HELD lock
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Debug trap if lock is not held.
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ;   This intentionally loops forever on failure.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .macro LOCK_ASSERT_HELD lock
000000r 2                   lda lock
000000r 2                   and #LOCK_BIT
000000r 2                   bne :+
000000r 2               :
000000r 2                   bra :-
000000r 2               :
000000r 2               .endmacro
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               .include "mailbox.inc"
000000r 2               ; ============================================================
000000r 2               ; mailbox.inc
000000r 2               ; NEOX - RP2350 mailbox / request block definitions
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Defines the shared ABI v2 request/result block layout used
000000r 2               ;   for communication between the 6502 kernel/syscall code and
000000r 2               ;   the RP2350 co-processor.
000000r 2               ;
000000r 2               ; Architecture:
000000r 2               ;   - Logical pages 0..7 are private per context
000000r 2               ;   - Logical pages 8..F are shared across all contexts; page E is I/O
000000r 2               ;   - MMIO control registers live in shared I/O page
000000r 2               ;
000000r 2               ; ABI v2:
000000r 2               ;   - RP_REQ_BASE is $B000 in ordinary shared RAM
000000r 2               ;   - Request block starts with RP_GROUP and RP_CMD
000000r 2               ;   - RP_DOORBELL is trigger-only; command identity is not
000000r 2               ;     encoded in the doorbell value anymore.
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __MAILBOX_INC__
000000r 2               __MAILBOX_INC__ = 1
000000r 2               
000000r 2               .include "config.inc"
000000r 3               ; ============================================================
000000r 3               ; config.inc
000000r 3               ; NEOX - kernel configuration
000000r 3               ;
000000r 3               ; Purpose:
000000r 3               ; ============================================================
000000r 3               
000000r 3               .ifndef __CONFIG_INC__
000000r 3               __CONFIG_INC__ = 1
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_FDS     = 6          ; per-process descriptor count
000000r 3               OPEN_MAX    = 16         ; system-wide open object slots
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active processes
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_PROCS   = 8
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active timer waits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_TIMER   = 8
000000r 3               
000000r 3               ;
000000r 3               ;
000000r 3               ;
000000r 3               
000000r 3               MAX_PIPES       = 8
000000r 3               PIPE_BUF_SIZE   = 64
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Filesystem path limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               NEOX_CWD_MAX  = 32        ; process-private current-directory path bytes
000000r 3               NEOX_PATH_MAX = 64        ; kernel path resolver buffer bytes
000000r 3               ; ============================================================
000000r 3               ;
000000r 3               ; ============================================================
000000r 3               
000000r 3               USER_IMAGE_TABLE = $1000
000000r 3               
000000r 3               ; Final 32/32 virtual-memory split.
000000r 3               USER_SPACE_LIMIT = $8000
000000r 3               KERNEL_SHARED_BASE = $B020
000000r 3               KERNEL_OVERFLOW_BASE = $C000
000000r 3               MICMON_BASE = $D000
000000r 3               IO_PAGE_BASE = $E000
000000r 3               BIOS_BASE = $F000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Kernel
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               KERNEL_BASE = $8000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Syscall table location
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               SYSCALL_BASE = $F100
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; RP2350 mailbox control registers (MMIO)
000000r 3               ;
000000r 3               ; Layout:
000000r 3               ;   Page E is shared I/O space
000000r 3               ;   OS-owned mailbox doorbell starts at $E010
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_DOORBELL  = $E010
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Shared RAM request/result block (ordinary shared RAM, not I/O)
000000r 3               ;
000000r 3               ; mailbox request block.
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_REQ_BASE  = $B000
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Request / result block layout, ABI v2
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_GROUP            = RP_REQ_BASE + 0
000000r 2               RP_CMD              = RP_REQ_BASE + 1
000000r 2               RP_STATUS           = RP_REQ_BASE + 2
000000r 2               RP_ERR              = RP_REQ_BASE + 3
000000r 2               
000000r 2               RP_FLAGS            = RP_REQ_BASE + 4
000000r 2               RP_STATE            = RP_REQ_BASE + 5
000000r 2               
000000r 2               RP_ARG0L            = RP_REQ_BASE + 6
000000r 2               RP_ARG0H            = RP_REQ_BASE + 7
000000r 2               RP_ARG1L            = RP_REQ_BASE + 8
000000r 2               RP_ARG1H            = RP_REQ_BASE + 9
000000r 2               RP_ARG2L            = RP_REQ_BASE + 10
000000r 2               RP_ARG2H            = RP_REQ_BASE + 11
000000r 2               
000000r 2               RP_RES0L            = RP_REQ_BASE + 12
000000r 2               RP_RES0H            = RP_REQ_BASE + 13
000000r 2               RP_RES1L            = RP_REQ_BASE + 14
000000r 2               RP_RES1H            = RP_REQ_BASE + 15
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Other shared RP state bytes
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IRQ_SOURCE       = RP_REQ_BASE + 16
000000r 2               RP_CONSOLE_PID      = RP_REQ_BASE + 17
000000r 2               RP_CONSOLE_RDY      = RP_REQ_BASE + 18
000000r 2               RP_IRQ_STATE        = RP_REQ_BASE + 19
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_STATUS values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IDLE             = $00
000000r 2               RP_BUSY             = $01
000000r 2               RP_DONE             = $02
000000r 2               RP_ERROR            = $03
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_GROUP values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_GROUP_NONE       = $00
000000r 2               RP_GROUP_CONSOLE    = $01
000000r 2               RP_GROUP_FS         = $02
000000r 2               RP_GROUP_SYSTEM     = $03
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_CMD values inside RP_GROUP_CONSOLE
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_CON_CMD_NONE     = $00
000000r 2               RP_CON_CMD_WRITE    = $01
000000r 2               RP_CON_CMD_READ     = $02
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_CMD values inside RP_GROUP_FS
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_FS_CMD_NONE      = $00
000000r 2               RP_FS_CMD_EXEC      = $11
000000r 2               
000000r 2               ; Generic filesystem operations carried in RP_STATE. Values $01-$10 retain
000000r 2               ; their established numeric assignments, but are no longer accepted as direct
000000r 2               ; RP_CMD values.
000000r 2               RP_FS_OP_STATUS        = $01
000000r 2               RP_FS_OP_OPEN          = $02
000000r 2               RP_FS_OP_READ          = $03
000000r 2               RP_FS_OP_CLOSE         = $04
000000r 2               RP_FS_OP_WRITE         = $05
000000r 2               RP_FS_OP_LOAD          = $06
000000r 2               RP_FS_OP_SAVE          = $07
000000r 2               RP_FS_OP_SEEK          = $08
000000r 2               RP_FS_OP_TELL          = $09
000000r 2               RP_FS_OP_DELETE        = $0A
000000r 2               RP_FS_OP_RENAME        = $0B
000000r 2               RP_FS_OP_OPENDIR       = $0C
000000r 2               RP_FS_OP_READDIR       = $0D
000000r 2               RP_FS_OP_CLOSEDIR      = $0E
000000r 2               RP_FS_OP_MKDIR         = $0F
000000r 2               RP_FS_OP_RMDIR         = $10
000000r 2               RP_FS_OP_CWD_INIT_ROOT = $12
000000r 2               RP_FS_OP_CWD_CLONE     = $13
000000r 2               RP_FS_OP_CHDIR         = $14
000000r 2               RP_FS_OP_GETCWD        = $15
000000r 2               
000000r 2               RP_FS_SEEK_SET      = $00
000000r 2               RP_FS_SEEK_CUR      = $01
000000r 2               RP_FS_SEEK_END      = $02
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_DOORBELL trigger value for ABI v2
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_DOORBELL_TRIGGER = $01
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_FLAGS values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_FLAG_NONE        = $00
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_IRQ_SOURCE values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IRQ_SRC_NONE     = $00
000000r 2               RP_IRQ_SRC_TIMER    = $01
000000r 2               RP_IRQ_SRC_MONITOR  = $02
000000r 2               RP_IRQ_SRC_FS_DONE  = $03
000000r 2               RP_IRQ_SRC_CONSOLE_BREAK = $04
000000r 2               
000000r 2               .endif
