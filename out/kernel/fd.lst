0004F0r 1               
0004F0r 1  A0 0A            ldy #ENODEV
0004F2r 1  38               sec
0004F3r 1  60               rts
0004F4r 1               
0004F4r 1               @dir_ok:
0004F4r 1  BD rr rr         lda open_file_handle,x
0004F7r 1  18               clc
0004F8r 1  60               rts
0004F9r 1               .endproc
