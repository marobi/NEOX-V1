0004F9r 1               ; ------------------------------------------------------------
0004F9r 1               ; fd_read
0004F9r 1               ;
0004F9r 1               ; Purpose:
0004F9r 1               ;   FD-layer implementation of read dispatch.
0004F9r 1               ;
0004F9r 1               ; Input:
0004F9r 1               ;   Y      = fd number
0004F9r 1               ;   io_ptr = destination buffer
0004F9r 1               ;   A/X    = requested length, low/high
0004F9r 1               ;
0004F9r 1               ; Output:
0004F9r 1               ;   C clear = success
0004F9r 1               ;             A/X = bytes read
0004F9r 1               ;
0004F9r 1               ;   C set   = failure
0004F9r 1               ;             Y = errno
0004F9r 1               ;
0004F9r 1               ; Flow:
0004F9r 1               ;   fd -> open object -> permission -> object type -> backend
0004F9r 1               ;
0004F9r 1               ; Notes:
0004F9r 1               ;   - FD lookup and permission check are protected by file_io_gate.
0004F9r 1               ;   - Device backend is tail-called through dev_ptr.
0004F9r 1               ;   - Pipe backend is called while file_io_gate is held.
0004F9r 1               ;   - pipe_ptr is a dedicated ZP pointer for pipe byte transfer.
0004F9r 1               ; ------------------------------------------------------------
0004F9r 1               
0004F9r 1               .proc fd_read
0004F9r 1                   ; Preserve requested length before touching debug state.
0004F9r 1  48               pha
0004FAr 1  DA               phx
0004FBr 1               
0004FBr 1               
0004FBr 1                   ; Resolve fd -> open object.
0004FBr 1               
0004FBr 1  98               tya
0004FCr 1  20 rr rr         jsr fd_lookup
0004FFr 1  90 04            bcc @fd_ok
000501r 1               
000501r 1  FA               plx
000502r 1  68               pla
000503r 1  38               sec
000504r 1  60               rts
000505r 1               
000505r 1               @fd_ok:
000505r 1               
000505r 1                   ; Save open object across permission check.
000505r 1  DA               phx
000506r 1               
000506r 1               
000506r 1  A9 01            lda #FD_FLAG_READ
000508r 1  20 rr rr         jsr fd_check_perm
00050Br 1  90 05            bcc @perm_ok
00050Dr 1               
00050Dr 1  FA               plx                         ; discard open object
00050Er 1               
00050Er 1  FA               plx
00050Fr 1  68               pla
000510r 1  38               sec
000511r 1  60               rts
000512r 1               
000512r 1               @perm_ok:
000512r 1               
000512r 1  FA               plx                         ; X = open object
000513r 1               
000513r 1               
000513r 1  BD rr rr         lda open_type,x
000516r 1  C9 03            cmp #OBJ_PIPE
000518r 1  F0 0A            beq @pipe_ok
00051Ar 1               
00051Ar 1  C9 01            cmp #OBJ_DEVICE
00051Cr 1  F0 17            beq @device_ok
00051Er 1               
00051Er 1                   ; Files are handled directly by ksys_read through rp_fs_exec.
00051Er 1  FA               plx
00051Fr 1  68               pla
000520r 1  A0 0A            ldy #ENODEV
000522r 1  38               sec
000523r 1  60               rts
000524r 1               
000524r 1               @pipe_ok:
000524r 1                   ; Save open object above saved length.
000524r 1  8A               txa
000525r 1  48               pha
000526r 1               
000526r 1               
000526r 1                   ; Snapshot caller buffer pointer into the pipe-specific ZP ptr.
000526r 1  A5 rr            lda io_ptr
000528r 1  85 rr            sta pipe_ptr
00052Ar 1  A5 rr            lda io_ptr+1
00052Cr 1  85 rr            sta pipe_ptr+1
00052Er 1               
00052Er 1                   ; Restore pipe backend arguments.
00052Er 1  68               pla
00052Fr 1  A8               tay                         ; Y = open object
000530r 1               
000530r 1  FA               plx                         ; X = length high
000531r 1  68               pla                         ; A = length low
000532r 1               
000532r 1  4C rr rr         jmp pipe_read
000535r 1               
000535r 1               @device_ok:
000535r 1               
000535r 1  A9 00            lda #DEVOP_READ
000537r 1  20 rr rr         jsr dev_resolve_op
00053Ar 1  90 04            bcc @op_ok
00053Cr 1               
00053Cr 1               
00053Cr 1  FA               plx
00053Dr 1  68               pla
00053Er 1  38               sec
00053Fr 1  60               rts
000540r 1               
000540r 1               @op_ok:
000540r 1  4C rr rr         jmp fd_tail_call_device
000543r 1               .endproc
000543r 1               
000543r 1               ; ------------------------------------------------------------
000543r 1               ; fd_write
000543r 1               ;
000543r 1               ; Purpose:
000543r 1               ;   FD-layer implementation of write dispatch.
000543r 1               ;
000543r 1               ; Input:
000543r 1               ;   Y      = fd number
000543r 1               ;   io_ptr = source buffer
000543r 1               ;   A/X    = requested length, low/high
000543r 1               ;
000543r 1               ; Output:
000543r 1               ;   C clear = success
000543r 1               ;             A/X = bytes written
000543r 1               ;
000543r 1               ;   C set   = failure
000543r 1               ;             Y = errno
000543r 1               ;
000543r 1               ; Flow:
000543r 1               ;   fd -> open object -> permission -> object type -> backend
000543r 1               ;
000543r 1               ; Notes:
000543r 1               ;   - FD lookup and permission check are protected by file_io_gate.
000543r 1               ;   - Device backend is tail-called through dev_ptr.
000543r 1               ;   - Pipe backend is called while file_io_gate is held.
000543r 1               ;   - pipe_ptr is a dedicated ZP pointer for pipe byte transfer.
000543r 1               ; ------------------------------------------------------------
000543r 1               
000543r 1               .proc fd_write
000543r 1                   ; Preserve requested length.
000543r 1  48               pha
000544r 1  DA               phx
000545r 1               
000545r 1               
000545r 1               
000545r 1                   ; Resolve fd -> open object.
000545r 1  98               tya
000546r 1  20 rr rr         jsr fd_lookup
000549r 1  90 04            bcc @fd_ok
00054Br 1               
00054Br 1               
00054Br 1  FA               plx
00054Cr 1  68               pla
00054Dr 1  38               sec
00054Er 1  60               rts
00054Fr 1               
00054Fr 1               @fd_ok:
00054Fr 1                   ; Save open object across permission check.
00054Fr 1  DA               phx
000550r 1               
000550r 1  A9 02            lda #FD_FLAG_WRITE
000552r 1  20 rr rr         jsr fd_check_perm
000555r 1  90 05            bcc @perm_ok
000557r 1               
000557r 1  FA               plx                         ; discard open object
000558r 1               
000558r 1               
000558r 1  FA               plx
000559r 1  68               pla
00055Ar 1  38               sec
00055Br 1  60               rts
00055Cr 1               
00055Cr 1               @perm_ok:
00055Cr 1  FA               plx                         ; X = open object
00055Dr 1               
00055Dr 1  BD rr rr         lda open_type,x
000560r 1  C9 03            cmp #OBJ_PIPE
000562r 1  F0 0A            beq @pipe_ok
000564r 1               
000564r 1  C9 01            cmp #OBJ_DEVICE
000566r 1  F0 17            beq @device_ok
000568r 1               
000568r 1                   ; Files are handled directly by ksys_write through rp_fs_exec.
000568r 1  FA               plx
000569r 1  68               pla
00056Ar 1  A0 0A            ldy #ENODEV
00056Cr 1  38               sec
00056Dr 1  60               rts
00056Er 1               
00056Er 1               @pipe_ok:
00056Er 1                   ; Save open object above saved length.
00056Er 1  8A               txa
00056Fr 1  48               pha
000570r 1               
000570r 1               
000570r 1                   ; Snapshot caller buffer pointer into the pipe-specific ZP ptr.
000570r 1  A5 rr            lda io_ptr
000572r 1  85 rr            sta pipe_ptr
000574r 1  A5 rr            lda io_ptr+1
000576r 1  85 rr            sta pipe_ptr+1
000578r 1               
000578r 1                   ; Restore pipe backend arguments.
000578r 1  68               pla
000579r 1  A8               tay                         ; Y = open object
00057Ar 1               
00057Ar 1  FA               plx                         ; X = length high
00057Br 1  68               pla                         ; A = length low
00057Cr 1               
00057Cr 1  4C rr rr         jmp pipe_write
00057Fr 1               
00057Fr 1               @device_ok:
00057Fr 1  A9 02            lda #DEVOP_WRITE
000581r 1  20 rr rr         jsr dev_resolve_op
000584r 1  90 04            bcc @op_ok
000586r 1               
000586r 1               
000586r 1  FA               plx
000587r 1  68               pla
000588r 1  38               sec
000589r 1  60               rts
00058Ar 1               
00058Ar 1               @op_ok:
00058Ar 1  4C rr rr         jmp fd_tail_call_device
00058Dr 1               .endproc
00058Dr 1               
00058Dr 1               ; ------------------------------------------------------------
00058Dr 1               ; fd_get_flags_current
00058Dr 1               ;
00058Dr 1               ; Purpose:
00058Dr 1               ;   Fetch proc_fd_flags[active_pid][fd_index_tmp].
00058Dr 1               ;
00058Dr 1               ; Input:
00058Dr 1               ;   fd_index_tmp = fd index
00058Dr 1               ;
00058Dr 1               ; Output:
00058Dr 1               ;   A = fd flags
00058Dr 1               ;
00058Dr 1               ; Clobbers:
00058Dr 1               ;   A, Y, fd_ptr
00058Dr 1               ; ------------------------------------------------------------
00058Dr 1               
00058Dr 1               .proc fd_get_flags_current
00058Dr 1  AD rr rr         lda active_pid
000590r 1  20 rr rr         jsr fd_calc_pid_offset
000593r 1               
000593r 1  18               clc
000594r 1  A9 rr            lda #<proc_fd_flags
000596r 1  6D rr rr         adc fd_mul_lo
000599r 1  85 rr            sta fd_ptr
00059Br 1               
00059Br 1  A9 rr            lda #>proc_fd_flags
00059Dr 1  6D rr rr         adc fd_mul_hi
0005A0r 1  85 rr            sta fd_ptr+1
0005A2r 1               
0005A2r 1  AC rr rr         ldy fd_index_tmp
0005A5r 1  B1 rr            lda (fd_ptr),y
0005A7r 1               
0005A7r 1  60               rts
0005A8r 1               .endproc
0005A8r 1               
0005A8r 1               ; ------------------------------------------------------------
0005A8r 1               ; fd_find_free_current
0005A8r 1               ;
0005A8r 1               ; Purpose:
0005A8r 1               ;   Find the lowest free fd slot for active_pid.
0005A8r 1               ;
0005A8r 1               ; Output:
0005A8r 1               ;   C clear = found
0005A8r 1               ;             Y = free fd index
0005A8r 1               ;
0005A8r 1               ;   C set   = no free descriptor
0005A8r 1               ;             Y = EMFILE
0005A8r 1               ;
0005A8r 1               ; Clobbers:
0005A8r 1               ;   A, Y, fd_ptr
0005A8r 1               ; ------------------------------------------------------------
0005A8r 1               
0005A8r 1               .proc fd_find_free_current
0005A8r 1  AD rr rr         lda active_pid
0005ABr 1  20 rr rr         jsr fd_calc_pid_offset
0005AEr 1               
0005AEr 1  18               clc
0005AFr 1  A9 rr            lda #<proc_fd_obj
0005B1r 1  6D rr rr         adc fd_mul_lo
0005B4r 1  85 rr            sta fd_ptr
0005B6r 1               
0005B6r 1  A9 rr            lda #>proc_fd_obj
0005B8r 1  6D rr rr         adc fd_mul_hi
0005BBr 1  85 rr            sta fd_ptr+1
0005BDr 1               
0005BDr 1  A0 00            ldy #0
0005BFr 1               
0005BFr 1               @scan:
0005BFr 1  C0 06            cpy #MAX_FDS
0005C1r 1  F0 0B            beq @full
0005C3r 1               
0005C3r 1  B1 rr            lda (fd_ptr),y
0005C5r 1  C9 FF            cmp #FD_NONE
0005C7r 1  F0 03            beq @found
0005C9r 1               
0005C9r 1  C8               iny
0005CAr 1  80 F3            bra @scan
0005CCr 1               
0005CCr 1               @found:
0005CCr 1  18               clc
0005CDr 1  60               rts
0005CEr 1               
0005CEr 1               @full:
0005CEr 1  A0 08            ldy #EMFILE
0005D0r 1  38               sec
0005D1r 1  60               rts
0005D2r 1               .endproc
0005D2r 1               
0005D2r 1               ; ------------------------------------------------------------
0005D2r 1               ; fd_alloc_fd_current
0005D2r 1               ;
0005D2r 1               ; Caller:
0005D2r 1               ;   file_io_gate held by caller
0005D2r 1               ;
0005D2r 1               ; Output:
0005D2r 1               ;   C clear = success, Y = fd
0005D2r 1               ;   C set   = failure, Y = EMFILE
0005D2r 1               ; ------------------------------------------------------------
0005D2r 1               
0005D2r 1               .proc fd_alloc_fd_current
0005D2r 1  4C rr rr         jmp fd_find_free_current
0005D5r 1               .endproc
0005D5r 1               
0005D5r 1               ; ------------------------------------------------------------
0005D5r 1               ; fd_dup
0005D5r 1               ;
0005D5r 1               ; Input:
0005D5r 1               ;   A = old fd
0005D5r 1               ;
0005D5r 1               ; Output:
0005D5r 1               ;   C clear = success
0005D5r 1               ;             A = new fd
0005D5r 1               ;             X = 0
0005D5r 1               ;
0005D5r 1               ;   C set   = failure
0005D5r 1               ;             Y = errno
0005D5r 1               ;
0005D5r 1               ; Notes:
0005D5r 1               ;
0005D5r 1               ; ------------------------------------------------------------
0005D5r 1               
0005D5r 1               .proc fd_dup
0005D5r 1  48               pha                         ; preserve oldfd across table setup
0005D6r 1               
0005D6r 1               
0005D6r 1  68               pla                         ; A = oldfd
0005D7r 1               
0005D7r 1                   ; Resolve old fd -> open object.
0005D7r 1  20 rr rr         jsr fd_lookup
0005DAr 1  90 02            bcc @old_ok
0005DCr 1               
0005DCr 1               
0005DCr 1  38               sec
0005DDr 1  60               rts
0005DEr 1               
0005DEr 1               @old_ok:
0005DEr 1                   ; X = old open object.
0005DEr 1  DA               phx                         ; stack: old object
0005DFr 1               
0005DFr 1                   ; Copy flags from old fd.
0005DFr 1  20 rr rr         jsr fd_get_flags_current
0005E2r 1  8D rr rr         sta fd_flags_tmp
0005E5r 1               
0005E5r 1                   ; Find lowest free fd.
0005E5r 1  20 rr rr         jsr fd_find_free_current
0005E8r 1  90 03            bcc @slot_ok
0005EAr 1               
0005EAr 1  FA               plx                         ; discard old object
0005EBr 1               
0005EBr 1               
0005EBr 1  38               sec
0005ECr 1  60               rts
0005EDr 1               
0005EDr 1               @slot_ok:
0005EDr 1                   ; Y = new fd.
0005EDr 1                   ;
0005EDr 1                   ; Preserve new fd on stack. Do not use fd_pid_tmp:
0005EDr 1                   ; fd_attach overwrites it.
0005EDr 1  5A               phy                         ; stack: old object, new fd
0005EEr 1               
0005EEr 1                   ; Restore old object into A.
0005EEr 1  7A               ply                         ; Y = new fd
0005EFr 1  FA               plx                         ; X = old object
0005F0r 1               
0005F0r 1  8A               txa                         ; A = old object
0005F1r 1  AE rr rr         ldx active_pid             ; X = PID
0005F4r 1               
0005F4r 1                   ; Preserve new fd for return.
0005F4r 1  5A               phy                         ; stack: new fd
0005F5r 1               
0005F5r 1                   ; Attach:
0005F5r 1                   ;   X = active_pid
0005F5r 1                   ;   Y = new fd
0005F5r 1                   ;   A = old object
0005F5r 1  20 rr rr         jsr fd_attach
0005F8r 1               
0005F8r 1                   ; Recover new fd return value.
0005F8r 1  7A               ply                         ; Y = new fd
0005F9r 1               
0005F9r 1               
0005F9r 1  98               tya                         ; A = new fd
0005FAr 1  A2 00            ldx #0
0005FCr 1  18               clc
0005FDr 1  60               rts
0005FEr 1               .endproc
0005FEr 1               
0005FEr 1               ; ------------------------------------------------------------
0005FEr 1               ; fd_dup2
0005FEr 1               ;
0005FEr 1               ; Input:
0005FEr 1               ;   A = old fd
0005FEr 1               ;   Y = new fd
0005FEr 1               ;
0005FEr 1               ; Output:
0005FEr 1               ;   C clear = success, A = new fd, X = 0
0005FEr 1               ;   C set   = failure, Y = errno
0005FEr 1               ; ------------------------------------------------------------
0005FEr 1               
0005FEr 1               ; ------------------------------------------------------------
0005FEr 1               ; fd_dup2
0005FEr 1               ;
0005FEr 1               ; Input:
0005FEr 1               ;   A = old fd
0005FEr 1               ;   Y = new fd
0005FEr 1               ;
0005FEr 1               ; Output:
0005FEr 1               ;   C clear = success
0005FEr 1               ;             A = new fd
0005FEr 1               ;             X = 0
0005FEr 1               ;
0005FEr 1               ;   C set   = failure
0005FEr 1               ;             Y = errno
0005FEr 1               ;
0005FEr 1               ; Notes:
0005FEr 1               ;   - Validates newfd before table work.
0005FEr 1               ;   - Validates oldfd before closing/replacing newfd.
0005FEr 1               ;   - dup2(oldfd, oldfd) returns oldfd without changing refcounts.
0005FEr 1               ;   - fd_close_current is used because file_io_gate is already held.
0005FEr 1               ; ------------------------------------------------------------
0005FEr 1               
0005FEr 1               .proc fd_dup2
0005FEr 1  C0 06            cpy #MAX_FDS
000600r 1  90 04            bcc @newfd_ok
000602r 1               
000602r 1  A0 09            ldy #EBADF
000604r 1  38               sec
000605r 1  60               rts
000606r 1               
000606r 1               @newfd_ok:
000606r 1  48               pha                         ; preserve oldfd
000607r 1  5A               phy                         ; preserve newfd
000608r 1               
000608r 1               
000608r 1  7A               ply                         ; Y = newfd
000609r 1  68               pla                         ; A = oldfd
00060Ar 1               
00060Ar 1                   ; Preserve newfd across fd_lookup.
00060Ar 1                   ; fd_lookup returns errno in Y on failure, so this saved byte
00060Ar 1                   ; must be discarded with PLA, not PLY, on the failure path.
00060Ar 1  5A               phy
00060Br 1               
00060Br 1                   ; Resolve old fd -> open object.
00060Br 1  20 rr rr         jsr fd_lookup
00060Er 1  90 03            bcc @old_ok
000610r 1               
000610r 1  68               pla                         ; discard saved newfd
000611r 1                                               ; preserve Y = errno from fd_lookup
000611r 1               
000611r 1               
000611r 1  38               sec
000612r 1  60               rts
000613r 1               
000613r 1               @old_ok:
000613r 1                   ; X = old object
000613r 1                   ; fd_index_tmp = old fd
000613r 1                   ; stack top = saved newfd
000613r 1               
000613r 1  7A               ply                         ; Y = newfd
000614r 1               
000614r 1                   ; dup2(fd, fd) succeeds and changes nothing.
000614r 1  CC rr rr         cpy fd_index_tmp
000617r 1  D0 05            bne @different
000619r 1               
000619r 1               
000619r 1  98               tya
00061Ar 1  A2 00            ldx #0
00061Cr 1  18               clc
00061Dr 1  60               rts
00061Er 1               
00061Er 1               @different:
00061Er 1                   ; Preserve old object and newfd.
00061Er 1  DA               phx                         ; old object
00061Fr 1  5A               phy                         ; newfd
000620r 1               
000620r 1                   ; Copy descriptor flags from old fd.
000620r 1                   ; fd_index_tmp still contains old fd here.
000620r 1  20 rr rr         jsr fd_get_flags_current
000623r 1  8D rr rr         sta fd_flags_tmp
000626r 1               
000626r 1                   ; Close target newfd if it is open.
000626r 1                   ; EBADF from closing target means it was already closed, which is OK.
000626r 1  7A               ply                         ; Y = newfd
000627r 1  5A               phy                         ; keep newfd for attach/return
000628r 1               
000628r 1  98               tya                         ; A = newfd
000629r 1  20 rr rr         jsr fd_close_current
00062Cr 1  90 08            bcc @target_closed_ok
00062Er 1               
00062Er 1  C0 09            cpy #EBADF
000630r 1  F0 04            beq @target_closed_ok
000632r 1               
000632r 1                   ; Real close failure.
000632r 1  7A               ply                         ; discard newfd
000633r 1  FA               plx                         ; discard old object
000634r 1               
000634r 1               
000634r 1  38               sec
000635r 1  60               rts
000636r 1               
000636r 1               @target_closed_ok:
000636r 1  7A               ply                         ; Y = newfd
000637r 1  FA               plx                         ; X = old object
000638r 1               
000638r 1                   ; Attach newfd to the old object.
000638r 1  8A               txa                         ; A = old object
000639r 1  AE rr rr         ldx active_pid             ; X = PID
00063Cr 1               
00063Cr 1  5A               phy                         ; preserve newfd across fd_attach
00063Dr 1               
00063Dr 1  20 rr rr         jsr fd_attach
000640r 1               
000640r 1  7A               ply                         ; Y = newfd
000641r 1               
000641r 1               
000641r 1  98               tya                         ; A = newfd
000642r 1  A2 00            ldx #0
000644r 1  18               clc
000645r 1  60               rts
000646r 1               .endproc
000646r 1               
000646r 1               
