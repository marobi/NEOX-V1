000249r 1               ; ------------------------------------------------------------
000249r 1               ; ksys_get_launch_id
000249r 1               ;
000249r 1               ; Input:
000249r 1               ;   none
000249r 1               ;
000249r 1               ; Return:
000249r 1               ;   C clear = success, A = launch selector for active_pid
000249r 1               ;   C set   = failure, Y = errno
000249r 1               ;
000249r 1               ; Purpose:
000249r 1               ;   Let a committed resident child retrieve the launch selector that
000249r 1               ;   its parent assigned before the child was published as PROC_NEW.
000249r 1               ; ------------------------------------------------------------
000249r 1               
000249r 1               .proc ksys_get_launch_id
000249r 1  AE rr rr         ldx active_pid
00024Cr 1  E0 08            cpx #MAX_PROCS
00024Er 1  90 04            bcc @pid_ok
000250r 1               
000250r 1  A0 06            ldy #EINVAL
000252r 1  38               sec
000253r 1  60               rts
000254r 1               
000254r 1               @pid_ok:
000254r 1  BD rr rr         lda proc_launch_id,x
000257r 1  C9 FF            cmp #SPAWN_LAUNCH_NONE
000259r 1  D0 04            bne @ok
00025Br 1               
00025Br 1  A0 06            ldy #EINVAL
00025Dr 1  38               sec
00025Er 1  60               rts
00025Fr 1               
00025Fr 1               @ok:
00025Fr 1  18               clc
000260r 1  60               rts
000261r 1               .endproc
000261r 1               
000261r 1               
