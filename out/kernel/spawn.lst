000000r 1  xx               .res 1
000001r 1               
000001r 1               spawn_arg_ptrH:
000001r 1  xx               .res 1
000002r 1               
000002r 1               spawn_entryL:
000002r 1  xx               .res 1
000003r 1               
000003r 1               spawn_entryH:
000003r 1  xx               .res 1
