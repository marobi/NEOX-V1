00000Fr 1               spawn_fd_clone_args:
00000Fr 1  xx xx xx xx      .tag fd_clone_args
000013r 1               
000013r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; spawn_set_launch_line_dev_ptr
000000r 1               ;
000000r 1               ; Input:
000000r 1               ;   X = PID
000000r 1               ;
000000r 1               ; Output:
000000r 1               ;   dev_ptr = selected process launch-line slot
000000r 1               ; ------------------------------------------------------------
000000r 1               .proc spawn_set_launch_line_dev_ptr
000000r 1  8A               txa
000001r 1  A2 40            ldx #SPAWN_LINE_MAX
000003r 1  20 rr rr         jsr mul8u
000006r 1               
000006r 1  18               clc
000007r 1  69 rr            adc #<proc_launch_line
000009r 1  85 rr            sta dev_ptr
00000Br 1               
00000Br 1  8A               txa
00000Cr 1  69 rr            adc #>proc_launch_line
00000Er 1  85 rr            sta dev_ptr+1
000010r 1  60               rts
000011r 1               .endproc
000011r 1               
000011r 1               ; ------------------------------------------------------------
000011r 1               ; spawn_copy_parent_to_launch_line
000011r 1               ;
000011r 1               ; Input:
000011r 1               ;   io_ptr         -> source bytes in active parent context
000011r 1               ;   dev_ptr        -> shared destination launch-line slot
000011r 1               ;   spawn_line_len = byte count excluding NUL
000011r 1               ; ------------------------------------------------------------
000011r 1               .proc spawn_copy_parent_to_launch_line
000011r 1  A0 00            ldy #0
000013r 1               @loop:
000013r 1  CC rr rr         cpy spawn_line_len
000016r 1  F0 07            beq @terminate
000018r 1  B1 rr            lda (io_ptr),y
00001Ar 1  91 rr            sta (dev_ptr),y
00001Cr 1  C8               iny
00001Dr 1  80 F4            bra @loop
00001Fr 1               
00001Fr 1               @terminate:
00001Fr 1  A9 00            lda #0
000021r 1  91 rr            sta (dev_ptr),y
000023r 1  18               clc
000024r 1  60               rts
000025r 1               .endproc
000025r 1               
000025r 1               ; ------------------------------------------------------------
000025r 1               ; spawn_copy_launch_line_to_child
000025r 1               ;
000025r 1               ; Input:
000025r 1               ;   dev_ptr        -> shared source launch-line slot
000025r 1               ;   io_ptr         -> destination buffer in active child context
000025r 1               ;   spawn_line_len = byte count excluding NUL
000025r 1               ; ------------------------------------------------------------
000025r 1               .proc spawn_copy_launch_line_to_child
000025r 1  A0 00            ldy #0
000027r 1               @loop:
000027r 1  CC rr rr         cpy spawn_line_len
00002Ar 1  F0 07            beq @terminate
00002Cr 1  B1 rr            lda (dev_ptr),y
00002Er 1  91 rr            sta (io_ptr),y
000030r 1  C8               iny
000031r 1  80 F4            bra @loop
000033r 1               
000033r 1               @terminate:
000033r 1  A9 00            lda #0
000035r 1  91 rr            sta (io_ptr),y
000037r 1  18               clc
000038r 1  60               rts
000039r 1               .endproc
000039r 1               
000039r 1               ; ------------------------------------------------------------
000039r 1               ; spawn_clone_mapped_fd_locked
000039r 1               ;
000039r 1               ; Input:
000039r 1               ;   A = fd number to clone from active parent into same child fd.
000039r 1               ;   spawn_child_pid = pending child PID.
000039r 1               ; ------------------------------------------------------------
000039r 1               .proc spawn_clone_mapped_fd_locked
000039r 1  C9 FF            cmp #SPAWN_FD_CLOSED
00003Br 1  F0 19            beq @closed
00003Dr 1               
00003Dr 1  8D rr rr         sta spawn_fd_clone_args + fd_clone_args::source_fd
000040r 1  8C rr rr         sty spawn_fd_clone_args + fd_clone_args::target_fd
000043r 1               
000043r 1  AD rr rr         lda active_pid
000046r 1  8D rr rr         sta spawn_fd_clone_args + fd_clone_args::source_pid
000049r 1               
000049r 1  AD rr rr         lda spawn_child_pid
00004Cr 1  8D rr rr         sta spawn_fd_clone_args + fd_clone_args::target_pid
00004Fr 1               
00004Fr 1  A2 rr            ldx #<spawn_fd_clone_args
000051r 1  A0 rr            ldy #>spawn_fd_clone_args
000053r 1  4C rr rr         jmp fd_clone_between
000056r 1               
000056r 1               @closed:
000056r 1  18               clc
000057r 1  60               rts
000058r 1               .endproc
000058r 1               
000058r 1               ; spawn_validate_mapped_fd
000058r 1               ;
000058r 1               ; Input:
000058r 1               ;   A = parent fd or SPAWN_FD_CLOSED
000058r 1               ;
000058r 1               ; Return:
000058r 1               ;   C clear = accepted
000058r 1               ;   C set   = invalid, Y = EBADF
000058r 1               ; ------------------------------------------------------------
000058r 1               .proc spawn_validate_mapped_fd
000058r 1  C9 FF            cmp #SPAWN_FD_CLOSED
00005Ar 1  F0 08            beq @ok
00005Cr 1  C9 06            cmp #MAX_FDS
00005Er 1  90 04            bcc @ok
000060r 1               
000060r 1  A0 09            ldy #EBADF
000062r 1  38               sec
000063r 1  60               rts
000064r 1               
000064r 1               @ok:
000064r 1  18               clc
000065r 1  60               rts
000066r 1               .endproc
000066r 1               
000066r 1               ; ------------------------------------------------------------
000066r 1               ; spawn_clear_process_slot_locked
000066r 1               ;
000066r 1               ; Requires proc_gate. The setup child must not be runnable.
000066r 1               ; Uses spawn_child_pid.
000066r 1               ; ------------------------------------------------------------
000066r 1               .proc spawn_clear_process_slot_locked
000066r 1  AE rr rr         ldx spawn_child_pid
000069r 1  20 rr rr         jsr ctx_free_for_pid
00006Cr 1               
00006Cr 1  AE rr rr         ldx spawn_child_pid
00006Fr 1  A9 00            lda #WAIT_NONE
000071r 1  9D rr rr         sta wait_reason,x
000074r 1  9E rr rr         stz wait_object,x
000077r 1  9E rr rr         stz proc_signal_pending,x
00007Ar 1  A9 00            lda #EXIT_OK
00007Cr 1  9D rr rr         sta proc_exit_code,x
00007Fr 1               
00007Fr 1  A9 FF            lda #$FF
000081r 1  9D rr rr         sta proc_parent_pid,x
000084r 1  9D rr rr         sta proc_context,x
000087r 1               
000087r 1  9E rr rr         stz proc_sp,x
00008Ar 1  9E rr rr         stz proc_entryL,x
00008Dr 1  9E rr rr         stz proc_entryH,x
000090r 1  9E rr rr         stz proc_flags,x
000093r 1  20 rr rr         jsr proc_clear_launch_state
000096r 1               
000096r 1  A9 00            lda #PROC_EMPTY
000098r 1  20 rr rr         jsr proc_set_state
00009Br 1  18               clc
00009Cr 1  60               rts
00009Dr 1               .endproc
00009Dr 1               
00009Dr 1               ; ------------------------------------------------------------
00009Dr 1               ; spawn_rollback_child_locked
00009Dr 1               ;
00009Dr 1               ; Requires lock order PROC -> FILE_IO with both gates held.
00009Dr 1               ; Uses spawn_child_pid.
00009Dr 1               ; ------------------------------------------------------------
00009Dr 1               .proc spawn_rollback_child_locked
00009Dr 1  AE rr rr         ldx spawn_child_pid
0000A0r 1  20 rr rr         jsr fd_close_process
0000A3r 1               
0000A3r 1                   ; Continue clearing the unpublished process slot even though the
0000A3r 1                   ; configured resident-spawn descriptors are expected to close cleanly.
0000A3r 1  4C rr rr         jmp spawn_clear_process_slot_locked
0000A6r 1               .endproc
0000A6r 1               
0000A6r 1               ; ------------------------------------------------------------
0000A6r 1               ; Common gate-release tails.
0000A6r 1               
0000A6r 1               .proc spawn_release_proc_success
0000A6r 1  20 rr rr         jsr proc_gate_release
0000A9r 1  B0 04            bcs @ok
0000ABr 1               
0000ABr 1  A0 0C            ldy #EAGAIN
0000ADr 1  38               sec
0000AEr 1  60               rts
0000AFr 1               
0000AFr 1               @ok:
0000AFr 1  18               clc
0000B0r 1  60               rts
0000B1r 1               .endproc
0000B1r 1               
0000B1r 1               .proc spawn_release_proc_error
0000B1r 1  8C rr rr         sty spawn_errno
0000B4r 1  20 rr rr         jsr proc_gate_release
0000B7r 1  AC rr rr         ldy spawn_errno
0000BAr 1  38               sec
0000BBr 1  60               rts
0000BCr 1               .endproc
0000BCr 1               
0000BCr 1               .proc spawn_release_both_success
0000BCr 1  9C rr rr         stz spawn_errno
0000BFr 1  20 rr rr         jsr file_io_gate_release
0000C2r 1  B0 05            bcs :+
0000C4r 1  A9 0C            lda #EAGAIN
0000C6r 1  8D rr rr         sta spawn_errno
0000C9r 1               :
0000C9r 1  20 rr rr         jsr proc_gate_release
0000CCr 1  B0 05            bcs :+
0000CEr 1  A9 0C            lda #EAGAIN
0000D0r 1  8D rr rr         sta spawn_errno
0000D3r 1               :
0000D3r 1  AD rr rr         lda spawn_errno
0000D6r 1  F0 03            beq @ok
0000D8r 1  A8               tay
0000D9r 1  38               sec
0000DAr 1  60               rts
0000DBr 1               @ok:
0000DBr 1  18               clc
0000DCr 1  60               rts
0000DDr 1               .endproc
0000DDr 1               
0000DDr 1               .proc spawn_release_both_error
0000DDr 1  8C rr rr         sty spawn_errno
0000E0r 1  20 rr rr         jsr file_io_gate_release
0000E3r 1  20 rr rr         jsr proc_gate_release
0000E6r 1  AC rr rr         ldy spawn_errno
0000E9r 1  38               sec
0000EAr 1  60               rts
0000EBr 1               .endproc
0000EBr 1               
0000EBr 1               ; ksys_spawn_resident
0000EBr 1               ;
0000EBr 1               ; Input:
0000EBr 1               ;   X/Y -> spawn_resident_args
0000EBr 1               ;
0000EBr 1               ; Return:
0000EBr 1               ;   C clear = child published, A = child PID
0000EBr 1               ;   C set   = failure, Y = errno
0000EBr 1               ;
0000EBr 1               ; Locking:
0000EBr 1               ;   One transaction using PROC -> FILE_IO. The caller argument pointer
0000EBr 1               ;   remains on the current process stack while proc_gate_acquire may
0000EBr 1               ;   block/yield. Shared spawn scratch is not touched until proc_gate is
0000EBr 1               ;   owned. Any pre-publication failure uses one rollback path.
0000EBr 1               ; ------------------------------------------------------------
0000EBr 1               .proc ksys_spawn_resident
0000EBr 1                   ; proc_gate_acquire may block/yield. Preserve the process-private
0000EBr 1                   ; syscall argument pointer on the current process hardware stack.
0000EBr 1  8A               txa
0000ECr 1  48               pha
0000EDr 1  98               tya
0000EEr 1  48               pha
0000EFr 1               
0000EFr 1  20 rr rr         jsr proc_gate_acquire
0000F2r 1  B0 06            bcs @proc_locked
0000F4r 1               
0000F4r 1  68               pla
0000F5r 1  68               pla
0000F6r 1  A0 0C            ldy #EAGAIN
0000F8r 1  38               sec
0000F9r 1  60               rts
0000FAr 1               
0000FAr 1               @proc_locked:
0000FAr 1  68               pla
0000FBr 1  8D rr rr         sta spawn_arg_ptrH
0000FEr 1  85 rr            sta sched_ptr+1
000100r 1  68               pla
000101r 1  8D rr rr         sta spawn_arg_ptrL
000104r 1  85 rr            sta sched_ptr
000106r 1               
000106r 1  A0 00            ldy #spawn_resident_args::entry
000108r 1  B1 rr            lda (sched_ptr),y
00010Ar 1  8D rr rr         sta spawn_entryL
00010Dr 1  C8               iny
00010Er 1  B1 rr            lda (sched_ptr),y
000110r 1  8D rr rr         sta spawn_entryH
000113r 1               
000113r 1  A0 02            ldy #spawn_resident_args::launch_id
000115r 1  B1 rr            lda (sched_ptr),y
000117r 1  8D rr rr         sta spawn_launch_id_arg
00011Ar 1               
00011Ar 1  A0 03            ldy #spawn_resident_args::arg_line_ptr
00011Cr 1  B1 rr            lda (sched_ptr),y
00011Er 1  8D rr rr         sta spawn_line_ptrL
000121r 1  C8               iny
000122r 1  B1 rr            lda (sched_ptr),y
000124r 1  8D rr rr         sta spawn_line_ptrH
000127r 1               
000127r 1  A0 05            ldy #spawn_resident_args::arg_line_len
000129r 1  B1 rr            lda (sched_ptr),y
00012Br 1  8D rr rr         sta spawn_line_len
00012Er 1  C9 40            cmp #SPAWN_LINE_MAX
000130r 1  90 05            bcc :+
000132r 1  A0 06            ldy #EINVAL
000134r 1  4C rr rr         jmp @fail_proc
000137r 1               :
000137r 1  A0 06            ldy #spawn_resident_args::stdin_fd
000139r 1  B1 rr            lda (sched_ptr),y
00013Br 1  8D rr rr         sta spawn_stdin_fd
00013Er 1  20 rr rr         jsr spawn_validate_mapped_fd
000141r 1  90 03            bcc :+
000143r 1  4C rr rr         jmp @fail_proc
000146r 1               :
000146r 1  A0 07            ldy #spawn_resident_args::stdout_fd
000148r 1  B1 rr            lda (sched_ptr),y
00014Ar 1  8D rr rr         sta spawn_stdout_fd
00014Dr 1  20 rr rr         jsr spawn_validate_mapped_fd
000150r 1  90 03            bcc :+
000152r 1  4C rr rr         jmp @fail_proc
000155r 1               :
000155r 1  A0 08            ldy #spawn_resident_args::stderr_fd
000157r 1  B1 rr            lda (sched_ptr),y
000159r 1  8D rr rr         sta spawn_stderr_fd
00015Cr 1  20 rr rr         jsr spawn_validate_mapped_fd
00015Fr 1  90 03            bcc :+
000161r 1  4C rr rr         jmp @fail_proc
000164r 1               :
000164r 1  A0 09            ldy #spawn_resident_args::flags
000166r 1  B1 rr            lda (sched_ptr),y
000168r 1  8D rr rr         sta spawn_flags
00016Br 1  29 F1            and #($FF ^ SPAWN_FLAGS_VALID)
00016Dr 1  F0 05            beq :+
00016Fr 1  A0 06            ldy #EINVAL
000171r 1  4C rr rr         jmp @fail_proc
000174r 1               :
000174r 1  AD rr rr         lda active_pid
000177r 1  AE rr rr         ldx spawn_entryL
00017Ar 1  AC rr rr         ldy spawn_entryH
00017Dr 1  20 rr rr         jsr proc_alloc_preloaded_unpublished
000180r 1  90 05            bcc @allocated
000182r 1               
000182r 1  A0 0D            ldy #ENOMEM
000184r 1  4C rr rr         jmp @fail_proc
000187r 1               
000187r 1               @allocated:
000187r 1  8D rr rr         sta spawn_child_pid
00018Ar 1  AA               tax
00018Br 1               
00018Br 1                   ; The existing spawn flags byte is the child's explicit initial
00018Br 1                   ; proc_flags value. There is no implicit inheritance from the parent.
00018Br 1  AD rr rr         lda spawn_flags
00018Er 1  9D rr rr         sta proc_flags,x
000191r 1               
000191r 1  20 rr rr         jsr proc_clear_launch_state
000194r 1  AD rr rr         lda spawn_launch_id_arg
000197r 1  9D rr rr         sta proc_launch_id,x
00019Ar 1  AD rr rr         lda spawn_line_len
00019Dr 1  9D rr rr         sta proc_launch_line_len,x
0001A0r 1               
0001A0r 1  AD rr rr         lda spawn_line_ptrL
0001A3r 1  85 rr            sta io_ptr
0001A5r 1  AD rr rr         lda spawn_line_ptrH
0001A8r 1  85 rr            sta io_ptr+1
0001AAr 1  AE rr rr         ldx spawn_child_pid
0001ADr 1  20 rr rr         jsr spawn_set_launch_line_dev_ptr
0001B0r 1  20 rr rr         jsr spawn_copy_parent_to_launch_line
0001B3r 1               
0001B3r 1  20 rr rr         jsr file_io_gate_acquire
0001B6r 1  B0 0E            bcs @file_locked
0001B8r 1               
0001B8r 1  A0 0C            ldy #EAGAIN
0001BAr 1  8C rr rr         sty spawn_errno
0001BDr 1  20 rr rr         jsr spawn_clear_process_slot_locked
0001C0r 1  AC rr rr         ldy spawn_errno
