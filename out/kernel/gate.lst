000000r 1               .export file_io_gate_acquire
000000r 1               .export file_io_gate_release
000000r 1               .export file_io_gate_cancel_wait
000000r 1               
000000r 1               .export proc_gate_init
000000r 1               .export proc_gate_acquire
000000r 1               .export proc_gate_release
000000r 1               .export proc_gate_cancel_wait
000000r 1               
000000r 1               .import active_pid
000000r 1               .import proc_set_wait
000000r 1               .import proc_wake
000000r 1               .import sched_yield
000000r 1               .import proc_signal_pending
000000r 1               .import proc_flags
000000r 1               
000000r 1               .import file_io_gate
000000r 1               .import file_io_gate_owner
000000r 1               .import file_io_gate_wait_head
000000r 1               .import file_io_gate_wait_tail
000000r 1               .import file_io_gate_next
000000r 1               
000000r 1               .import proc_gate
