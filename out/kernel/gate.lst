000000r 1               .import proc_gate_wait_head
000000r 1               .import proc_gate_wait_tail
000000r 1               .import proc_gate_next
000000r 1               
000000r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; gate_signal_checkpoint
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Force a scheduler pass immediately after the active process has released
000000r 1               ;   its final sleepable gate when a default-action SIG_INT is pending.
000000r 1               ;
000000r 1               ; Policy:
000000r 1               ;   - never acts on PID 0
000000r 1               ;   - never acts while the active process still owns FILE_IO or PROC
000000r 1               ;   - leaves PROC_FLAG_SIGINT_INTERRUPT processes alive; their pending SIG_INT
000000r 1               ;     is consumed by the interruptible console-read path as EINTR
000000r 1               ;   - does not apply the signal directly; scheduler signal handling remains
000000r 1               ;     the sole owner of process termination
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               .proc gate_signal_checkpoint
000000r 1  AE rr rr         ldx active_pid
000003r 1  E0 00            cpx #IDLE_PID
000005r 1  F0 25            beq @done
000007r 1               
000007r 1  E0 08            cpx #MAX_PROCS
000009r 1  B0 21            bcs @done
00000Br 1               
00000Br 1  BD rr rr         lda proc_signal_pending,x
00000Er 1  C9 02            cmp #SIG_INT
000010r 1  D0 1A            bne @done
000012r 1               
000012r 1  BD rr rr         lda proc_flags,x
000015r 1  29 08            and #PROC_FLAG_SIGINT_INTERRUPT
000017r 1  D0 13            bne @done
000019r 1               
000019r 1  AD rr rr         lda file_io_gate_owner
00001Cr 1  CD rr rr         cmp active_pid
00001Fr 1  F0 0B            beq @done
000021r 1               
000021r 1  AD rr rr         lda proc_gate_owner
000024r 1  CD rr rr         cmp active_pid
000027r 1  F0 03            beq @done
000029r 1               
000029r 1  20 rr rr         jsr sched_yield
00002Cr 1               
00002Cr 1               @done:
00002Cr 1  60               rts
00002Dr 1               .endproc
00002Dr 1               
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               ; DEFINE_SLEEPABLE_GATE
00002Dr 1               ;
00002Dr 1               ; Parameters:
00002Dr 1               ;   init_proc       concrete init routine name
00002Dr 1               ;   acquire_proc    concrete acquire routine name
00002Dr 1               ;   release_proc    concrete release routine name
00002Dr 1               ;   enqueue_proc    private FIFO enqueue routine name
00002Dr 1               ;   dequeue_proc    private FIFO dequeue routine name
00002Dr 1               ;   gate_byte       0/1 ownership byte
00002Dr 1               ;   owner_byte      debug owner PID, $FF when free
00002Dr 1               ;   phase_byte      debug phase byte, gate-specific values
00002Dr 1               ;   wait_head       FIFO head PID, $FF when empty
00002Dr 1               ;   wait_tail       FIFO tail PID, $FF when empty
00002Dr 1               ;   next_table      next[pid] FIFO links, $FF when not queued
00002Dr 1               ;   lock_id         WAIT_LOCK object id
00002Dr 1               ;   idle_phase      phase value written on init/release
00002Dr 1               ;
00002Dr 1               ; IRQ policy:
00002Dr 1               ;   acquire/release protect gate metadata with php/sei/plp.
00002Dr 1               ;   They do not disable scheduling after returning. A timer preemption does
00002Dr 1               ;   not transfer ownership; owner_byte continues to identify the owning PID.
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               
00002Dr 1               .macro DEFINE_SLEEPABLE_GATE init_proc, acquire_proc, release_proc, enqueue_proc, dequeue_proc, gate_byte, owner_byte, wait_head, wait_tail, next_table, lock_id
00002Dr 1               
00002Dr 1               .proc init_proc
00002Dr 1                   stz gate_byte
00002Dr 1                   lda #GATE_OWNER_NONE
00002Dr 1                   sta owner_byte
00002Dr 1                   sta wait_head
00002Dr 1                   sta wait_tail
00002Dr 1               
00002Dr 1                   ldx #MAX_PROCS - 1
00002Dr 1               @clear_next:
00002Dr 1                   sta next_table,x
00002Dr 1                   dex
00002Dr 1                   bpl @clear_next
00002Dr 1               
00002Dr 1                   rts
00002Dr 1               .endproc
00002Dr 1               
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               ; enqueue_proc
00002Dr 1               ;
00002Dr 1               ; Input:
00002Dr 1               ;   X = current PID
00002Dr 1               ;
00002Dr 1               ; IRQ policy:
00002Dr 1               ;   Caller has IRQs disabled.
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               
00002Dr 1               .proc enqueue_proc
00002Dr 1                   ; Mark this PID as queue tail by default.
00002Dr 1                   lda #GATE_OWNER_NONE
00002Dr 1                   sta next_table,x
00002Dr 1               
00002Dr 1                   lda wait_tail
00002Dr 1                   cmp #GATE_OWNER_NONE
00002Dr 1                   beq @empty
00002Dr 1               
00002Dr 1                   ; Existing tail -> current PID.
00002Dr 1                   tay
00002Dr 1                   txa
00002Dr 1                   sta next_table,y
00002Dr 1                   stx wait_tail
00002Dr 1                   rts
00002Dr 1               
00002Dr 1               @empty:
00002Dr 1                   stx wait_head
00002Dr 1                   stx wait_tail
00002Dr 1                   rts
00002Dr 1               .endproc
00002Dr 1               
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               ; dequeue_proc
00002Dr 1               ;
00002Dr 1               ; Output:
00002Dr 1               ;   C clear = X contains dequeued PID
00002Dr 1               ;   C set   = FIFO empty
00002Dr 1               ;
00002Dr 1               ; IRQ policy:
00002Dr 1               ;   Caller has IRQs disabled.
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               
00002Dr 1               .proc dequeue_proc
00002Dr 1                   ldx wait_head
00002Dr 1                   cpx #GATE_OWNER_NONE
00002Dr 1                   bne @have_pid
00002Dr 1               
00002Dr 1                   sec
00002Dr 1                   rts
00002Dr 1               
00002Dr 1               @have_pid:
00002Dr 1                   lda next_table,x
00002Dr 1                   sta wait_head
00002Dr 1                   cmp #GATE_OWNER_NONE
00002Dr 1                   bne @clear_link
00002Dr 1               
00002Dr 1                   sta wait_tail
00002Dr 1               
00002Dr 1               @clear_link:
00002Dr 1                   lda #GATE_OWNER_NONE
00002Dr 1                   sta next_table,x
00002Dr 1               
00002Dr 1                   clc
00002Dr 1                   rts
00002Dr 1               .endproc
00002Dr 1               
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               ; acquire_proc
00002Dr 1               ;
00002Dr 1               ; Behavior:
00002Dr 1               ;   If the gate is free, acquire it and return.
00002Dr 1               ;   If another PID owns it, enqueue active_pid FIFO, block on
00002Dr 1               ;   WAIT_LOCK / lock_id, yield, and retry when woken.
00002Dr 1               ;   If active_pid already owns it, trap.
00002Dr 1               ;
00002Dr 1               ; Return:
00002Dr 1               ;   C set = acquired
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               
00002Dr 1               .proc acquire_proc
00002Dr 1               @retry:
00002Dr 1                   php
00002Dr 1                   sei
00002Dr 1               
00002Dr 1                   lda #$01
00002Dr 1                   tsb gate_byte
00002Dr 1                   beq @acquired
00002Dr 1               
00002Dr 1                   lda owner_byte
00002Dr 1                   cmp active_pid
00002Dr 1                   bne @wait_for_owner
00002Dr 1               
00002Dr 1                   ; Do not hard-hang the system here.  A recursive acquire is
00002Dr 1                   ; still a kernel bug, but the monitor must remain usable.
00002Dr 1                   ; Return C clear so checked callers can fail/diagnose instead
00002Dr 1                   ; of spinning forever.  The original owner keeps the gate.
00002Dr 1                   plp
00002Dr 1                   clc
00002Dr 1                   rts
00002Dr 1               
00002Dr 1               @wait_for_owner:
00002Dr 1                   ldx active_pid
00002Dr 1                   jsr enqueue_proc
00002Dr 1               
00002Dr 1                   lda #WAIT_LOCK
00002Dr 1                   ldy #lock_id
00002Dr 1                   jsr proc_set_wait
00002Dr 1               
00002Dr 1                   plp
00002Dr 1               
00002Dr 1                   jsr sched_yield
00002Dr 1                   bra @retry
00002Dr 1               
00002Dr 1               @acquired:
00002Dr 1                   ldx active_pid
00002Dr 1                   stx owner_byte
00002Dr 1               
00002Dr 1                   plp
00002Dr 1                   sec
00002Dr 1                   rts
00002Dr 1               .endproc
00002Dr 1               
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               ; release_proc
00002Dr 1               ;
00002Dr 1               ; Release the gate and wake exactly one FIFO waiter.
00002Dr 1               ;
00002Dr 1               ; Return:
00002Dr 1               ;   C set
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               
00002Dr 1               .proc release_proc
00002Dr 1                   php
00002Dr 1                   sei
00002Dr 1               
00002Dr 1                   lda owner_byte
00002Dr 1                   cmp active_pid
00002Dr 1                   beq @owner_ok
00002Dr 1               
00002Dr 1                   ; Do not hard-hang on bad release either.  Leave the gate state
00002Dr 1                   ; untouched and return C clear for checked callers/monitor output.
00002Dr 1                   plp
00002Dr 1                   clc
00002Dr 1                   rts
00002Dr 1               
00002Dr 1               @owner_ok:
00002Dr 1                   lda #GATE_OWNER_NONE
00002Dr 1                   sta owner_byte
00002Dr 1               
00002Dr 1                   lda #$01
00002Dr 1                   trb gate_byte
00002Dr 1               
00002Dr 1                   jsr dequeue_proc
00002Dr 1                   bcs @done
00002Dr 1               
00002Dr 1                   ; X = FIFO waiter PID.
00002Dr 1                   jsr proc_wake
00002Dr 1               
00002Dr 1               @done:
00002Dr 1                   plp
00002Dr 1               
00002Dr 1                   ; A pending default SIG_INT may have been deferred while this process
00002Dr 1                   ; owned the gate. Once its final gate is released, enter the scheduler
00002Dr 1                   ; before user code can begin another syscall.
00002Dr 1                   jsr gate_signal_checkpoint
00002Dr 1               
00002Dr 1                   sec
00002Dr 1                   rts
00002Dr 1               .endproc
00002Dr 1               
00002Dr 1               .endmacro
00002Dr 1               
00002Dr 1               
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               ; DEFINE_GATE_CANCEL_WAIT
00002Dr 1               ;
00002Dr 1               ; Remove PID X from a gate FIFO without changing gate ownership.
00002Dr 1               ; This is used when SIG_KILL converts a WAIT_LOCK process to ZOMBIE.
00002Dr 1               ; IRQs are masked while the singly-linked FIFO is changed.
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               
00002Dr 1               .macro DEFINE_GATE_CANCEL_WAIT cancel_proc, wait_head, wait_tail, next_table
00002Dr 1               
00002Dr 1               .proc cancel_proc
00002Dr 1                   php
00002Dr 1                   sei
00002Dr 1               
00002Dr 1                   cpx wait_head
00002Dr 1                   bne @scan
00002Dr 1               
00002Dr 1                   ; Removing the queue head.
00002Dr 1                   lda next_table,x
00002Dr 1                   sta wait_head
00002Dr 1                   cmp #GATE_OWNER_NONE
00002Dr 1                   bne @clear_link
00002Dr 1               
00002Dr 1                   ; Removed the only queue entry.
00002Dr 1                   sta wait_tail
00002Dr 1                   bra @clear_link
00002Dr 1               
00002Dr 1               @scan:
00002Dr 1                   ldy wait_head
00002Dr 1               
00002Dr 1               @scan_next:
00002Dr 1                   cpy #GATE_OWNER_NONE
00002Dr 1                   beq @done
00002Dr 1               
00002Dr 1                   txa
00002Dr 1                   cmp next_table,y
00002Dr 1                   beq @found
00002Dr 1               
00002Dr 1                   lda next_table,y
00002Dr 1                   tay
00002Dr 1                   bra @scan_next
00002Dr 1               
00002Dr 1               @found:
00002Dr 1                   ; Y = predecessor, X = entry being removed.
00002Dr 1                   lda next_table,x
00002Dr 1                   sta next_table,y
00002Dr 1               
00002Dr 1                   cpx wait_tail
00002Dr 1                   bne @clear_link
00002Dr 1               
00002Dr 1                   sty wait_tail
00002Dr 1               
00002Dr 1               @clear_link:
00002Dr 1                   lda #GATE_OWNER_NONE
00002Dr 1                   sta next_table,x
00002Dr 1               
00002Dr 1               @done:
00002Dr 1                   plp
00002Dr 1                   rts
00002Dr 1               .endproc
00002Dr 1               
00002Dr 1               .endmacro
00002Dr 1               
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               ; Concrete gate instances
00002Dr 1               ; ------------------------------------------------------------
00002Dr 1               
00002Dr 1  9C rr rr A9  DEFINE_SLEEPABLE_GATE file_io_gate_init, file_io_gate_acquire, file_io_gate_release, file_io_gate_enqueue_current, file_io_gate_dequeue_one, file_io_gate, file_io_gate_owner, file_io_gate_wait_head, file_io_gate_wait_tail, file_io_gate_next, LOCK_ID_FILE_IO
000031r 1  FF 8D rr rr  
000035r 1  8D rr rr 8D  
0000D2r 1  08 78 EC rr  DEFINE_GATE_CANCEL_WAIT file_io_gate_cancel_wait, file_io_gate_wait_head, file_io_gate_wait_tail, file_io_gate_next
0000D6r 1  rr D0 0F BD  
0000DAr 1  rr rr 8D rr  
000110r 1               
000110r 1  9C rr rr A9  DEFINE_SLEEPABLE_GATE proc_gate_init, proc_gate_acquire, proc_gate_release, proc_gate_enqueue_current, proc_gate_dequeue_one, proc_gate, proc_gate_owner, proc_gate_wait_head, proc_gate_wait_tail, proc_gate_next, LOCK_ID_PROC
000114r 1  FF 8D rr rr  
000118r 1  8D rr rr 8D  
0001B5r 1  08 78 EC rr  DEFINE_GATE_CANCEL_WAIT proc_gate_cancel_wait, proc_gate_wait_head, proc_gate_wait_tail, proc_gate_next
0001B9r 1  rr D0 0F BD  
0001BDr 1  rr rr 8D rr  
0001B5r 1               
