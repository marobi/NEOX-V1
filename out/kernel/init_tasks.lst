000000r 1               
000000r 1               .export tasks_init
000000r 1               
000000r 1               .import proc_create
000000r 1               
000000r 1               .import init_task_count
000000r 1               .import init_task_ptr
000000r 1               
000000r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               USER_MAGIC0      = USER_IMAGE_TABLE + 0
000000r 1               USER_MAGIC1      = USER_IMAGE_TABLE + 1
000000r 1               USER_VERSION     = USER_IMAGE_TABLE + 2
000000r 1               USER_TASK_COUNT  = USER_IMAGE_TABLE + 3
000000r 1               USER_TASK_TABLE  = USER_IMAGE_TABLE + 4
000000r 1               
000000r 1               USER_ENTRY_SIZE  = 4
000000r 1               
000000r 1               .proc tasks_init
000000r 1                   ; Validate magic.
000000r 1  AD 00 10         lda USER_MAGIC0
000003r 1  C9 4E            cmp #'N'
000005r 1  D0 6D            bne @bad_user_image
000007r 1               
000007r 1  AD 01 10         lda USER_MAGIC1
00000Ar 1  C9 58            cmp #'X'
00000Cr 1  D0 66            bne @bad_user_image
00000Er 1               
00000Er 1                   ; Validate version.
00000Er 1  AD 02 10         lda USER_VERSION
000011r 1  C9 01            cmp #$01
000013r 1  D0 5F            bne @bad_user_image
000015r 1               
000015r 1  AD 03 10         lda USER_TASK_COUNT
000018r 1  F0 58            beq @done
00001Ar 1               
00001Ar 1  8D rr rr         sta init_task_count
00001Dr 1               
00001Dr 1  A9 04            lda #<USER_TASK_TABLE
00001Fr 1  8D rr rr         sta init_task_ptr
000022r 1  A9 10            lda #>USER_TASK_TABLE
000024r 1  8D rr rr         sta init_task_ptr+1
000027r 1               
000027r 1               @loop:
000027r 1  AE rr rr         ldx init_task_ptr
00002Ar 1  AC rr rr         ldy init_task_ptr+1
00002Dr 1  20 rr rr         jsr proc_create
000030r 1  90 02            bcc @task_created
000032r 1               
000032r 1               @task_create_failed:
000032r 1  80 FE            bra @task_create_failed
000034r 1               
000034r 1               @task_created:
000034r 1  18               clc
000035r 1  AD rr rr         lda init_task_ptr
000038r 1  69 04            adc #USER_ENTRY_SIZE
00003Ar 1  8D rr rr         sta init_task_ptr
00003Dr 1               
00003Dr 1  AD rr rr         lda init_task_ptr+1
000040r 1  69 00            adc #0
000042r 1  8D rr rr         sta init_task_ptr+1
000045r 1               
000045r 1  CE rr rr         dec init_task_count
000048r 1  D0 DD            bne @loop
00004Ar 1               
00004Ar 1                   ; Only wire static inter-process test pipe when PID 1 and PID 2 exist.
00004Ar 1  AD 03 10         lda USER_TASK_COUNT
00004Dr 1  C9 02            cmp #2
00004Fr 1  90 21            bcc @done
000051r 1               
000051r 1                   ; --------------------------------------------------------
000051r 1                   ; Static ping-pong pipes.
000051r 1                   ;
000051r 1                   ; Pipe A:
000051r 1                   ;   PID 1 fd 3 = write
000051r 1                   ;   PID 2 fd 3 = read
000051r 1                   ;
000051r 1                   ; Pipe B:
000051r 1                   ;   PID 2 fd 4 = write
000051r 1                   ;   PID 1 fd 4 = read
000051r 1                   ; --------------------------------------------------------
000051r 1               
000051r 1  AD 03 10         lda USER_TASK_COUNT
000054r 1  C9 02            cmp #2
000056r 1  90 1A            bcc @done
000058r 1               
000058r 1                   ; Pipe A: Task 1 -> Task 2
000058r 1  A9 02            lda #2          ; reader PID
00005Ar 1  A2 01            ldx #1          ; writer PID
00005Cr 1  A0 03            ldy #3          ; fd number in both processes
00005Er 1  20 27 80         jsr KERN_ENTRY_PIPE_CREATE_BETWEEN_FD
000061r 1  90 02            bcc :+
000063r 1               
000063r 1               @pipe_a_setup_failed:
000063r 1  80 FE            bra @pipe_a_setup_failed
000065r 1               :
000065r 1               
000065r 1                   ; Pipe B: Task 2 -> Task 1
000065r 1  A9 01            lda #1          ; reader PID
000067r 1  A2 02            ldx #2          ; writer PID
000069r 1  A0 04            ldy #4          ; fd number in both processes
00006Br 1  20 27 80         jsr KERN_ENTRY_PIPE_CREATE_BETWEEN_FD
00006Er 1  90 02            bcc @done
000070r 1               
000070r 1               @pipe_b_setup_failed:
000070r 1  80 FE            bra @pipe_b_setup_failed
000072r 1               
000072r 1               @done:
000072r 1  18               clc
000073r 1  60               rts
000074r 1               
000074r 1               @bad_user_image:
000074r 1                   ; For now, trap hard. Later print a boot error.
000074r 1  80 FE            bra @bad_user_image
000076r 1               .endproc
000076r 1               
