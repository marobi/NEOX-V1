000000r 1               ; ============================================================
000000r 1               ; init_tasks.asm
000000r 1               ; NEOX - initial runnable task setup
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Creates initial user/test tasks.
000000r 1               ;
000000r 1               ; Model:
000000r 1               ;   - PID 0 is the idle process, initialized by scheduler/main.
000000r 1               ;   - Monitor is not a process.
000000r 1               ;   - Normal tasks are allocated from PID 1 upward.
000000r 1               ;   - User process code lives in USER_TEXT, not KERN_TEXT.
000000r 1               ;   - The task table supplies entry points, not MMU context ids.
000000r 1               ;   - proc_create allocates both PID and preloaded context.
000000r 1               ; ============================================================
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .include "config.inc"
000000r 2               ; ============================================================
000000r 2               ; config.inc
000000r 2               ; NEOX - kernel configuration
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __CONFIG_INC__
000000r 2               __CONFIG_INC__ = 1
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Limits
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               MAX_FDS     = 6          ; per-process descriptor count
000000r 2               OPEN_MAX    = 16         ; system-wide open object slots
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Maximum simultaneously active processes
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               MAX_PROCS   = 8
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Maximum simultaneously active timer waits
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               MAX_TIMER   = 8
000000r 2               
000000r 2               ;
000000r 2               ;
000000r 2               ;
000000r 2               
000000r 2               MAX_PIPES       = 8
000000r 2               PIPE_BUF_SIZE   = 64
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Filesystem path limits
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               NEOX_CWD_MAX  = 32        ; process-private current-directory path bytes
000000r 2               NEOX_PATH_MAX = 64        ; kernel path resolver buffer bytes
000000r 2               ; ============================================================
000000r 2               ;
000000r 2               ; ============================================================
000000r 2               
000000r 2               USER_IMAGE_TABLE = $1000
000000r 2               
000000r 2               ; Final 32/32 virtual-memory split.
000000r 2               USER_SPACE_LIMIT = $8000
000000r 2               KERNEL_SHARED_BASE = $B020
000000r 2               KERNEL_OVERFLOW_BASE = $C000
000000r 2               MICMON_BASE = $D000
000000r 2               IO_PAGE_BASE = $E000
000000r 2               BIOS_BASE = $F000
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Kernel
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               KERNEL_BASE = $8000
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Syscall table location
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               SYSCALL_BASE = $F100
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP2350 mailbox control registers (MMIO)
000000r 2               ;
000000r 2               ; Layout:
000000r 2               ;   Page E is shared I/O space
000000r 2               ;   OS-owned mailbox doorbell starts at $E010
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_DOORBELL  = $E010
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Shared RAM request/result block (ordinary shared RAM, not I/O)
000000r 2               ;
000000r 2               ; mailbox request block.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_REQ_BASE  = $B000
000000r 2               
000000r 2               .endif
000000r 2               
