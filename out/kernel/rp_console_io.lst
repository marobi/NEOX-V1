000000r 1               ; ============================================================
000000r 1               ; rp_console_io.asm
000000r 1               ; NEOX - RP2350 console mailbox command usage
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Implements synchronous console read/write requests through
000000r 1               ;   the shared RP2350 mailbox transport.
000000r 1               ; ============================================================
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .include "mailbox.inc"
000000r 2               ; ============================================================
000000r 2               ; mailbox.inc
000000r 2               ; NEOX - RP2350 mailbox / request block definitions
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Defines the shared ABI v2 request/result block layout used
000000r 2               ;   for communication between the 6502 kernel/syscall code and
000000r 2               ;   the RP2350 co-processor.
000000r 2               ;
000000r 2               ; Architecture:
000000r 2               ;   - Logical pages 0..7 are private per context
000000r 2               ;   - Logical pages 8..F are shared across all contexts; page E is I/O
000000r 2               ;   - MMIO control registers live in shared I/O page
000000r 2               ;
000000r 2               ; ABI v2:
000000r 2               ;   - RP_REQ_BASE is $B000 in ordinary shared RAM
000000r 2               ;   - Request block starts with RP_GROUP and RP_CMD
000000r 2               ;   - RP_DOORBELL is trigger-only; command identity is not
000000r 2               ;     encoded in the doorbell value anymore.
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __MAILBOX_INC__
000000r 2               __MAILBOX_INC__ = 1
000000r 2               
000000r 2               .include "config.inc"
000000r 3               ; ============================================================
000000r 3               ; config.inc
000000r 3               ; NEOX - kernel configuration
000000r 3               ;
000000r 3               ; Purpose:
000000r 3               ; ============================================================
000000r 3               
000000r 3               .ifndef __CONFIG_INC__
000000r 3               __CONFIG_INC__ = 1
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_FDS     = 6          ; per-process descriptor count
000000r 3               OPEN_MAX    = 16         ; system-wide open object slots
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active processes
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_PROCS   = 8
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active timer waits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_TIMER   = 8
000000r 3               
000000r 3               ;
000000r 3               ;
000000r 3               ;
000000r 3               
000000r 3               MAX_PIPES       = 8
000000r 3               PIPE_BUF_SIZE   = 64
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Filesystem path limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               NEOX_CWD_MAX  = 32        ; process-private current-directory path bytes
000000r 3               NEOX_PATH_MAX = 64        ; kernel path resolver buffer bytes
000000r 3               ; ============================================================
000000r 3               ;
000000r 3               ; ============================================================
000000r 3               
000000r 3               USER_IMAGE_TABLE = $1000
000000r 3               
000000r 3               ; Final 32/32 virtual-memory split.
000000r 3               USER_SPACE_LIMIT = $8000
000000r 3               KERNEL_SHARED_BASE = $B020
000000r 3               KERNEL_OVERFLOW_BASE = $C000
000000r 3               MICMON_BASE = $D000
000000r 3               IO_PAGE_BASE = $E000
000000r 3               BIOS_BASE = $F000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Kernel
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               KERNEL_BASE = $8000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Syscall table location
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               SYSCALL_BASE = $F100
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; RP2350 mailbox control registers (MMIO)
000000r 3               ;
000000r 3               ; Layout:
000000r 3               ;   Page E is shared I/O space
000000r 3               ;   OS-owned mailbox doorbell starts at $E010
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_DOORBELL  = $E010
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Shared RAM request/result block (ordinary shared RAM, not I/O)
000000r 3               ;
000000r 3               ; mailbox request block.
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_REQ_BASE  = $B000
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Request / result block layout, ABI v2
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_GROUP            = RP_REQ_BASE + 0
000000r 2               RP_CMD              = RP_REQ_BASE + 1
000000r 2               RP_STATUS           = RP_REQ_BASE + 2
000000r 2               RP_ERR              = RP_REQ_BASE + 3
000000r 2               
000000r 2               RP_FLAGS            = RP_REQ_BASE + 4
000000r 2               RP_STATE            = RP_REQ_BASE + 5
000000r 2               
000000r 2               RP_ARG0L            = RP_REQ_BASE + 6
000000r 2               RP_ARG0H            = RP_REQ_BASE + 7
000000r 2               RP_ARG1L            = RP_REQ_BASE + 8
000000r 2               RP_ARG1H            = RP_REQ_BASE + 9
000000r 2               RP_ARG2L            = RP_REQ_BASE + 10
000000r 2               RP_ARG2H            = RP_REQ_BASE + 11
000000r 2               
000000r 2               RP_RES0L            = RP_REQ_BASE + 12
000000r 2               RP_RES0H            = RP_REQ_BASE + 13
000000r 2               RP_RES1L            = RP_REQ_BASE + 14
000000r 2               RP_RES1H            = RP_REQ_BASE + 15
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Other shared RP state bytes
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IRQ_SOURCE       = RP_REQ_BASE + 16
000000r 2               RP_CONSOLE_PID      = RP_REQ_BASE + 17
000000r 2               RP_CONSOLE_RDY      = RP_REQ_BASE + 18
000000r 2               RP_IRQ_STATE        = RP_REQ_BASE + 19
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_STATUS values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IDLE             = $00
000000r 2               RP_BUSY             = $01
000000r 2               RP_DONE             = $02
000000r 2               RP_ERROR            = $03
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_GROUP values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_GROUP_NONE       = $00
000000r 2               RP_GROUP_CONSOLE    = $01
000000r 2               RP_GROUP_FS         = $02
000000r 2               RP_GROUP_SYSTEM     = $03
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_CMD values inside RP_GROUP_CONSOLE
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_CON_CMD_NONE     = $00
000000r 2               RP_CON_CMD_WRITE    = $01
000000r 2               RP_CON_CMD_READ     = $02
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_CMD values inside RP_GROUP_FS
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_FS_CMD_NONE      = $00
000000r 2               RP_FS_CMD_EXEC      = $11
000000r 2               
000000r 2               ; Generic filesystem operations carried in RP_STATE. Values $01-$10 retain
000000r 2               ; their established numeric assignments, but are no longer accepted as direct
000000r 2               ; RP_CMD values.
000000r 2               RP_FS_OP_STATUS        = $01
000000r 2               RP_FS_OP_OPEN          = $02
000000r 2               RP_FS_OP_READ          = $03
000000r 2               RP_FS_OP_CLOSE         = $04
000000r 2               RP_FS_OP_WRITE         = $05
000000r 2               RP_FS_OP_LOAD          = $06
000000r 2               RP_FS_OP_SAVE          = $07
000000r 2               RP_FS_OP_SEEK          = $08
000000r 2               RP_FS_OP_TELL          = $09
000000r 2               RP_FS_OP_DELETE        = $0A
000000r 2               RP_FS_OP_RENAME        = $0B
000000r 2               RP_FS_OP_OPENDIR       = $0C
000000r 2               RP_FS_OP_READDIR       = $0D
000000r 2               RP_FS_OP_CLOSEDIR      = $0E
000000r 2               RP_FS_OP_MKDIR         = $0F
000000r 2               RP_FS_OP_RMDIR         = $10
000000r 2               RP_FS_OP_CWD_INIT_ROOT = $12
000000r 2               RP_FS_OP_CWD_CLONE     = $13
000000r 2               RP_FS_OP_CHDIR         = $14
000000r 2               RP_FS_OP_GETCWD        = $15
000000r 2               
000000r 2               RP_FS_SEEK_SET      = $00
000000r 2               RP_FS_SEEK_CUR      = $01
000000r 2               RP_FS_SEEK_END      = $02
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_DOORBELL trigger value for ABI v2
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_DOORBELL_TRIGGER = $01
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_FLAGS values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_FLAG_NONE        = $00
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_IRQ_SOURCE values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IRQ_SRC_NONE     = $00
000000r 2               RP_IRQ_SRC_TIMER    = $01
000000r 2               RP_IRQ_SRC_MONITOR  = $02
000000r 2               RP_IRQ_SRC_FS_DONE  = $03
000000r 2               RP_IRQ_SRC_CONSOLE_BREAK = $04
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               
000000r 1               .export rp_console_read
000000r 1               .export rp_console_write
000000r 1               
000000r 1               .importzp io_ptr
000000r 1               
000000r 1               .import rp_acquire_lock
000000r 1               .import rp_release_lock
000000r 1               .import rp_wait_done
000000r 1               .import rp_mailbox_clear_request
000000r 1               .import rp_mailbox_trigger
000000r 1               .import rp_mailbox_mark_idle
000000r 1               
000000r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               ; <summary>
000000r 1               ; Fills the common ABI-v2 console request fields.
000000r 1               ; </summary>
000000r 1               ; <param name="A">Transfer length low byte.</param>
000000r 1               ; <param name="X">Transfer length high byte.</param>
000000r 1               ; <param name="Y">RP_CON_CMD_READ or RP_CON_CMD_WRITE.</param>
000000r 1               ; <returns>Nothing.</returns>
000000r 1               .proc rp_console_fill_request
000000r 1  48               pha
000001r 1  DA               phx
000002r 1  5A               phy
000003r 1               
000003r 1  20 rr rr         jsr rp_mailbox_clear_request
000006r 1               
000006r 1  A9 01            lda #RP_GROUP_CONSOLE
000008r 1  8D 00 B0         sta RP_GROUP
00000Br 1               
00000Br 1  7A               ply
00000Cr 1  8C 01 B0         sty RP_CMD
00000Fr 1  FA               plx
000010r 1  68               pla
000011r 1               
000011r 1  8D 08 B0         sta RP_ARG1L
000014r 1  8E 09 B0         stx RP_ARG1H
000017r 1               
000017r 1  A5 rr            lda io_ptr
000019r 1  8D 06 B0         sta RP_ARG0L
00001Cr 1  A5 rr            lda io_ptr+1
00001Er 1  8D 07 B0         sta RP_ARG0H
000021r 1  60               rts
000022r 1               .endproc
000022r 1               
000022r 1               ; <summary>
000022r 1               ; Submits one synchronous console mailbox transfer.
000022r 1               ; </summary>
000022r 1               ; <param name="io_ptr">Caller buffer pointer.</param>
000022r 1               ; <param name="A">Transfer length low byte.</param>
000022r 1               ; <param name="X">Transfer length high byte.</param>
000022r 1               ; <param name="Y">RP_CON_CMD_READ or RP_CON_CMD_WRITE.</param>
000022r 1               ; <returns>C clear with A/X = bytes transferred; C set with Y = errno.</returns>
000022r 1               .proc rp_console_transfer
000022r 1  48               pha
000023r 1  DA               phx
000024r 1  5A               phy
000025r 1               
000025r 1  20 rr rr         jsr rp_acquire_lock
000028r 1               
000028r 1  7A               ply
000029r 1  FA               plx
00002Ar 1  68               pla
00002Br 1               
00002Br 1  20 rr rr         jsr rp_console_fill_request
00002Er 1  20 rr rr         jsr rp_mailbox_trigger
000031r 1  20 rr rr         jsr rp_wait_done
000034r 1  B0 12            bcs @fail
000036r 1               
000036r 1  AD 0C B0         lda RP_RES0L
000039r 1  AE 0D B0         ldx RP_RES0H
00003Cr 1  48               pha
00003Dr 1  DA               phx
00003Er 1               
00003Er 1  20 rr rr         jsr rp_mailbox_mark_idle
000041r 1  20 rr rr         jsr rp_release_lock
000044r 1               
000044r 1  FA               plx
000045r 1  68               pla
000046r 1  18               clc
000047r 1  60               rts
000048r 1               
000048r 1               @fail:
000048r 1  5A               phy
000049r 1  20 rr rr         jsr rp_mailbox_mark_idle
00004Cr 1  20 rr rr         jsr rp_release_lock
00004Fr 1  7A               ply
000050r 1  38               sec
000051r 1  60               rts
000052r 1               .endproc
000052r 1               
000052r 1               ; <summary>
000052r 1               ; Reads console bytes synchronously through the RP2350 mailbox.
000052r 1               ; </summary>
000052r 1               ; <param name="io_ptr">Destination buffer pointer.</param>
000052r 1               ; <param name="A">Requested length low byte.</param>
000052r 1               ; <param name="X">Requested length high byte.</param>
000052r 1               ; <returns>C clear with A/X = bytes read; C set with Y = errno.</returns>
000052r 1               .proc rp_console_read
000052r 1  A0 02            ldy #RP_CON_CMD_READ
000054r 1  4C rr rr         jmp rp_console_transfer
000057r 1               .endproc
000057r 1               
000057r 1               ; <summary>
000057r 1               ; Writes console bytes synchronously through the RP2350 mailbox.
000057r 1               ; </summary>
000057r 1               ; <param name="io_ptr">Source buffer pointer.</param>
000057r 1               ; <param name="A">Requested length low byte.</param>
000057r 1               ; <param name="X">Requested length high byte.</param>
000057r 1               ; <returns>C clear with A/X = bytes written; C set with Y = errno.</returns>
000057r 1               .proc rp_console_write
000057r 1  A0 01            ldy #RP_CON_CMD_WRITE
000059r 1  4C rr rr         jmp rp_console_transfer
00005Cr 1               .endproc
00005Cr 1               
