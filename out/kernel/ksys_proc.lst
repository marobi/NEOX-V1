000000r 1               
000000r 1               .export ksys_exit
000000r 1               .export ksys_yield
000000r 1               .export ksys_sleep
000000r 1               .export ksys_signal
000000r 1               .export ksys_getprocinfo
000000r 1               .export ksys_waitpid
000000r 1               
000000r 1               .import idle_loop
000000r 1               .import proc_exit_current
000000r 1               .import sched_yield
000000r 1               .import sched_block_current
000000r 1               .import proc_set_wait
000000r 1               
000000r 1               .import timer_start_current
000000r 1               .import proc_send_signal
000000r 1               .import proc_reap_waited_child
000000r 1               .import proc_gate_acquire
000000r 1               .import proc_gate_release
000000r 1               .import active_pid
000000r 1               .import console_owner_pid
000000r 1               .import scheduler_wake_console_owner
000000r 1               .importzp io_ptr
000000r 1               .import proc_state
000000r 1               .import proc_parent_pid
000000r 1               .import proc_signal_pending
000000r 1               .import wait_reason
000000r 1               .import wait_object
000000r 1               .import file_io_gate_owner
000000r 1               .import proc_gate_owner
000000r 1               
000000r 1               
000000r 1               .segment "KERN_BSS"
000000r 1               
000000r 1               ; Protected by proc_gate while ksys_signal is executing.
000000r 1               ksys_signal_self_kill:
000000r 1  xx               .res 1
000001r 1               
000001r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; ksys_exit
000000r 1               ;
000000r 1               ; Input:
000000r 1               ;   A = exit code
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Terminate the current process.
000000r 1               ;
000000r 1               ; Current scheduler model:
000000r 1               ;   After marking this process dead, execution must not continue
000000r 1               ;   into user code. Transfer to the idle loop until the scheduler
000000r 1               ;   selects another runnable process.
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               .proc ksys_exit
000000r 1  20 rr rr         jsr proc_exit_current
000003r 1               
000003r 1  4C rr rr     	jmp idle_loop
000006r 1               .endproc
000006r 1               
000006r 1               ; ------------------------------------------------------------
000006r 1               ; ksys_yield
000006r 1               ;
000006r 1               ; Purpose:
000006r 1               ;   Voluntary yield syscall.
000006r 1               ;
000006r 1               ; Current model:
000006r 1               ;   Cooperative scheduling enters the same scheduler handoff path
000006r 1               ;   used by preemptive scheduling.
000006r 1               ; ------------------------------------------------------------
000006r 1               
000006r 1               .proc ksys_yield
000006r 1  4C rr rr         jmp sched_yield
000009r 1               .endproc
000009r 1               
000009r 1               ; ------------------------------------------------------------
000009r 1               ; ksys_sleep
000009r 1               ;
000009r 1               ; Input:
000009r 1               ;   A = relative sleep ticks
000009r 1               ;
000009r 1               ; Purpose:
000009r 1               ;   Block current process until timer expiration.
000009r 1               ;
000009r 1               ; Notes:
000009r 1               ;   timer_start_current reserves and arms a timer slot only.
000009r 1               ;   sched_block_current owns the actual process block transition.
000009r 1               ; ------------------------------------------------------------
000009r 1               
000009r 1               .proc ksys_sleep
000009r 1  C9 00            cmp #0
00000Br 1  F0 0E            beq @done
00000Dr 1               
00000Dr 1  20 rr rr         jsr timer_start_current
000010r 1  B0 05            bcs @fail
000012r 1               
000012r 1                   ; Y = armed timer slot.  The scheduler-owned block primitive
000012r 1                   ; saves the syscall continuation first, then commits WAIT_TIMER.
000012r 1  A9 04            lda #WAIT_TIMER
000014r 1  4C rr rr         jmp sched_block_current
000017r 1               
000017r 1               @fail:
000017r 1  A0 0C            ldy #EAGAIN
000019r 1  38               sec
00001Ar 1  60               rts
00001Br 1               
00001Br 1               @done:
00001Br 1  18               clc
00001Cr 1  60               rts
00001Dr 1               .endproc
00001Dr 1               
00001Dr 1               
00001Dr 1               ; ------------------------------------------------------------
00001Dr 1               ; ksys_signal
00001Dr 1               ;
00001Dr 1               ; Input:
00001Dr 1               ;   A = Linux-compatible signal number (SIG_INT, SIG_KILL, SIG_CONT, SIG_STOP)
00001Dr 1               ;   X = target PID
00001Dr 1               ;
00001Dr 1               ; Return:
00001Dr 1               ;   C clear = signal accepted
00001Dr 1               ;   C set   = failure
00001Dr 1               ;   Y       = errno
00001Dr 1               ;
00001Dr 1               ; Notes:
00001Dr 1               ;   proc_gate serializes the process-table write performed by
00001Dr 1               ;   proc_send_signal.  Arguments are preserved on the current
00001Dr 1               ;   process stack while proc_gate_acquire may block/yield.
00001Dr 1               ;
00001Dr 1               ;   This syscall queues STOP/CONT as pending signals.  SIG_KILL is
00001Dr 1               ;   converted immediately to PROC_ZOMBIE through proc_send_signal;
00001Dr 1               ;   final FD/process-slot cleanup is deferred to the idle reaper.
00001Dr 1               ; ------------------------------------------------------------
00001Dr 1               
00001Dr 1               .proc ksys_signal
00001Dr 1  C9 13            cmp #SIG_STOP
00001Fr 1  F0 10            beq @valid_signal
000021r 1               
000021r 1  C9 12            cmp #SIG_CONT
000023r 1  F0 0C            beq @valid_signal
000025r 1               
000025r 1  C9 09            cmp #SIG_KILL
000027r 1  F0 08            beq @valid_signal
000029r 1               
000029r 1  C9 02            cmp #SIG_INT
00002Br 1  F0 04            beq @valid_signal
00002Dr 1               
00002Dr 1  A0 06            ldy #EINVAL
00002Fr 1  38               sec
000030r 1  60               rts
000031r 1               
000031r 1               @valid_signal:
000031r 1                   ; Preserve syscall arguments across proc_gate_acquire.  The gate
000031r 1                   ; may block and yield; the current process stack is the safe place
000031r 1                   ; to keep these per-call values.
000031r 1  48               pha             ; signal
000032r 1  8A               txa
000033r 1  48               pha             ; target PID
000034r 1               
000034r 1  20 rr rr         jsr proc_gate_acquire
000037r 1  B0 06            bcs @gate_acquired
000039r 1               
000039r 1                   ; Recursive/bad gate acquisition.  Drop saved arguments.
000039r 1  68               pla
00003Ar 1  68               pla
00003Br 1  A0 0C            ldy #EAGAIN
00003Dr 1  38               sec
00003Er 1  60               rts
00003Fr 1               
00003Fr 1               @gate_acquired:
00003Fr 1  9C rr rr         stz ksys_signal_self_kill
000042r 1               
000042r 1  68               pla
000043r 1  AA               tax             ; target PID
000044r 1  68               pla             ; signal
000045r 1               
000045r 1                   ; If the caller sends SIG_KILL to itself, proc_send_signal marks
000045r 1                   ; the active process PROC_ZOMBIE.  After releasing proc_gate the
000045r 1                   ; syscall must not return to user code; it yields out instead.
000045r 1  C9 09            cmp #SIG_KILL
000047r 1  D0 0D            bne @send_signal
000049r 1               
000049r 1  48               pha
00004Ar 1  8A               txa
00004Br 1  CD rr rr         cmp active_pid
00004Er 1  D0 05            bne @not_self_kill
000050r 1               
000050r 1  A9 01            lda #$01
000052r 1  8D rr rr         sta ksys_signal_self_kill
000055r 1               
000055r 1               @not_self_kill:
000055r 1  68               pla
000056r 1               
000056r 1               @send_signal:
000056r 1  20 rr rr         jsr proc_send_signal
000059r 1  B0 13            bcs @invalid_target
00005Br 1               
00005Br 1  20 rr rr         jsr proc_gate_release
00005Er 1  B0 04            bcs @released
000060r 1               
000060r 1  A0 0C            ldy #EAGAIN
000062r 1  38               sec
000063r 1  60               rts
000064r 1               
000064r 1               @released:
000064r 1  AD rr rr         lda ksys_signal_self_kill
000067r 1  D0 02            bne @yield_zombie
000069r 1               
000069r 1  18               clc
00006Ar 1  60               rts
00006Br 1               
00006Br 1               @yield_zombie:
00006Br 1  4C rr rr         jmp sched_yield
00006Er 1               
00006Er 1               @invalid_target:
00006Er 1                   ; proc_send_signal returns the specific rejection reason in Y. Preserve
00006Er 1                   ; it across gate release so a protected gate owner reports EAGAIN rather
00006Er 1                   ; than being misreported as an invalid PID.
00006Er 1  5A               phy
00006Fr 1  20 rr rr         jsr proc_gate_release
000072r 1  7A               ply
000073r 1  38               sec
000074r 1  60               rts
000075r 1               .endproc
000075r 1               
000075r 1               
000075r 1               ; ------------------------------------------------------------
000075r 1               ; ksys_waitpid
000075r 1               ;
000075r 1               ; Input:
000075r 1               ;   A = child PID
000075r 1               ;
000075r 1               ; Return:
000075r 1               ;   C clear = child reaped
000075r 1               ;             A = child exit code
000075r 1               ;
000075r 1               ;   C set   = failure
000075r 1               ;             Y = errno
000075r 1               ;
000075r 1               ; Purpose:
000075r 1               ;   Wait for a specific child owned by the active parent.  If the
000075r 1               ;   child is not yet a zombie, block on WAIT_PROC / child_pid and
000075r 1               ;   retry after wake.
000075r 1               ;
000075r 1               ; Notes:
000075r 1               ;   The requested child PID is kept on the current process stack across
000075r 1               ;   proc_gate acquisition and sched_yield.  Do not use module-global
000075r 1               ;   scratch for this value because another process can enter WAITPID
000075r 1               ;   while this one is blocked.
000075r 1               ; ------------------------------------------------------------
000075r 1               .proc ksys_waitpid
000075r 1  48               pha                         ; persistent requested child PID
000076r 1               
000076r 1               @retry:
000076r 1  20 rr rr         jsr proc_gate_acquire
000079r 1  B0 05            bcs @gate_acquired
00007Br 1               
00007Br 1  68               pla                         ; discard child PID
00007Cr 1  A0 0C            ldy #EAGAIN
00007Er 1  38               sec
00007Fr 1  60               rts
000080r 1               
000080r 1               @gate_acquired:
000080r 1                   ; Reload requested child PID without removing the persistent copy.
000080r 1  68               pla
000081r 1  48               pha
000082r 1               
000082r 1  C9 08            cmp #MAX_PROCS
000084r 1  90 05            bcc @pid_range_ok
000086r 1               
000086r 1  A0 06            ldy #EINVAL
000088r 1  4C rr rr         jmp @fail_release
00008Br 1               
00008Br 1               @pid_range_ok:
00008Br 1  AA               tax
00008Cr 1  E0 00            cpx #IDLE_PID
00008Er 1  D0 05            bne @not_idle
000090r 1               
000090r 1  A0 06            ldy #EINVAL
000092r 1  4C rr rr         jmp @fail_release
000095r 1               
000095r 1               @not_idle:
000095r 1  BD rr rr         lda proc_parent_pid,x
000098r 1  CD rr rr         cmp active_pid
00009Br 1  F0 05            beq @owned_child
00009Dr 1               
00009Dr 1  A0 06            ldy #EINVAL
00009Fr 1  4C rr rr         jmp @fail_release
0000A2r 1               
0000A2r 1               @owned_child:
0000A2r 1  BD rr rr         lda proc_state,x
0000A5r 1  C9 06            cmp #PROC_ZOMBIE
0000A7r 1  F0 1E            beq @reap_child
0000A9r 1               
0000A9r 1  C9 00            cmp #PROC_EMPTY
0000ABr 1  F0 15            beq @invalid_state
0000ADr 1               
0000ADr 1                   ; Child is still alive.  Commit the wait state while proc_gate is
0000ADr 1                   ; held, then release the gate and yield immediately with IRQs
0000ADr 1                   ; masked so no child-exit wake can be lost in between.
0000ADr 1  78               sei
0000AEr 1               
0000AEr 1  68               pla
0000AFr 1  A8               tay                         ; wait_object = child PID
0000B0r 1  48               pha                         ; keep child PID for retry after wake
0000B1r 1               
0000B1r 1  AE rr rr         ldx active_pid
0000B4r 1  A9 05            lda #WAIT_PROC
0000B6r 1  20 rr rr         jsr proc_set_wait
0000B9r 1               
0000B9r 1  20 rr rr         jsr proc_gate_release
0000BCr 1               
0000BCr 1  20 rr rr         jsr sched_yield
0000BFr 1  4C rr rr         jmp @retry
0000C2r 1               
0000C2r 1               @invalid_state:
0000C2r 1  A0 06            ldy #EINVAL
0000C4r 1  4C rr rr         jmp @fail_release
0000C7r 1               
0000C7r 1               @reap_child:
0000C7r 1                   ; X = child PID.  Reap under proc_gate, then return the stored
0000C7r 1                   ; exit code to the parent.
0000C7r 1  20 rr rr         jsr proc_reap_waited_child
0000CAr 1  90 05            bcc @reaped
0000CCr 1               
0000CCr 1  A0 06            ldy #EINVAL
0000CEr 1  4C rr rr         jmp @fail_release
0000D1r 1               
0000D1r 1               @reaped:
0000D1r 1                   ; Preserve the exit code above the persistent child PID before touching A.
0000D1r 1  48               pha
0000D2r 1               
0000D2r 1                   ; X still identifies the reaped child. Restore foreground ownership only
0000D2r 1                   ; when this exact child owned the console. Background children therefore
0000D2r 1                   ; never affect console_owner_pid.
0000D2r 1  EC rr rr         cpx console_owner_pid
0000D5r 1  D0 09            bne :+
0000D7r 1  AD rr rr         lda active_pid
0000DAr 1  8D rr rr         sta console_owner_pid
0000DDr 1  20 rr rr         jsr scheduler_wake_console_owner
0000E0r 1               :
0000E0r 1  20 rr rr         jsr proc_gate_release
0000E3r 1  90 10            bcc @release_fail_after_reap
0000E5r 1               
0000E5r 1  68               pla                         ; A = exit code
0000E6r 1  AA               tax                         ; preserve in X while dropping child PID
0000E7r 1  68               pla                         ; discard persistent child PID
0000E8r 1  8A               txa                         ; A = exit code
0000E9r 1  18               clc
0000EAr 1  60               rts
0000EBr 1               
0000EBr 1               @fail_release:
0000EBr 1  98               tya                         ; save errno above persistent child PID
0000ECr 1  48               pha
0000EDr 1  20 rr rr         jsr proc_gate_release
0000F0r 1  68               pla
0000F1r 1  A8               tay
0000F2r 1  68               pla                         ; discard persistent child PID
0000F3r 1  38               sec
0000F4r 1  60               rts
0000F5r 1               
0000F5r 1               @release_fail_after_reap:
0000F5r 1  68               pla                         ; discard exit code
0000F6r 1  68               pla                         ; discard persistent child PID
0000F7r 1  A0 0C            ldy #EAGAIN
0000F9r 1  38               sec
0000FAr 1  60               rts
0000FBr 1               .endproc
0000FBr 1               
0000FBr 1               ; ------------------------------------------------------------
0000FBr 1               ; ksys_getprocinfo
0000FBr 1               ;
0000FBr 1               ; Input:
0000FBr 1               ;   X/Y = procinfo_args pointer
0000FBr 1               ;
0000FBr 1               ; Return:
0000FBr 1               ;   C clear = record copied
0000FBr 1               ;   C set   = failure
0000FBr 1               ;   Y       = errno
0000FBr 1               ;
0000FBr 1               ; Purpose:
0000FBr 1               ;   Copy one compact process-table snapshot record for user-space PS.
0000FBr 1               ;
0000FBr 1               ; Record layout:
0000FBr 1               ;   +0 pid
0000FBr 1               ;   +1 ppid
0000FBr 1               ;   +2 state
0000FBr 1               ;   +3 wait_reason
0000FBr 1               ;   +4 signal_pending
0000FBr 1               ;   +5 wait_object
0000FBr 1               ;   +6 held_gate_mask
0000FBr 1               ;
0000FBr 1               ; Notes:
0000FBr 1               ;   This is a small diagnostic syscall. It keeps IRQs disabled while
0000FBr 1               ;   reading process and gate state. Callers supplying the original
0000FBr 1               ;   five-byte buffer receive the original record; buffers of seven bytes
0000FBr 1               ;   or more receive the wait object and derived gate-hold mask as well.
0000FBr 1               ; ------------------------------------------------------------
0000FBr 1               .proc ksys_getprocinfo
0000FBr 1  08               php
0000FCr 1  78               sei
0000FDr 1               
0000FDr 1  86 rr            stx io_ptr
0000FFr 1  84 rr            sty io_ptr+1
000101r 1               
000101r 1  A0 00            ldy #procinfo_args::pid
000103r 1  B1 rr            lda (io_ptr),y
000105r 1  C9 08            cmp #MAX_PROCS
000107r 1  90 06            bcc @pid_ok
000109r 1  28               plp
00010Ar 1  58               cli
00010Br 1  A0 06            ldy #EINVAL
00010Dr 1  38               sec
00010Er 1  60               rts
00010Fr 1               
00010Fr 1               @pid_ok:
00010Fr 1  AA               tax
000110r 1               
000110r 1                   ; Preserve compatibility with the original five-byte record. A
000110r 1                   ; seven-byte or larger buffer receives the extended diagnostic fields.
000110r 1  A0 05            ldy #procinfo_args::buffer_size + 1
000112r 1  B1 rr            lda (io_ptr),y
000114r 1  D0 0F            bne @extended_size
000116r 1               
000116r 1  88               dey
000117r 1  B1 rr            lda (io_ptr),y
000119r 1  C9 05            cmp #PROCINFO_RECORD_MIN_SIZE
00011Br 1  90 0D            bcc @size_fail
00011Dr 1               
00011Dr 1  C9 07            cmp #PROCINFO_RECORD_SIZE
00011Fr 1  B0 04            bcs @extended_size
000121r 1               
000121r 1  A9 00            lda #$00
000123r 1  80 02            bra @save_size_mode
000125r 1               
000125r 1               @extended_size:
000125r 1  A9 01            lda #$01
000127r 1               
000127r 1               @save_size_mode:
000127r 1  48               pha                         ; 0 = legacy record, 1 = extended record
000128r 1  80 06            bra @size_ok
00012Ar 1               
00012Ar 1               @size_fail:
00012Ar 1  28               plp
00012Br 1  58               cli
00012Cr 1  A0 06            ldy #EINVAL
00012Er 1  38               sec
00012Fr 1  60               rts
000130r 1               
000130r 1               @size_ok:
000130r 1  A0 02            ldy #procinfo_args::buffer_ptr
000132r 1  B1 rr            lda (io_ptr),y
000134r 1  48               pha
000135r 1  C8               iny
000136r 1  B1 rr            lda (io_ptr),y
000138r 1  85 rr            sta io_ptr+1
00013Ar 1  68               pla
00013Br 1  85 rr            sta io_ptr
00013Dr 1               
00013Dr 1  A0 00            ldy #0
00013Fr 1  8A               txa
000140r 1  91 rr            sta (io_ptr),y
000142r 1  C8               iny
000143r 1               
000143r 1  BD rr rr         lda proc_parent_pid,x
000146r 1  91 rr            sta (io_ptr),y
000148r 1  C8               iny
000149r 1               
000149r 1  BD rr rr         lda proc_state,x
00014Cr 1  91 rr            sta (io_ptr),y
00014Er 1  C8               iny
00014Fr 1               
00014Fr 1  BD rr rr         lda wait_reason,x
000152r 1  91 rr            sta (io_ptr),y
000154r 1  C8               iny
000155r 1               
000155r 1  BD rr rr         lda proc_signal_pending,x
000158r 1  91 rr            sta (io_ptr),y
00015Ar 1               
00015Ar 1  68               pla                         ; extended-record flag
00015Br 1  F0 19            beq @record_done
00015Dr 1               
00015Dr 1  C8               iny
00015Er 1  BD rr rr         lda wait_object,x
000161r 1  91 rr            sta (io_ptr),y
000163r 1               
000163r 1  C8               iny
000164r 1  A9 00            lda #PROC_HOLD_NONE
000166r 1               
000166r 1  EC rr rr         cpx file_io_gate_owner
000169r 1  D0 02            bne @not_file_io_owner
00016Br 1  09 01            ora #PROC_HOLD_FILE_IO
00016Dr 1               
00016Dr 1               @not_file_io_owner:
00016Dr 1  EC rr rr         cpx proc_gate_owner
000170r 1  D0 02            bne @hold_mask_ready
000172r 1  09 02            ora #PROC_HOLD_PROC
000174r 1               
000174r 1               @hold_mask_ready:
000174r 1  91 rr            sta (io_ptr),y
000176r 1               
000176r 1               @record_done:
000176r 1  28               plp
000177r 1  58               cli
000178r 1  18               clc
000179r 1  60               rts
00017Ar 1               .endproc
00017Ar 1               
