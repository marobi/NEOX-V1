000000r 1               ; ============================================================
000000r 1               ; ksys_proc.asm
000000r 1               ; NEOX - kernel-owned process lifecycle syscall services
000000r 1               ;
000000r 1               ; The syscall page only jumps here. Process lifecycle state is
000000r 1               ; owned by the kernel, not by the syscall veneer.
000000r 1               ; ============================================================
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .include "process.inc"
000000r 2               .ifndef __PROCESS_INC__
000000r 2               __PROCESS_INC__ = 1
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Process states
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               PROC_EMPTY      = $00
000000r 2               PROC_NEW        = $01
000000r 2               PROC_READY      = $02
000000r 2               PROC_RUNNING    = $03
000000r 2               PROC_BLOCKED    = $04
000000r 2               PROC_STOPPED    = $05
000000r 2               PROC_ZOMBIE     = $06
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Flags byte bit definitions
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               PROC_FLAG_NONE              = $00
000000r 2               PROC_FLAG_IDLE              = $01
000000r 2               PROC_FLAG_ATTACHED_CON      = $02
000000r 2               PROC_FLAG_FOREGROUND        = $04
000000r 2               PROC_FLAG_SIGINT_INTERRUPT  = $08
000000r 2               
000000r 2               ; Flags that may be supplied as initial process characteristics by a
000000r 2               ; boot-task record or resident spawn request. PROC_FLAG_IDLE remains
000000r 2               ; kernel-owned and cannot be requested through these creation interfaces.
000000r 2               PROC_FLAGS_CREATE_MASK = PROC_FLAG_ATTACHED_CON | PROC_FLAG_FOREGROUND | PROC_FLAG_SIGINT_INTERRUPT
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Process frame format
000000r 2               ;
000000r 2               ; All saved runnable process stacks use the IRQ-compatible
000000r 2               ; extended RTI frame:
000000r 2               ;     Y, X, A, P, PCL, PCH
000000r 2               ; The scheduler has no per-process resume mode; normal task
000000r 2               ; resume is always RTI.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Process wait reasons
000000r 2               ;
000000r 2               ; WAIT_NONE means the process is not blocked on a known wait object.
000000r 2               ; Other values describe why a PROC_BLOCKED process is blocked.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               WAIT_NONE       = $00
000000r 2               WAIT_CONSOLE    = $01
000000r 2               WAIT_DEVICE     = $02
000000r 2               WAIT_PIPE_READ  = $03        ; pipe read wait on empty pipe
000000r 2               WAIT_PIPE       = WAIT_PIPE_READ ; compatibility alias
000000r 2               WAIT_TIMER      = $04
000000r 2               WAIT_PROC       = $05
000000r 2               
000000r 2               ; Generic sleepable gate wait.
000000r 2               ;
000000r 2               ; wait_object identifies the gate object:
000000r 2               ;   LOCK_ID_FILE_IO = FD/open-object/pipe/console syscall gate
000000r 2               ;   LOCK_ID_PROC    = future process-management syscall gate
000000r 2               WAIT_LOCK       = $06
000000r 2               
000000r 2               ; Pipe write wait on a full pipe. Kept separate from WAIT_PIPE_READ so
000000r 2               ; readers and writers can be woken by the correct readiness event.
000000r 2               WAIT_PIPE_WRITE = $07
000000r 2               
000000r 2               ; Blocked while retaining FILE_IO ownership until the RP2350 completes
000000r 2               ; the single active generic filesystem request. wait_object contains the
000000r 2               ; filesystem operation code.
000000r 2               WAIT_RP         = $08
000000r 2               
000000r 2               LOCK_ID_FILE_IO = $00
000000r 2               LOCK_ID_PROC    = $01
000000r 2               
000000r 2               ; Diagnostic gate-hold mask returned by SYS_GETPROCINFO.
000000r 2               PROC_HOLD_NONE     = $00
000000r 2               PROC_HOLD_FILE_IO  = $01
000000r 2               PROC_HOLD_PROC     = $02
000000r 2               
000000r 2               ; Sentinel used for free gate owners and empty gate wait queues.
000000r 2               GATE_OWNER_NONE = $FF
000000r 2               
000000r 2               EXIT_OK         = $00
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               .include "syscall.inc"
000000r 2               ; ============================================================
000000r 2               ; syscall.inc
000000r 2               ; NEOX - syscall definitions
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Defines syscall numbers, fixed syscall entry addresses,
000000r 2               ;   error codes, and common syscall argument structures.
000000r 2               ;
000000r 2               ; Architecture:
000000r 2               ;   - Syscall jump table is located in the shared BIOS page at $F100
000000r 2               ;   - Each syscall entry is a 3-byte JMP stub
000000r 2               ;   - User code calls fixed syscall entry addresses
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ;   SYS_MONITOR enters supervisor/MICMON context through the
000000r 2               ;   kernel-defined monitor entry path. It is a controlled
000000r 2               ;   privileged transfer, not direct user control of MMU/scheduler.
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __SYSCALL_INC__
000000r 2               __SYSCALL_INC__ = 1
000000r 2               
000000r 2               .include "config.inc"
000000r 3               ; ============================================================
000000r 3               ; config.inc
000000r 3               ; NEOX - kernel configuration
000000r 3               ;
000000r 3               ; Purpose:
000000r 3               ; ============================================================
000000r 3               
000000r 3               .ifndef __CONFIG_INC__
000000r 3               __CONFIG_INC__ = 1
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_FDS     = 6          ; per-process descriptor count
000000r 3               OPEN_MAX    = 16         ; system-wide open object slots
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active processes
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_PROCS   = 8
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active timer waits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_TIMER   = 8
000000r 3               
000000r 3               ;
000000r 3               ;
000000r 3               ;
000000r 3               
000000r 3               MAX_PIPES       = 8
000000r 3               PIPE_BUF_SIZE   = 64
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Filesystem path limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               NEOX_CWD_MAX  = 32        ; process-private current-directory path bytes
000000r 3               NEOX_PATH_MAX = 64        ; kernel path resolver buffer bytes
000000r 3               ; ============================================================
000000r 3               ;
000000r 3               ; ============================================================
000000r 3               
000000r 3               USER_IMAGE_TABLE = $1000
000000r 3               
000000r 3               ; Final 32/32 virtual-memory split.
000000r 3               USER_SPACE_LIMIT = $8000
000000r 3               KERNEL_SHARED_BASE = $B020
000000r 3               KERNEL_OVERFLOW_BASE = $C000
000000r 3               MICMON_BASE = $D000
000000r 3               IO_PAGE_BASE = $E000
000000r 3               BIOS_BASE = $F000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Kernel
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               KERNEL_BASE = $8000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Syscall table location
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               SYSCALL_BASE = $F100
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; RP2350 mailbox control registers (MMIO)
000000r 3               ;
000000r 3               ; Layout:
000000r 3               ;   Page E is shared I/O space
000000r 3               ;   OS-owned mailbox doorbell starts at $E010
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_DOORBELL  = $E010
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Shared RAM request/result block (ordinary shared RAM, not I/O)
000000r 3               ;
000000r 3               ; mailbox request block.
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_REQ_BASE  = $B000
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               SYSCALL_ENTRY_SIZE  = 3
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Standard file descriptors
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               STDIN               = 0
000000r 2               STDOUT              = 1
000000r 2               STDERR              = 2
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Syscall numbers
000000r 2               ; ------------------------------------------------------------
000000r 2               SYS_EXIT			= $00
000000r 2               SYS_OPEN            = $01
000000r 2               SYS_CLOSE			= $02
000000r 2               SYS_READ            = $03
000000r 2               SYS_WRITE           = $04
000000r 2               SYS_MONITOR         = $05
000000r 2               SYS_LOAD_FILE_TO_MEMORY = $06
000000r 2               SYS_SAVE_MEMORY_TO_FILE = $07
000000r 2               SYS_SEEK            = $08
000000r 2               SYS_TELL            = $09
000000r 2               SYS_PIPE			= $0A
000000r 2               SYS_DELETE          = $0C
000000r 2               SYS_RENAME          = $0D
000000r 2               SYS_YIELD           = $0B
000000r 2               SYS_SLEEP           = $0E
000000r 2               SYS_DUP				= $0F
000000r 2               SYS_DUP2			= $10
000000r 2               SYS_TICKS           = $11
000000r 2               SYS_SIGNAL          = $12
000000r 2               SYS_OPENDIR         = $13
000000r 2               SYS_READDIR         = $14
000000r 2               SYS_CLOSEDIR        = $15
000000r 2               SYS_CHDIR           = $16
000000r 2               SYS_GETCWD          = $17
000000r 2               SYS_MKDIR           = $18
000000r 2               SYS_RMDIR           = $19
000000r 2               SYS_GETPROCINFO      = $1A
000000r 2               SYS_WAITPID           = $1B
000000r 2               SYS_GET_LAUNCH_ID     = $1C
000000r 2               SYS_GET_LAUNCH_LINE   = $1D
000000r 2               SYS_SPAWN_RESIDENT    = $1E
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Fixed syscall entry addresses
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               sys_exit            = SYSCALL_BASE + (SYS_EXIT    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_open            = SYSCALL_BASE + (SYS_OPEN    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_close           = SYSCALL_BASE + (SYS_CLOSE   * SYSCALL_ENTRY_SIZE)
000000r 2               sys_read            = SYSCALL_BASE + (SYS_READ    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_write           = SYSCALL_BASE + (SYS_WRITE   * SYSCALL_ENTRY_SIZE)
000000r 2               sys_monitor         = SYSCALL_BASE + (SYS_MONITOR * SYSCALL_ENTRY_SIZE)
000000r 2               sys_load_file_to_memory = SYSCALL_BASE + (SYS_LOAD_FILE_TO_MEMORY * SYSCALL_ENTRY_SIZE)
000000r 2               sys_save_memory_to_file = SYSCALL_BASE + (SYS_SAVE_MEMORY_TO_FILE * SYSCALL_ENTRY_SIZE)
000000r 2               sys_seek            = SYSCALL_BASE + (SYS_SEEK    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_tell            = SYSCALL_BASE + (SYS_TELL    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_delete          = SYSCALL_BASE + (SYS_DELETE  * SYSCALL_ENTRY_SIZE)
000000r 2               sys_rename          = SYSCALL_BASE + (SYS_RENAME  * SYSCALL_ENTRY_SIZE)
000000r 2               sys_pipe            = SYSCALL_BASE + (SYS_PIPE    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_yield           = SYSCALL_BASE + (SYS_YIELD   * SYSCALL_ENTRY_SIZE)
000000r 2               sys_sleep           = SYSCALL_BASE + (SYS_SLEEP   * SYSCALL_ENTRY_SIZE)
000000r 2               sys_dup				= SYSCALL_BASE + (SYS_DUP     * SYSCALL_ENTRY_SIZE)
000000r 2               sys_dup2			= SYSCALL_BASE + (SYS_DUP2    * SYSCALL_ENTRY_SIZE)
000000r 2               sys_ticks           = SYSCALL_BASE + (SYS_TICKS   * SYSCALL_ENTRY_SIZE)
000000r 2               sys_signal          = SYSCALL_BASE + (SYS_SIGNAL  * SYSCALL_ENTRY_SIZE)
000000r 2               sys_opendir         = SYSCALL_BASE + (SYS_OPENDIR * SYSCALL_ENTRY_SIZE)
000000r 2               sys_readdir         = SYSCALL_BASE + (SYS_READDIR * SYSCALL_ENTRY_SIZE)
000000r 2               sys_closedir        = SYSCALL_BASE + (SYS_CLOSEDIR * SYSCALL_ENTRY_SIZE)
000000r 2               sys_chdir           = SYSCALL_BASE + (SYS_CHDIR * SYSCALL_ENTRY_SIZE)
000000r 2               sys_getcwd          = SYSCALL_BASE + (SYS_GETCWD * SYSCALL_ENTRY_SIZE)
000000r 2               sys_mkdir           = SYSCALL_BASE + (SYS_MKDIR * SYSCALL_ENTRY_SIZE)
000000r 2               sys_rmdir           = SYSCALL_BASE + (SYS_RMDIR * SYSCALL_ENTRY_SIZE)
000000r 2               sys_getprocinfo      = SYSCALL_BASE + (SYS_GETPROCINFO * SYSCALL_ENTRY_SIZE)
000000r 2               sys_waitpid          = SYSCALL_BASE + (SYS_WAITPID * SYSCALL_ENTRY_SIZE)
000000r 2               sys_get_launch_id    = SYSCALL_BASE + (SYS_GET_LAUNCH_ID * SYSCALL_ENTRY_SIZE)
000000r 2               sys_get_launch_line  = SYSCALL_BASE + (SYS_GET_LAUNCH_LINE * SYSCALL_ENTRY_SIZE)
000000r 2               sys_spawn_resident   = SYSCALL_BASE + (SYS_SPAWN_RESIDENT * SYSCALL_ENTRY_SIZE)
