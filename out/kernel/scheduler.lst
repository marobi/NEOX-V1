000000r 1               ;---------------------------------------------
000000r 1               
000000r 1               .import idle_loop
000000r 1               
000000r 1               
000000r 1               .import active_pid
000000r 1               .import sched_cursor_pid
000000r 1               .import proc_state
000000r 1               .import proc_context
000000r 1               .import proc_sp
000000r 1               .import proc_entryL
000000r 1               .import proc_entryH
000000r 1               .import proc_flags
000000r 1               .import proc_parent_pid
000000r 1               .import proc_signal_pending
000000r 1               
000000r 1               .import console_owner_pid
000000r 1               .import console_focus_pid
000000r 1               
000000r 1               .import active_context
000000r 1               
000000r 1               .importzp sched_ptr
000000r 1               
000000r 1               .import wait_reason
000000r 1               .import wait_object
000000r 1               
000000r 1               .import proc_apply_scheduler_signal
000000r 1               .import proc_terminate
000000r 1               .import proc_exit_lifecycle
000000r 1               .import proc_gate_acquire
000000r 1               .import proc_gate_release
000000r 1               
000000r 1               .import proc_exit_code
000000r 1               
000000r 1               .import timer_init
000000r 1               .import timer_commit_current
000000r 1               .import timer_free
000000r 1               .import scheduler_wake_timers
000000r 1               
000000r 1               .import system_ticks_lo
000000r 1               .import system_ticks_hi
000000r 1               
000000r 1               .import proc_ticks_lo
000000r 1               .import proc_ticks_hi
000000r 1               
000000r 1               .import monitor_active
000000r 1               
000000r 1               .import irq_restore
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               .segment "KERN_BSS"
000000r 1               
000000r 1               sched_wake_reason_tmp:
000000r 1  xx               .res 1
000001r 1               
000001r 1               sched_wake_object_tmp:
000001r 1  xx               .res 1
000002r 1               
000002r 1               ; Scheduler-local scratch used only while sched_lock is held.
000002r 1               ; It is not shared/RP-visible because it is an internal commit helper.
000002r 1               sched_selected_tmp:
000002r 1  xx               .res 1
000003r 1               
000003r 1               ; Scheduler-local bounded-scan counter.  This replaces the old misuse
000003r 1               ; of the zero-page sched_ptr pointer as a one-byte loop counter.
000003r 1               sched_scan_count:
000003r 1  xx               .res 1
000004r 1               
000004r 1               ; Scheduler-local signal scan cursor.  Signal application is kept out
000004r 1               ; of sched_pick_next so the picker remains a pure runnable selector.
000004r 1               sched_signal_pid:
000004r 1  xx               .res 1
000005r 1               
000005r 1               ; Handoff scratch used to publish active_pid/active_context only
000005r 1               ; after IRQs are masked and immediately before BIOS context transfer.
000005r 1               sched_handoff_pid:
000005r 1  xx               .res 1
000006r 1               
000006r 1               sched_handoff_context:
000006r 1  xx               .res 1
000007r 1               
000007r 1               sched_handoff_sp:
000007r 1  xx               .res 1
000008r 1               
000008r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; scheduler_tick
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Increment global 16-bit scheduler tick counter.
000000r 1               ;
000000r 1               ; Called from:
000000r 1               ;   timer IRQ path, once per scheduler tick.
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               .proc scheduler_tick
000000r 1  EE rr rr         inc system_ticks_lo
000003r 1  D0 03            bne @done
000005r 1               
000005r 1  EE rr rr         inc system_ticks_hi
000008r 1               
000008r 1               @done:
000008r 1  60               rts
000009r 1               .endproc
000009r 1               
000009r 1               ; ------------------------------------------------------------
000009r 1               ; scheduler_irq_tick
000009r 1               ;
000009r 1               ; Purpose:
000009r 1               ;   Account one hardware timer IRQ.
000009r 1               ;
000009r 1               ; Policy:
000009r 1               ;   This must run for every timer IRQ, even when the kernel is
000009r 1               ;   not at a safe preemption point.
000009r 1               ;
000009r 1               ; Notes:
000009r 1               ;   This only accounts time. It does not select or switch tasks.
000009r 1               ; ------------------------------------------------------------
000009r 1               
000009r 1               .proc scheduler_irq_tick
000009r 1  20 rr rr         jsr sched_account_tick
00000Cr 1  4C rr rr         jmp scheduler_tick
00000Fr 1               .endproc
00000Fr 1               
00000Fr 1               ; ------------------------------------------------------------
00000Fr 1               ; proc_set_state
00000Fr 1               ;
00000Fr 1               ; Input:
00000Fr 1               ;   X = PID
00000Fr 1               ;   A = new state
00000Fr 1               ;
00000Fr 1               ; Purpose:
00000Fr 1               ;   Set proc_state[X].
00000Fr 1               ; ------------------------------------------------------------
00000Fr 1               
00000Fr 1               .proc proc_set_state
00000Fr 1  9D rr rr         sta proc_state,x
000012r 1  60               rts
000013r 1               .endproc
000013r 1               
000013r 1               ; ------------------------------------------------------------
000013r 1               ; proc_set_ready
000013r 1               ;
000013r 1               ; Input:
000013r 1               ;   X = pid
000013r 1               ; ------------------------------------------------------------
000013r 1               
000013r 1               .proc proc_set_ready
000013r 1  A9 02            lda #PROC_READY
000015r 1  4C rr rr         jmp proc_set_state
000018r 1               .endproc
000018r 1               
000018r 1               ; ------------------------------------------------------------
000018r 1               ; proc_set_running
000018r 1               ;
000018r 1               ; Input:
000018r 1               ;   X = selected PID
000018r 1               ;
000018r 1               ; Purpose:
000018r 1               ;   Commit X as the current running process.
000018r 1               ;
000018r 1               ; Policy:
000018r 1               ;   PROC_RUNNING is exclusive. On a single CPU, only active_pid
000018r 1               ;   may be RUNNING.
000018r 1               ;
000018r 1               ;   This routine owns the transition:
000018r 1               ;
000018r 1               ;       old active_pid -> READY, if it was RUNNING
000018r 1               ;       selected X      -> RUNNING
000018r 1               ;       sched_cursor_pid -> X
000018r 1               ;
000018r 1               ; Important:
000018r 1               ;   Call this before loading the selected process stack/context.
000018r 1               ; ------------------------------------------------------------
000018r 1               
000018r 1               .proc proc_set_running
000018r 1                   ; Enforce the single-RUNNING invariant directly.  Earlier code
000018r 1                   ; only demoted active_pid.  Once a stale RUNNING process exists,
000018r 1                   ; that leaves two RUNNING tasks visible and corrupts later picks.
000018r 1                   ; This routine is called only with sched_lock held.
000018r 1  8E rr rr         stx sched_selected_tmp
00001Br 1               
00001Br 1  A2 00            ldx #IDLE_PID
00001Dr 1               
00001Dr 1               @scan_running:
00001Dr 1  EC rr rr         cpx sched_selected_tmp
000020r 1  F0 0C            beq @next_pid
000022r 1               
000022r 1  BD rr rr         lda proc_state,x
000025r 1  C9 03            cmp #PROC_RUNNING
000027r 1  D0 05            bne @next_pid
000029r 1               
000029r 1  A9 02            lda #PROC_READY
00002Br 1  20 rr rr         jsr proc_set_state
00002Er 1               
00002Er 1               @next_pid:
00002Er 1  E8               inx
00002Fr 1  E0 08            cpx #MAX_PROCS
000031r 1  D0 EA            bne @scan_running
000033r 1               
000033r 1  AE rr rr         ldx sched_selected_tmp
000036r 1  A9 03            lda #PROC_RUNNING
000038r 1  20 rr rr         jsr proc_set_state
00003Br 1               
00003Br 1  8E rr rr         stx sched_cursor_pid
00003Er 1  60               rts
00003Fr 1               .endproc
00003Fr 1               
00003Fr 1               ; ------------------------------------------------------------
00003Fr 1               ; proc_wake
00003Fr 1               ;
00003Fr 1               ; Input:
00003Fr 1               ;   X = pid
00003Fr 1               ;
00003Fr 1               ; Purpose:
00003Fr 1               ;   Wake a blocked process:
00003Fr 1               ;     - clear its wait reason/object
00003Fr 1               ;     - mark it READY
00003Fr 1               ;
00003Fr 1               ; Notes:
00003Fr 1               ;   The caller decides that the wait condition is satisfied.
00003Fr 1               ; ------------------------------------------------------------
00003Fr 1               
00003Fr 1               .proc proc_wake
00003Fr 1                   ; Stale wait queues may still contain a process that was killed
00003Fr 1                   ; and marked PROC_ZOMBIE.  Never revive non-blocked/zombie tasks
00003Fr 1                   ; from an old wake path.
00003Fr 1  BD rr rr         lda proc_state,x
000042r 1  C9 04            cmp #PROC_BLOCKED
000044r 1  D0 06            bne @done
000046r 1               
000046r 1  20 rr rr         jsr proc_clear_wait
000049r 1  4C rr rr         jmp proc_set_ready
00004Cr 1               
00004Cr 1               @done:
00004Cr 1  60               rts
00004Dr 1               .endproc
00004Dr 1               
00004Dr 1               ; ------------------------------------------------------------
00004Dr 1               ; scheduler_wake_one
00004Dr 1               ;
00004Dr 1               ; Input:
00004Dr 1               ;   A = wait reason
00004Dr 1               ;   Y = wait object
00004Dr 1               ;
00004Dr 1               ; Output:
00004Dr 1               ;   C clear = one matching process was woken
00004Dr 1               ;   C set   = no matching waiter found
00004Dr 1               ;
00004Dr 1               ; Purpose:
00004Dr 1               ;   Wake one blocked process waiting on a specific
00004Dr 1               ;   wait_reason / wait_object pair.
00004Dr 1               ;
00004Dr 1               ; Policy:
00004Dr 1               ;   Scans normal task PIDs in round-robin order, starting after
00004Dr 1               ;   sched_cursor_pid. This avoids always waking the lowest PID first.
00004Dr 1               ;
00004Dr 1               ; Example:
00004Dr 1               ;   lda #WAIT_LOCK
00004Dr 1               ;   ldy #LOCK_ID_FILE_IO
00004Dr 1               ;   jsr scheduler_wake_one
00004Dr 1               ;
00004Dr 1               ; Notes:
00004Dr 1               ;   This helper does not disable IRQs by itself.
00004Dr 1               ;   Callers that need release+wake atomicity must already protect
00004Dr 1               ;   the surrounding sequence, for example:
00004Dr 1               ;
00004Dr 1               ;       php
00004Dr 1               ;       sei
00004Dr 1               ;       release resource
00004Dr 1               ;       jsr scheduler_wake_one
00004Dr 1               ;       plp
00004Dr 1               ; ------------------------------------------------------------
00004Dr 1               
00004Dr 1               .proc scheduler_wake_one
00004Dr 1  8D rr rr         sta sched_wake_reason_tmp
000050r 1  8C rr rr         sty sched_wake_object_tmp
000053r 1               
000053r 1                   ; Start scan after sched_cursor_pid for round-robin fairness.
000053r 1  AE rr rr         ldx sched_cursor_pid
000056r 1               
000056r 1  E0 01            cpx #FIRST_TASK_PID
000058r 1  90 05            bcc @start_first
00005Ar 1               
00005Ar 1  E8               inx
00005Br 1  E0 08            cpx #MAX_PROCS
00005Dr 1  D0 02            bne @set_count
00005Fr 1               
00005Fr 1               @start_first:
00005Fr 1  A2 01            ldx #FIRST_TASK_PID
000061r 1               
000061r 1               @set_count:
000061r 1  A9 07            lda #(MAX_PROCS - FIRST_TASK_PID)
000063r 1  8D rr rr         sta sched_scan_count
000066r 1               
000066r 1               @check:
000066r 1  BD rr rr         lda proc_state,x
000069r 1  C9 04            cmp #PROC_BLOCKED
00006Br 1  D0 15            bne @next
00006Dr 1               
00006Dr 1  BD rr rr         lda wait_reason,x
000070r 1  CD rr rr         cmp sched_wake_reason_tmp
000073r 1  D0 0D            bne @next
000075r 1               
000075r 1  BD rr rr         lda wait_object,x
000078r 1  CD rr rr         cmp sched_wake_object_tmp
00007Br 1  D0 05            bne @next
00007Dr 1               
00007Dr 1  20 rr rr         jsr proc_wake
000080r 1  18               clc
000081r 1  60               rts
000082r 1               
000082r 1               @next:
000082r 1  CE rr rr         dec sched_scan_count
000085r 1  F0 09            beq @none
000087r 1               
000087r 1  E8               inx
000088r 1  E0 08            cpx #MAX_PROCS
00008Ar 1  D0 DA            bne @check
00008Cr 1               
00008Cr 1  A2 01            ldx #FIRST_TASK_PID
00008Er 1  80 D6            bra @check
000090r 1               
000090r 1               @none:
000090r 1  38               sec
000091r 1  60               rts
000092r 1               .endproc
000092r 1               
000092r 1               ; ------------------------------------------------------------
000092r 1               ; proc_set_wait
000092r 1               ;
000092r 1               ; Mark process X blocked on wait reason A / object Y.
000092r 1               ;
000092r 1               ; PID 0 is the idle task and must never enter a wait state.
000092r 1               ; If idle blocks, the scheduler has no guaranteed fallback task.
000092r 1               ; ------------------------------------------------------------
000092r 1               .proc proc_set_wait
000092r 1  E0 00            cpx #IDLE_PID
000094r 1  F0 0C            beq @done
000096r 1               
000096r 1  9D rr rr         sta wait_reason,x
000099r 1  98               tya
00009Ar 1  9D rr rr         sta wait_object,x
00009Dr 1               
00009Dr 1  A9 04            lda #PROC_BLOCKED
00009Fr 1  20 rr rr         jsr proc_set_state
0000A2r 1               
0000A2r 1               @done:
0000A2r 1  60               rts
0000A3r 1               .endproc
0000A3r 1               
0000A3r 1               ; ------------------------------------------------------------
0000A3r 1               ; proc_clear_wait
0000A3r 1               ;
0000A3r 1               ; Input:
0000A3r 1               ;   X = pid
0000A3r 1               ;
0000A3r 1               ; Purpose:
0000A3r 1               ;   Clear the wait reason/object for a process.
0000A3r 1               ;
0000A3r 1               ; Notes:
0000A3r 1               ;   This does not change proc_state. The caller decides whether
0000A3r 1               ;   the process becomes READY, RUNNING, etc.
0000A3r 1               ; ------------------------------------------------------------
0000A3r 1               
0000A3r 1               .proc proc_clear_wait
0000A3r 1  A9 00            lda #WAIT_NONE
0000A5r 1  9D rr rr         sta wait_reason,x
0000A8r 1               
0000A8r 1  9E rr rr         stz wait_object,x
0000ABr 1               
0000ABr 1  60               rts
0000ACr 1               .endproc
0000ACr 1               
0000ACr 1               ; ------------------------------------------------------------
0000ACr 1               ; proc_exit_current
0000ACr 1               ;
0000ACr 1               ; Input:
0000ACr 1               ;   A = exit code
0000ACr 1               ;
0000ACr 1               ; Purpose:
0000ACr 1               ;   Terminate the currently running process.
0000ACr 1               ; ------------------------------------------------------------
0000ACr 1               
0000ACr 1               .proc proc_exit_current
0000ACr 1  AE rr rr         ldx active_pid
0000AFr 1  E0 00            cpx #IDLE_PID
0000B1r 1  F0 13            beq @yield
0000B3r 1               
0000B3r 1                   ; Process exit is a lifecycle operation.  Serialize it with
0000B3r 1                   ; proc_gate, but release the gate before yielding away from the
0000B3r 1                   ; terminating process.
0000B3r 1                   ;
0000B3r 1                   ; Preserve the user-supplied exit code across gate acquisition
0000B3r 1                   ; and debug phase writes.  proc_gate_acquire and the debug marker
0000B3r 1                   ; clobber A; proc_exit_lifecycle requires A = exit code.
0000B3r 1  48               pha
0000B4r 1  20 rr rr         jsr proc_gate_acquire
0000B7r 1  B0 03            bcs @gate_acquired
0000B9r 1               
0000B9r 1  68               pla                         ; discard saved exit code on failure
0000BAr 1  80 0A            bra @yield
0000BCr 1               
0000BCr 1               @gate_acquired:
0000BCr 1               
0000BCr 1  AE rr rr         ldx active_pid
0000BFr 1  68               pla                         ; restore exit code for lifecycle
0000C0r 1  20 rr rr         jsr proc_exit_lifecycle
0000C3r 1  20 rr rr         jsr proc_gate_release
0000C6r 1               
0000C6r 1               @yield:
0000C6r 1  4C rr rr         jmp sched_yield
0000C9r 1               .endproc
0000C9r 1               
0000C9r 1               ; ------------------------------------------------------------
0000C9r 1               ; proc_accounting_init
0000C9r 1               ;
0000C9r 1               ; Clear per-process runtime counters.
0000C9r 1               ;
0000C9r 1               ; This must run during scheduler/process initialization before
0000C9r 1               ; the timer IRQ is enabled. Once IRQ accounting starts, these
0000C9r 1               ; counters are updated from interrupt context and must not be
0000C9r 1               ; cleared casually.
0000C9r 1               ;
0000C9r 1               ; Clobbers:
0000C9r 1               ;   X
0000C9r 1               ; ------------------------------------------------------------
0000C9r 1               .proc proc_accounting_init
0000C9r 1  A2 07            ldx #MAX_PROCS - 1
0000CBr 1               
0000CBr 1               @clear_proc:
0000CBr 1  9E rr rr         stz proc_ticks_lo,x
0000CEr 1  9E rr rr         stz proc_ticks_hi,x
0000D1r 1               
0000D1r 1  CA               dex
0000D2r 1  10 F7            bpl @clear_proc
0000D4r 1               
0000D4r 1  60               rts
0000D5r 1               .endproc
0000D5r 1               
0000D5r 1               ; ------------------------------------------------------------
0000D5r 1               ; sched_account_tick
0000D5r 1               ;
0000D5r 1               ; Account one scheduler tick to the currently running process.
0000D5r 1               ;
0000D5r 1               ; PID 0 is the idle task. System idle time is therefore equal
0000D5r 1               ; to proc_ticks[0].
0000D5r 1               ;
0000D5r 1               ; Called from timer IRQ context.
0000D5r 1               ;
0000D5r 1               ; Clobbers:
0000D5r 1               ;   X
0000D5r 1               ; ------------------------------------------------------------
0000D5r 1               .proc sched_account_tick
0000D5r 1  AE rr rr         ldx active_pid
0000D8r 1               
0000D8r 1  FE rr rr         inc proc_ticks_lo,x
0000DBr 1  D0 03            bne @done
0000DDr 1               
0000DDr 1  FE rr rr         inc proc_ticks_hi,x
0000E0r 1               
0000E0r 1               @done:
0000E0r 1  60               rts
0000E1r 1               .endproc
0000E1r 1               
0000E1r 1               ; ------------------------------------------------------------
0000E1r 1               ; sched_update_console_focus
0000E1r 1               ;
0000E1r 1               ; Purpose:
0000E1r 1               ;   Synchronize console ownership with RP console focus state.
0000E1r 1               ;
0000E1r 1               ; Model:
0000E1r 1               ;   RP_CONSOLE_PID is authoritative and controlled only by the
0000E1r 1               ;   RP2350 side.
0000E1r 1               ;
0000E1r 1               ; Policy:
0000E1r 1               ;   - $FF = no focused task
0000E1r 1               ;   - 0   = monitor/supervisor focus
0000E1r 1               ;   - >0  = foreground process
0000E1r 1               ;
0000E1r 1               ; Safety:
0000E1r 1               ;   If RP points at an EMPTY or ZOMBIE process slot, ownership is cleared.
0000E1r 1               ; ------------------------------------------------------------
0000E1r 1               
0000E1r 1               .proc sched_update_console_focus
0000E1r 1  AD 11 B0         lda RP_CONSOLE_PID
0000E4r 1               
0000E4r 1                   ; Convert the RP route into a validated normal-process focus PID.
0000E4r 1  C9 FF            cmp #$FF
0000E6r 1  F0 17            beq @validated_none
0000E8r 1               
0000E8r 1  C9 00            cmp #0
0000EAr 1  F0 13            beq @validated_none
0000ECr 1               
0000ECr 1  C9 08            cmp #MAX_PROCS
0000EEr 1  B0 0F            bcs @validated_none
0000F0r 1               
0000F0r 1  AA               tax
0000F1r 1  BD rr rr         lda proc_state,x
0000F4r 1  C9 00            cmp #PROC_EMPTY
0000F6r 1  F0 07            beq @validated_none
0000F8r 1               
0000F8r 1  C9 06            cmp #PROC_ZOMBIE
0000FAr 1  F0 03            beq @validated_none
0000FCr 1               
0000FCr 1  8A               txa
0000FDr 1  80 02            bra @validated
0000FFr 1               
0000FFr 1               @validated_none:
0000FFr 1  A9 FF            lda #$FF
000101r 1               
000101r 1               @validated:
000101r 1                   ; RP routing and foreground ownership are separate. Only a route change
000101r 1                   ; resets the foreground owner to the newly selected routed process.
000101r 1  CD rr rr         cmp console_focus_pid
000104r 1  F0 09            beq @done
000106r 1               
000106r 1  8D rr rr         sta console_focus_pid
000109r 1  8D rr rr         sta console_owner_pid
00010Cr 1  20 rr rr         jsr scheduler_wake_console_owner
00010Fr 1               
00010Fr 1               @done:
00010Fr 1  60               rts
000110r 1               .endproc
000110r 1               
000110r 1               ; ------------------------------------------------------------
000110r 1               ; scheduler_wake_console_owner
000110r 1               ;
000110r 1               ; Wake the current console owner if it is blocked on WAIT_CONSOLE.
000110r 1               ;
000110r 1               ; This helper does not require RP_CONSOLE_RDY. It is used when foreground
000110r 1               ; ownership changes so the newly selected owner can retry its read. If no
000110r 1               ; input is available, console_read immediately blocks it again.
000110r 1               ; ------------------------------------------------------------
000110r 1               
000110r 1               .proc scheduler_wake_console_owner
000110r 1  AE rr rr         ldx console_owner_pid
000113r 1  E0 FF            cpx #$FF
000115r 1  F0 19            beq @done
000117r 1               
000117r 1  E0 01            cpx #FIRST_TASK_PID
000119r 1  90 15            bcc @done
00011Br 1               
00011Br 1  E0 08            cpx #MAX_PROCS
00011Dr 1  B0 11            bcs @done
00011Fr 1               
00011Fr 1  BD rr rr         lda proc_state,x
000122r 1  C9 04            cmp #PROC_BLOCKED
000124r 1  D0 0A            bne @done
000126r 1               
000126r 1  BD rr rr         lda wait_reason,x
000129r 1  C9 01            cmp #WAIT_CONSOLE
00012Br 1  D0 03            bne @done
00012Dr 1               
00012Dr 1  4C rr rr         jmp proc_wake
000130r 1               
000130r 1               @done:
000130r 1  60               rts
000131r 1               .endproc
000131r 1               
000131r 1               ; ------------------------------------------------------------
000131r 1               ; scheduler_wake_console_input
000131r 1               ;
000131r 1               ; Wake the console owner if it is blocked on console input.
000131r 1               ;
000131r 1               ; RP_CONSOLE_RDY only means input may be available. The woken
000131r 1               ; process must retry the actual console read after resuming.
000131r 1               ;
000131r 1               ; This routine does not consume input.
000131r 1               ; ------------------------------------------------------------
000131r 1               
000131r 1               .proc scheduler_wake_console_input
000131r 1  AD 12 B0         lda RP_CONSOLE_RDY
000134r 1  F0 20            beq @done
000136r 1               
000136r 1  AE rr rr         ldx console_owner_pid
000139r 1  E0 FF            cpx #$FF
00013Br 1  F0 19            beq @done
00013Dr 1               
00013Dr 1  E0 01            cpx #FIRST_TASK_PID
00013Fr 1  90 15            bcc @done
000141r 1               
000141r 1  E0 08            cpx #MAX_PROCS
000143r 1  B0 11            bcs @done
000145r 1               
000145r 1  BD rr rr         lda proc_state,x
000148r 1  C9 04            cmp #PROC_BLOCKED
00014Ar 1  D0 0A            bne @done
00014Cr 1               
00014Cr 1  BD rr rr         lda wait_reason,x
00014Fr 1  C9 01            cmp #WAIT_CONSOLE
000151r 1  D0 03            bne @done
000153r 1               
000153r 1  4C rr rr         jmp proc_wake
000156r 1               
000156r 1               @done:
000156r 1  60               rts
000157r 1               .endproc
000157r 1               
000157r 1               ; ------------------------------------------------------------
000157r 1               ; scheduler_init
000157r 1               ;
000157r 1               ; Purpose:
000157r 1               ;   Initialize scheduler state.
000157r 1               ;
000157r 1               ; Boot policy:
000157r 1               ;   Boot starts in pid 0 (supervisor context).
000157r 1               ; ------------------------------------------------------------
000157r 1               
000157r 1               .proc scheduler_init
000157r 1  20 rr rr     	jsr proc_accounting_init
00015Ar 1               
00015Ar 1  9C rr rr         stz system_ticks_lo
00015Dr 1  9C rr rr         stz system_ticks_hi
000160r 1               
000160r 1  9C rr rr         stz active_pid
000163r 1  9C rr rr         stz sched_cursor_pid
000166r 1  9C rr rr         stz sched_lock
000169r 1  9C rr rr     	stz active_context
00016Cr 1               
00016Cr 1               
00016Cr 1  9C rr rr     	stz monitor_active
00016Fr 1               
00016Fr 1  A9 FF            lda #$FF
000171r 1  8D rr rr         sta console_focus_pid
000174r 1  8D rr rr         sta console_owner_pid
000177r 1               
000177r 1  A2 00            ldx #$00
000179r 1               
000179r 1               @clear:
000179r 1  9E rr rr         stz proc_state,x
00017Cr 1               
00017Cr 1                   ; Empty process slots must not appear to own context 0.
00017Cr 1                   ; Context 0 is a real reserved supervisor context, so use $FF
00017Cr 1                   ; as the no-context sentinel until a process is created.
00017Cr 1  A9 FF            lda #$FF
00017Er 1  9D rr rr         sta proc_context,x
000181r 1               
000181r 1  9E rr rr         stz proc_sp,x
000184r 1  9E rr rr         stz proc_entryL,x
000187r 1  9E rr rr         stz proc_entryH,x
00018Ar 1  9E rr rr         stz proc_flags,x
00018Dr 1  9E rr rr     	stz proc_signal_pending,x
000190r 1               
000190r 1  A9 FF            lda #$FF
000192r 1  9D rr rr     	sta proc_parent_pid,x
000195r 1               
000195r 1  A9 00        	lda #WAIT_NONE
000197r 1  9D rr rr         sta wait_reason,x
00019Ar 1  9E rr rr         stz wait_object,x
00019Dr 1               
00019Dr 1  9E rr rr     	stz proc_exit_code,x
0001A0r 1               
0001A0r 1  E8               inx
0001A1r 1  E0 08            cpx #MAX_PROCS
0001A3r 1  D0 D4            bne @clear
0001A5r 1               
0001A5r 1                   ; --------------------------------------------------------
0001A5r 1                   ; Initialize PID 0 as idle descriptor.
0001A5r 1                   ;
0001A5r 1                   ; It becomes PROC_RUNNING in kernel_main because kernel_main
0001A5r 1                   ; is already executing the idle/supervisor loop in context 0.
0001A5r 1                   ; --------------------------------------------------------
0001A5r 1  A9 00            lda #$00
0001A7r 1  8D rr rr         sta proc_context+IDLE_PID
0001AAr 1               
0001AAr 1  A9 FF            lda #$FF
0001ACr 1  8D rr rr         sta proc_sp+IDLE_PID
0001AFr 1               
0001AFr 1  A9 01            lda #PROC_FLAG_IDLE
0001B1r 1  8D rr rr         sta proc_flags+IDLE_PID
0001B4r 1               
0001B4r 1  20 rr rr     	jsr timer_init
0001B7r 1  60               rts
0001B8r 1               .endproc
0001B8r 1               
0001B8r 1               ; ------------------------------------------------------------
0001B8r 1               ; scheduler_set_current_context
0001B8r 1               ;
0001B8r 1               ; Input:
0001B8r 1               ;   A = context id
0001B8r 1               ; ------------------------------------------------------------
0001B8r 1               
0001B8r 1               .proc scheduler_set_current_context
0001B8r 1  AE rr rr         ldx active_pid
0001BBr 1  9D rr rr         sta proc_context,x
0001BEr 1  60               rts
0001BFr 1               .endproc
0001BFr 1               
0001BFr 1               ; ------------------------------------------------------------
0001BFr 1               ; sched_pick_next
0001BFr 1               ;
0001BFr 1               ; Purpose:
0001BFr 1               ;   Select the next runnable task.
0001BFr 1               ;
0001BFr 1               ; Return:
0001BFr 1               ;   C set   = found runnable task, X = pid
0001BFr 1               ;   C clear = none found
0001BFr 1               ;
0001BFr 1               ; Runnable states:
0001BFr 1               ;   PROC_NEW
0001BFr 1               ;   PROC_READY
0001BFr 1               ;
0001BFr 1               ; Non-runnable states:
0001BFr 1               ;   PROC_EMPTY
0001BFr 1               ;   PROC_RUNNING
0001BFr 1               ;   PROC_BLOCKED
0001BFr 1               ;
0001BFr 1               ; Notes:
0001BFr 1               ;   - PID 0 is excluded from normal scheduling.
0001BFr 1               ;   - Bounded scan prevents infinite loop when sched_cursor_pid = 0.
0001BFr 1               ;   - Uses scheduler-local sched_scan_count as a bounded scan counter.
0001BFr 1               ; ------------------------------------------------------------
0001BFr 1               
0001BFr 1               .proc sched_pick_next
0001BFr 1  AE rr rr         ldx sched_cursor_pid
0001C2r 1               
0001C2r 1  E0 01            cpx #FIRST_TASK_PID
0001C4r 1  90 05            bcc @start_first
0001C6r 1               
0001C6r 1  E8               inx
0001C7r 1  E0 08            cpx #MAX_PROCS
0001C9r 1  D0 02            bne @set_count
0001CBr 1               
0001CBr 1               @start_first:
0001CBr 1  A2 01            ldx #FIRST_TASK_PID
0001CDr 1               
0001CDr 1               @set_count:
0001CDr 1  A9 07            lda #(MAX_PROCS - FIRST_TASK_PID)
0001CFr 1  8D rr rr         sta sched_scan_count
0001D2r 1               
0001D2r 1               @check:
0001D2r 1  BD rr rr         lda proc_state,x
0001D5r 1               
0001D5r 1               
0001D5r 1  C9 01            cmp #PROC_NEW
0001D7r 1  F0 26            beq @found
0001D9r 1               
0001D9r 1  C9 02            cmp #PROC_READY
0001DBr 1  F0 22            beq @found
0001DDr 1               
0001DDr 1  CE rr rr         dec sched_scan_count
0001E0r 1  F0 09            beq @idle
0001E2r 1               
0001E2r 1  E8               inx
0001E3r 1  E0 08            cpx #MAX_PROCS
0001E5r 1  D0 EB            bne @check
0001E7r 1               
0001E7r 1  A2 01            ldx #FIRST_TASK_PID
0001E9r 1  80 E7            bra @check
0001EBr 1               
0001EBr 1               @idle:
0001EBr 1                   ; No PROC_NEW or PROC_READY task was found.
0001EBr 1                   ; That is only valid if no normal task is still PROC_RUNNING.
0001EBr 1                   ;
0001EBr 1                   ; If a normal task is PROC_RUNNING here, scheduler state is
0001EBr 1                   ; corrupt: that PID should have been demoted to PROC_READY
0001EBr 1                   ; before this scan.
0001EBr 1  A2 01            ldx #FIRST_TASK_PID
0001EDr 1               
0001EDr 1               @scan_stale_running:
0001EDr 1  BD rr rr         lda proc_state,x
0001F0r 1  C9 03            cmp #PROC_RUNNING
0001F2r 1  F0 09            beq @stale_running
0001F4r 1               
0001F4r 1  E8               inx
0001F5r 1  E0 08            cpx #MAX_PROCS
0001F7r 1  D0 F4            bne @scan_stale_running
0001F9r 1               
0001F9r 1  A2 00            ldx #IDLE_PID
0001FBr 1  38               sec
0001FCr 1  60               rts
0001FDr 1               
0001FDr 1               @stale_running:
0001FDr 1               
0001FDr 1                   ; A RUNNING normal process while no READY/NEW task was found is
0001FDr 1                   ; not a valid steady-state scheduler result, but halting here makes
0001FDr 1                   ; recovery impossible. Resume the RUNNING PID.
0001FDr 1  38               sec
0001FEr 1  60               rts
0001FFr 1               
0001FFr 1               @found:
0001FFr 1  38               sec
000200r 1  60               rts
000201r 1               .endproc
000201r 1               
000201r 1               ; ------------------------------------------------------------
000201r 1               ; scheduler_apply_pending_signals
000201r 1               ;
000201r 1               ; Purpose:
000201r 1               ;   Apply scheduler-safe pending process-control signals before
000201r 1               ;   runnable selection.
000201r 1               ;
000201r 1               ; Policy:
000201r 1               ;   - Scans normal task PIDs only; PID 0 is never signalled here.
000201r 1               ;   - Calls only proc_apply_scheduler_signal, which may handle
000201r 1               ;     SIG_STOP/SIG_CONT but deliberately does not apply SIG_KILL.
000201r 1               ;   - Keeps sched_pick_next free of process-control side effects.
000201r 1               ; ------------------------------------------------------------
000201r 1               
000201r 1               .proc scheduler_apply_pending_signals
000201r 1  A2 01            ldx #FIRST_TASK_PID
000203r 1               
000203r 1               @scan:
000203r 1  8E rr rr         stx sched_signal_pid
000206r 1  20 rr rr         jsr proc_apply_scheduler_signal
000209r 1  AE rr rr         ldx sched_signal_pid
00020Cr 1               
00020Cr 1  E8               inx
00020Dr 1  E0 08            cpx #MAX_PROCS
00020Fr 1  D0 F2            bne @scan
000211r 1               
000211r 1  60               rts
000212r 1               .endproc
000212r 1               
000212r 1               ; ------------------------------------------------------------
000212r 1               ; sched_switch_context
000212r 1               ;
000212r 1               ; Shared scheduler switch/resume path.
000212r 1               ;
000212r 1               ; Called by:
000212r 1               ;   sched_context_switch
000212r 1               ;   sched_yield
000212r 1               ;
000212r 1               ; Responsibilities:
000212r 1               ;   - pick next runnable PID
000212r 1               ;   - commit selected PID as RUNNING
000212r 1               ;   - start PROC_NEW tasks
000212r 1               ;   - resume existing tasks through the unified RTI path
000212r 1               ;   - enter PID 0 idle loop if no normal task is runnable
000212r 1               ;
000212r 1               ; Notes:
000212r 1               ;   This routine never returns.
000212r 1               ; ------------------------------------------------------------
000212r 1               
000212r 1               .proc sched_switch_context
000212r 1  20 rr rr         jsr sched_pick_next
000215r 1               
000215r 1               
000215r 1                   ; PID 0 is entered directly, not through proc_sp[0].
000215r 1  E0 00            cpx #IDLE_PID
000217r 1  D0 03            bne @not_idle
000219r 1  4C rr rr         jmp resume_idle
00021Cr 1               
00021Cr 1               @not_idle:
00021Cr 1  BD rr rr         lda proc_state,x
00021Fr 1  C9 01            cmp #PROC_NEW
000221r 1  D0 03            bne @resume_existing
000223r 1  4C rr rr         jmp start_new
000226r 1               
000226r 1               @resume_existing:
000226r 1                   ; Commit selected PID as RUNNING.
000226r 1                   ;
000226r 1                   ; proc_set_running returns with:
000226r 1                   ;   X = selected PID / sched_cursor_pid
000226r 1  20 rr rr         jsr proc_set_running
000229r 1               
000229r 1  BD rr rr         lda proc_context,x
00022Cr 1  8D rr rr         sta sched_handoff_context
00022Fr 1  8E rr rr         stx sched_handoff_pid
000232r 1               
000232r 1                   ; The selected process stack is private to the selected context.
000232r 1                   ; Do not TXS or touch $0100..$01FF until after BIOS_CONTEXT_SWITCH.
000232r 1                   ; Carry the target SP in X; BIOS_CONTEXT_SWITCH preserves X.
000232r 1  BD rr rr         lda proc_sp,x
000235r 1  8D rr rr         sta sched_handoff_sp
000238r 1  AA               tax
000239r 1               
000239r 1               
000239r 1                   ; Publish identity/context in the final masked handoff window while
000239r 1                   ; sched_lock is still held.  IRQ remains masked until the selected
000239r 1                   ; private stack is installed and sched_lock is released below.
000239r 1  AD rr rr         lda sched_handoff_pid
00023Cr 1  8D rr rr         sta active_pid
00023Fr 1  AD rr rr         lda sched_handoff_context
000242r 1  8D rr rr         sta active_context
000245r 1               
000245r 1                   ; Switch private memory first.  This macro is stack-free and does
000245r 1                   ; not cross contexts with JSR/RTS.  X still contains target SP and
000245r 1                   ; A still contains the target context after storing active_context.
000245r 1  A8 AD 02 E0      BIOS_CONTEXT_SWITCH
000249r 1  D0 FB 8C 03  
00024Dr 1  E0 A9 02 8D  
000258r 1               
000258r 1                   ; Now the selected process private stack is mapped.
000258r 1                   ; X still contains the selected process SP after TXS, so it can be
000258r 1                   ; used directly for stack-frame indexing below.
000258r 1  9A               txs
000259r 1               
000259r 1                   ; Force IRQ enabled in the selected task's saved P byte.
000259r 1                   ; Frame layout after TXS:
000259r 1                   ;   SP+1 = Y
000259r 1                   ;   SP+2 = X
000259r 1                   ;   SP+3 = A
000259r 1                   ;   SP+4 = P
000259r 1                   ;   SP+5 = PCL
000259r 1                   ;   SP+6 = PCH
000259r 1  BD 04 01         lda $0104,x
00025Cr 1  29 FB            and #$fb
00025Er 1  9D 04 01         sta $0104,x
000261r 1               
000261r 1               
000261r 1                   ; Release as late as possible: context is switched and the selected
000261r 1                   ; private stack is installed, but the task frame has not yet been
000261r 1                   ; consumed.  sched_lock_leave uses the currently installed stack and restores it before return.
000261r 1  20 rr rr         jsr sched_lock_leave
000264r 1               
000264r 1  7A               ply
000265r 1  FA               plx
000266r 1  68               pla
000267r 1  40               rti
000268r 1               
000268r 1               start_new:
000268r 1  20 rr rr         jsr proc_set_running
00026Br 1               
00026Br 1  BD rr rr         lda proc_context,x
00026Er 1  8D rr rr         sta sched_handoff_context
000271r 1  8E rr rr         stx sched_handoff_pid
000274r 1               
000274r 1                   ; First-run handoff: switch private context first, install a clean
000274r 1                   ; stack in that context, then release sched_lock and enter the
000274r 1                   ; bootstrap trampoline.  No JSR/RTS crosses the context switch.
000274r 1                   ;
000274r 1               
000274r 1  AD rr rr         lda sched_handoff_pid
000277r 1  8D rr rr         sta active_pid
00027Ar 1  AD rr rr         lda sched_handoff_context
00027Dr 1  8D rr rr         sta active_context
000280r 1               
000280r 1                   ; A still contains the target context after publishing active_context.
000280r 1  A8 AD 02 E0      BIOS_CONTEXT_SWITCH
000284r 1  D0 FB 8C 03  
000288r 1  E0 A9 02 8D  
000293r 1               
000293r 1  A2 FF            ldx #$FF
000295r 1  9A               txs
000296r 1               
000296r 1  20 rr rr         jsr sched_lock_leave
000299r 1               
000299r 1  4C rr rr         jmp first_run_entry
00029Cr 1               
00029Cr 1               resume_idle:
00029Cr 1  A2 00            ldx #IDLE_PID
00029Er 1  20 rr rr         jsr proc_set_running
0002A1r 1               
0002A1r 1               
0002A1r 1                   ; Idle runs in context 0.  If the scheduler is already executing in
0002A1r 1                   ; context 0, do not issue a redundant RP BIOS context-switch command.
0002A1r 1                   ; This keeps repeated idle-to-idle IRQ scheduler passes from waiting
0002A1r 1                   ; on the RP polled BIOS command path while IRQs are masked.
0002A1r 1  AD rr rr         lda active_context
0002A4r 1  F0 1D            beq idle_context_ready
0002A6r 1               
0002A6r 1  9C rr rr         stz active_pid
0002A9r 1  9C rr rr         stz active_context
0002ACr 1  A9 00            lda #IDLE_PID
0002AEr 1  A8 AD 02 E0      BIOS_CONTEXT_SWITCH
0002B2r 1  D0 FB 8C 03  
0002B6r 1  E0 A9 02 8D  
0002C1r 1  80 06            bra idle_stack_ready
0002C3r 1               
0002C3r 1               idle_context_ready:
0002C3r 1  9C rr rr         stz active_pid
0002C6r 1  9C rr rr         stz active_context
0002C9r 1               
0002C9r 1               idle_stack_ready:
0002C9r 1  A2 FF            ldx #$FF
0002CBr 1  9A               txs
0002CCr 1               
0002CCr 1  20 rr rr         jsr sched_lock_leave
0002CFr 1               
0002CFr 1  4C rr rr         jmp idle_loop
0002D2r 1               .endproc
0002D2r 1               
0002D2r 1               
0002D2r 1               ; ------------------------------------------------------------
0002D2r 1               ; sched_context_switch
0002D2r 1               ;
0002D2r 1               ; IRQ/timer scheduler entry.
0002D2r 1               ;
0002D2r 1               ; Called from IRQ context. The current task stack is saved as
0002D2r 1               ; RTI-style state because the interrupted stack contains an IRQ
0002D2r 1               ; return frame.
0002D2r 1               ;
0002D2r 1               ; Responsibilities:
0002D2r 1               ;   - save current normal task state, if active_pid != 0
0002D2r 1               ;   - account timer tick
0002D2r 1               ;   - wake timer/console waiters
0002D2r 1               ;   - jump to shared dispatch/resume path
0002D2r 1               ;
0002D2r 1               ; Notes:
0002D2r 1               ;   This routine never returns directly.
0002D2r 1               ; ------------------------------------------------------------
0002D2r 1               
0002D2r 1               .proc sched_context_switch
0002D2r 1                   ; IRQ handler normally enters here only when sched_lock and
0002D2r 1                   ; subsystem locks were zero.  Still use the real try-lock result
0002D2r 1                   ; as the authority: if the guard is already held, this IRQ must
0002D2r 1                   ; resume the interrupted context unchanged.
0002D2r 1  20 rr rr         jsr sched_lock_try_enter
0002D5r 1  90 03            bcc @irq_lock_acquired
0002D7r 1  4C rr rr         jmp @skip_locked
0002DAr 1               
0002DAr 1               @irq_lock_acquired:
0002DAr 1               
0002DAr 1                   ; Current interrupted owner.
0002DAr 1  AC rr rr         ldy active_pid
0002DDr 1               
0002DDr 1               
0002DDr 1                   ; --------------------------------------------------------
0002DDr 1                   ; PID 0 is not a normal saved task.
0002DDr 1                   ;
0002DDr 1                   ; Do not save proc_sp[0].
0002DDr 1                   ; Do not convert PID 0 to READY.
0002DDr 1                   ; --------------------------------------------------------
0002DDr 1               
0002DDr 1  C0 00            cpy #IDLE_PID
0002DFr 1  F0 11            beq @wake_events
0002E1r 1               
0002E1r 1                   ; Save interrupted SP for normal task.
0002E1r 1  BA               tsx
0002E2r 1               
0002E2r 1               
0002E2r 1  8A               txa
0002E3r 1  99 rr rr         sta proc_sp,y
0002E6r 1               
0002E6r 1                   ; This stack was saved from IRQ context and is RTI-compatible.
0002E6r 1               
0002E6r 1                   ; IRQ preemption: RUNNING -> READY.
0002E6r 1  B9 rr rr         lda proc_state,y
0002E9r 1  C9 03            cmp #PROC_RUNNING
0002EBr 1  D0 05            bne @wake_events
0002EDr 1               
0002EDr 1               
0002EDr 1  98               tya
0002EEr 1  AA               tax
0002EFr 1  20 rr rr         jsr proc_set_ready
0002F2r 1               
0002F2r 1               
0002F2r 1               @wake_events:
0002F2r 1  20 rr rr         jsr sched_update_console_focus
0002F5r 1  20 rr rr         jsr scheduler_wake_console_input
0002F8r 1  20 rr rr         jsr scheduler_wake_timers
0002FBr 1  20 rr rr         jsr scheduler_apply_pending_signals
0002FEr 1               
0002FEr 1  4C rr rr         jmp sched_switch_context
000301r 1               
000301r 1               @skip_locked:
000301r 1  4C rr rr         jmp irq_restore
000304r 1               .endproc
000304r 1               
000304r 1               ; ------------------------------------------------------------
000304r 1               ; sched_yield
000304r 1               ;
000304r 1               ; Cooperative scheduler entry.
000304r 1               ;
000304r 1               ; Stack model:
000304r 1               ;   The cooperative JSR return address is converted in-place into
000304r 1               ;   the same IRQ-compatible extended RTI frame used by timer IRQ:
000304r 1               ;
000304r 1               ;       Y, X, A, P, PCL, PCH
000304r 1               ;
000304r 1               ;   The saved P byte has I cleared so the resumed task continues
000304r 1               ;   with IRQs enabled.  The JSR return address is incremented by
000304r 1               ;   one because RTS stores PC-1 while RTI expects the exact PC.
000304r 1               ;
000304r 1               ; Notes:
000304r 1               ;   This routine never returns directly.
000304r 1               ; ------------------------------------------------------------
000304r 1               
000304r 1               .proc sched_yield
000304r 1                   ; --------------------------------------------------------
000304r 1                   ; Short atomic entry section.
000304r 1                   ; --------------------------------------------------------
000304r 1  78               sei
000305r 1  20 rr rr         jsr sched_lock_try_enter
000308r 1  90 03            bcc @yield_lock_acquired
00030Ar 1  4C rr rr         jmp @lock_busy
00030Dr 1               
00030Dr 1               @yield_lock_acquired:
00030Dr 1               
00030Dr 1                   ; Current yielding owner.
00030Dr 1  AC rr rr         ldy active_pid
000310r 1               
000310r 1               
000310r 1                   ; PID 0 is not a normal saved task.
000310r 1  C0 00            cpy #IDLE_PID
000312r 1  F0 25            beq @entry_done
000314r 1               
000314r 1                   ; Convert current cooperative JSR continuation into the unified
000314r 1                   ; extended RTI frame expected by scheduler RTI resume / irq_restore:
000314r 1                   ;     Y, X, A, P, PCL, PCH
000314r 1                   ;
000314r 1                   ; Existing stack on entry:
000314r 1                   ;     PCL(JSR return - 1), PCH(JSR return - 1)
000314r 1                   ;
000314r 1                   ; Push order below transforms it into:
000314r 1                   ;     Y, X, A, P, PCL, PCH
000314r 1  08               php
000315r 1  48               pha
000316r 1  DA               phx
000317r 1  5A               phy
000318r 1               
000318r 1                   ; Stack now points at saved Y.  Clear I in saved P and convert
000318r 1                   ; the JSR return address from PC-1 to exact RTI PC.
000318r 1  BA               tsx
000319r 1               
000319r 1  BD 04 01         lda $0104,x
00031Cr 1  29 FB            and #$fb
00031Er 1  9D 04 01         sta $0104,x
000321r 1               
000321r 1  FE 05 01         inc $0105,x
000324r 1  D0 03            bne @pc_adjust_done
000326r 1  FE 06 01         inc $0106,x
000329r 1               
000329r 1               @pc_adjust_done:
000329r 1               
000329r 1               
000329r 1  8A               txa
00032Ar 1  99 rr rr         sta proc_sp,y
00032Dr 1               
00032Dr 1                   ; This stack is now an RTI-compatible frame.
00032Dr 1               
00032Dr 1                   ; If caller is still RUNNING, make it READY.
00032Dr 1                   ; Blocking syscalls set PROC_BLOCKED before calling this,
00032Dr 1                   ; so they are left blocked.
00032Dr 1  B9 rr rr         lda proc_state,y
000330r 1  C9 03            cmp #PROC_RUNNING
000332r 1  D0 05            bne @entry_done
000334r 1               
000334r 1               
000334r 1  98               tya
000335r 1  AA               tax
000336r 1  20 rr rr         jsr proc_set_ready
000339r 1               
000339r 1               
000339r 1               @entry_done:
000339r 1                   ; --------------------------------------------------------
000339r 1                   ; Scheduler work remains IRQ-disabled.
000339r 1                   ;
000339r 1                   ; The current process stack now contains the saved RTI frame.
000339r 1                   ; Do not allow a nested IRQ/monitor entry to observe or save an
000339r 1                   ; intermediate scheduler stack depth as the process SP.
000339r 1                   ; --------------------------------------------------------
000339r 1               
000339r 1  20 rr rr         jsr sched_update_console_focus
00033Cr 1  20 rr rr         jsr scheduler_wake_console_input
00033Fr 1  20 rr rr         jsr scheduler_wake_timers
000342r 1  20 rr rr         jsr scheduler_apply_pending_signals
000345r 1               
000345r 1  4C rr rr         jmp sched_switch_context
000348r 1               
000348r 1               @lock_busy:
000348r 1                   ; Cooperative yield while sched_lock is held is a scheduler
000348r 1                   ; recursion/invariant fault. Returning would continue with a
000348r 1                   ; caller that expected sched_yield not to return, so stop here
000348r 1                   ; instead of corrupting scheduler state.
000348r 1               @halt:
000348r 1  80 FE            bra @halt
00034Ar 1               .endproc
00034Ar 1               
00034Ar 1               ; ------------------------------------------------------------
00034Ar 1               ; sched_block_current
00034Ar 1               ;
00034Ar 1               ; Input:
00034Ar 1               ;   A = wait reason
00034Ar 1               ;   Y = wait object
00034Ar 1               ;
00034Ar 1               ; Purpose:
00034Ar 1               ;   Scheduler-owned blocking transition for syscalls that must block
00034Ar 1               ;   the current process.  This routine saves/converts the current
00034Ar 1               ;   syscall continuation into the normal RTI-compatible frame first,
00034Ar 1               ;   then commits the wait reason/object, then enters the normal final
00034Ar 1               ;   context handoff path.
00034Ar 1               ;
00034Ar 1               ; Current user:
00034Ar 1               ;   ksys_sleep / WAIT_TIMER.
00034Ar 1               ;
00034Ar 1               ; Notes:
00034Ar 1               ;   This routine never returns directly.  The blocked syscall resumes
00034Ar 1               ;   when its wait condition wakes the process and the scheduler later
00034Ar 1               ;   restores its saved RTI frame.
00034Ar 1               ; ------------------------------------------------------------
00034Ar 1               
00034Ar 1               .proc sched_block_current
00034Ar 1                   ; Store requested wait before clobbering A/Y for frame setup.
00034Ar 1  08               php
00034Br 1  78               sei
00034Cr 1  8D rr rr         sta sched_wake_reason_tmp
00034Fr 1  8C rr rr         sty sched_wake_object_tmp
000352r 1               
000352r 1                   ; WAIT_TIMER has an armed timer slot.  Validate it before saving
000352r 1                   ; the continuation.  If a very short sleep already expired and the
000352r 1                   ; stale slot was freed, return success immediately instead of
000352r 1                   ; blocking forever on a dead wait_object.
000352r 1  AD rr rr         lda sched_wake_reason_tmp
000355r 1  C9 04            cmp #WAIT_TIMER
000357r 1  D0 0B            bne @discard_entry_p
000359r 1               
000359r 1  AE rr rr         ldx sched_wake_object_tmp
00035Cr 1  20 rr rr         jsr timer_commit_current
00035Fr 1  90 03            bcc @discard_entry_p
000361r 1               
000361r 1  28               plp
000362r 1  18               clc
000363r 1  60               rts
000364r 1               
000364r 1               @discard_entry_p:
000364r 1  68               pla                         ; discard saved caller P byte
000365r 1               
000365r 1  20 rr rr         jsr sched_lock_try_enter
000368r 1  90 0F            bcc @block_lock_acquired
00036Ar 1               
00036Ar 1                   ; If the only current caller armed a timer slot but cannot enter
00036Ar 1                   ; the scheduler, release that slot before stopping.
00036Ar 1  AD rr rr         lda sched_wake_reason_tmp
00036Dr 1  C9 04            cmp #WAIT_TIMER
00036Fr 1  D0 06            bne @lock_busy
000371r 1               
000371r 1  AE rr rr         ldx sched_wake_object_tmp
000374r 1  20 rr rr         jsr timer_free
000377r 1               
000377r 1               @lock_busy:
000377r 1               @halt:
000377r 1  80 FE            bra @halt
000379r 1               
000379r 1               @block_lock_acquired:
000379r 1               
000379r 1                   ; Current blocking owner.
000379r 1  AC rr rr         ldy active_pid
00037Cr 1               
00037Cr 1               
00037Cr 1                   ; PID 0 is not allowed to block.  If it reaches this path, keep the
00037Cr 1                   ; scheduler alive by treating it as an immediate scheduler entry.
00037Cr 1  C0 00            cpy #IDLE_PID
00037Er 1  F0 28            beq @entry_done
000380r 1               
000380r 1                   ; Convert current cooperative syscall continuation into the unified
000380r 1                   ; extended RTI frame expected by scheduler RTI resume / irq_restore:
000380r 1                   ;     Y, X, A, P, PCL, PCH
000380r 1                   ;
000380r 1                   ; Save a successful syscall return state for the eventual resume:
000380r 1                   ;   C clear, I clear in saved P, A = 0.
000380r 1  18               clc
000381r 1  08               php
000382r 1  A9 00            lda #0
000384r 1  48               pha
000385r 1  DA               phx
000386r 1  5A               phy
000387r 1               
000387r 1                   ; Stack now points at saved Y.  Clear I in saved P and convert
000387r 1                   ; the JSR return address from PC-1 to exact RTI PC.
000387r 1  BA               tsx
000388r 1               
000388r 1  BD 04 01         lda $0104,x
00038Br 1  29 FB            and #$fb
00038Dr 1  9D 04 01         sta $0104,x
000390r 1               
000390r 1  FE 05 01         inc $0105,x
000393r 1  D0 03            bne @pc_adjust_done
000395r 1  FE 06 01         inc $0106,x
000398r 1               
000398r 1               @pc_adjust_done:
000398r 1               
000398r 1  8A               txa
000399r 1  99 rr rr         sta proc_sp,y
00039Cr 1               
00039Cr 1                   ; WAIT_TIMER was validated before the continuation was saved.
00039Cr 1                   ; Now commit the process wait state.
00039Cr 1               @set_wait:
00039Cr 1  AE rr rr         ldx active_pid
00039Fr 1  AD rr rr         lda sched_wake_reason_tmp
0003A2r 1  AC rr rr         ldy sched_wake_object_tmp
0003A5r 1  20 rr rr         jsr proc_set_wait
0003A8r 1               
0003A8r 1               @entry_done:
0003A8r 1  20 rr rr         jsr sched_update_console_focus
0003ABr 1  20 rr rr         jsr scheduler_wake_console_input
0003AEr 1  20 rr rr         jsr scheduler_wake_timers
0003B1r 1  20 rr rr         jsr scheduler_apply_pending_signals
0003B4r 1               
0003B4r 1  4C rr rr         jmp sched_switch_context
0003B7r 1               .endproc
0003B7r 1               
0003B7r 1               
0003B7r 1               ; ------------------------------------------------------------
0003B7r 1               ; first_run_entry
0003B7r 1               ;
0003B7r 1               ; Purpose:
0003B7r 1               ;   Inline first-run bootstrap for PROC_NEW tasks.
0003B7r 1               ;
0003B7r 1               ; Notes:
0003B7r 1               ;   This is a one-time bootstrap into a new MMU context, not a
0003B7r 1               ;   process return-frame format.  Once the task yields or is
0003B7r 1               ;   preempted, its continuation is saved only as an RTI frame.
0003B7r 1               ; ------------------------------------------------------------
0003B7r 1               
0003B7r 1               .proc first_run_entry
0003B7r 1                   ; Start with a clean private stack.
0003B7r 1  A2 FF            ldx #$FF
0003B9r 1  9A               txs
0003BAr 1               
0003BAr 1                   ; Initialise process-private cwd state in the selected context
0003BAr 1                   ; from the shared per-process cwd mirror.
0003BAr 1               
0003BAr 1                   ; Resolve entry address into private zero-page sched_ptr.
0003BAr 1  AE rr rr         ldx active_pid
0003BDr 1  BD rr rr         lda proc_entryL,x
0003C0r 1  85 rr            sta sched_ptr
0003C2r 1  BD rr rr         lda proc_entryH,x
0003C5r 1  85 rr            sta sched_ptr+1
0003C7r 1               
0003C7r 1  BD rr rr         lda proc_context,x
0003CAr 1  8D rr rr         sta active_context
0003CDr 1               
0003CDr 1  D8               cld
0003CEr 1  58               cli
0003CFr 1               
0003CFr 1  6C rr rr         jmp (sched_ptr)
0003D2r 1               .endproc
0003D2r 1               
