000000r 2               ; sched_lock.inc
000000r 2               ; NEOX - public scheduler-lock interface
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Provides the callable scheduler-lock interface and real guard byte.
000000r 2               ;
000000r 2               ; Rule:
000000r 2               ;   All exits, including final context handoff after the target
000000r 2               ;   private stack is installed, use jsr sched_lock_leave.
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __SCHED_LOCK_INC__
000000r 2               __SCHED_LOCK_INC__ = 1
