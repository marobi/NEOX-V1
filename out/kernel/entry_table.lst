000069r 1               
000069r 1               ; KERNEL_ENTRY area is $0100 bytes.
000069r 1               ; Current table: 35 absolute JMP entries * 3 bytes = $69 bytes.
000069r 1               ; Remaining fixed padding: $0100 - $69 = $97 bytes.
000069r 1               ; Keep this explicit because ca65 cannot use relocatable PC (*)
000069r 1               ; in the .res count expression here.
000069r 1               KERNEL_ENTRY_COUNT         = 35
000069r 1               KERNEL_ENTRY_RESERVED_SIZE = $0100
000069r 1               KERNEL_ENTRY_USED_BYTES    = KERNEL_ENTRY_COUNT * KERNEL_ENTRY_SIZE
000069r 1               
000069r 1                   .assert KERNEL_ENTRY_USED_BYTES <= KERNEL_ENTRY_RESERVED_SIZE, error, "KERNEL_ENTRY overflows reserved entry area"
000069r 1  00 00 00 00      .res KERNEL_ENTRY_RESERVED_SIZE - KERNEL_ENTRY_USED_BYTES, $00
00006Dr 1  00 00 00 00  
000071r 1  00 00 00 00  
000069r 1               
