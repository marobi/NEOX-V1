000000r 1               
000000r 1               .export kernel_entry_table
000000r 1               
000000r 1               .import kernel_main
000000r 1               .import set_brk_vector
000000r 1               .import enter_monitor
000000r 1               .import leave_monitor
000000r 1               .import ksys_read
000000r 1               .import ksys_write
000000r 1               .import ksys_exit
000000r 1               .import ksys_yield
000000r 1               .import ksys_sleep
000000r 1               .import ksys_close
000000r 1               .import ksys_dup
000000r 1               .import ksys_dup2
000000r 1               .import ksys_pipe
000000r 1               .import pipe_create_between_fd
000000r 1               .import ksys_ticks
000000r 1               .import ksys_signal
000000r 1               .import ksys_open
000000r 1               .import ksys_load_file_to_memory
000000r 1               .import ksys_save_memory_to_file
