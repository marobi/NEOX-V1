000000r 1               .segment "KERNEL_ENTRY"
000000r 1               
000000r 1               .assert * = KERNEL_BASE, error, "KERNEL_ENTRY must start at KERNEL_BASE"
000000r 1               
000000r 1               RESET:
000000r 1               kernel_entry_table:
000000r 1  4C rr rr         jmp kernel_main
