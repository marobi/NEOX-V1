000000r 1               ; kernel/math8.asm
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .importzp factor1
000000r 1               .importzp factor2
000000r 1               
000000r 1               .export mul8u
000000r 1               
000000r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; mul8u
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Unsigned 8x8 multiply.
000000r 1               ;
000000r 1               ; Input:
000000r 1               ;   factor1 = multiplicand
000000r 1               ;   factor2 = multiplier
000000r 1               ;
000000r 1               ; Output:
000000r 1               ;   factor1 = product low
000000r 1               ;   factor2 = product high
000000r 1               ;
000000r 1               ; Clobbers:
000000r 1               ;   A, X, C
000000r 1               ;
000000r 1               ; Notes:
000000r 1               ;   Destructive: original factors are overwritten.
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               .proc mul8u_core
000000r 1  A9 00            lda #$00
000002r 1  A2 08            ldx #$08
000004r 1               
000004r 1  46 rr            lsr factor1
000006r 1               
000006r 1               @loop:
000006r 1  90 03            bcc @no_add
000008r 1               
000008r 1  18               clc
000009r 1  65 rr            adc factor2
00000Br 1               
00000Br 1               @no_add:
00000Br 1  6A               ror a
00000Cr 1  66 rr            ror factor1
00000Er 1               
00000Er 1  CA               dex
00000Fr 1  D0 F5            bne @loop
000011r 1               
000011r 1  85 rr            sta factor2
000013r 1  60               rts
000014r 1               .endproc
000014r 1               
000014r 1               ; ------------------------------------------------------------
000014r 1               ; mul8u
000014r 1               ;
000014r 1               ; Input:
000014r 1               ;   A = multiplicand
000014r 1               ;   X = multiplier
000014r 1               ;
000014r 1               ; Output:
000014r 1               ;   A       = product low
000014r 1               ;   X       = product high
000014r 1               ;   factor1 = product low
000014r 1               ;   factor2 = product high
000014r 1               ;
000014r 1               ; Clobbers:
000014r 1               ;   flags
000014r 1               ;
000014r 1               ; Concurrency:
000014r 1               ;   factor1 and factor2 are context-private zero-page storage.
000014r 1               ;   The routine is therefore safe across normal process preemption
000014r 1               ;   without disabling interrupts or acquiring a semaphore.
000014r 1               ;
000014r 1               ; Restriction:
000014r 1               ;   IRQ handlers must not call mul8u or modify factor1/factor2.
000014r 1               ;   An IRQ runs in the interrupted context and shares that context's
000014r 1               ;   zero page until the scheduler switches context.
000014r 1               ; ------------------------------------------------------------
000014r 1               
000014r 1               .proc mul8u
000014r 1  85 rr            sta factor1
000016r 1  86 rr            stx factor2
000018r 1               
000018r 1  20 rr rr         jsr mul8u_core
00001Br 1               
00001Br 1  A5 rr            lda factor1
00001Dr 1  A6 rr            ldx factor2
00001Fr 1  60               rts
000020r 1               .endproc
000020r 1               
