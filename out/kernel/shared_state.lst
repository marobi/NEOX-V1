00002Fr 1               ;   owning PID or $FF when not process-owned.
00002Fr 1               ;
00002Fr 1               ; Notes:
00002Fr 1               ;   proc_context[pid] maps PID -> MMU context.
00002Fr 1               ;   context_owner_pid[ctx] is the inverse ownership map used by
00002Fr 1               ;   the future spawn/context allocator.
00002Fr 1               ; ------------------------------------------------------------
00002Fr 1               
00002Fr 1               .export context_state
