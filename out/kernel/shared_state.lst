0000D7r 1               ;   open_file_handle - RP filesystem handle for OBJ_FILE objects
0000D7r 1               ; ------------------------------------------------------------
0000D7r 1               
0000D7r 1               .export open_type
0000D7r 1               .export open_refcnt
0000D7r 1               .export open_flags
0000D7r 1               .export open_dev
0000D7r 1               .export open_file_handle
