000073r 1               
000073r 1               ; ------------------------------------------------------------
000073r 1               ; Scheduler / monitor state
000073r 1               ;
000073r 1               ; sched_lock:
000073r 1               ;   Non-sleeping scheduler preemption guard. Bit 0 is acquired with
000073r 1               ;   W65C02 TSB by sched_lock_try_enter and cleared with TRB by
000073r 1               ;   sched_lock_leave.  Try-enter returns C clear only when this caller
000073r 1               ;   acquired the bit; callers must not enter scheduler-critical code
000073r 1               ;   or call leave when C is set.  This is not a FIFO gate and must
000073r 1               ;   never block or yield.  It is deliberately non-recursive.
000073r 1               ;
000073r 1               ; console_owner_pid:
000073r 1               ;   Identifies which process currently owns console input.
000073r 1               ;   $FF = none / monitor-side default.
000073r 1               ;
000073r 1               ; monitor_active:
000073r 1               ;   Nonzero while monitor mode is active.
000073r 1               ;
000073r 1               ; active_context:
000073r 1               ;   Actual MMU context currently executing on the 6502.
000073r 1               ;   This is paired with active_pid and changes only at the
000073r 1               ;   final scheduler/context handoff boundary.
000073r 1               ; ------------------------------------------------------------
000073r 1               
000073r 1               .export sched_lock
000073r 1               .export console_owner_pid
000073r 1               .export monitor_active
000073r 1               .export active_context
000073r 1               
000073r 1               sched_lock:
000073r 1  xx               .res 1
000074r 1               
000074r 1               console_owner_pid:
000074r 1  xx               .res 1
000075r 1               
000075r 1               monitor_active:
000075r 1  xx               .res 1
000076r 1               
000076r 1               active_context:
000076r 1  xx           	.res 1
