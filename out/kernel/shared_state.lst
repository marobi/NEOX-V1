000000r 1               ; ------------------------------------------------------------
000000r 1               ; Kernel metadata
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               .export kernel_version
000000r 1               .export brk_vector
000000r 1               
000000r 1               kernel_version:
000000r 1  xx xx            .res 2
000002r 1               
000002r 1               brk_vector:
000002r 1  xx xx            .res 2
000004r 1               
000004r 1               ; ------------------------------------------------------------
000004r 1               ; RP2350 mailbox serialization lock
000004r 1               ;
000004r 1               ; Purpose:
000004r 1               ;   Ensures only one kernel-side mailbox transaction is active
000004r 1               ;   at a time.
000004r 1               ;
000004r 1               ; Notes:
000004r 1               ;   This is shared state because the mailbox hardware and request
000004r 1               ;   block are global resources, not per-process resources.
000004r 1               ; ------------------------------------------------------------
000004r 1               
000004r 1               .export rp_lock
000004r 1               
000004r 1               rp_lock:
000004r 1  xx               .res 1
000005r 1               
000005r 1               ; ------------------------------------------------------------
000005r 1               ; File I/O syscall serialization gate
000005r 1               ;
000005r 1               ; Purpose:
000005r 1               ;   Serializes FD/open-object/pipe/console syscall paths:
000005r 1               ;     read, write, close, pipe, dup, dup2.
000005r 1               ;
000005r 1               ; Policy:
000005r 1               ;   This is a sleepable PID-owned gate, not an IRQ-preemption blocker.
000005r 1               ;   Timer scheduling may continue while the gate is owned. A process that
000005r 1               ;   cannot acquire it blocks on WAIT_LOCK / LOCK_ID_FILE_IO. Normal console
000005r 1               ;   and pipe waits release the gate before yielding; the planned generic RP
000005r 1               ;   transaction may retain it while the owner blocks on WAIT_RP.
000005r 1               ;
000005r 1               ; FIFO queue:
000005r 1               ;   file_io_gate_wait_head / tail hold waiting PIDs or $FF.
000005r 1               ;   file_io_gate_next[pid] links waiting PIDs.
000005r 1               ; ------------------------------------------------------------
000005r 1               
000005r 1               .export file_io_gate
000005r 1               .export file_io_gate_owner
000005r 1               .export file_io_gate_wait_head
000005r 1               .export file_io_gate_wait_tail
000005r 1               .export file_io_gate_next
000005r 1               
000005r 1               .export proc_gate
000005r 1               .export proc_gate_owner
000005r 1               .export proc_gate_wait_head
000005r 1               .export proc_gate_wait_tail
000005r 1               .export proc_gate_next
000005r 1               
000005r 1               file_io_gate:
000005r 1  xx               .res 1
000006r 1               
000006r 1               file_io_gate_owner:
000006r 1  xx               .res 1
000007r 1               
000007r 1               file_io_gate_wait_head:
000007r 1  xx               .res 1
000008r 1               
000008r 1               file_io_gate_wait_tail:
000008r 1  xx               .res 1
000009r 1               
000009r 1               file_io_gate_next:
000009r 1  xx xx xx xx      .res MAX_PROCS
00000Dr 1  xx xx xx xx  
