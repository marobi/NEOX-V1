000077r 1               ; Layout:
000077r 1               ;   proc_fd_obj[pid * MAX_FDS + fd]
000077r 1               ;   proc_fd_flags[pid * MAX_FDS + fd]
000077r 1               ; ------------------------------------------------------------
000077r 1               
000077r 1               .export proc_fd_obj
000077r 1               .export proc_fd_flags
000077r 1               
000077r 1               proc_fd_obj:
