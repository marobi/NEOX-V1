000000r 1               .include "context.inc"
000000r 2               .ifndef __CONTEXT_INC__
000000r 2               __CONTEXT_INC__ = 1
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; MMU context slot states
000000r 2               ; ------------------------------------------------------------
000000r 2               ;
000000r 2               ; These states describe kernel ownership of RP-created/preloaded
000000r 2               ; MMU contexts.  They do not create contexts and they do not load
000000r 2               ; images; RP/boot configuration still owns physical context setup.
000000r 2               ;
000000r 2               ; Current development configuration preloads neox_user.rom into
000000r 2               ; contexts 1..9.  Keep MAX_CONTEXTS aligned with the RP-side
000000r 2               ; configuration and monitor/debug_neox.cpp if mirrored there.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               MAX_CONTEXTS       = 10
000000r 2               
000000r 2               CTX_INVALID        = $00    ; context does not exist / not usable
000000r 2               CTX_RESERVED       = $01    ; BIOS/kernel/monitor/supervisor-owned
000000r 2               CTX_PRELOADED_FREE = $02    ; resident neox_user image present and available
000000r 2               CTX_EMPTY_FREE     = $03    ; available, but no guaranteed resident image
000000r 2               CTX_IN_USE         = $04    ; owned by a process
000000r 2               
000000r 2               .endif
000000r 2               
