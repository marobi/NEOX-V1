00001Dr 1               
00001Dr 1               ; ------------------------------------------------------------
00001Dr 1               ; Scheduler core state
00001Dr 1               ;
00001Dr 1               ; active_pid:
00001Dr 1               ;   PID whose CPU/MMU context is actually executing.
00001Dr 1               ;
00001Dr 1               ; sched_cursor_pid:
00001Dr 1               ;   Scheduler-local round-robin cursor / last selected PID.
00001Dr 1               ;   It must not be used as caller identity.
00001Dr 1               ;
00001Dr 1               ; proc_state[pid]:
00001Dr 1               ;   Process lifecycle / scheduler state:
00001Dr 1               ;     PROC_EMPTY
00001Dr 1               ;     PROC_NEW
00001Dr 1               ;     PROC_READY
00001Dr 1               ;     PROC_RUNNING
00001Dr 1               ;     PROC_BLOCKED
00001Dr 1               ;
00001Dr 1               ; proc_context[pid]:
00001Dr 1               ;   MMU context number associated with each process.
00001Dr 1               ;
00001Dr 1               ; proc_sp[pid]:
00001Dr 1               ;   Saved stack pointer for processes that have already executed
00001Dr 1               ;   and have been preempted/yielded at least once.
00001Dr 1               ;
00001Dr 1               ; proc_entryL/H[pid]:
00001Dr 1               ;   First-entry address for PROC_NEW tasks.
00001Dr 1               ;
00001Dr 1               ; proc_flags[pid]:
00001Dr 1               ;   Process characteristics flags.
00001Dr 1               ;
00001Dr 1               ; proc_parent_pid[pid]:
00001Dr 1               ;   PID of creator/owner process.
00001Dr 1               ;   $FF = no parent / kernel-owned.
00001Dr 1               ; ------------------------------------------------------------
00001Dr 1               
00001Dr 1               .export active_pid
00001Dr 1               .export sched_cursor_pid
00001Dr 1               .export proc_state
00001Dr 1               .export proc_context
00001Dr 1               .export proc_sp
00001Dr 1               .export proc_entryL
00001Dr 1               .export proc_entryH
00001Dr 1               .export proc_flags
00001Dr 1               .export proc_parent_pid
00001Dr 1               .export proc_signal_pending
00001Dr 1               
00001Dr 1               active_pid:
00001Dr 1  xx               .res 1
00001Er 1               
00001Er 1               sched_cursor_pid:
00001Er 1  xx               .res 1
