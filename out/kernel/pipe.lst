000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; FD values
000000r 2               ; ------------------------------------------------------------
000000r 2               FD_NONE     = $FF        ; invalid / unused descriptor
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; FD flags (per process)
000000r 2               ;
000000r 2               ; These describe how the process uses the descriptor.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               FD_FLAG_READ    = $01
000000r 2               FD_FLAG_WRITE   = $02
000000r 2               FD_FLAG_CLOEXEC = $80    ; reserved for later exec() support
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Open object types (system-wide)
000000r 2               ;
000000r 2               ; Each open object represents a shared resource. Multiple
000000r 2               ; processes may reference the same object.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               OBJ_NONE    = $00
000000r 2               OBJ_DEVICE  = $01        ; console for now
000000r 2               OBJ_FILE    = $02        ; RP filesystem file handle
000000r 2               OBJ_PIPE    = $03        ; reserved
000000r 2               OBJ_DIR     = $04        ; RP filesystem directory handle
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; FD clone argument block
000000r 2               ;
000000r 2               ; Used by kernel-internal cross-process descriptor cloning.
000000r 2               ; The source descriptor is resolved in source_pid/source_fd and
000000r 2               ; attached to target_pid/target_fd with the same per-FD flags.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct fd_clone_args
000000r 2                   source_pid      .byte
000000r 2                   source_fd       .byte
000000r 2                   target_pid      .byte
000000r 2                   target_fd       .byte
000000r 2               .endstruct
000000r 2               
000000r 2               FD_CLONE_ARGS_SIZE = .sizeof(fd_clone_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Device identifiers
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               DEV_NONE        = $00
000000r 2               DEV_CONSOLE     = $01
000000r 2               
000000r 2               DEV_MAX         = $02
000000r 2               
000000r 2               ; Each dev_ops entry is one 16-bit operation-table pointer.
000000r 2               DEV_OPS_ENTRY_SIZE = 2
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Device operation offsets
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               DEVOP_READ      = 0
000000r 2               DEVOP_WRITE     = 2
000000r 2               DEVOP_IOCTL     = 4
000000r 2               DEVOP_CLOSE     = 6
000000r 2               
000000r 2               .endif
