000000r 4               __PROCESS_INC__ = 1
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Process states
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               PROC_EMPTY      = $00
000000r 4               PROC_NEW        = $01
000000r 4               PROC_READY      = $02
000000r 4               PROC_RUNNING    = $03
000000r 4               PROC_BLOCKED    = $04
000000r 4               PROC_STOPPED    = $05
000000r 4               PROC_ZOMBIE     = $06
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Flags byte bit definitions
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               PROC_FLAG_NONE              = $00
000000r 4               PROC_FLAG_IDLE              = $01
000000r 4               PROC_FLAG_ATTACHED_CON      = $02
000000r 4               PROC_FLAG_FOREGROUND        = $04
000000r 4               PROC_FLAG_SIGINT_INTERRUPT  = $08
000000r 4               
000000r 4               ; Flags that may be supplied as initial process characteristics by a
000000r 4               ; boot-task record or resident spawn request. PROC_FLAG_IDLE remains
000000r 4               ; kernel-owned and cannot be requested through these creation interfaces.
000000r 4               PROC_FLAGS_CREATE_MASK = PROC_FLAG_ATTACHED_CON | PROC_FLAG_FOREGROUND | PROC_FLAG_SIGINT_INTERRUPT
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Process frame format
000000r 4               ;
000000r 4               ; All saved runnable process stacks use the IRQ-compatible
000000r 4               ; extended RTI frame:
000000r 4               ;     Y, X, A, P, PCL, PCH
000000r 4               ; The scheduler has no per-process resume mode; normal task
000000r 4               ; resume is always RTI.
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Process wait reasons
000000r 4               ;
000000r 4               ; WAIT_NONE means the process is not blocked on a known wait object.
000000r 4               ; Other values describe why a PROC_BLOCKED process is blocked.
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               WAIT_NONE       = $00
000000r 4               WAIT_CONSOLE    = $01
000000r 4               WAIT_DEVICE     = $02
000000r 4               WAIT_PIPE_READ  = $03        ; pipe read wait on empty pipe
000000r 4               WAIT_PIPE       = WAIT_PIPE_READ ; compatibility alias
000000r 4               WAIT_TIMER      = $04
000000r 4               WAIT_PROC       = $05
000000r 4               
000000r 4               ; Generic sleepable gate wait.
000000r 4               ;
000000r 4               ; wait_object identifies the gate object:
000000r 4               ;   LOCK_ID_FILE_IO = FD/open-object/pipe/console syscall gate
000000r 4               ;   LOCK_ID_PROC    = future process-management syscall gate
000000r 4               WAIT_LOCK       = $06
000000r 4               
000000r 4               ; Pipe write wait on a full pipe. Kept separate from WAIT_PIPE_READ so
000000r 4               ; readers and writers can be woken by the correct readiness event.
000000r 4               WAIT_PIPE_WRITE = $07
000000r 4               
000000r 4               ; Blocked while retaining FILE_IO ownership until the RP2350 completes
000000r 4               ; the single active generic filesystem request. wait_object contains the
000000r 4               ; filesystem operation code.
000000r 4               WAIT_RP         = $08
000000r 4               
000000r 4               LOCK_ID_FILE_IO = $00
000000r 4               LOCK_ID_PROC    = $01
000000r 4               
000000r 4               ; Diagnostic gate-hold mask returned by SYS_GETPROCINFO.
000000r 4               PROC_HOLD_NONE     = $00
000000r 4               PROC_HOLD_FILE_IO  = $01
000000r 4               PROC_HOLD_PROC     = $02
000000r 4               
000000r 4               ; Sentinel used for free gate owners and empty gate wait queues.
000000r 4               GATE_OWNER_NONE = $FF
000000r 4               
000000r 4               EXIT_OK         = $00
000000r 4               
000000r 4               .endif
000000r 4               
000000r 3               
000000r 3               SPAWN_FLAGS_NONE = PROC_FLAG_NONE
000000r 3               SPAWN_FLAGS_VALID = PROC_FLAGS_CREATE_MASK
000000r 3               SPAWN_LAUNCH_NONE = $FF
000000r 3               SPAWN_FD_CLOSED = $FF
000000r 3               
000000r 3               ; Maximum process-private launch-line storage including its terminating NUL.
000000r 3               ; The public length excludes the NUL and must be less than SPAWN_LINE_MAX.
000000r 3               SPAWN_LINE_MAX = 64
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; spawn_resident_args
000000r 3               ;
000000r 3               ; The parent transfers one opaque argument line to the child. The kernel
000000r 3               ; does not tokenize, count, quote, or otherwise interpret argument bytes.
000000r 3               ; arg_line_len excludes the terminating NUL.
000000r 3               ; ------------------------------------------------------------
000000r 3               .struct spawn_resident_args
000000r 3                   entry           .word
000000r 3                   launch_id       .byte
000000r 3                   arg_line_ptr    .word
000000r 3                   arg_line_len    .byte
000000r 3                   stdin_fd        .byte
000000r 3                   stdout_fd       .byte
000000r 3                   stderr_fd       .byte
000000r 3                   flags           .byte   ; initial child proc_flags
000000r 3                   result_pid      .byte
000000r 3               .endstruct
000000r 3               
000000r 3               SPAWN_RESIDENT_ARGS_SIZE = .sizeof(spawn_resident_args)
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; spawn_get_line_args
000000r 3               ;
000000r 3               ; Child-side retrieval of the opaque launch argument line.
000000r 3               ; buffer_size includes space for the terminating NUL.
000000r 3               ; result_len excludes the terminating NUL.
000000r 3               ; ------------------------------------------------------------
000000r 3               .struct spawn_get_line_args
000000r 3                   buffer_ptr      .word
000000r 3                   buffer_size     .byte
000000r 3                   result_len      .byte
000000r 3               .endstruct
000000r 3               
000000r 3               SPAWN_GET_LINE_ARGS_SIZE = .sizeof(spawn_get_line_args)
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Common open argument block
000000r 2               ;
000000r 2               ; path_ptr:
000000r 2               ;   Pointer to a NUL-terminated 8.3 filename in the current task
000000r 2               ;   context. The RP-side FS_OPEN command scans at most max_len bytes.
000000r 2               ;
000000r 2               ; max_len:
000000r 2               ;   Maximum filename scan length. Use a small bounded value such as 64.
000000r 2               ;
000000r 2               ; flags:
000000r 2               ;   Open mode. V32 supports read-only, write/truncate, write-existing,
000000r 2               ;   read/write-existing, and read/write-create.
000000r 2               ;
000000r 2               ; device:
000000r 2               ;   RP filesystem device/FatFs drive number: 0..3.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct open_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   flags           .byte
000000r 2                   device          .byte
000000r 2               .endstruct
000000r 2               
000000r 2               OPEN_ARGS_SIZE = .sizeof(open_args)
000000r 2               
000000r 2               OPEN_READ           = $00    ; read existing
000000r 2               OPEN_WRITE_TRUNC    = $01    ; write create/truncate
000000r 2               OPEN_WRITE_EXISTING = $02    ; write existing, no truncate
000000r 2               OPEN_RW_EXISTING    = $03    ; read/write existing, no truncate
000000r 2               OPEN_RW_CREATE      = $04    ; read/write create if missing, no truncate if existing
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Bulk filesystem argument blocks
000000r 2               ;
000000r 2               ; Names and paths use NEOX 8.3 path components. The path string is
000000r 2               ; NUL-terminated and is validated by the RP side.
000000r 2               ;
000000r 2               ; max_bytes / byte_count:
000000r 2               ;   $0000 means 65536 bytes.
000000r 2               ;
000000r 2               ; flags:
000000r 2               ;   Reserved for now. Must be 0.
000000r 2               ;
000000r 2               ; Context rule:
000000r 2               ;   User code never supplies a context. The kernel derives the caller
000000r 2               ;   context and passes it separately to the RP mailbox in ARG2L.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct fs_load_args
000000r 2                   path_ptr        .word
000000r 2                   dest_ptr        .word
000000r 2                   max_bytes       .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               FS_LOAD_ARGS_SIZE = .sizeof(fs_load_args)
000000r 2               
000000r 2               .struct fs_save_args
000000r 2                   path_ptr        .word
000000r 2                   src_ptr         .word
000000r 2                   byte_count      .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               FS_SAVE_ARGS_SIZE = .sizeof(fs_save_args)
000000r 2               
000000r 2               FS_BULK_FLAGS_NONE = $00
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Seek/tell filesystem argument blocks
000000r 2               ;
000000r 2               ; offset_lo/offset_hi:
000000r 2               ;   Signed 32-bit offset split into low/high words.  SEEK_SET
000000r 2               ;   requires a non-negative final target; SEEK_CUR and SEEK_END
000000r 2               ;   allow negative offsets.
000000r 2               ;
000000r 2               ; result_lo/result_hi:
000000r 2               ;   Kernel writes the resulting unsigned 32-bit file position here.
000000r 2               ;   A/X also return result_lo for convenience.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               SEEK_SET            = $00
000000r 2               SEEK_CUR            = $01
000000r 2               SEEK_END            = $02
000000r 2               
000000r 2               .struct seek_args
000000r 2                   fd              .byte
000000r 2                   whence          .byte
000000r 2                   offset_lo       .word
000000r 2                   offset_hi       .word
000000r 2                   result_lo       .word
000000r 2                   result_hi       .word
000000r 2               .endstruct
000000r 2               
000000r 2               SEEK_ARGS_SIZE = .sizeof(seek_args)
000000r 2               
000000r 2               .struct tell_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2                   result_lo       .word
000000r 2                   result_hi       .word
000000r 2               .endstruct
000000r 2               
000000r 2               TELL_ARGS_SIZE = .sizeof(tell_args)
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Delete/rename filesystem argument blocks
000000r 2               ;
000000r 2               ; V34 path handling uses the same RP-side 8.3 validator as open.
000000r 2               ; flags is reserved and must be 0.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               FS_PATH_FLAGS_NONE  = $00
000000r 2               
000000r 2               .struct delete_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               DELETE_ARGS_SIZE = .sizeof(delete_args)
000000r 2               
000000r 2               .struct rename_args
000000r 2                   old_path_ptr    .word
000000r 2                   new_path_ptr    .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               RENAME_ARGS_SIZE = .sizeof(rename_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Common read/write argument block
000000r 2               ;
000000r 2               ; fd:
000000r 2               ;   STDIN / STDOUT / STDERR
000000r 2               ;
000000r 2               ; buf_ptr:
000000r 2               ;   Pointer to caller buffer in the current task context
000000r 2               ;
000000r 2               ; len:
000000r 2               ;   Requested transfer length
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct rw_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2                   buf_ptr         .word
000000r 2                   len             .word
000000r 2               .endstruct
000000r 2               
000000r 2               RW_ARGS_SIZE = .sizeof(rw_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; SYSCALL helper macro
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Load X/Y with the address of an argument block and call the
000000r 2               ;   fixed syscall entry.
000000r 2               ;
000000r 2               ; Example:
000000r 2               ;   SYSCALL my_args, sys_write
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .macro SYSCALL argblk, entry
000000r 2                   ; Keep the register argument pointer stable across the tiny user-side
000000r 2                   ; setup window. The kernel snapshots the process-private pointer before
000000r 2                   ; taking file_io_gate and decodes the block after the owner resumes.
000000r 2                   sei
000000r 2                   ldx #<argblk
000000r 2                   ldy #>argblk
000000r 2                   jsr entry
000000r 2               .endmacro
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Directory control argument blocks
000000r 2               ;
000000r 2               ; V35 exposes directory handles as normal NEOX fd numbers. The RP
000000r 2               ; directory handle remains kernel-private in the FD/open-object table.
000000r 2               ;
000000r 2               ; dir_entry layout matches the RP serialized directory entry:
000000r 2               ;   name[13] = NUL-terminated 8.3 name
000000r 2               ;   attr     = FatFs attribute byte
000000r 2               ;   size     = unsigned 32-bit byte size
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               DIR_ENTRY_NAME_SIZE = 13
000000r 2               DIR_ENTRY_SIZE      = 18
000000r 2               
000000r 2               .struct dir_entry
000000r 2                   name            .res 13
000000r 2                   attr            .byte
000000r 2                   size_lo         .word
000000r 2                   size_hi         .word
000000r 2               .endstruct
000000r 2               
000000r 2               .struct opendir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               OPENDIR_ARGS_SIZE = .sizeof(opendir_args)
000000r 2               
000000r 2               .struct readdir_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2                   entry_ptr       .word
000000r 2                   entry_size      .word
000000r 2               .endstruct
000000r 2               
000000r 2               READDIR_ARGS_SIZE = .sizeof(readdir_args)
000000r 2               
000000r 2               .struct closedir_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2               .endstruct
000000r 2               
000000r 2               CLOSEDIR_ARGS_SIZE = .sizeof(closedir_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Current directory argument blocks
000000r 2               ;
000000r 2               ; V36 stores current directory per process as drive + absolute path.
000000r 2               ; User-visible getcwd form is D:/PATH.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               NEOX_PATH_FLAGS_NONE = $00
000000r 2               
000000r 2               .struct chdir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               CHDIR_ARGS_SIZE = .sizeof(chdir_args)
000000r 2               
000000r 2               .struct getcwd_args
000000r 2                   buffer_ptr      .word
000000r 2                   buffer_size     .word
000000r 2                   result_len      .word
000000r 2                   flags           .byte
000000r 2                   reserved        .byte
000000r 2               .endstruct
000000r 2               
000000r 2               GETCWD_ARGS_SIZE = .sizeof(getcwd_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Directory create/remove argument blocks
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct mkdir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               MKDIR_ARGS_SIZE = .sizeof(mkdir_args)
000000r 2               
000000r 2               .struct rmdir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               RMDIR_ARGS_SIZE = .sizeof(rmdir_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Process information argument block
000000r 2               ;
000000r 2               ; SYS_GETPROCINFO copies one compact process-table snapshot record
000000r 2               ; into caller memory.  The record is deliberately binary; user-space
000000r 2               ; commands such as PS own all text formatting.
000000r 2               ;
000000r 2               ; Record layout:
000000r 2               ;   +0 pid
000000r 2               ;   +1 ppid
000000r 2               ;   +2 state
000000r 2               ;   +3 wait_reason
000000r 2               ;   +4 signal_pending
000000r 2               ;   +5 wait_object
000000r 2               ;   +6 held_gate_mask (PROC_HOLD_*)
000000r 2               ;
000000r 2               ; Kernels accepting the extended record remain compatible with callers
000000r 2               ; that provide the original five-byte buffer.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               PROCINFO_RECORD_MIN_SIZE = 5
000000r 2               PROCINFO_RECORD_SIZE     = 7
000000r 2               
000000r 2               .struct procinfo_args
000000r 2                   pid             .byte
000000r 2                   reserved        .byte
000000r 2                   buffer_ptr      .word
000000r 2                   buffer_size     .word
000000r 2               .endstruct
000000r 2               
000000r 2               PROCINFO_ARGS_SIZE = .sizeof(procinfo_args)
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               .include "process.inc"
000000r 2               .ifndef __PROCESS_INC__
000000r 2               __PROCESS_INC__ = 1
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Process states
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               PROC_EMPTY      = $00
000000r 2               PROC_NEW        = $01
000000r 2               PROC_READY      = $02
000000r 2               PROC_RUNNING    = $03
000000r 2               PROC_BLOCKED    = $04
000000r 2               PROC_STOPPED    = $05
000000r 2               PROC_ZOMBIE     = $06
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Flags byte bit definitions
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               PROC_FLAG_NONE              = $00
000000r 2               PROC_FLAG_IDLE              = $01
000000r 2               PROC_FLAG_ATTACHED_CON      = $02
000000r 2               PROC_FLAG_FOREGROUND        = $04
000000r 2               PROC_FLAG_SIGINT_INTERRUPT  = $08
000000r 2               
000000r 2               ; Flags that may be supplied as initial process characteristics by a
000000r 2               ; boot-task record or resident spawn request. PROC_FLAG_IDLE remains
000000r 2               ; kernel-owned and cannot be requested through these creation interfaces.
000000r 2               PROC_FLAGS_CREATE_MASK = PROC_FLAG_ATTACHED_CON | PROC_FLAG_FOREGROUND | PROC_FLAG_SIGINT_INTERRUPT
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Process frame format
000000r 2               ;
000000r 2               ; All saved runnable process stacks use the IRQ-compatible
000000r 2               ; extended RTI frame:
000000r 2               ;     Y, X, A, P, PCL, PCH
000000r 2               ; The scheduler has no per-process resume mode; normal task
000000r 2               ; resume is always RTI.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Process wait reasons
000000r 2               ;
000000r 2               ; WAIT_NONE means the process is not blocked on a known wait object.
000000r 2               ; Other values describe why a PROC_BLOCKED process is blocked.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               WAIT_NONE       = $00
000000r 2               WAIT_CONSOLE    = $01
000000r 2               WAIT_DEVICE     = $02
000000r 2               WAIT_PIPE_READ  = $03        ; pipe read wait on empty pipe
000000r 2               WAIT_PIPE       = WAIT_PIPE_READ ; compatibility alias
000000r 2               WAIT_TIMER      = $04
000000r 2               WAIT_PROC       = $05
000000r 2               
000000r 2               ; Generic sleepable gate wait.
000000r 2               ;
000000r 2               ; wait_object identifies the gate object:
000000r 2               ;   LOCK_ID_FILE_IO = FD/open-object/pipe/console syscall gate
000000r 2               ;   LOCK_ID_PROC    = future process-management syscall gate
000000r 2               WAIT_LOCK       = $06
000000r 2               
000000r 2               ; Pipe write wait on a full pipe. Kept separate from WAIT_PIPE_READ so
000000r 2               ; readers and writers can be woken by the correct readiness event.
000000r 2               WAIT_PIPE_WRITE = $07
000000r 2               
000000r 2               ; Blocked while retaining FILE_IO ownership until the RP2350 completes
000000r 2               ; the single active generic filesystem request. wait_object contains the
000000r 2               ; filesystem operation code.
000000r 2               WAIT_RP         = $08
000000r 2               
000000r 2               LOCK_ID_FILE_IO = $00
000000r 2               LOCK_ID_PROC    = $01
000000r 2               
000000r 2               ; Diagnostic gate-hold mask returned by SYS_GETPROCINFO.
000000r 2               PROC_HOLD_NONE     = $00
000000r 2               PROC_HOLD_FILE_IO  = $01
000000r 2               PROC_HOLD_PROC     = $02
000000r 2               
000000r 2               ; Sentinel used for free gate owners and empty gate wait queues.
000000r 2               GATE_OWNER_NONE = $FF
000000r 2               
000000r 2               EXIT_OK         = $00
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               
000000r 1               .export pipe_init_tables
000000r 1               .export pipe_read
000000r 1               .export pipe_write
000000r 1               .export pipe_close_endpoint
000000r 1               
000000r 1               .export pipe_create
000000r 1               .export pipe_create_between_fd
000000r 1               
000000r 1               .import fd_alloc_open
000000r 1               .import fd_free_open
000000r 1               .import fd_alloc_fd_current
000000r 1               .import fd_attach_current
000000r 1               .import fd_detach_current
000000r 1               .import fd_init_open
000000r 1               .import fd_check_free_pid_fd
000000r 1               .import fd_attach_pid_fd_read
000000r 1               .import fd_attach_pid_fd_write
000000r 1               
000000r 1               .import pipe_state
000000r 1               .import pipe_head
000000r 1               .import pipe_tail
000000r 1               .import pipe_count
000000r 1               .import pipe_buf
000000r 1               
000000r 1               .import open_pipe
000000r 1               .import open_pipe_mode
000000r 1               
000000r 1               .importzp pipe_ptr
000000r 1               .importzp pipe_buf_ptr
000000r 1               
000000r 1               .import file_io_gate_acquire
000000r 1               .import file_io_gate_release
000000r 1               .import scheduler_wake_one
000000r 1               .import mul8u
000000r 1               
000000r 1               .segment "KERN_BSS"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; Pipe-private scratch
000000r 1               ;
000000r 1               ; These variables are protected by file_io_gate.
000000r 1               ;
000000r 1               ; Rules:
000000r 1               ;   - valid only while file_io_gate is held
000000r 1               ;   - never live across sched_yield
000000r 1               ;   - never live across a call into another backend subsystem
000000r 1               ;   - pipe_read / pipe_write are nonblocking primitives
000000r 1               ;
000000r 1               ; This intentionally matches the fd.asm style: subsystem-private
000000r 1               ; scratch under a subsystem lock, instead of stack-frame state.
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1  xx           pipe_obj:           .res 1      ; pair read open object
000001r 1  xx           pipe_idx:           .res 1      ; pipe table index
000002r 1  xx           pipe_mode:          .res 1      ; pair write object / close mode or wait reason
000003r 1               
000003r 1  xx           pipe_req_lo:        .res 1      ; requested byte count low / temporary errno
000004r 1  xx           pipe_req_hi:        .res 1      ; requested byte count high
000005r 1               
000005r 1  xx           pipe_done_lo:       .res 1      ; completed byte count, always 0..PIPE_BUF_SIZE
000006r 1               
000006r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               .assert (MAX_PIPES * PIPE_BUF_SIZE) <= $10000, error, "configured pipe storage exceeds 16-bit address range"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; pipe_set_buf_base
000000r 1               ;
000000r 1               ; Input:
000000r 1               ;   X = pipe index
000000r 1               ;
000000r 1               ; Output:
000000r 1               ;   pipe_buf_ptr = pipe_buf + X * PIPE_BUF_SIZE
000000r 1               ;
000000r 1               ; Clobbers:
000000r 1               ;   A, flags
000000r 1               ;
000000r 1               ; Preserves:
000000r 1               ;   X, Y
000000r 1               ;
000000r 1               ; Notes:
000000r 1               ;   Uses mul8u so PIPE_BUF_SIZE remains configurable.
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               .proc pipe_set_buf_base
000000r 1  DA               phx
000001r 1               
000001r 1  8A               txa
000002r 1  A2 40            ldx #PIPE_BUF_SIZE
000004r 1  20 rr rr         jsr mul8u
000007r 1               
000007r 1  18               clc
000008r 1  69 rr            adc #<pipe_buf
00000Ar 1  85 rr            sta pipe_buf_ptr
00000Cr 1               
00000Cr 1  8A               txa
00000Dr 1  69 rr            adc #>pipe_buf
00000Fr 1  85 rr            sta pipe_buf_ptr+1
000011r 1               
000011r 1  FA               plx
000012r 1  60               rts
000013r 1               .endproc
000013r 1               
000013r 1               ; ------------------------------------------------------------
000013r 1               ; pipe_init_tables
000013r 1               ;
000013r 1               ; Clears pipe table and open-object pipe metadata.
000013r 1               ;
000013r 1               ; Return:
000013r 1               ;   C clear
000013r 1               ;
000013r 1               ; Clobbers: A, X
000013r 1               ; ------------------------------------------------------------
000013r 1               
000013r 1               .proc pipe_init_tables
000013r 1               
000013r 1  A2 00            ldx #$00
000015r 1               @clear_pipes:
000015r 1  9E rr rr         stz pipe_state,x
000018r 1  9E rr rr         stz pipe_head,x
00001Br 1  9E rr rr         stz pipe_tail,x
00001Er 1  9E rr rr         stz pipe_count,x
000021r 1  E8               inx
000022r 1  E0 08            cpx #MAX_PIPES
000024r 1  D0 EF            bne @clear_pipes
000026r 1               
000026r 1  A2 00            ldx #$00
000028r 1               @clear_open:
000028r 1  A9 FF            lda #PIPE_NONE
00002Ar 1  9D rr rr         sta open_pipe,x
00002Dr 1  9E rr rr         stz open_pipe_mode,x
000030r 1  E8               inx
000031r 1  E0 10            cpx #OPEN_MAX
000033r 1  D0 F3            bne @clear_open
000035r 1               
000035r 1  18               clc
000036r 1  60               rts
000037r 1               .endproc
000037r 1               
000037r 1               ; ------------------------------------------------------------
000037r 1               ; pipe_alloc_pair
000037r 1               ;
000037r 1               ; Allocate and initialize one complete pipe backend pair.
000037r 1               ;
000037r 1               ; Caller:
000037r 1               ;   must hold file_io_gate
000037r 1               ;
000037r 1               ; Return:
000037r 1               ;   C clear:
000037r 1               ;       A = pipe index
000037r 1               ;       X = read open object
000037r 1               ;       Y = write open object
000037r 1               ;
000037r 1               ;   C set:
000037r 1               ;       Y = errno
000037r 1               ;
000037r 1               ; Notes:
000037r 1               ;   This routine owns all common open-object, pipe-table, endpoint
000037r 1               ;   initialization, and pre-attachment rollback work.
000037r 1               ;
000037r 1               ;   pipe_obj / pipe_mode / pipe_idx are used as protected scratch:
000037r 1               ;       pipe_obj  = read open object
000037r 1               ;       pipe_mode = write open object
000037r 1               ;       pipe_idx  = pipe index
000037r 1               ; ------------------------------------------------------------
000037r 1               
000037r 1               .proc pipe_alloc_pair
000037r 1  A9 FF            lda #PIPE_NONE
000039r 1  8D rr rr         sta pipe_obj
00003Cr 1  8D rr rr         sta pipe_mode
00003Fr 1  8D rr rr         sta pipe_idx
000042r 1               
000042r 1  20 rr rr         jsr fd_alloc_open
000045r 1  90 01            bcc @read_obj_ok
000047r 1  60               rts
000048r 1               
000048r 1               @read_obj_ok:
000048r 1  8E rr rr         stx pipe_obj
00004Br 1               
00004Br 1  A9 03            lda #OBJ_PIPE
00004Dr 1  A0 01            ldy #FD_FLAG_READ
00004Fr 1  20 rr rr         jsr fd_init_open
000052r 1               
000052r 1  20 rr rr         jsr fd_alloc_open
000055r 1  90 0E            bcc @write_obj_ok
000057r 1               
000057r 1  8C rr rr         sty pipe_req_lo
00005Ar 1  AE rr rr         ldx pipe_obj
00005Dr 1  20 rr rr         jsr fd_free_open
000060r 1  AC rr rr         ldy pipe_req_lo
000063r 1  38               sec
000064r 1  60               rts
000065r 1               
000065r 1               @write_obj_ok:
000065r 1  8E rr rr         stx pipe_mode
000068r 1               
000068r 1  A9 03            lda #OBJ_PIPE
00006Ar 1  A0 02            ldy #FD_FLAG_WRITE
00006Cr 1  20 rr rr         jsr fd_init_open
00006Fr 1               
00006Fr 1  20 rr rr         jsr pipe_alloc
000072r 1  90 14            bcc @pipe_ok
000074r 1               
000074r 1  8C rr rr         sty pipe_req_lo
000077r 1               
000077r 1  AE rr rr         ldx pipe_mode
00007Ar 1  20 rr rr         jsr fd_free_open
00007Dr 1               
00007Dr 1  AE rr rr         ldx pipe_obj
000080r 1  20 rr rr         jsr fd_free_open
000083r 1               
000083r 1  AC rr rr         ldy pipe_req_lo
000086r 1  38               sec
000087r 1  60               rts
000088r 1               
000088r 1               @pipe_ok:
000088r 1  8D rr rr         sta pipe_idx
00008Br 1               
00008Br 1  AD rr rr         lda pipe_obj
00008Er 1  AE rr rr         ldx pipe_idx
000091r 1  A0 01            ldy #PIPE_END_READ
000093r 1  20 rr rr         jsr pipe_endpoint_init
000096r 1               
000096r 1  AD rr rr         lda pipe_mode
000099r 1  AE rr rr         ldx pipe_idx
00009Cr 1  A0 02            ldy #PIPE_END_WRITE
00009Er 1  20 rr rr         jsr pipe_endpoint_init
0000A1r 1               
0000A1r 1  AD rr rr         lda pipe_idx
0000A4r 1  AE rr rr         ldx pipe_obj
0000A7r 1  AC rr rr         ldy pipe_mode
0000AAr 1  18               clc
0000ABr 1  60               rts
0000ACr 1               .endproc
0000ACr 1               
0000ACr 1               ; ------------------------------------------------------------
0000ACr 1               ; pipe_release_pair
0000ACr 1               ;
0000ACr 1               ; Roll back a complete, unattached pipe pair.
0000ACr 1               ;
0000ACr 1               ; Input:
0000ACr 1               ;   X = read open object
0000ACr 1               ;   Y = write open object
0000ACr 1               ;
0000ACr 1               ; Caller:
0000ACr 1               ;   must hold file_io_gate
0000ACr 1               ;
0000ACr 1               ; Return:
0000ACr 1               ;   C clear
0000ACr 1               ; ------------------------------------------------------------
0000ACr 1               
0000ACr 1               .proc pipe_release_pair
0000ACr 1  DA               phx
0000ADr 1               
0000ADr 1  98               tya
0000AEr 1  48               pha
0000AFr 1  20 rr rr         jsr pipe_close_endpoint
0000B2r 1               
0000B2r 1  68               pla
0000B3r 1  AA               tax
0000B4r 1  20 rr rr         jsr fd_free_open
0000B7r 1               
0000B7r 1  68               pla
0000B8r 1  48               pha
0000B9r 1  20 rr rr         jsr pipe_close_endpoint
0000BCr 1               
0000BCr 1  68               pla
0000BDr 1  AA               tax
0000BEr 1  4C rr rr         jmp fd_free_open
0000C1r 1               .endproc
0000C1r 1               
0000C1r 1               ; ------------------------------------------------------------
0000C1r 1               ; pipe_create
0000C1r 1               ;
0000C1r 1               ; Create an anonymous pipe for active_pid.
0000C1r 1               ;
0000C1r 1               ; Return:
0000C1r 1               ;   C clear = success
0000C1r 1               ;             A = read fd
0000C1r 1               ;             X = write fd
0000C1r 1               ;
0000C1r 1               ;   C set   = failure
0000C1r 1               ;             Y = errno
0000C1r 1               ;
0000C1r 1               ; Stack frame while active:
0000C1r 1               ;   $0101,S = errno
0000C1r 1               ;   $0102,S = read open object
0000C1r 1               ;   $0103,S = write open object
0000C1r 1               ;   $0104,S = read fd
0000C1r 1               ;   $0105,S = write fd
0000C1r 1               ; ------------------------------------------------------------
0000C1r 1               
0000C1r 1               .proc pipe_create
0000C1r 1  A9 FF            lda #PIPE_NONE
0000C3r 1  48               pha
0000C4r 1  48               pha
0000C5r 1  48               pha
0000C6r 1  48               pha
0000C7r 1               
0000C7r 1  A9 03            lda #EIO
0000C9r 1  48               pha
0000CAr 1               
0000CAr 1  20 rr rr         jsr pipe_alloc_pair
0000CDr 1  90 08            bcc @pair_ok
0000CFr 1               
0000CFr 1  98               tya
0000D0r 1  BA               tsx
0000D1r 1  9D 01 01         sta $0101,x
0000D4r 1  4C rr rr         jmp @fail_frame
0000D7r 1               
0000D7r 1               @pair_ok:
0000D7r 1  BA               tsx
0000D8r 1  AD rr rr         lda pipe_obj
0000DBr 1  9D 02 01         sta $0102,x
0000DEr 1               
0000DEr 1  AD rr rr         lda pipe_mode
0000E1r 1  9D 03 01         sta $0103,x
0000E4r 1               
0000E4r 1  20 rr rr         jsr fd_alloc_fd_current
0000E7r 1  90 08            bcc @read_fd_ok
0000E9r 1               
0000E9r 1  98               tya
0000EAr 1  BA               tsx
0000EBr 1  9D 01 01         sta $0101,x
0000EEr 1  4C rr rr         jmp @fail_pair
0000F1r 1               
0000F1r 1               @read_fd_ok:
0000F1r 1  98               tya
0000F2r 1  BA               tsx
0000F3r 1  9D 04 01         sta $0104,x
0000F6r 1               
0000F6r 1  BC 04 01         ldy $0104,x
0000F9r 1  BD 02 01         lda $0102,x
0000FCr 1  AA               tax
0000FDr 1  A9 01            lda #FD_FLAG_READ
0000FFr 1  20 rr rr         jsr fd_attach_current
000102r 1               
000102r 1  20 rr rr         jsr fd_alloc_fd_current
000105r 1  90 08            bcc @write_fd_ok
000107r 1               
000107r 1  98               tya
000108r 1  BA               tsx
000109r 1  9D 01 01         sta $0101,x
00010Cr 1  4C rr rr         jmp @fail_read_fd
00010Fr 1               
00010Fr 1               @write_fd_ok:
00010Fr 1  98               tya
000110r 1  BA               tsx
000111r 1  9D 05 01         sta $0105,x
000114r 1               
000114r 1  BC 05 01         ldy $0105,x
000117r 1  BD 03 01         lda $0103,x
00011Ar 1  AA               tax
00011Br 1  A9 02            lda #FD_FLAG_WRITE
00011Dr 1  20 rr rr         jsr fd_attach_current
000120r 1               
000120r 1  BA               tsx
000121r 1  BD 04 01         lda $0104,x
000124r 1  48               pha
000125r 1               
000125r 1  BD 05 01         lda $0105,x
000128r 1  48               pha
000129r 1               
000129r 1  68               pla
00012Ar 1  AA               tax
00012Br 1               
00012Br 1  68               pla
00012Cr 1  A8               tay
00012Dr 1               
00012Dr 1  68               pla
00012Er 1  68               pla
00012Fr 1  68               pla
000130r 1  68               pla
000131r 1  68               pla
000132r 1               
000132r 1  98               tya
000133r 1  18               clc
000134r 1  60               rts
000135r 1               
000135r 1               @fail_read_fd:
000135r 1  BA               tsx
000136r 1  BD 04 01         lda $0104,x
000139r 1  20 rr rr         jsr fd_detach_current
00013Cr 1               
00013Cr 1               @fail_pair:
00013Cr 1  BA               tsx
00013Dr 1  BD 02 01         lda $0102,x
000140r 1  48               pha
000141r 1               
000141r 1  BD 03 01         lda $0103,x
000144r 1  A8               tay
000145r 1               
000145r 1  68               pla
000146r 1  AA               tax
000147r 1  20 rr rr         jsr pipe_release_pair
00014Ar 1               
00014Ar 1               @fail_frame:
00014Ar 1  BA               tsx
00014Br 1  BC 01 01         ldy $0101,x
00014Er 1               
00014Er 1  68               pla
00014Fr 1  68               pla
000150r 1  68               pla
000151r 1  68               pla
000152r 1  68               pla
000153r 1               
000153r 1  38               sec
000154r 1  60               rts
000155r 1               .endproc
