000155r 1               ; ------------------------------------------------------------
000155r 1               ; pipe_create_between_fd
000155r 1               ;
000155r 1               ; Kernel-only static wiring helper.
000155r 1               ;
000155r 1               ; Input:
000155r 1               ;   A = reader PID
000155r 1               ;   X = writer PID
000155r 1               ;   Y = fd number to install in both processes
000155r 1               ;
000155r 1               ; Return:
000155r 1               ;   C clear = success
000155r 1               ;   C set   = failure, Y = errno
000155r 1               ; ------------------------------------------------------------
000155r 1               
000155r 1               .proc pipe_create_between_fd
000155r 1  48               pha
000156r 1  DA               phx
000157r 1  5A               phy
000158r 1  20 rr rr         jsr file_io_gate_acquire
00015Br 1  B0 07            bcs @gate_acquired
00015Dr 1               
00015Dr 1  7A               ply
00015Er 1  FA               plx
00015Fr 1  68               pla
000160r 1  A0 06            ldy #EINVAL
000162r 1  38               sec
000163r 1  60               rts
000164r 1               
000164r 1               @gate_acquired:
000164r 1  7A               ply
000165r 1  FA               plx
000166r 1  68               pla
000167r 1               
000167r 1  20 rr rr         jsr pipe_create_between_fd_inner
00016Ar 1               
00016Ar 1  08               php
00016Br 1  48               pha
00016Cr 1  DA               phx
00016Dr 1  5A               phy
00016Er 1  20 rr rr         jsr file_io_gate_release
000171r 1  7A               ply
000172r 1  FA               plx
000173r 1  68               pla
000174r 1  28               plp
000175r 1  60               rts
000176r 1               .endproc
000176r 1               
000176r 1               ; ------------------------------------------------------------
000176r 1               ; pipe_create_between_fd_inner
000176r 1               ;
000176r 1               ; Input:
000176r 1               ;   A = reader PID
000176r 1               ;   X = writer PID
000176r 1               ;   Y = common fd
000176r 1               ;
000176r 1               ; Caller:
000176r 1               ;   must hold file_io_gate
000176r 1               ;
000176r 1               ; Stack frame:
000176r 1               ;   $0101,S = errno
000176r 1               ;   $0102,S = write open object
000176r 1               ;   $0103,S = read open object
000176r 1               ;   $0104,S = common fd
000176r 1               ;   $0105,S = writer PID
000176r 1               ;   $0106,S = reader PID
000176r 1               ; ------------------------------------------------------------
000176r 1               
000176r 1               .proc pipe_create_between_fd_inner
000176r 1  48               pha
000177r 1  DA               phx
000178r 1  5A               phy
000179r 1               
000179r 1  A9 FF            lda #PIPE_NONE
00017Br 1  48               pha
00017Cr 1  48               pha
00017Dr 1               
00017Dr 1  A9 03            lda #EIO
00017Fr 1  48               pha
000180r 1               
000180r 1  BA               tsx
000181r 1  BD 06 01         lda $0106,x
000184r 1  DD 05 01         cmp $0105,x
000187r 1  D0 08            bne @pids_ok
000189r 1               
000189r 1  A9 06            lda #EINVAL
00018Br 1  9D 01 01         sta $0101,x
00018Er 1  4C rr rr         jmp @fail_frame
000191r 1               
000191r 1               @pids_ok:
000191r 1  BC 04 01         ldy $0104,x
000194r 1  BD 06 01         lda $0106,x
000197r 1  AA               tax
000198r 1  20 rr rr         jsr fd_check_free_pid_fd
00019Br 1  90 08            bcc @reader_fd_free
00019Dr 1               
00019Dr 1  98               tya
00019Er 1  BA               tsx
00019Fr 1  9D 01 01         sta $0101,x
0001A2r 1  4C rr rr         jmp @fail_frame
0001A5r 1               
0001A5r 1               @reader_fd_free:
0001A5r 1  BA               tsx
0001A6r 1  BC 04 01         ldy $0104,x
0001A9r 1  BD 05 01         lda $0105,x
0001ACr 1  AA               tax
0001ADr 1  20 rr rr         jsr fd_check_free_pid_fd
0001B0r 1  90 08            bcc @writer_fd_free
0001B2r 1               
0001B2r 1  98               tya
0001B3r 1  BA               tsx
0001B4r 1  9D 01 01         sta $0101,x
0001B7r 1  4C rr rr         jmp @fail_frame
0001BAr 1               
0001BAr 1               @writer_fd_free:
0001BAr 1  20 rr rr         jsr pipe_alloc_pair
0001BDr 1  90 08            bcc @pair_ok
0001BFr 1               
0001BFr 1  98               tya
0001C0r 1  BA               tsx
0001C1r 1  9D 01 01         sta $0101,x
0001C4r 1  4C rr rr         jmp @fail_frame
0001C7r 1               
0001C7r 1               @pair_ok:
0001C7r 1  BA               tsx
0001C8r 1  AD rr rr         lda pipe_mode
0001CBr 1  9D 02 01         sta $0102,x
0001CEr 1               
0001CEr 1  AD rr rr         lda pipe_obj
0001D1r 1  9D 03 01         sta $0103,x
0001D4r 1               
0001D4r 1  BC 04 01         ldy $0104,x
0001D7r 1  BD 03 01         lda $0103,x
0001DAr 1  48               pha
0001DBr 1               
0001DBr 1  BD 06 01         lda $0106,x
0001DEr 1  FA               plx
0001DFr 1  20 rr rr         jsr fd_attach_pid_fd_read
0001E2r 1  90 08            bcc @read_attached
0001E4r 1               
0001E4r 1  98               tya
0001E5r 1  BA               tsx
0001E6r 1  9D 01 01         sta $0101,x
0001E9r 1  4C rr rr         jmp @fail_frame
0001ECr 1               
0001ECr 1               @read_attached:
0001ECr 1  BA               tsx
0001EDr 1  BC 04 01         ldy $0104,x
0001F0r 1  BD 02 01         lda $0102,x
0001F3r 1  48               pha
0001F4r 1               
0001F4r 1  BD 05 01         lda $0105,x
0001F7r 1  FA               plx
0001F8r 1  20 rr rr         jsr fd_attach_pid_fd_write
0001FBr 1  90 08            bcc @success
0001FDr 1               
0001FDr 1  98               tya
0001FEr 1  BA               tsx
0001FFr 1  9D 01 01         sta $0101,x
000202r 1  4C rr rr         jmp @fail_frame
000205r 1               
000205r 1               @success:
000205r 1  68               pla
000206r 1  68               pla
000207r 1  68               pla
000208r 1  68               pla
000209r 1  68               pla
00020Ar 1  68               pla
00020Br 1               
00020Br 1  18               clc
00020Cr 1  60               rts
00020Dr 1               
00020Dr 1               @fail_frame:
00020Dr 1  BA               tsx
00020Er 1  BC 01 01         ldy $0101,x
000211r 1               
000211r 1  68               pla
000212r 1  68               pla
000213r 1  68               pla
000214r 1  68               pla
000215r 1  68               pla
000216r 1  68               pla
000217r 1               
000217r 1  38               sec
000218r 1  60               rts
000219r 1               .endproc
000219r 1               
000219r 1               ; ------------------------------------------------------------
000219r 1               ; pipe_alloc
000219r 1               ;
000219r 1               ; Allocate a pipe table entry.
000219r 1               ;
000219r 1               ; Caller:
000219r 1               ;   must hold file_io_gate
000219r 1               ;
000219r 1               ; Return:
000219r 1               ;   C clear, A = pipe index
000219r 1               ;   C set,   Y = ENOMEM
000219r 1               ;
000219r 1               ; Clobbers: A, X, Y
000219r 1               ; ------------------------------------------------------------
000219r 1               
000219r 1               .proc pipe_alloc
000219r 1  A2 00            ldx #$00
00021Br 1               
00021Br 1               @scan:
00021Br 1  BD rr rr         lda pipe_state,x
00021Er 1  F0 09            beq @found
000220r 1               
000220r 1  E8               inx
000221r 1  E0 08            cpx #MAX_PIPES
000223r 1  D0 F6            bne @scan
000225r 1               
000225r 1  A0 0D            ldy #ENOMEM
000227r 1  38               sec
000228r 1  60               rts
000229r 1               
000229r 1               @found:
000229r 1  A9 03            lda #PIPE_STATE_USED
00022Br 1  9D rr rr         sta pipe_state,x
00022Er 1               
00022Er 1  9E rr rr         stz pipe_head,x
000231r 1  9E rr rr         stz pipe_tail,x
000234r 1  9E rr rr         stz pipe_count,x
000237r 1               
000237r 1  8A               txa
000238r 1  18               clc
000239r 1  60               rts
00023Ar 1               .endproc
00023Ar 1               
00023Ar 1               ; ------------------------------------------------------------
00023Ar 1               ; pipe_free
00023Ar 1               ;
00023Ar 1               ; Free a pipe table entry.
00023Ar 1               ;
00023Ar 1               ; Input:
00023Ar 1               ;   A = pipe index
00023Ar 1               ;
00023Ar 1               ; Caller:
00023Ar 1               ;   must hold file_io_gate
00023Ar 1               ;
00023Ar 1               ; Return:
00023Ar 1               ;   C clear
00023Ar 1               ;
00023Ar 1               ; Clobbers: A, X
00023Ar 1               ; ------------------------------------------------------------
00023Ar 1               
00023Ar 1               .proc pipe_free
00023Ar 1  AA               tax
00023Br 1               
00023Br 1  9E rr rr         stz pipe_state,x
00023Er 1  9E rr rr         stz pipe_head,x
000241r 1  9E rr rr         stz pipe_tail,x
000244r 1  9E rr rr         stz pipe_count,x
000247r 1               
000247r 1  18               clc
000248r 1  60               rts
000249r 1               .endproc
000249r 1               
000249r 1               ; ------------------------------------------------------------
000249r 1               ; pipe_endpoint_init
000249r 1               ;
000249r 1               ; Input:
000249r 1               ;   A = open object
000249r 1               ;   X = pipe index
000249r 1               ;   Y = PIPE_END_READ or PIPE_END_WRITE
000249r 1               ;
000249r 1               ; Caller:
000249r 1               ;   file_io_gate held
000249r 1               ;
000249r 1               ; Return:
000249r 1               ;   C clear
000249r 1               ;
000249r 1               ; Clobbers:
000249r 1               ;   A, X, flags
000249r 1               ; ------------------------------------------------------------
000249r 1               
000249r 1               .proc pipe_endpoint_init
000249r 1  DA               phx                         ; save pipe index
00024Ar 1  AA               tax                         ; X = open object
00024Br 1               
00024Br 1  68               pla                         ; A = pipe index
00024Cr 1  9D rr rr         sta open_pipe,x
00024Fr 1               
00024Fr 1  98               tya
000250r 1  9D rr rr         sta open_pipe_mode,x
000253r 1               
000253r 1  18               clc
000254r 1  60               rts
000255r 1               .endproc
000255r 1               
000255r 1               ; ------------------------------------------------------------
000255r 1               ; pipe_resolve_endpoint
000255r 1               ;
000255r 1               ; Resolve and validate one pipe endpoint.
000255r 1               ;
000255r 1               ; Input:
000255r 1               ;   A = required endpoint mode
000255r 1               ;   X = open object index
000255r 1               ;
000255r 1               ; Return:
000255r 1               ;   C clear:
000255r 1               ;       X = pipe index
000255r 1               ;       pipe_idx = pipe index
000255r 1               ;
000255r 1               ;   C set:
000255r 1               ;       Y = EBADF
000255r 1               ;
000255r 1               ; Caller:
000255r 1               ;   must hold file_io_gate
000255r 1               ;
000255r 1               ; Clobbers:
000255r 1               ;   A, X, Y, flags
000255r 1               ; ------------------------------------------------------------
000255r 1               
000255r 1               .proc pipe_resolve_endpoint
000255r 1  DD rr rr         cmp open_pipe_mode,x
000258r 1  D0 12            bne @bad_endpoint
00025Ar 1               
00025Ar 1  BD rr rr         lda open_pipe,x
00025Dr 1  C9 FF            cmp #PIPE_NONE
00025Fr 1  F0 0B            beq @bad_endpoint
000261r 1               
000261r 1  8D rr rr         sta pipe_idx
000264r 1  AA               tax
000265r 1               
000265r 1  BD rr rr         lda pipe_state,x
000268r 1  F0 02            beq @bad_endpoint
00026Ar 1               
00026Ar 1  18               clc
00026Br 1  60               rts
00026Cr 1               
00026Cr 1               @bad_endpoint:
00026Cr 1  A0 09            ldy #EBADF
00026Er 1  38               sec
00026Fr 1  60               rts
000270r 1               .endproc
000270r 1               
000270r 1               ; ------------------------------------------------------------
000270r 1               ; pipe_close_endpoint
000270r 1               ;
000270r 1               ; Close pipe endpoint effects.
000270r 1               ;
000270r 1               ; Input:
000270r 1               ;   A = open object index
000270r 1               ;
000270r 1               ; Return:
000270r 1               ;   C clear
000270r 1               ;
000270r 1               ; Locking:
000270r 1               ;   file_io_gate protects pipe-private scratch and pipe tables.
000270r 1               ;
000270r 1               ; Notes:
000270r 1               ;   - This does not touch proc_fd_obj/proc_fd_flags.
000270r 1               ;   - FD layer owns refcounts and open-object lifetime.
000270r 1               ;   - If the last writer closes while readers are blocked on an
000270r 1               ;     empty pipe, wake them so they can retry and observe EOF.
000270r 1               ;   - If the last reader closes while writers are blocked on a full
000270r 1               ;     pipe, wake them so they can retry and observe EPIPE.
000270r 1               ;
000270r 1               ; Clobbers:
000270r 1               ;   A, X, Y, flags
000270r 1               ; ------------------------------------------------------------
000270r 1               
000270r 1               .proc pipe_close_endpoint
000270r 1  AA               tax
000271r 1               
000271r 1  BD rr rr         lda open_pipe,x
000274r 1  C9 FF            cmp #PIPE_NONE
000276r 1  D0 02            bne @have_pipe
000278r 1               
000278r 1  18               clc
000279r 1  60               rts
00027Ar 1               
00027Ar 1               @have_pipe:
00027Ar 1  8D rr rr         sta pipe_idx
00027Dr 1               
00027Dr 1  BD rr rr         lda open_pipe_mode,x
000280r 1  8D rr rr         sta pipe_mode
000283r 1               
000283r 1                   ; Detach the final open-object reference from its endpoint.
000283r 1  A9 FF            lda #PIPE_NONE
000285r 1  9D rr rr         sta open_pipe,x
000288r 1  9E rr rr         stz open_pipe_mode,x
00028Br 1               
00028Br 1                   ; PIPE_END_READ/WRITE use the same bit values as the corresponding
00028Br 1                   ; pipe_state endpoint-presence flags.
00028Br 1  AD rr rr         lda pipe_mode
00028Er 1  C9 01            cmp #PIPE_END_READ
000290r 1  F0 04            beq @valid_mode
000292r 1               
000292r 1  C9 02            cmp #PIPE_END_WRITE
000294r 1  D0 31            bne @maybe_free
000296r 1               
000296r 1               @valid_mode:
000296r 1  AE rr rr         ldx pipe_idx
000299r 1               
000299r 1  BD rr rr         lda pipe_state,x
00029Cr 1  2D rr rr         and pipe_mode
00029Fr 1  F0 26            beq @maybe_free
0002A1r 1               
0002A1r 1                   ; Clear the endpoint-presence bit selected by pipe_mode.
0002A1r 1  AD rr rr         lda pipe_mode
0002A4r 1  49 FF            eor #$FF
0002A6r 1  3D rr rr         and pipe_state,x
0002A9r 1  9D rr rr         sta pipe_state,x
0002ACr 1               
0002ACr 1                   ; Closing the read end wakes writers for EPIPE.
0002ACr 1                   ; Closing the write end wakes readers for data/EOF.
0002ACr 1  AD rr rr         lda pipe_mode
0002AFr 1  C9 01            cmp #PIPE_END_READ
0002B1r 1  F0 04            beq @wake_writers
0002B3r 1               
0002B3r 1  A9 03            lda #WAIT_PIPE_READ
0002B5r 1  80 02            bra @wake_all
0002B7r 1               
0002B7r 1               @wake_writers:
0002B7r 1  A9 07            lda #WAIT_PIPE_WRITE
0002B9r 1               
0002B9r 1               @wake_all:
0002B9r 1  8D rr rr         sta pipe_mode
0002BCr 1               
0002BCr 1               @wake_next:
0002BCr 1  AD rr rr         lda pipe_mode
0002BFr 1  AC rr rr         ldy pipe_idx
0002C2r 1  20 rr rr         jsr scheduler_wake_one
0002C5r 1  90 F5            bcc @wake_next
0002C7r 1               
0002C7r 1               @maybe_free:
0002C7r 1  AE rr rr         ldx pipe_idx
0002CAr 1  BD rr rr         lda pipe_state,x
0002CDr 1  D0 04            bne @done
0002CFr 1               
0002CFr 1  8A               txa
0002D0r 1  20 rr rr         jsr pipe_free
0002D3r 1               
0002D3r 1               @done:
0002D3r 1  18               clc
0002D4r 1  60               rts
0002D5r 1               .endproc
0002D5r 1               
0002D5r 1               ; ------------------------------------------------------------
0002D5r 1               ; pipe_read
0002D5r 1               ;
0002D5r 1               ; Read from a pipe endpoint.
0002D5r 1               ;
0002D5r 1               ; Input:
0002D5r 1               ;   Y        = open object index
0002D5r 1               ;   pipe_ptr = destination buffer
0002D5r 1               ;   A/X      = requested length, low/high
0002D5r 1               ;
0002D5r 1               ; Return:
0002D5r 1               ;   C clear:
0002D5r 1               ;       A/X = bytes read
0002D5r 1               ;       A/X = 0 means EOF when no writers exist
0002D5r 1               ;
0002D5r 1               ;   C set:
0002D5r 1               ;       Y = errno
0002D5r 1               ;
0002D5r 1               ; Nonblocking semantics:
0002D5r 1               ;   empty + writers present -> EAGAIN
0002D5r 1               ;   empty + no writers      -> EOF / 0 bytes
0002D5r 1               ;
0002D5r 1               ; Locking:
0002D5r 1               ;   file_io_gate protects pipe-private scratch and pipe tables.
0002D5r 1               ;
0002D5r 1               ; Important:
0002D5r 1               ;   pipe-private scratch is safe because ksys_io owns file_io_gate
0002D5r 1               ;   before dispatching into the pipe backend.
0002D5r 1               ;
0002D5r 1               ; Clobbers:
0002D5r 1               ;   A, X, Y, flags
0002D5r 1               ; ------------------------------------------------------------
0002D5r 1               
0002D5r 1               .proc pipe_read
0002D5r 1                   ; Zero-length read succeeds immediately. This check uses only
0002D5r 1                   ; the incoming registers and does not touch shared scratch.
0002D5r 1  E0 00            cpx #$00
0002D7r 1  D0 09            bne @save_inputs
0002D9r 1               
0002D9r 1  C9 00            cmp #$00
0002DBr 1  D0 05            bne @save_inputs
0002DDr 1               
0002DDr 1  A9 00            lda #$00
0002DFr 1  AA               tax
0002E0r 1  18               clc
0002E1r 1  60               rts
0002E2r 1               
0002E2r 1               @save_inputs:
0002E2r 1                   ; Preserve call inputs before populating pipe-private scratch.
0002E2r 1  48               pha                         ; requested length low
0002E3r 1  DA               phx                         ; requested length high
0002E4r 1  5A               phy                         ; open object
0002E5r 1               
0002E5r 1               
0002E5r 1                   ; file_io_gate is already held by the syscall wrapper.
0002E5r 1  7A               ply                         ; Y = open object
0002E6r 1               
0002E6r 1  FA               plx
0002E7r 1  8E rr rr         stx pipe_req_hi
0002EAr 1               
0002EAr 1  68               pla
0002EBr 1  8D rr rr         sta pipe_req_lo
0002EEr 1               
0002EEr 1                   ; Resolve and validate the read endpoint.
0002EEr 1  98               tya
0002EFr 1  AA               tax
0002F0r 1  A9 01            lda #PIPE_END_READ
0002F2r 1  20 rr rr         jsr pipe_resolve_endpoint
0002F5r 1  90 01            bcc @state_ok
0002F7r 1               
0002F7r 1  60               rts
0002F8r 1               
0002F8r 1               @state_ok:
0002F8r 1                   ; Empty pipe:
0002F8r 1                   ;   writers present -> EAGAIN
0002F8r 1                   ;   no writers      -> EOF
0002F8r 1  BD rr rr         lda pipe_count,x
0002FBr 1  D0 0C            bne @can_read
0002FDr 1               
0002FDr 1  BD rr rr         lda pipe_state,x
000300r 1  29 02            and #PIPE_STATE_WRITE_OPEN
000302r 1  D0 4B            bne @err_eagain
000304r 1               
000304r 1               
000304r 1  A9 00            lda #$00
000306r 1  AA               tax
000307r 1  18               clc
000308r 1  60               rts
000309r 1               
000309r 1               @can_read:
000309r 1  9C rr rr         stz pipe_done_lo
00030Cr 1               
00030Cr 1                   ; Resolve this pipe's 64-byte buffer base once for the call.
00030Cr 1  20 rr rr         jsr pipe_set_buf_base
00030Fr 1               
00030Fr 1               @read_loop:
00030Fr 1                   ; Stop when requested length has been reached.
00030Fr 1                   ;
00030Fr 1                   ; If req_hi != 0, the pipe buffer will empty first because
00030Fr 1                   ; PIPE_BUF_SIZE is currently 64 bytes.
00030Fr 1  AD rr rr         lda pipe_req_hi
000312r 1  D0 08            bne @check_available
000314r 1               
000314r 1  AD rr rr         lda pipe_done_lo
000317r 1  CD rr rr         cmp pipe_req_lo
00031Ar 1  F0 20            beq @done
00031Cr 1               
00031Cr 1               @check_available:
00031Cr 1  BD rr rr         lda pipe_count,x
00031Fr 1  F0 1B            beq @done
000321r 1               
000321r 1                   ; Read one byte from pipe buffer[tail] into user buffer[done].
000321r 1  BC rr rr         ldy pipe_tail,x
000324r 1  B1 rr            lda (pipe_buf_ptr),y
000326r 1               
000326r 1  AC rr rr         ldy pipe_done_lo
000329r 1  91 rr            sta (pipe_ptr),y
00032Br 1               
00032Br 1                   ; Advance tail.
00032Br 1  BD rr rr         lda pipe_tail,x
00032Er 1  1A               ina
00032Fr 1  29 3F            and #(PIPE_BUF_SIZE - 1)
000331r 1  9D rr rr         sta pipe_tail,x
000334r 1               
000334r 1  DE rr rr         dec pipe_count,x
000337r 1               
000337r 1                   ; done++. One call can transfer at most PIPE_BUF_SIZE bytes,
000337r 1                   ; so the one-byte counter cannot wrap.
000337r 1  EE rr rr         inc pipe_done_lo
00033Ar 1  80 D3            bra @read_loop
00033Cr 1               
00033Cr 1               @done:
00033Cr 1                   ; If at least one byte was read, wake one blocked writer.
00033Cr 1                   ; The backend can return at most PIPE_BUF_SIZE bytes, so X is zero.
00033Cr 1  AD rr rr         lda pipe_done_lo
00033Fr 1  F0 0A            beq @return_done
000341r 1               
000341r 1  48               pha
000342r 1  A9 07            lda #WAIT_PIPE_WRITE
000344r 1  AC rr rr         ldy pipe_idx
000347r 1  20 rr rr         jsr scheduler_wake_one
00034Ar 1  68               pla
00034Br 1               
00034Br 1               @return_done:
00034Br 1  A2 00            ldx #$00
00034Dr 1  18               clc
00034Er 1  60               rts
00034Fr 1               
00034Fr 1               @err_eagain:
00034Fr 1               
00034Fr 1  A0 0C            ldy #EAGAIN
000351r 1  38               sec
000352r 1  60               rts
000353r 1               .endproc
000353r 1               
000353r 1               ; ------------------------------------------------------------
000353r 1               ; pipe_write
000353r 1               ;
000353r 1               ; Write to a pipe endpoint.
000353r 1               ;
000353r 1               ; Input:
000353r 1               ;   Y        = open object index
000353r 1               ;   pipe_ptr = source buffer
000353r 1               ;   A/X      = requested length, low/high
000353r 1               ;
000353r 1               ; Return:
000353r 1               ;   C clear:
000353r 1               ;       A/X = bytes written
000353r 1               ;       short write is possible when pipe fills after progress
000353r 1               ;
000353r 1               ;   C set:
000353r 1               ;       Y = errno
000353r 1               ;
000353r 1               ; Nonblocking semantics:
000353r 1               ;   no readers                -> EPIPE
000353r 1               ;   full + zero bytes written -> EAGAIN
000353r 1               ;   full + some bytes written -> short success
000353r 1               ;
000353r 1               ; Locking:
000353r 1               ;   file_io_gate protects pipe-private scratch and pipe tables.
000353r 1               ;
000353r 1               ; Important:
000353r 1               ;   pipe-private scratch is safe because ksys_io owns file_io_gate
000353r 1               ;   before dispatching into the pipe backend.
000353r 1               ;
000353r 1               ; Clobbers:
000353r 1               ;   A, X, Y, flags
000353r 1               ; ------------------------------------------------------------
000353r 1               
000353r 1               .proc pipe_write
000353r 1                   ; Zero-length write succeeds immediately. This check uses only
000353r 1                   ; the incoming registers and does not touch shared scratch.
000353r 1  E0 00            cpx #$00
000355r 1  D0 09            bne @save_inputs
000357r 1               
000357r 1  C9 00            cmp #$00
000359r 1  D0 05            bne @save_inputs
00035Br 1               
00035Br 1  A9 00            lda #$00
00035Dr 1  AA               tax
00035Er 1  18               clc
00035Fr 1  60               rts
000360r 1               
000360r 1               @save_inputs:
000360r 1                   ; Preserve call inputs before populating pipe-private scratch.
000360r 1  48               pha                         ; requested length low
000361r 1  DA               phx                         ; requested length high
000362r 1  5A               phy                         ; open object
000363r 1               
000363r 1               
000363r 1                   ; file_io_gate is already held by the syscall wrapper.
000363r 1  7A               ply                         ; Y = open object
000364r 1               
000364r 1  FA               plx
000365r 1  8E rr rr         stx pipe_req_hi
000368r 1               
000368r 1  68               pla
000369r 1  8D rr rr         sta pipe_req_lo
00036Cr 1               
00036Cr 1                   ; Resolve and validate the write endpoint.
00036Cr 1  98               tya
00036Dr 1  AA               tax
00036Er 1  A9 02            lda #PIPE_END_WRITE
000370r 1  20 rr rr         jsr pipe_resolve_endpoint
000373r 1  90 01            bcc @state_ok
000375r 1               
000375r 1  60               rts
000376r 1               
000376r 1               @state_ok:
000376r 1                   ; Broken pipe: no readers.
000376r 1  BD rr rr         lda pipe_state,x
000379r 1  29 01            and #PIPE_STATE_READ_OPEN
00037Br 1  D0 03            bne @can_start
00037Dr 1               
00037Dr 1  4C rr rr         jmp @err_epipe
000380r 1               
000380r 1               @can_start:
000380r 1  9C rr rr         stz pipe_done_lo
000383r 1               
000383r 1                   ; Resolve this pipe's 64-byte buffer base once for the call.
000383r 1  20 rr rr         jsr pipe_set_buf_base
000386r 1               
000386r 1               @write_loop:
000386r 1                   ; Stop when requested length has been reached.
000386r 1                   ;
000386r 1                   ; If req_hi != 0, the pipe buffer will fill first because
000386r 1                   ; PIPE_BUF_SIZE is currently 64 bytes.
000386r 1  AD rr rr         lda pipe_req_hi
000389r 1  D0 08            bne @check_space
00038Br 1               
00038Br 1  AD rr rr         lda pipe_done_lo
00038Er 1  CD rr rr         cmp pipe_req_lo
000391r 1  F0 2A            beq @done
000393r 1               
000393r 1               @check_space:
000393r 1  BD rr rr         lda pipe_count,x
000396r 1  C9 40            cmp #PIPE_BUF_SIZE
000398r 1  D0 08            bne @space_available
00039Ar 1               
00039Ar 1                   ; Full pipe.
00039Ar 1                   ; If some progress was made, return a short write.
00039Ar 1  AD rr rr         lda pipe_done_lo
00039Dr 1  D0 1E            bne @done
00039Fr 1               
00039Fr 1                   ; Full with zero progress: nonblocking would-block.
00039Fr 1  4C rr rr         jmp @err_eagain
0003A2r 1               
0003A2r 1               @space_available:
0003A2r 1                   ; Write one byte from user buffer[done] to pipe buffer[head].
0003A2r 1  AC rr rr         ldy pipe_done_lo
0003A5r 1  B1 rr            lda (pipe_ptr),y
0003A7r 1               
0003A7r 1  BC rr rr         ldy pipe_head,x
0003AAr 1  91 rr            sta (pipe_buf_ptr),y
0003ACr 1               
0003ACr 1                   ; Advance head.
0003ACr 1  BD rr rr         lda pipe_head,x
0003AFr 1  1A               ina
0003B0r 1  29 3F            and #(PIPE_BUF_SIZE - 1)
0003B2r 1  9D rr rr         sta pipe_head,x
0003B5r 1               
0003B5r 1  FE rr rr         inc pipe_count,x
0003B8r 1               
0003B8r 1                   ; done++. One call can transfer at most PIPE_BUF_SIZE bytes,
0003B8r 1                   ; so the one-byte counter cannot wrap.
0003B8r 1  EE rr rr         inc pipe_done_lo
0003BBr 1  80 C9            bra @write_loop
0003BDr 1               
0003BDr 1               @done:
0003BDr 1                   ; If at least one byte was written, wake one blocked reader.
0003BDr 1                   ; The backend can return at most PIPE_BUF_SIZE bytes, so X is zero.
0003BDr 1  AD rr rr         lda pipe_done_lo
0003C0r 1  F0 0A            beq @return_done
0003C2r 1               
0003C2r 1  48               pha
0003C3r 1  A9 03            lda #WAIT_PIPE_READ
0003C5r 1  AC rr rr         ldy pipe_idx
0003C8r 1  20 rr rr         jsr scheduler_wake_one
0003CBr 1  68               pla
0003CCr 1               
0003CCr 1               @return_done:
0003CCr 1  A2 00            ldx #$00
0003CEr 1  18               clc
0003CFr 1  60               rts
0003D0r 1               
0003D0r 1               @err_eagain:
0003D0r 1               
0003D0r 1  A0 0C            ldy #EAGAIN
0003D2r 1  38               sec
0003D3r 1  60               rts
0003D4r 1               
0003D4r 1               @err_epipe:
0003D4r 1               
0003D4r 1  A0 0E            ldy #EPIPE
0003D6r 1  38               sec
0003D7r 1  60               rts
0003D8r 1               .endproc
0003D8r 1               
