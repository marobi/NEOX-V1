0000D5r 1  4C rr rr         jmp @fail
0000D8r 1               @flags_ok:
0000D8r 1  20 rr rr         jsr fd_alloc_open
0000DBr 1  90 03            bcc @open_obj_ok
0000DDr 1  4C rr rr         jmp @fail
0000E0r 1               @open_obj_ok:
0000E0r 1  8E rr rr         stx ksys_open_obj
0000E3r 1  20 rr rr         jsr fd_alloc_fd_current
0000E6r 1  90 09            bcc @fd_ok
0000E8r 1  AE rr rr         ldx ksys_open_obj
0000EBr 1  20 rr rr         jsr fd_free_open
0000EEr 1  4C rr rr         jmp @fail
0000F1r 1               @fd_ok:
0000F1r 1  8C rr rr         sty ksys_open_fd
0000F4r 1  A9 02            lda #RP_FS_OP_OPEN
0000F6r 1  A2 FF            ldx #$FF
0000F8r 1  A0 00            ldy #0
0000FAr 1  20 rr rr         jsr rp_fs_exec
0000FDr 1  90 0B            bcc @rp_ok
0000FFr 1  5A               phy
000100r 1  AE rr rr         ldx ksys_open_obj
000103r 1  20 rr rr         jsr fd_free_open
000106r 1  7A               ply
000107r 1  4C rr rr         jmp @fail
00010Ar 1               @rp_ok:
00010Ar 1                   ; A = RP handle; Y = resolved device returned in RP_FLAGS.
00010Ar 1  8C rr rr         sty ksys_open_device
00010Dr 1  AE rr rr         ldx ksys_open_obj
