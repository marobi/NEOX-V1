0000BFr 1  C9 00            cmp #OPEN_READ
0000C1r 1  F0 15            beq @flags_ok
0000C3r 1  C9 01            cmp #OPEN_WRITE_TRUNC
0000C5r 1  F0 11            beq @flags_ok
0000C7r 1  C9 02            cmp #OPEN_WRITE_EXISTING
0000C9r 1  F0 0D            beq @flags_ok
