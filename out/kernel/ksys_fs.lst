000089r 1  48               pha
00008Ar 1  20 rr rr         jsr ksys_fs_begin
00008Dr 1  B0 03            bcs @owned
00008Fr 1               
00008Fr 1  68               pla
000090r 1  38               sec
000091r 1  60               rts
000092r 1               
000092r 1               @owned:
000092r 1  A0 00            ldy #$00
000094r 1  B1 rr            lda (io_ptr),y
000096r 1  A8               tay
000097r 1  20 rr rr         jsr fd_resolve_file
00009Ar 1  B0 0A            bcs @resolve_fail
00009Cr 1               
00009Cr 1  AA               tax
00009Dr 1  68               pla
00009Er 1  A0 00            ldy #$00
0000A0r 1  20 rr rr         jsr rp_fs_exec
0000A3r 1  4C rr rr         jmp ksys_fs_finish
0000A6r 1               
0000A6r 1               @resolve_fail:
0000A6r 1  68               pla
0000A7r 1  4C rr rr         jmp ksys_fs_finish
0000AAr 1               .endproc
