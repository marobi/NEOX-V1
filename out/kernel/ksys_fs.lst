000083r 1  20 rr rr         jsr rp_fs_exec
000086r 1  4C rr rr         jmp ksys_fs_finish
000089r 1               .endproc
000089r 1               
000089r 1               ; <summary>
000089r 1               ; Executes a file-handle operation whose fd is byte zero of the argument block.
000089r 1               ; </summary>
000089r 1               ; <param name="A">RP_FS_OP_SEEK or RP_FS_OP_TELL.</param>
000089r 1               ; <param name="X/Y">Caller argument-block pointer.</param>
