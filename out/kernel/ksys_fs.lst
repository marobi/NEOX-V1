000000r 3               .include "process.inc"
000000r 4               .ifndef __PROCESS_INC__
000000r 4               __PROCESS_INC__ = 1
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Process states
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               PROC_EMPTY      = $00
000000r 4               PROC_NEW        = $01
000000r 4               PROC_READY      = $02
000000r 4               PROC_RUNNING    = $03
000000r 4               PROC_BLOCKED    = $04
000000r 4               PROC_STOPPED    = $05
000000r 4               PROC_ZOMBIE     = $06
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Flags byte bit definitions
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               PROC_FLAG_NONE              = $00
000000r 4               PROC_FLAG_IDLE              = $01
000000r 4               PROC_FLAG_ATTACHED_CON      = $02
000000r 4               PROC_FLAG_FOREGROUND        = $04
000000r 4               PROC_FLAG_SIGINT_INTERRUPT  = $08
000000r 4               
000000r 4               ; Flags that may be supplied as initial process characteristics by a
000000r 4               ; boot-task record or resident spawn request. PROC_FLAG_IDLE remains
000000r 4               ; kernel-owned and cannot be requested through these creation interfaces.
000000r 4               PROC_FLAGS_CREATE_MASK = PROC_FLAG_ATTACHED_CON | PROC_FLAG_FOREGROUND | PROC_FLAG_SIGINT_INTERRUPT
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Process frame format
000000r 4               ;
000000r 4               ; All saved runnable process stacks use the IRQ-compatible
000000r 4               ; extended RTI frame:
000000r 4               ;     Y, X, A, P, PCL, PCH
000000r 4               ; The scheduler has no per-process resume mode; normal task
000000r 4               ; resume is always RTI.
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               ; ------------------------------------------------------------
000000r 4               ; Process wait reasons
000000r 4               ;
000000r 4               ; WAIT_NONE means the process is not blocked on a known wait object.
000000r 4               ; Other values describe why a PROC_BLOCKED process is blocked.
000000r 4               ; ------------------------------------------------------------
000000r 4               
000000r 4               WAIT_NONE       = $00
000000r 4               WAIT_CONSOLE    = $01
000000r 4               WAIT_DEVICE     = $02
000000r 4               WAIT_PIPE_READ  = $03        ; pipe read wait on empty pipe
000000r 4               WAIT_PIPE       = WAIT_PIPE_READ ; compatibility alias
000000r 4               WAIT_TIMER      = $04
000000r 4               WAIT_PROC       = $05
000000r 4               
000000r 4               ; Generic sleepable gate wait.
000000r 4               ;
000000r 4               ; wait_object identifies the gate object:
000000r 4               ;   LOCK_ID_FILE_IO = FD/open-object/pipe/console syscall gate
000000r 4               ;   LOCK_ID_PROC    = future process-management syscall gate
000000r 4               WAIT_LOCK       = $06
000000r 4               
000000r 4               ; Pipe write wait on a full pipe. Kept separate from WAIT_PIPE_READ so
000000r 4               ; readers and writers can be woken by the correct readiness event.
000000r 4               WAIT_PIPE_WRITE = $07
000000r 4               
000000r 4               ; Blocked while retaining FILE_IO ownership until the RP2350 completes
000000r 4               ; the single active generic filesystem request. wait_object contains the
000000r 4               ; filesystem operation code.
000000r 4               WAIT_RP         = $08
000000r 4               
000000r 4               LOCK_ID_FILE_IO = $00
000000r 4               LOCK_ID_PROC    = $01
000000r 4               
000000r 4               ; Diagnostic gate-hold mask returned by SYS_GETPROCINFO.
000000r 4               PROC_HOLD_NONE     = $00
000000r 4               PROC_HOLD_FILE_IO  = $01
000000r 4               PROC_HOLD_PROC     = $02
000000r 4               
000000r 4               ; Sentinel used for free gate owners and empty gate wait queues.
000000r 4               GATE_OWNER_NONE = $FF
000000r 4               
000000r 4               EXIT_OK         = $00
000000r 4               
000000r 4               .endif
000000r 4               
000000r 3               
000000r 3               SPAWN_FLAGS_NONE = PROC_FLAG_NONE
000000r 3               SPAWN_FLAGS_VALID = PROC_FLAGS_CREATE_MASK
000000r 3               SPAWN_LAUNCH_NONE = $FF
000000r 3               SPAWN_FD_CLOSED = $FF
000000r 3               
000000r 3               ; Maximum process-private launch-line storage including its terminating NUL.
000000r 3               ; The public length excludes the NUL and must be less than SPAWN_LINE_MAX.
000000r 3               SPAWN_LINE_MAX = 64
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; spawn_resident_args
000000r 3               ;
000000r 3               ; The parent transfers one opaque argument line to the child. The kernel
000000r 3               ; does not tokenize, count, quote, or otherwise interpret argument bytes.
000000r 3               ; arg_line_len excludes the terminating NUL.
000000r 3               ; ------------------------------------------------------------
000000r 3               .struct spawn_resident_args
000000r 3                   entry           .word
000000r 3                   launch_id       .byte
000000r 3                   arg_line_ptr    .word
000000r 3                   arg_line_len    .byte
000000r 3                   stdin_fd        .byte
000000r 3                   stdout_fd       .byte
000000r 3                   stderr_fd       .byte
000000r 3                   flags           .byte   ; initial child proc_flags
000000r 3                   result_pid      .byte
000000r 3               .endstruct
000000r 3               
000000r 3               SPAWN_RESIDENT_ARGS_SIZE = .sizeof(spawn_resident_args)
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; spawn_get_line_args
000000r 3               ;
000000r 3               ; Child-side retrieval of the opaque launch argument line.
000000r 3               ; buffer_size includes space for the terminating NUL.
000000r 3               ; result_len excludes the terminating NUL.
000000r 3               ; ------------------------------------------------------------
000000r 3               .struct spawn_get_line_args
000000r 3                   buffer_ptr      .word
000000r 3                   buffer_size     .byte
000000r 3                   result_len      .byte
000000r 3               .endstruct
000000r 3               
000000r 3               SPAWN_GET_LINE_ARGS_SIZE = .sizeof(spawn_get_line_args)
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Common open argument block
000000r 2               ;
000000r 2               ; path_ptr:
000000r 2               ;   Pointer to a NUL-terminated 8.3 filename in the current task
000000r 2               ;   context. The RP-side FS_OPEN command scans at most max_len bytes.
000000r 2               ;
000000r 2               ; max_len:
000000r 2               ;   Maximum filename scan length. Use a small bounded value such as 64.
000000r 2               ;
000000r 2               ; flags:
000000r 2               ;   Open mode. V32 supports read-only, write/truncate, write-existing,
000000r 2               ;   read/write-existing, and read/write-create.
000000r 2               ;
000000r 2               ; device:
000000r 2               ;   RP filesystem device/FatFs drive number: 0..3.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct open_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   flags           .byte
000000r 2                   device          .byte
000000r 2               .endstruct
000000r 2               
000000r 2               OPEN_ARGS_SIZE = .sizeof(open_args)
000000r 2               
000000r 2               OPEN_READ           = $00    ; read existing
000000r 2               OPEN_WRITE_TRUNC    = $01    ; write create/truncate
000000r 2               OPEN_WRITE_EXISTING = $02    ; write existing, no truncate
000000r 2               OPEN_RW_EXISTING    = $03    ; read/write existing, no truncate
000000r 2               OPEN_RW_CREATE      = $04    ; read/write create if missing, no truncate if existing
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Bulk filesystem argument blocks
000000r 2               ;
000000r 2               ; Names and paths use NEOX 8.3 path components. The path string is
000000r 2               ; NUL-terminated and is validated by the RP side.
000000r 2               ;
000000r 2               ; max_bytes / byte_count:
000000r 2               ;   $0000 means 65536 bytes.
000000r 2               ;
000000r 2               ; flags:
000000r 2               ;   Reserved for now. Must be 0.
000000r 2               ;
000000r 2               ; Context rule:
000000r 2               ;   User code never supplies a context. The kernel derives the caller
000000r 2               ;   context and passes it separately to the RP mailbox in ARG2L.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct fs_load_args
000000r 2                   path_ptr        .word
000000r 2                   dest_ptr        .word
000000r 2                   max_bytes       .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               FS_LOAD_ARGS_SIZE = .sizeof(fs_load_args)
000000r 2               
000000r 2               .struct fs_save_args
000000r 2                   path_ptr        .word
000000r 2                   src_ptr         .word
000000r 2                   byte_count      .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               FS_SAVE_ARGS_SIZE = .sizeof(fs_save_args)
000000r 2               
000000r 2               FS_BULK_FLAGS_NONE = $00
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Seek/tell filesystem argument blocks
000000r 2               ;
000000r 2               ; offset_lo/offset_hi:
000000r 2               ;   Signed 32-bit offset split into low/high words.  SEEK_SET
000000r 2               ;   requires a non-negative final target; SEEK_CUR and SEEK_END
000000r 2               ;   allow negative offsets.
000000r 2               ;
000000r 2               ; result_lo/result_hi:
000000r 2               ;   Kernel writes the resulting unsigned 32-bit file position here.
000000r 2               ;   A/X also return result_lo for convenience.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               SEEK_SET            = $00
000000r 2               SEEK_CUR            = $01
000000r 2               SEEK_END            = $02
000000r 2               
000000r 2               .struct seek_args
000000r 2                   fd              .byte
000000r 2                   whence          .byte
000000r 2                   offset_lo       .word
000000r 2                   offset_hi       .word
000000r 2                   result_lo       .word
000000r 2                   result_hi       .word
000000r 2               .endstruct
000000r 2               
000000r 2               SEEK_ARGS_SIZE = .sizeof(seek_args)
000000r 2               
000000r 2               .struct tell_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2                   result_lo       .word
000000r 2                   result_hi       .word
000000r 2               .endstruct
000000r 2               
000000r 2               TELL_ARGS_SIZE = .sizeof(tell_args)
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Delete/rename filesystem argument blocks
000000r 2               ;
000000r 2               ; V34 path handling uses the same RP-side 8.3 validator as open.
000000r 2               ; flags is reserved and must be 0.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               FS_PATH_FLAGS_NONE  = $00
000000r 2               
000000r 2               .struct delete_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               DELETE_ARGS_SIZE = .sizeof(delete_args)
000000r 2               
000000r 2               .struct rename_args
000000r 2                   old_path_ptr    .word
000000r 2                   new_path_ptr    .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               RENAME_ARGS_SIZE = .sizeof(rename_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Common read/write argument block
000000r 2               ;
000000r 2               ; fd:
000000r 2               ;   STDIN / STDOUT / STDERR
000000r 2               ;
000000r 2               ; buf_ptr:
000000r 2               ;   Pointer to caller buffer in the current task context
000000r 2               ;
000000r 2               ; len:
000000r 2               ;   Requested transfer length
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct rw_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2                   buf_ptr         .word
000000r 2                   len             .word
000000r 2               .endstruct
000000r 2               
000000r 2               RW_ARGS_SIZE = .sizeof(rw_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; SYSCALL helper macro
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Load X/Y with the address of an argument block and call the
000000r 2               ;   fixed syscall entry.
000000r 2               ;
000000r 2               ; Example:
000000r 2               ;   SYSCALL my_args, sys_write
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .macro SYSCALL argblk, entry
000000r 2                   ; Keep the register argument pointer stable across the tiny user-side
000000r 2                   ; setup window. The kernel snapshots the process-private pointer before
000000r 2                   ; taking file_io_gate and decodes the block after the owner resumes.
000000r 2                   sei
000000r 2                   ldx #<argblk
000000r 2                   ldy #>argblk
000000r 2                   jsr entry
000000r 2               .endmacro
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Directory control argument blocks
000000r 2               ;
000000r 2               ; V35 exposes directory handles as normal NEOX fd numbers. The RP
000000r 2               ; directory handle remains kernel-private in the FD/open-object table.
000000r 2               ;
000000r 2               ; dir_entry layout matches the RP serialized directory entry:
000000r 2               ;   name[13] = NUL-terminated 8.3 name
000000r 2               ;   attr     = FatFs attribute byte
000000r 2               ;   size     = unsigned 32-bit byte size
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               DIR_ENTRY_NAME_SIZE = 13
000000r 2               DIR_ENTRY_SIZE      = 18
000000r 2               
000000r 2               .struct dir_entry
000000r 2                   name            .res 13
000000r 2                   attr            .byte
000000r 2                   size_lo         .word
000000r 2                   size_hi         .word
000000r 2               .endstruct
000000r 2               
000000r 2               .struct opendir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               OPENDIR_ARGS_SIZE = .sizeof(opendir_args)
000000r 2               
000000r 2               .struct readdir_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2                   entry_ptr       .word
000000r 2                   entry_size      .word
000000r 2               .endstruct
000000r 2               
000000r 2               READDIR_ARGS_SIZE = .sizeof(readdir_args)
000000r 2               
000000r 2               .struct closedir_args
000000r 2                   fd              .byte
000000r 2                   reserved        .byte
000000r 2               .endstruct
000000r 2               
000000r 2               CLOSEDIR_ARGS_SIZE = .sizeof(closedir_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Current directory argument blocks
000000r 2               ;
000000r 2               ; V36 stores current directory per process as drive + absolute path.
000000r 2               ; User-visible getcwd form is D:/PATH.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               NEOX_PATH_FLAGS_NONE = $00
000000r 2               
000000r 2               .struct chdir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               CHDIR_ARGS_SIZE = .sizeof(chdir_args)
000000r 2               
000000r 2               .struct getcwd_args
000000r 2                   buffer_ptr      .word
000000r 2                   buffer_size     .word
000000r 2                   result_len      .word
000000r 2                   flags           .byte
000000r 2                   reserved        .byte
000000r 2               .endstruct
000000r 2               
000000r 2               GETCWD_ARGS_SIZE = .sizeof(getcwd_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Directory create/remove argument blocks
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct mkdir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               MKDIR_ARGS_SIZE = .sizeof(mkdir_args)
000000r 2               
000000r 2               .struct rmdir_args
000000r 2                   path_ptr        .word
000000r 2                   max_len         .word
000000r 2                   device          .byte
000000r 2                   flags           .byte
000000r 2               .endstruct
000000r 2               
000000r 2               RMDIR_ARGS_SIZE = .sizeof(rmdir_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Process information argument block
000000r 2               ;
000000r 2               ; SYS_GETPROCINFO copies one compact process-table snapshot record
000000r 2               ; into caller memory.  The record is deliberately binary; user-space
000000r 2               ; commands such as PS own all text formatting.
000000r 2               ;
000000r 2               ; Record layout:
000000r 2               ;   +0 pid
000000r 2               ;   +1 ppid
000000r 2               ;   +2 state
000000r 2               ;   +3 wait_reason
000000r 2               ;   +4 signal_pending
000000r 2               ;   +5 wait_object
000000r 2               ;   +6 held_gate_mask (PROC_HOLD_*)
000000r 2               ;
000000r 2               ; Kernels accepting the extended record remain compatible with callers
000000r 2               ; that provide the original five-byte buffer.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               PROCINFO_RECORD_MIN_SIZE = 5
000000r 2               PROCINFO_RECORD_SIZE     = 7
000000r 2               
000000r 2               .struct procinfo_args
000000r 2                   pid             .byte
000000r 2                   reserved        .byte
000000r 2                   buffer_ptr      .word
000000r 2                   buffer_size     .word
000000r 2               .endstruct
000000r 2               
000000r 2               PROCINFO_ARGS_SIZE = .sizeof(procinfo_args)
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               .include "mailbox.inc"
000000r 2               ; ============================================================
000000r 2               ; mailbox.inc
000000r 2               ; NEOX - RP2350 mailbox / request block definitions
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   Defines the shared ABI v2 request/result block layout used
000000r 2               ;   for communication between the 6502 kernel/syscall code and
000000r 2               ;   the RP2350 co-processor.
000000r 2               ;
000000r 2               ; Architecture:
000000r 2               ;   - Logical pages 0..7 are private per context
000000r 2               ;   - Logical pages 8..F are shared across all contexts; page E is I/O
000000r 2               ;   - MMIO control registers live in shared I/O page
000000r 2               ;
000000r 2               ; ABI v2:
000000r 2               ;   - RP_REQ_BASE is $B000 in ordinary shared RAM
000000r 2               ;   - Request block starts with RP_GROUP and RP_CMD
000000r 2               ;   - RP_DOORBELL is trigger-only; command identity is not
000000r 2               ;     encoded in the doorbell value anymore.
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __MAILBOX_INC__
000000r 2               __MAILBOX_INC__ = 1
000000r 2               
000000r 2               .include "config.inc"
000000r 3               ; ============================================================
000000r 3               ; config.inc
000000r 3               ; NEOX - kernel configuration
000000r 3               ;
000000r 3               ; Purpose:
000000r 3               ; ============================================================
000000r 3               
000000r 3               .ifndef __CONFIG_INC__
000000r 3               __CONFIG_INC__ = 1
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_FDS     = 6          ; per-process descriptor count
000000r 3               OPEN_MAX    = 16         ; system-wide open object slots
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active processes
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_PROCS   = 8
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active timer waits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_TIMER   = 8
000000r 3               
000000r 3               ;
000000r 3               ;
000000r 3               ;
000000r 3               
000000r 3               MAX_PIPES       = 8
000000r 3               PIPE_BUF_SIZE   = 64
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Filesystem path limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               NEOX_CWD_MAX  = 32        ; process-private current-directory path bytes
000000r 3               NEOX_PATH_MAX = 64        ; kernel path resolver buffer bytes
000000r 3               ; ============================================================
000000r 3               ;
000000r 3               ; ============================================================
000000r 3               
000000r 3               USER_IMAGE_TABLE = $1000
000000r 3               
000000r 3               ; Final 32/32 virtual-memory split.
000000r 3               USER_SPACE_LIMIT = $8000
000000r 3               KERNEL_SHARED_BASE = $B020
000000r 3               KERNEL_OVERFLOW_BASE = $C000
000000r 3               MICMON_BASE = $D000
000000r 3               IO_PAGE_BASE = $E000
000000r 3               BIOS_BASE = $F000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Kernel
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               KERNEL_BASE = $8000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Syscall table location
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               SYSCALL_BASE = $F100
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; RP2350 mailbox control registers (MMIO)
000000r 3               ;
000000r 3               ; Layout:
000000r 3               ;   Page E is shared I/O space
000000r 3               ;   OS-owned mailbox doorbell starts at $E010
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_DOORBELL  = $E010
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Shared RAM request/result block (ordinary shared RAM, not I/O)
000000r 3               ;
000000r 3               ; mailbox request block.
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_REQ_BASE  = $B000
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Request / result block layout, ABI v2
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_GROUP            = RP_REQ_BASE + 0
000000r 2               RP_CMD              = RP_REQ_BASE + 1
000000r 2               RP_STATUS           = RP_REQ_BASE + 2
000000r 2               RP_ERR              = RP_REQ_BASE + 3
000000r 2               
000000r 2               RP_FLAGS            = RP_REQ_BASE + 4
000000r 2               RP_STATE            = RP_REQ_BASE + 5
000000r 2               
000000r 2               RP_ARG0L            = RP_REQ_BASE + 6
000000r 2               RP_ARG0H            = RP_REQ_BASE + 7
000000r 2               RP_ARG1L            = RP_REQ_BASE + 8
000000r 2               RP_ARG1H            = RP_REQ_BASE + 9
000000r 2               RP_ARG2L            = RP_REQ_BASE + 10
000000r 2               RP_ARG2H            = RP_REQ_BASE + 11
000000r 2               
000000r 2               RP_RES0L            = RP_REQ_BASE + 12
000000r 2               RP_RES0H            = RP_REQ_BASE + 13
000000r 2               RP_RES1L            = RP_REQ_BASE + 14
000000r 2               RP_RES1H            = RP_REQ_BASE + 15
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Other shared RP state bytes
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IRQ_SOURCE       = RP_REQ_BASE + 16
000000r 2               RP_CONSOLE_PID      = RP_REQ_BASE + 17
000000r 2               RP_CONSOLE_RDY      = RP_REQ_BASE + 18
000000r 2               RP_IRQ_STATE        = RP_REQ_BASE + 19
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_STATUS values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IDLE             = $00
000000r 2               RP_BUSY             = $01
000000r 2               RP_DONE             = $02
000000r 2               RP_ERROR            = $03
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_GROUP values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_GROUP_NONE       = $00
000000r 2               RP_GROUP_CONSOLE    = $01
000000r 2               RP_GROUP_FS         = $02
000000r 2               RP_GROUP_SYSTEM     = $03
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_CMD values inside RP_GROUP_CONSOLE
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_CON_CMD_NONE     = $00
000000r 2               RP_CON_CMD_WRITE    = $01
000000r 2               RP_CON_CMD_READ     = $02
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_CMD values inside RP_GROUP_FS
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_FS_CMD_NONE      = $00
000000r 2               RP_FS_CMD_EXEC      = $11
000000r 2               
000000r 2               ; Generic filesystem operations carried in RP_STATE. Values $01-$10 retain
000000r 2               ; their established numeric assignments, but are no longer accepted as direct
000000r 2               ; RP_CMD values.
000000r 2               RP_FS_OP_STATUS        = $01
000000r 2               RP_FS_OP_OPEN          = $02
000000r 2               RP_FS_OP_READ          = $03
000000r 2               RP_FS_OP_CLOSE         = $04
000000r 2               RP_FS_OP_WRITE         = $05
000000r 2               RP_FS_OP_LOAD          = $06
000000r 2               RP_FS_OP_SAVE          = $07
000000r 2               RP_FS_OP_SEEK          = $08
000000r 2               RP_FS_OP_TELL          = $09
000000r 2               RP_FS_OP_DELETE        = $0A
000000r 2               RP_FS_OP_RENAME        = $0B
000000r 2               RP_FS_OP_OPENDIR       = $0C
000000r 2               RP_FS_OP_READDIR       = $0D
000000r 2               RP_FS_OP_CLOSEDIR      = $0E
000000r 2               RP_FS_OP_MKDIR         = $0F
000000r 2               RP_FS_OP_RMDIR         = $10
000000r 2               RP_FS_OP_CWD_INIT_ROOT = $12
000000r 2               RP_FS_OP_CWD_CLONE     = $13
000000r 2               RP_FS_OP_CHDIR         = $14
000000r 2               RP_FS_OP_GETCWD        = $15
000000r 2               
000000r 2               RP_FS_SEEK_SET      = $00
000000r 2               RP_FS_SEEK_CUR      = $01
000000r 2               RP_FS_SEEK_END      = $02
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_DOORBELL trigger value for ABI v2
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_DOORBELL_TRIGGER = $01
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_FLAGS values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_FLAG_NONE        = $00
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_IRQ_SOURCE values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IRQ_SRC_NONE     = $00
000000r 2               RP_IRQ_SRC_TIMER    = $01
000000r 2               RP_IRQ_SRC_MONITOR  = $02
000000r 2               RP_IRQ_SRC_FS_DONE  = $03
000000r 2               RP_IRQ_SRC_CONSOLE_BREAK = $04
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               .include "fd.inc"
000000r 2               ; ============================================================
000000r 2               ; fd.inc
000000r 2               ; NEOX - file descriptor and open object definitions
000000r 2               ;
000000r 2               ; Purpose:
000000r 2               ;   devices/files.
000000r 2               ;   This forms the FD/open-object/device layer
000000r 2               ;   used by read/write/close/dup/dup2.;
000000r 2               ; Model:
000000r 2               ;   process fd table → open object table → device/file backend
000000r 2               ; ============================================================
000000r 2               
000000r 2               .ifndef __FD_INC__
000000r 2               __FD_INC__ = 1
000000r 2               
000000r 2               .include "config.inc"
000000r 3               ; ============================================================
000000r 3               ; config.inc
000000r 3               ; NEOX - kernel configuration
000000r 3               ;
000000r 3               ; Purpose:
000000r 3               ; ============================================================
000000r 3               
000000r 3               .ifndef __CONFIG_INC__
000000r 3               __CONFIG_INC__ = 1
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_FDS     = 6          ; per-process descriptor count
000000r 3               OPEN_MAX    = 16         ; system-wide open object slots
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active processes
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_PROCS   = 8
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Maximum simultaneously active timer waits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               MAX_TIMER   = 8
000000r 3               
000000r 3               ;
000000r 3               ;
000000r 3               ;
000000r 3               
000000r 3               MAX_PIPES       = 8
000000r 3               PIPE_BUF_SIZE   = 64
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Filesystem path limits
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               NEOX_CWD_MAX  = 32        ; process-private current-directory path bytes
000000r 3               NEOX_PATH_MAX = 64        ; kernel path resolver buffer bytes
000000r 3               ; ============================================================
000000r 3               ;
000000r 3               ; ============================================================
000000r 3               
000000r 3               USER_IMAGE_TABLE = $1000
000000r 3               
000000r 3               ; Final 32/32 virtual-memory split.
000000r 3               USER_SPACE_LIMIT = $8000
000000r 3               KERNEL_SHARED_BASE = $B020
000000r 3               KERNEL_OVERFLOW_BASE = $C000
000000r 3               MICMON_BASE = $D000
000000r 3               IO_PAGE_BASE = $E000
000000r 3               BIOS_BASE = $F000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Kernel
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               KERNEL_BASE = $8000
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Syscall table location
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               SYSCALL_BASE = $F100
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; RP2350 mailbox control registers (MMIO)
000000r 3               ;
000000r 3               ; Layout:
000000r 3               ;   Page E is shared I/O space
000000r 3               ;   OS-owned mailbox doorbell starts at $E010
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_DOORBELL  = $E010
000000r 3               
000000r 3               ; ------------------------------------------------------------
000000r 3               ; Shared RAM request/result block (ordinary shared RAM, not I/O)
000000r 3               ;
000000r 3               ; mailbox request block.
000000r 3               ; ------------------------------------------------------------
000000r 3               
000000r 3               RP_REQ_BASE  = $B000
000000r 3               
000000r 3               .endif
000000r 3               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; FD values
000000r 2               ; ------------------------------------------------------------
000000r 2               FD_NONE     = $FF        ; invalid / unused descriptor
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; FD flags (per process)
000000r 2               ;
000000r 2               ; These describe how the process uses the descriptor.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               FD_FLAG_READ    = $01
000000r 2               FD_FLAG_WRITE   = $02
000000r 2               FD_FLAG_CLOEXEC = $80    ; reserved for later exec() support
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Open object types (system-wide)
000000r 2               ;
000000r 2               ; Each open object represents a shared resource. Multiple
000000r 2               ; processes may reference the same object.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               OBJ_NONE    = $00
000000r 2               OBJ_DEVICE  = $01        ; console for now
000000r 2               OBJ_FILE    = $02        ; RP filesystem file handle
000000r 2               OBJ_PIPE    = $03        ; reserved
000000r 2               OBJ_DIR     = $04        ; RP filesystem directory handle
000000r 2               
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; FD clone argument block
000000r 2               ;
000000r 2               ; Used by kernel-internal cross-process descriptor cloning.
000000r 2               ; The source descriptor is resolved in source_pid/source_fd and
000000r 2               ; attached to target_pid/target_fd with the same per-FD flags.
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               .struct fd_clone_args
000000r 2                   source_pid      .byte
000000r 2                   source_fd       .byte
000000r 2                   target_pid      .byte
000000r 2                   target_fd       .byte
000000r 2               .endstruct
000000r 2               
000000r 2               FD_CLONE_ARGS_SIZE = .sizeof(fd_clone_args)
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Device identifiers
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               DEV_NONE        = $00
000000r 2               DEV_CONSOLE     = $01
000000r 2               
000000r 2               DEV_MAX         = $02
000000r 2               
000000r 2               ; Each dev_ops entry is one 16-bit operation-table pointer.
000000r 2               DEV_OPS_ENTRY_SIZE = 2
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Device operation offsets
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               DEVOP_READ      = 0
000000r 2               DEVOP_WRITE     = 2
000000r 2               DEVOP_IOCTL     = 4
000000r 2               DEVOP_CLOSE     = 6
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               
000000r 1               .export ksys_open
000000r 1               .export ksys_load_file_to_memory
000000r 1               .export ksys_save_memory_to_file
000000r 1               .export ksys_seek
000000r 1               .export ksys_tell
000000r 1               .export ksys_delete
000000r 1               .export ksys_rename
