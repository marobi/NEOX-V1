000000r 1               .export ksys_readdir
000000r 1               .export ksys_closedir
000000r 1               .export ksys_chdir
000000r 1               .export ksys_getcwd
000000r 1               .export ksys_mkdir
000000r 1               .export ksys_rmdir
000000r 1               
000000r 1               .import file_io_gate_acquire
000000r 1               .import file_io_gate_release
000000r 1               
000000r 1               .import fd_alloc_open
000000r 1               .import fd_free_open
000000r 1               .import fd_alloc_fd_current
000000r 1               .import fd_attach_current
000000r 1               .import fd_resolve_file
000000r 1               .import fd_resolve_dir
000000r 1               .import fd_close
000000r 1               
000000r 1               .import open_type
000000r 1               .import open_flags
000000r 1               .import open_dev
000000r 1               .import open_file_handle
000000r 1               
000000r 1               .import rp_fs_exec
000000r 1               
000000r 1               .importzp io_ptr
000000r 1               .importzp dev_ptr
000000r 1               
000000r 1               
000000r 1               .segment "BSS"
000000r 1               
000000r 1               ; Process-private argument pointer snapshot.
000000r 1               ;
000000r 1               ; file_io_gate_acquire may block and yield, so ksys_fs_begin preserves the
000000r 1               ; caller argument-block pointer in the process context before acquiring FILE_IO.
000000r 1               ksys_fs_snap0:
000000r 1  xx               .res 1
000001r 1               
000001r 1               ksys_fs_snap1:
000001r 1  xx               .res 1
000002r 1               
000002r 1               
000002r 1               .segment "KERN_BSS"
000000r 1               
000000r 1               ; Shared open/opendir transaction scratch. FILE_IO remains owned while these
000000r 1               ; values are live, including across WAIT_RP.
000000r 1               ksys_open_device:
000000r 1  xx               .res 1
000001r 1               
000001r 1               ksys_open_obj:
000001r 1  xx               .res 1
000002r 1               
000002r 1               ksys_open_fd:
000002r 1  xx               .res 1
000003r 1               
000003r 1               ; Current no-handle filesystem operation while FILE_IO is owned.
000003r 1               ksys_fs_operation:
000003r 1  xx               .res 1
000004r 1               
000004r 1               
000004r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               
000000r 1               ; <summary>
000000r 1               ; ksys_fs_begin saves the caller argument-block pointer in process-private
000000r 1               ; storage, acquires FILE_IO, and restores io_ptr after a possible wait.
000000r 1               ; </summary>
000000r 1               ; <param name="X/Y">Caller argument-block pointer.</param>
000000r 1               ; <returns>C set when FILE_IO is owned; C clear with Y=EINVAL on failure.</returns>
000000r 1               .proc ksys_fs_begin
000000r 1  8E rr rr         stx ksys_fs_snap0
000003r 1  8C rr rr         sty ksys_fs_snap1
000006r 1  20 rr rr         jsr file_io_gate_acquire
000009r 1  B0 04            bcs @owned
00000Br 1  A0 06            ldy #EINVAL
00000Dr 1  18               clc
00000Er 1  60               rts
00000Fr 1               @owned:
00000Fr 1  AD rr rr         lda ksys_fs_snap0
000012r 1  85 rr            sta io_ptr
000014r 1  AD rr rr         lda ksys_fs_snap1
000017r 1  85 rr            sta io_ptr+1
000019r 1  38               sec
00001Ar 1  60               rts
00001Br 1               .endproc
00001Br 1               
00001Br 1               ; <summary>
00001Br 1               ; ksys_fs_finish releases FILE_IO while preserving A, X, Y, and status.
00001Br 1               ; </summary>
00001Br 1               .proc ksys_fs_finish
00001Br 1  08               php
00001Cr 1  48               pha
00001Dr 1  DA               phx
00001Er 1  5A               phy
00001Fr 1  20 rr rr         jsr file_io_gate_release
000022r 1  7A               ply
000023r 1  FA               plx
000024r 1  68               pla
000025r 1  28               plp
000026r 1  60               rts
000027r 1               .endproc
000027r 1               
000027r 1               ; <summary>
000027r 1               ; Converts one caller pathname to uppercase ASCII in place.
000027r 1               ;
000027r 1               ; This is filesystem policy, not command parsing. Generic argument buffers
000027r 1               ; remain byte-preserving until a pathname-bearing filesystem syscall is made.
000027r 1               ; dev_ptr is shared zero-page scratch and is safe here because FILE_IO is
000027r 1               ; owned for the complete normalization and RP transaction.
000027r 1               ; </summary>
000027r 1               ; <param name="Y">Offset of the pathname pointer inside the syscall block.</param>
000027r 1               ; <returns>C clear on success.</returns>
000027r 1               .proc ksys_fs_uppercase_path_at_y
000027r 1  B1 rr            lda (io_ptr),y
000029r 1  85 rr            sta dev_ptr
00002Br 1  C8               iny
00002Cr 1  B1 rr            lda (io_ptr),y
00002Er 1  85 rr            sta dev_ptr+1
000030r 1               
000030r 1  A0 00            ldy #0
000032r 1               @loop:
000032r 1  B1 rr            lda (dev_ptr),y
000034r 1  F0 14            beq @done
000036r 1               
000036r 1  C9 61            cmp #'a'
000038r 1  90 09            bcc @next
00003Ar 1  C9 7B            cmp #'z' + 1
00003Cr 1  B0 05            bcs @next
00003Er 1               
00003Er 1  38               sec
00003Fr 1  E9 20            sbc #$20
000041r 1  91 rr            sta (dev_ptr),y
000043r 1               
000043r 1               @next:
000043r 1  C8               iny
000044r 1  D0 EC            bne @loop
000046r 1               
000046r 1                   ; A pathname without a terminator in the first 256 bytes is invalid.
000046r 1  A0 06            ldy #EINVAL
000048r 1  38               sec
000049r 1  60               rts
00004Ar 1               
00004Ar 1               @done:
00004Ar 1  18               clc
00004Br 1  60               rts
00004Cr 1               .endproc
00004Cr 1               
00004Cr 1               ; <summary>
00004Cr 1               ; Applies pathname normalization required by a no-handle filesystem operation.
00004Cr 1               ; </summary>
00004Cr 1               ; <param name="A">RP_FS_OP_* operation code.</param>
00004Cr 1               ; <returns>C clear on success; C set with Y=errno on failure.</returns>
00004Cr 1               .proc ksys_fs_normalize_no_handle_paths
00004Cr 1  C9 15            cmp #RP_FS_OP_GETCWD
00004Er 1  F0 15            beq @none
000050r 1  C9 0B            cmp #RP_FS_OP_RENAME
000052r 1  F0 05            beq @rename
000054r 1               
000054r 1                   ; LOAD, SAVE, DELETE, CHDIR, MKDIR, and RMDIR all place their first
000054r 1                   ; pathname pointer at byte zero of the syscall argument block.
000054r 1  A0 00            ldy #0
000056r 1  4C rr rr         jmp ksys_fs_uppercase_path_at_y
000059r 1               
000059r 1               @rename:
000059r 1  A0 00            ldy #rename_args::old_path_ptr
00005Br 1  20 rr rr         jsr ksys_fs_uppercase_path_at_y
00005Er 1  B0 06            bcs @fail
000060r 1               
000060r 1  A0 02            ldy #rename_args::new_path_ptr
000062r 1  4C rr rr         jmp ksys_fs_uppercase_path_at_y
000065r 1               
000065r 1               @none:
000065r 1  18               clc
000066r 1               @fail:
000066r 1  60               rts
000067r 1               .endproc
000067r 1               
000067r 1               ; <summary>
000067r 1               ; Executes a path/bulk filesystem operation that needs no trusted RP handle.
000067r 1               ; </summary>
000067r 1               ; <param name="A">RP_FS_OP_* operation.</param>
000067r 1               ; <param name="X/Y">Caller argument-block pointer.</param>
000067r 1               ; <returns>The generic filesystem result.</returns>
