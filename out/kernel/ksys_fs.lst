00006Dr 1               
00006Dr 1  68               pla
00006Er 1  38               sec
00006Fr 1  60               rts
000070r 1               
000070r 1               @owned:
000070r 1  68               pla
000071r 1  8D rr rr         sta ksys_fs_operation
