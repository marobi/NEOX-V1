00015Dr 1  D0 17            bne @write_fail
00015Fr 1               
00015Fr 1  AD rr rr         lda ksys_rw_wait_reason
000162r 1  F0 12            beq @write_fail
000164r 1               
000164r 1  AC rr rr         ldy ksys_rw_wait_object
000167r 1  20 rr rr         jsr ksys_io_block
00016Ar 1  4C rr rr         jmp @retry_gate
00016Dr 1               
00016Dr 1               @write_success:
00016Dr 1  48               pha
00016Er 1  DA               phx
00016Fr 1  20 rr rr         jsr file_io_gate_release
000172r 1  FA               plx
000173r 1  68               pla
000174r 1  18               clc
000175r 1  60               rts
000176r 1               
000176r 1               @write_fail:
000176r 1  5A               phy
000177r 1  20 rr rr         jsr file_io_gate_release
00017Ar 1  7A               ply
00017Br 1  38               sec
00017Cr 1  60               rts
00017Dr 1               
00017Dr 1               .endproc
