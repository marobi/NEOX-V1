000000r 1               ; ------------------------------------------------------------
000000r 1               ; ksys_io private scratch
000000r 1               ;
000000r 1               ; Protected by:
000000r 1               ;   file_io_gate
000000r 1               ;
000000r 1               ; Rules:
000000r 1               ;   - valid only while file_io_gate is owned by active_pid
000000r 1               ;   - not live across sched_yield
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               ksys_rw_fd_tmp:
000000r 1  xx               .res 1
000001r 1               
000001r 1               ksys_rw_len_lo:
000001r 1  xx               .res 1
000002r 1               
000002r 1               ksys_rw_len_hi:
000002r 1  xx               .res 1
000003r 1               
000003r 1               ksys_rw_buf_lo:
000003r 1  xx               .res 1
000004r 1               
000004r 1               ksys_rw_buf_hi:
000004r 1  xx               .res 1
000005r 1               
000005r 1               ; Local EAGAIN conversion selected during descriptor classification.
000005r 1               ; A zero reason means that EAGAIN must be returned to the caller.
000005r 1               ksys_rw_wait_reason:
000005r 1  xx               .res 1
000006r 1               
000006r 1               ksys_rw_wait_object:
000006r 1  xx               .res 1
000007r 1               
000007r 1               .segment "BSS"
000000r 1               
000000r 1               ; Process-private read/write syscall argument pointer. Each MMU context owns
000000r 1               ; its copy, so the pointer remains stable while FILE_IO acquisition blocks.
000000r 1               ksys_rw_args_lo:
000000r 1  xx               .res 1
000001r 1               
000001r 1               ksys_rw_args_hi:
000001r 1  xx               .res 1
000002r 1               
000002r 1               
000002r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; ksys_io_init
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               .proc ksys_io_init
000000r 1                   ; Initialize all currently defined sleepable syscall gates.
000000r 1                   ; proc_gate is generated now but process syscalls are routed to it later.
000000r 1  20 rr rr         jsr file_io_gate_init
000003r 1  4C rr rr         jmp proc_gate_init
000006r 1               .endproc
000006r 1               
000006r 1               
000006r 1               
000006r 1               
000006r 1               ; ------------------------------------------------------------
000006r 1               ; ksys_io_block
000006r 1               ;
000006r 1               ; Block the active process for a local console or pipe wait.
000006r 1               ;
000006r 1               ; Input:
000006r 1               ;   A = wait reason
000006r 1               ;   Y = wait object
000006r 1               ;
000006r 1               ; Caller:
000006r 1               ;   owns file_io_gate
000006r 1               ;
000006r 1               ; Behavior:
000006r 1               ;   - preserves the wait reason/object across gate release
000006r 1               ;   - releases file_io_gate
000006r 1               ;   - enters the scheduler-owned blocking transition
000006r 1               ;   - resumes at the instruction following the JSR when woken
000006r 1               ;
000006r 1               ; Notes:
000006r 1               ;   WAIT_CONSOLE and WAIT_PIPE_* cannot complete synchronously inside
000006r 1               ;   sched_block_current, so this helper normally does not return until
000006r 1               ;   the process has been woken and rescheduled.
000006r 1               ; ------------------------------------------------------------
000006r 1               
000006r 1               .proc ksys_io_block
000006r 1  48               pha
000007r 1  5A               phy
000008r 1               
000008r 1  20 rr rr         jsr file_io_gate_release
00000Br 1               
00000Br 1  7A               ply
00000Cr 1  68               pla
00000Dr 1  4C rr rr         jmp sched_block_current
000010r 1               .endproc
000010r 1               
000010r 1               
000010r 1               ; ------------------------------------------------------------
000010r 1               ; ksys_read
000010r 1               ;
000010r 1               ; Kernel-side syscall wrapper for read(fd, buf, len).
000010r 1               ; ------------------------------------------------------------
000010r 1               
000010r 1               .proc ksys_read
000010r 1                   ; Save the caller argument pointer in this process context before gate
000010r 1                   ; acquisition can block. Other processes cannot access this private copy.
000010r 1  8E rr rr         stx ksys_rw_args_lo
000013r 1  8C rr rr         sty ksys_rw_args_hi
000016r 1               
000016r 1               @retry_gate:
000016r 1  20 rr rr         jsr file_io_gate_acquire
000019r 1  B0 04            bcs @gate_acquired
00001Br 1               
00001Br 1  A0 06            ldy #EINVAL
00001Dr 1  38               sec
00001Er 1  60               rts
00001Fr 1               
00001Fr 1               @gate_acquired:
00001Fr 1                   ; Restore the caller argument pointer in the caller's active context.
00001Fr 1  AD rr rr         lda ksys_rw_args_lo
000022r 1  85 rr            sta io_ptr
000024r 1  AD rr rr         lda ksys_rw_args_hi
000027r 1  85 rr            sta io_ptr+1
000029r 1               
000029r 1                   ; Decode local dispatch fields once while file_io_gate is owned.
000029r 1  A0 00            ldy #rw_args::fd
00002Br 1  B1 rr            lda (io_ptr),y
00002Dr 1  8D rr rr         sta ksys_rw_fd_tmp
000030r 1               
000030r 1  A0 02            ldy #rw_args::buf_ptr
000032r 1  B1 rr            lda (io_ptr),y
000034r 1  8D rr rr         sta ksys_rw_buf_lo
000037r 1  C8               iny
000038r 1  B1 rr            lda (io_ptr),y
00003Ar 1  8D rr rr         sta ksys_rw_buf_hi
00003Dr 1               
00003Dr 1  A0 04            ldy #rw_args::len
00003Fr 1  B1 rr            lda (io_ptr),y
000041r 1  8D rr rr         sta ksys_rw_len_lo
000044r 1  C8               iny
000045r 1  B1 rr            lda (io_ptr),y
000047r 1  8D rr rr         sta ksys_rw_len_hi
00004Ar 1               
00004Ar 1                   ; Classify and validate the descriptor. Files are submitted directly to
00004Ar 1                   ; the generic RP request while console and pipe behavior remains local.
00004Ar 1  9C rr rr         stz ksys_rw_wait_reason
00004Dr 1  9C rr rr         stz ksys_rw_wait_object
000050r 1               
000050r 1  AC rr rr         ldy ksys_rw_fd_tmp
000053r 1  20 rr rr         jsr fd_resolve_read
000056r 1  90 03            bcc @read_resolve_ok
000058r 1  4C rr rr         jmp @read_fail
00005Br 1               
00005Br 1               @read_resolve_ok:
00005Br 1  C9 02            cmp #OBJ_FILE
00005Dr 1  F0 0D            beq @read_file
00005Fr 1               
00005Fr 1  C9 01            cmp #OBJ_DEVICE
000061r 1  F0 19            beq @class_device
000063r 1               
000063r 1  C9 03            cmp #OBJ_PIPE
000065r 1  F0 20            beq @class_pipe
000067r 1               
000067r 1  A0 0A            ldy #ENODEV
000069r 1  4C rr rr         jmp @read_fail
00006Cr 1               
00006Cr 1               @read_file:
00006Cr 1                   ; io_ptr still points to the original rw_args block. The kernel supplies
00006Cr 1                   ; the trusted RP handle; the RP decodes buffer and length in caller context.
00006Cr 1  BD rr rr         lda open_file_handle,x
00006Fr 1  AA               tax
000070r 1  A9 03            lda #RP_FS_OP_READ
000072r 1  A0 00            ldy #$00
000074r 1  20 rr rr         jsr rp_fs_exec
000077r 1  90 43            bcc @read_success
000079r 1  4C rr rr         jmp @read_fail
00007Cr 1               
00007Cr 1               @class_device:
00007Cr 1  C0 01            cpy #DEV_CONSOLE
00007Er 1  D0 12            bne @read_call
000080r 1               
000080r 1  A9 01            lda #WAIT_CONSOLE
000082r 1  8D rr rr         sta ksys_rw_wait_reason
000085r 1  80 0B            bra @read_call
000087r 1               
000087r 1               @class_pipe:
000087r 1                   ; X = open object from fd_resolve_read.
000087r 1  BD rr rr         lda open_pipe,x
00008Ar 1  8D rr rr         sta ksys_rw_wait_object
00008Dr 1               
00008Dr 1  A9 03            lda #WAIT_PIPE_READ
00008Fr 1  8D rr rr         sta ksys_rw_wait_reason
000092r 1               
000092r 1               @read_call:
000092r 1                   ; Local console/pipe backends retain their existing ABI.
000092r 1  AD rr rr         lda ksys_rw_buf_lo
000095r 1  85 rr            sta io_ptr
000097r 1  AD rr rr         lda ksys_rw_buf_hi
00009Ar 1  85 rr            sta io_ptr+1
00009Cr 1               
00009Cr 1  AC rr rr         ldy ksys_rw_fd_tmp
00009Fr 1  AD rr rr         lda ksys_rw_len_lo
0000A2r 1  AE rr rr         ldx ksys_rw_len_hi
0000A5r 1  20 rr rr         jsr fd_read
0000A8r 1  90 12            bcc @read_success
0000AAr 1               
0000AAr 1  C0 0C            cpy #EAGAIN
0000ACr 1  D0 17            bne @read_fail
0000AEr 1               
0000AEr 1  AD rr rr         lda ksys_rw_wait_reason
0000B1r 1  F0 12            beq @read_fail
0000B3r 1               
0000B3r 1  AC rr rr         ldy ksys_rw_wait_object
0000B6r 1  20 rr rr         jsr ksys_io_block
0000B9r 1  4C rr rr         jmp @retry_gate
0000BCr 1               
0000BCr 1               @read_success:
0000BCr 1  48               pha
0000BDr 1  DA               phx
0000BEr 1  20 rr rr         jsr file_io_gate_release
0000C1r 1  FA               plx
0000C2r 1  68               pla
0000C3r 1  18               clc
0000C4r 1  60               rts
0000C5r 1               
0000C5r 1               @read_fail:
0000C5r 1  5A               phy
0000C6r 1  20 rr rr         jsr file_io_gate_release
0000C9r 1  7A               ply
0000CAr 1  38               sec
0000CBr 1  60               rts
0000CCr 1               
0000CCr 1               .endproc
0000CCr 1               
0000CCr 1               ; ------------------------------------------------------------
0000CCr 1               ; ksys_write
0000CCr 1               ;
0000CCr 1               ; Kernel-side syscall wrapper for write(fd, buf, len).
0000CCr 1               ; ------------------------------------------------------------
0000CCr 1               
0000CCr 1               .proc ksys_write
0000CCr 1                   ; Save the caller argument pointer in this process context before gate
0000CCr 1                   ; acquisition can block. Other processes cannot access this private copy.
0000CCr 1  8E rr rr         stx ksys_rw_args_lo
0000CFr 1  8C rr rr         sty ksys_rw_args_hi
0000D2r 1               
0000D2r 1               @retry_gate:
0000D2r 1  20 rr rr         jsr file_io_gate_acquire
0000D5r 1  B0 04            bcs @gate_acquired
0000D7r 1               
0000D7r 1  A0 06            ldy #EINVAL
0000D9r 1  38               sec
0000DAr 1  60               rts
0000DBr 1               
0000DBr 1               @gate_acquired:
0000DBr 1                   ; Restore and decode the caller argument block in its active context.
0000DBr 1  AD rr rr         lda ksys_rw_args_lo
0000DEr 1  85 rr            sta io_ptr
0000E0r 1  AD rr rr         lda ksys_rw_args_hi
0000E3r 1  85 rr            sta io_ptr+1
0000E5r 1               
0000E5r 1  A0 00            ldy #rw_args::fd
0000E7r 1  B1 rr            lda (io_ptr),y
0000E9r 1  8D rr rr         sta ksys_rw_fd_tmp
0000ECr 1               
0000ECr 1  A0 02            ldy #rw_args::buf_ptr
0000EEr 1  B1 rr            lda (io_ptr),y
0000F0r 1  8D rr rr         sta ksys_rw_buf_lo
0000F3r 1  C8               iny
0000F4r 1  B1 rr            lda (io_ptr),y
0000F6r 1  8D rr rr         sta ksys_rw_buf_hi
0000F9r 1               
0000F9r 1  A0 04            ldy #rw_args::len
0000FBr 1  B1 rr            lda (io_ptr),y
0000FDr 1  8D rr rr         sta ksys_rw_len_lo
000100r 1  C8               iny
000101r 1  B1 rr            lda (io_ptr),y
000103r 1  8D rr rr         sta ksys_rw_len_hi
000106r 1               
000106r 1  9C rr rr         stz ksys_rw_wait_reason
000109r 1  9C rr rr         stz ksys_rw_wait_object
00010Cr 1               
00010Cr 1  AC rr rr         ldy ksys_rw_fd_tmp
00010Fr 1  20 rr rr         jsr fd_resolve_write
000112r 1  90 03            bcc @write_resolve_ok
000114r 1  4C rr rr         jmp @write_fail
000117r 1               
000117r 1               @write_resolve_ok:
000117r 1  C9 02            cmp #OBJ_FILE
000119r 1  F0 0D            beq @write_file
00011Br 1               
00011Br 1  C9 03            cmp #OBJ_PIPE
00011Dr 1  F0 19            beq @class_pipe
00011Fr 1               
00011Fr 1  C9 01            cmp #OBJ_DEVICE
000121r 1  F0 20            beq @write_call
000123r 1               
000123r 1  A0 0A            ldy #ENODEV
000125r 1  4C rr rr         jmp @write_fail
000128r 1               
000128r 1               @write_file:
000128r 1                   ; Keep io_ptr on rw_args and submit the trusted RP handle.
000128r 1  BD rr rr         lda open_file_handle,x
00012Br 1  AA               tax
00012Cr 1  A9 05            lda #RP_FS_OP_WRITE
00012Er 1  A0 00            ldy #$00
000130r 1  20 rr rr         jsr rp_fs_exec
000133r 1  90 38            bcc @write_success
000135r 1  4C rr rr         jmp @write_fail
000138r 1               
000138r 1               @class_pipe:
000138r 1                   ; X = open object from fd_resolve_write.
000138r 1  BD rr rr         lda open_pipe,x
00013Br 1  8D rr rr         sta ksys_rw_wait_object
00013Er 1               
00013Er 1  A9 07            lda #WAIT_PIPE_WRITE
000140r 1  8D rr rr         sta ksys_rw_wait_reason
000143r 1               
000143r 1               @write_call:
000143r 1                   ; Local console/pipe backends retain their existing ABI.
000143r 1  AD rr rr         lda ksys_rw_buf_lo
000146r 1  85 rr            sta io_ptr
000148r 1  AD rr rr         lda ksys_rw_buf_hi
00014Br 1  85 rr            sta io_ptr+1
00014Dr 1               
00014Dr 1  AC rr rr         ldy ksys_rw_fd_tmp
000150r 1  AD rr rr         lda ksys_rw_len_lo
000153r 1  AE rr rr         ldx ksys_rw_len_hi
000156r 1  20 rr rr         jsr fd_write
