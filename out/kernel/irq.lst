000000r 2               SIG_CONT = 18
000000r 2               SIG_STOP = 19
000000r 2               
000000r 2               ; Source compatibility for older NEOX assembly code.
000000r 2               SIG_HALT = SIG_STOP
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               
000000r 1               .export irq_entry
000000r 1               .export nmi_entry
000000r 1               
000000r 1               .import brk_vector
000000r 1               
000000r 1               .import supervisor_enter_from_irq
000000r 1               
000000r 1               .import scheduler_irq_tick
000000r 1               .import sched_context_switch
000000r 1               .import sched_lock
000000r 1               .import monitor_active
000000r 1               .import console_owner_pid
000000r 1               .import proc_signal_pending
000000r 1               
000000r 1               .import rp_lock
000000r 1               
000000r 1               .import file_io_gate_owner
000000r 1               .import proc_state
000000r 1               .import wait_reason
000000r 1               .import proc_wake
000000r 1               
000000r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; irq_entry
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Main kernel IRQ entry point.
000000r 1               ;
000000r 1               ; Inputs:
000000r 1               ;   None explicitly.
000000r 1               ;   CPU arrives here from hardware IRQ with interrupt frame
000000r 1               ;   already stacked by the processor.
000000r 1               ;
000000r 1               ; Outputs:
000000r 1               ;   Does not return normally.
000000r 1               ;
000000r 1               ; Either:
000000r 1               ;   - restores interrupted context and RTI
000000r 1               ;   - enters MICMON immediately for a monitor request
000000r 1               ;   - or transfers to scheduler switch logic for a timer IRQ
000000r 1               ;
000000r 1               ; Clobbers:
000000r 1               ;   A, X, Y
000000r 1               ;
000000r 1               ; Notes:
000000r 1               ;   The interrupted context is preserved on its private stack
000000r 1               ;   until a dispatch decision is made.
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               .proc irq_entry
000000r 1  78           	sei
000001r 1  48               pha
000002r 1  DA               phx
000003r 1  5A               phy
000004r 1               
000004r 1                   ; BRK uses the IRQ vector but is not an RP IRQ.
000004r 1                   ; Test the stacked status B flag before reading/ACKing
000004r 1                   ; RP_IRQ_SOURCE. Otherwise BRK with RP_IRQ_SOURCE = NONE would
000004r 1                   ; be misclassified as "no IRQ" and restored immediately.
000004r 1  BA               tsx
000005r 1  BD 04 01         lda $0104,x
000008r 1  29 10            and #$10
00000Ar 1  F0 03            beq :+
00000Cr 1  4C rr rr         jmp brk_entry                  ; BREAK
00000Fr 1               :
00000Fr 1               
00000Fr 1  AD 10 B0         lda RP_IRQ_SOURCE
000012r 1  20 06 F0         jsr BIOS_ACK_IRQ               ; ack IRQ
000015r 1               
000015r 1  C9 00            cmp #RP_IRQ_SRC_NONE           ; non IRQ
000017r 1  D0 03            bne :+
000019r 1  4C rr rr         jmp irq_restore
00001Cr 1               :
00001Cr 1               
00001Cr 1  C9 01            cmp #RP_IRQ_SRC_TIMER          ; TIMER IRQ
00001Er 1  D0 03            bne :+
000020r 1  4C rr rr         jmp @timer
000023r 1               :
000023r 1               
000023r 1  C9 02            cmp #RP_IRQ_SRC_MONITOR        ; MONITOR IRQ
000025r 1  D0 03            bne :+
000027r 1  4C rr rr         jmp @monitor
00002Ar 1               :
00002Ar 1               
00002Ar 1  C9 03            cmp #RP_IRQ_SRC_FS_DONE        ; RP filesystem completion
00002Cr 1  D0 03            bne :+
00002Er 1  4C rr rr         jmp @fs_done
000031r 1               :
000031r 1               
000031r 1  C9 04            cmp #RP_IRQ_SRC_CONSOLE_BREAK  ; foreground console interrupt
000033r 1  D0 03            bne :+
000035r 1  4C rr rr         jmp @console_break
000038r 1               :
000038r 1               
000038r 1                   ; unknown -> just return
000038r 1  4C rr rr         jmp irq_restore
00003Br 1               
00003Br 1               @monitor:
00003Br 1  4C rr rr         jmp supervisor_enter_from_irq	; must be JMP
00003Er 1               
00003Er 1               @console_break:
00003Er 1                   ; MICMON is a freeze-style supervisor and is explicitly excluded from
00003Er 1                   ; NEOX foreground process interruption.
00003Er 1  AD rr rr         lda monitor_active
000041r 1  D0 65            bne irq_restore
000043r 1               
000043r 1                   ; The current RP console focus is synchronized into console_owner_pid by
000043r 1                   ; the scheduler. Only normal live process PIDs may receive SIG_INT.
000043r 1  AE rr rr         ldx console_owner_pid
000046r 1  E0 01            cpx #FIRST_TASK_PID
000048r 1  90 5E            bcc irq_restore
00004Ar 1  E0 08            cpx #MAX_PROCS
00004Cr 1  B0 5A            bcs irq_restore
00004Er 1               
00004Er 1  BD rr rr         lda proc_state,x
000051r 1  C9 00            cmp #PROC_EMPTY
000053r 1  F0 53            beq irq_restore
000055r 1  C9 06            cmp #PROC_ZOMBIE
000057r 1  F0 4F            beq irq_restore
000059r 1               
000059r 1  A9 02            lda #SIG_INT
00005Br 1  9D rr rr         sta proc_signal_pending,x
00005Er 1               
00005Er 1                   ; Do not enter the scheduler through an already active handoff or short
00005Er 1                   ; RP critical section. The pending signal remains recorded and will be
00005Er 1                   ; applied at the next safe scheduler pass.
00005Er 1  AD rr rr         lda sched_lock
000061r 1  0D rr rr         ora rp_lock
000064r 1  D0 42            bne irq_restore
000066r 1               
000066r 1  4C rr rr         jmp sched_context_switch
000069r 1               
000069r 1               @fs_done:
000069r 1                   ; The FILE_IO gate owner is the sole possible generic filesystem
000069r 1                   ; request owner. Wake it only when the recorded process state still
000069r 1                   ; matches an active WAIT_RP transaction. The owner itself will read
000069r 1                   ; the mailbox result and release FILE_IO after resuming.
000069r 1  AE rr rr         ldx file_io_gate_owner
00006Cr 1  E0 FF            cpx #GATE_OWNER_NONE
00006Er 1  F0 38            beq irq_restore
000070r 1               
000070r 1  E0 08            cpx #MAX_PROCS
000072r 1  B0 34            bcs irq_restore
000074r 1               
000074r 1  BD rr rr         lda proc_state,x
000077r 1  C9 04            cmp #PROC_BLOCKED
000079r 1  D0 2D            bne irq_restore
00007Br 1               
00007Br 1  BD rr rr         lda wait_reason,x
00007Er 1  C9 08            cmp #WAIT_RP
000080r 1  D0 26            bne irq_restore
000082r 1               
000082r 1  20 rr rr         jsr proc_wake
000085r 1               
000085r 1                   ; MICMON remains a freeze-style supervisor. Keep the owner READY but
000085r 1                   ; do not leave the monitor through a filesystem completion interrupt.
000085r 1  AD rr rr         lda monitor_active
000088r 1  D0 1E            bne irq_restore
00008Ar 1               
00008Ar 1                   ; A completion IRQ does not advance ticks. If a short scheduler or
00008Ar 1                   ; mailbox critical section is active, leave the owner READY and let
00008Ar 1                   ; the next scheduling opportunity select it.
00008Ar 1  AD rr rr         lda sched_lock
00008Dr 1  0D rr rr         ora rp_lock
000090r 1  D0 16            bne irq_restore
000092r 1               
000092r 1  4C rr rr         jmp sched_context_switch
000095r 1               
000095r 1               @timer:
000095r 1                   ; Freeze-style monitor:
000095r 1                   ; timer IRQs are already acknowledged by BIOS_ACK_IRQ before
000095r 1                   ; reaching this branch. While MICMON is active, do not advance
000095r 1                   ; system_ticks and do not run scheduler tick accounting.
000095r 1  AD rr rr         lda monitor_active
000098r 1  D0 0E            bne irq_restore
00009Ar 1               
00009Ar 1                   ; Count every hardware timer IRQ outside monitor mode.
00009Ar 1  20 rr rr         jsr scheduler_irq_tick
00009Dr 1               
00009Dr 1                   ; sched_lock protects the scheduler handoff itself. rp_lock remains a
00009Dr 1                   ; short non-sleeping mailbox lock until the generic RP request path
00009Dr 1                   ; replaces it. Sleepable FILE_IO/PROC gates deliberately do not block
00009Dr 1                   ; timer preemption: another process may run, but cannot enter the same
00009Dr 1                   ; protected subsystem until the owning PID releases its gate.
00009Dr 1  AD rr rr         lda sched_lock
0000A0r 1  0D rr rr         ora rp_lock
0000A3r 1  D0 03            bne irq_restore
0000A5r 1               
0000A5r 1  4C rr rr         jmp sched_context_switch
0000A8r 1               .endproc
0000A8r 1               
0000A8r 1               ;
0000A8r 1               	.export irq_restore
0000A8r 1               irq_restore:
0000A8r 1  7A               ply
0000A9r 1  FA               plx
0000AAr 1  68               pla
0000ABr 1  40               rti
0000ACr 1               
0000ACr 1               .proc brk_entry
0000ACr 1  6C rr rr     	jmp (brk_vector)
0000AFr 1               .endproc
0000AFr 1               
0000AFr 1               ; ------------------------------------------------------------
0000AFr 1               ; nmi_entry
0000AFr 1               ;
0000AFr 1               ; Purpose:
0000AFr 1               ;   Minimal NMI handler stub.
0000AFr 1               ;
0000AFr 1               ; Notes:
0000AFr 1               ;   No NMI-specific functionality is implemented yet.
0000AFr 1               ; ------------------------------------------------------------
0000AFr 1               
0000AFr 1               .proc nmi_entry
0000AFr 1  40               rti
0000B0r 1               .endproc
0000B0r 1               
