000000r 1               ; ============================================================
000000r 1               ; irq.asm
000000r 1               ; NEOX - IRQ / NMI entry handling
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Handles hardware IRQ entry on the 6502 side and dispatches
000000r 1               ;   to the correct kernel action based on the IRQ source.
000000r 1               ;
000000r 1               ; Architecture:
000000r 1               ;   - BIOS owns the real CPU vectors and jumps here
000000r 1               ;   - Context 0 is supervisor / MICMON
000000r 1               ;   - Contexts 1..N are schedulable tasks
000000r 1               ;   - Timer IRQ drives normal scheduling
000000r 1               ;   - RP2350 may also request entry into MICMON
000000r 1               ;
000000r 1               ; IRQ policy:
000000r 1               ;   1. Save A/X/Y onto the interrupted context stack.
000000r 1               ;   2. Read and acknowledge the RP IRQ source through BIOS_ACK_IRQ.
000000r 1               ;   3. If source = monitor request:
000000r 1               ;        -> enter MICMON immediately through supervisor_enter_from_irq
000000r 1               ;        -> preserve the current IRQ stack as the frozen continuation
000000r 1               ;        -> return later through irq_restore / RTI
000000r 1               ;   4. If source = timer tick:
000000r 1               ;        -> count the tick
000000r 1               ;        -> if sched_lock or rp_lock is held, resume unchanged
000000r 1               ;        -> else perform normal scheduler context switch
000000r 1               ;
000000r 1               ;   Sleepable gates do not suppress timer preemption. Gate ownership is
000000r 1               ;   tracked by PID and remains valid while another process runs.
000000r 1               ;   5. All other IRQ sources:
000000r 1               ;        -> restore interrupted context unchanged
000000r 1               ;
000000r 1               ; Stack model:
000000r 1               ;   On hardware IRQ entry, CPU has already pushed:
000000r 1               ;       PCH, PCL, SR
000000r 1               ;
000000r 1               ;   This file extends the frame by pushing:
000000r 1               ;       A, X, Y
000000r 1               ;
000000r 1               ;   So sched_context_switch may later restore with:
000000r 1               ;       PLY / PLX / PLA / RTI
000000r 1               ;
000000r 1               ;   Monitor entry is immediate/freeze-style and does not use the scheduler.
000000r 1               ; ============================================================
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .include "bios.inc"
000000r 2               ;
000000r 2               ; BIOS jumptable + inline context switch primitive
000000r 2               ;
000000r 2               .ifndef __BIOS_INC__
000000r 2               __BIOS_INC__ = 1
000000r 2               
000000r 2               .include "config.inc"
