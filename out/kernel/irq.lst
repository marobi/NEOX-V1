000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Request / result block layout, ABI v2
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_GROUP            = RP_REQ_BASE + 0
000000r 2               RP_CMD              = RP_REQ_BASE + 1
000000r 2               RP_STATUS           = RP_REQ_BASE + 2
000000r 2               RP_ERR              = RP_REQ_BASE + 3
000000r 2               
000000r 2               RP_FLAGS            = RP_REQ_BASE + 4
000000r 2               RP_STATE            = RP_REQ_BASE + 5
000000r 2               
000000r 2               RP_ARG0L            = RP_REQ_BASE + 6
000000r 2               RP_ARG0H            = RP_REQ_BASE + 7
000000r 2               RP_ARG1L            = RP_REQ_BASE + 8
000000r 2               RP_ARG1H            = RP_REQ_BASE + 9
000000r 2               RP_ARG2L            = RP_REQ_BASE + 10
000000r 2               RP_ARG2H            = RP_REQ_BASE + 11
000000r 2               
000000r 2               RP_RES0L            = RP_REQ_BASE + 12
000000r 2               RP_RES0H            = RP_REQ_BASE + 13
000000r 2               RP_RES1L            = RP_REQ_BASE + 14
000000r 2               RP_RES1H            = RP_REQ_BASE + 15
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; Other shared RP state bytes
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IRQ_SOURCE       = RP_REQ_BASE + 16
000000r 2               RP_CONSOLE_PID      = RP_REQ_BASE + 17
000000r 2               RP_CONSOLE_RDY      = RP_REQ_BASE + 18
000000r 2               RP_IRQ_STATE        = RP_REQ_BASE + 19
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_STATUS values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IDLE             = $00
000000r 2               RP_BUSY             = $01
000000r 2               RP_DONE             = $02
000000r 2               RP_ERROR            = $03
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_GROUP values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_GROUP_NONE       = $00
000000r 2               RP_GROUP_CONSOLE    = $01
000000r 2               RP_GROUP_FS         = $02
000000r 2               RP_GROUP_SYSTEM     = $03
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_CMD values inside RP_GROUP_CONSOLE
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_CON_CMD_NONE     = $00
000000r 2               RP_CON_CMD_WRITE    = $01
000000r 2               RP_CON_CMD_READ     = $02
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_CMD values inside RP_GROUP_FS
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_FS_CMD_NONE      = $00
000000r 2               RP_FS_CMD_EXEC      = $11
000000r 2               
000000r 2               ; Generic filesystem operations carried in RP_STATE. Values $01-$10 retain
000000r 2               ; their established numeric assignments, but are no longer accepted as direct
000000r 2               ; RP_CMD values.
000000r 2               RP_FS_OP_STATUS        = $01
000000r 2               RP_FS_OP_OPEN          = $02
000000r 2               RP_FS_OP_READ          = $03
000000r 2               RP_FS_OP_CLOSE         = $04
000000r 2               RP_FS_OP_WRITE         = $05
000000r 2               RP_FS_OP_LOAD          = $06
000000r 2               RP_FS_OP_SAVE          = $07
000000r 2               RP_FS_OP_SEEK          = $08
000000r 2               RP_FS_OP_TELL          = $09
000000r 2               RP_FS_OP_DELETE        = $0A
000000r 2               RP_FS_OP_RENAME        = $0B
000000r 2               RP_FS_OP_OPENDIR       = $0C
000000r 2               RP_FS_OP_READDIR       = $0D
000000r 2               RP_FS_OP_CLOSEDIR      = $0E
000000r 2               RP_FS_OP_MKDIR         = $0F
000000r 2               RP_FS_OP_RMDIR         = $10
000000r 2               RP_FS_OP_CWD_INIT_ROOT = $12
000000r 2               RP_FS_OP_CWD_CLONE     = $13
000000r 2               RP_FS_OP_CHDIR         = $14
000000r 2               RP_FS_OP_GETCWD        = $15
000000r 2               
000000r 2               RP_FS_SEEK_SET      = $00
000000r 2               RP_FS_SEEK_CUR      = $01
000000r 2               RP_FS_SEEK_END      = $02
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_DOORBELL trigger value for ABI v2
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_DOORBELL_TRIGGER = $01
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_FLAGS values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_FLAG_NONE        = $00
000000r 2               
000000r 2               ; ------------------------------------------------------------
000000r 2               ; RP_IRQ_SOURCE values
000000r 2               ; ------------------------------------------------------------
000000r 2               
000000r 2               RP_IRQ_SRC_NONE     = $00
000000r 2               RP_IRQ_SRC_TIMER    = $01
000000r 2               RP_IRQ_SRC_MONITOR  = $02
000000r 2               RP_IRQ_SRC_FS_DONE  = $03
000000r 2               RP_IRQ_SRC_CONSOLE_BREAK = $04
000000r 2               
000000r 2               .endif
