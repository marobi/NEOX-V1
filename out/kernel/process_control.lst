000072r 1                   ; file_io_gate. Preserve the allocated PID across gate acquisition.
000072r 1  DA               phx
000073r 1  20 rr rr         jsr file_io_gate_acquire
000076r 1  B0 06            bcs @file_gate_acquired
000078r 1               
000078r 1  FA               plx
000079r 1  20 rr rr         jsr ctx_free_for_pid
00007Cr 1  80 32            bra @fail
00007Er 1               
00007Er 1               @file_gate_acquired:
00007Er 1  FA               plx
00007Fr 1               
00007Fr 1  AD rr rr         lda proc_alloc_mode
000082r 1  F0 05            beq @init_boot_fds
000084r 1               
000084r 1  20 rr rr         jsr fd_clear_process_slots
000087r 1  80 03            bra @fd_initialized
000089r 1               
000089r 1               @init_boot_fds:
000089r 1  20 rr rr         jsr fd_init_process
00008Cr 1               
00008Cr 1               @fd_initialized:
00008Cr 1  B0 14            bcs @fd_fail_release
00008Er 1               
00008Er 1  DA               phx
00008Fr 1  20 rr rr         jsr file_io_gate_release
000092r 1  90 18            bcc @file_release_fail
000094r 1  FA               plx
000095r 1               
000095r 1  AD rr rr         lda proc_alloc_mode
