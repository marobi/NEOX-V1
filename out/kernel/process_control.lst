000000r 1               
000000r 1               .segment "KERN_BSS"
000000r 1               
000000r 1               proc_alloc_parent_pid:
000000r 1  xx               .res 1
000001r 1               
000001r 1               proc_alloc_entryL:
000001r 1  xx               .res 1
000002r 1               
000002r 1               proc_alloc_entryH:
000002r 1  xx               .res 1
000003r 1               
000003r 1               proc_alloc_mode:
000003r 1  xx               .res 1
000004r 1               
000004r 1               .segment "KERN_TEXT"
000000r 1               
000000r 1               ; ------------------------------------------------------------
000000r 1               ; proc_find_free_pid
000000r 1               ;
000000r 1               ; Return:
000000r 1               ;   C set   = found, X = free pid
000000r 1               ;   C clear = none available
000000r 1               ;
000000r 1               ; Notes:
000000r 1               ;   PID 0 is reserved for idle/supervisor fallback.
000000r 1               ; ------------------------------------------------------------
000000r 1               
000000r 1               .proc proc_find_free_pid
000000r 1  A2 01            ldx #$01
000002r 1               
000002r 1               @scan:
000002r 1  BD rr rr         lda proc_state,x
000005r 1  F0 07            beq @found
000007r 1               
000007r 1  E8               inx
000008r 1  E0 08            cpx #MAX_PROCS
00000Ar 1  D0 F6            bne @scan
00000Cr 1               
00000Cr 1  18               clc
00000Dr 1  60               rts
00000Er 1               
00000Er 1               @found:
00000Er 1  38               sec
00000Fr 1  60               rts
000010r 1               .endproc
000010r 1               
000010r 1               
000010r 1               ; ------------------------------------------------------------
000010r 1               ; proc_clear_launch_state
000010r 1               ;
000010r 1               ; Input:
000010r 1               ;   X = PID
000010r 1               ;
000010r 1               ; Purpose:
000010r 1               ;   Clear minimal resident launch state for a process slot. The large
000010r 1               ;   arg/cwd path blobs are not scrubbed; their lengths/selectors make
000010r 1               ;   them inactive.
000010r 1               ; ------------------------------------------------------------
000010r 1               .proc proc_clear_launch_state
000010r 1  A9 FF            lda #SPAWN_LAUNCH_NONE
000012r 1  9D rr rr         sta proc_launch_id,x
000015r 1  9E rr rr         stz proc_launch_line_len,x
000018r 1  60               rts
000019r 1               .endproc
000019r 1               
000019r 1               ; ------------------------------------------------------------
000019r 1               ; Preloaded process allocation modes.
000019r 1               ; ------------------------------------------------------------
000019r 1               
000019r 1               PROC_ALLOC_MODE_BOOT        = 0
000019r 1               PROC_ALLOC_MODE_UNPUBLISHED = 1
000019r 1               
000019r 1               ; ------------------------------------------------------------
000019r 1               ; proc_alloc_preloaded
000019r 1               ;
000019r 1               ; Allocate and publish a normal boot/preloaded process.
000019r 1               ;
000019r 1               ; Inputs:
000019r 1               ;   A = parent PID
000019r 1               ;   X = entry low byte
000019r 1               ;   Y = entry high byte
000019r 1               ;
000019r 1               ; Return:
000019r 1               ;   C clear = success, A = allocated PID
000019r 1               ;   C set   = failure
000019r 1               ;
000019r 1               ; Caller:
000019r 1               ;   must hold proc_gate
000019r 1               ; ------------------------------------------------------------
000019r 1               
000019r 1               .proc proc_alloc_preloaded
000019r 1  18               clc                         ; boot/published mode
00001Ar 1  4C rr rr         jmp proc_alloc_preloaded_common
00001Dr 1               .endproc
00001Dr 1               
00001Dr 1               ; ------------------------------------------------------------
00001Dr 1               ; proc_alloc_preloaded_unpublished
00001Dr 1               ;
00001Dr 1               ; Allocate a resident-spawn child without publishing proc_state.
00001Dr 1               ;
00001Dr 1               ; Inputs:
00001Dr 1               ;   A = parent PID
00001Dr 1               ;   X = entry low byte
00001Dr 1               ;   Y = entry high byte
00001Dr 1               ;
00001Dr 1               ; Return:
00001Dr 1               ;   C clear = success, A = allocated PID
00001Dr 1               ;   C set   = failure
00001Dr 1               ;
00001Dr 1               ; Caller:
00001Dr 1               ;   must hold proc_gate
00001Dr 1               ;
00001Dr 1               ; Notes:
00001Dr 1               ;   Unified spawn keeps proc_gate until the fully initialized child is
00001Dr 1               ;   published as PROC_NEW or rolled back.
00001Dr 1               ; ------------------------------------------------------------
00001Dr 1               
00001Dr 1               .proc proc_alloc_preloaded_unpublished
00001Dr 1  38               sec                         ; unpublished spawn mode
00001Er 1  4C rr rr         jmp proc_alloc_preloaded_common
000021r 1               .endproc
000021r 1               
000021r 1               ; ------------------------------------------------------------
000021r 1               ; proc_alloc_preloaded_common
000021r 1               ;
000021r 1               ; Common PID/context/PCB/FD initialization for boot and resident spawn.
000021r 1               ;
000021r 1               ; Entry carry:
000021r 1               ;   clear = initialize default process descriptors and publish PROC_NEW
000021r 1               ;   set   = clear all descriptors and leave proc_state as PROC_EMPTY
000021r 1               ;
000021r 1               ; Locking:
000021r 1               ;   caller owns proc_gate
000021r 1               ;   this routine acquires file_io_gate
000021r 1               ;   lock order is PROC -> FILE_IO
000021r 1               ; ------------------------------------------------------------
000021r 1               
000021r 1               .proc proc_alloc_preloaded_common
000021r 1                   ; STA/STX/STY preserve carry, so the wrapper-selected mode remains
000021r 1                   ; available after saving the call arguments.
000021r 1  8D rr rr         sta proc_alloc_parent_pid
000024r 1  8E rr rr         stx proc_alloc_entryL
000027r 1  8C rr rr         sty proc_alloc_entryH
00002Ar 1               
00002Ar 1  90 07            bcc @boot_mode
00002Cr 1               
00002Cr 1  A9 01            lda #PROC_ALLOC_MODE_UNPUBLISHED
00002Er 1  8D rr rr         sta proc_alloc_mode
000031r 1  80 03            bra @allocate
000033r 1               
000033r 1               @boot_mode:
000033r 1  9C rr rr         stz proc_alloc_mode
000036r 1               
000036r 1               @allocate:
000036r 1  20 rr rr         jsr proc_find_free_pid
000039r 1  90 75            bcc @fail
00003Br 1               
00003Br 1                   ; X = allocated PID. Allocate the MMU context before publishing.
00003Br 1  20 rr rr         jsr ctx_alloc_preloaded_for_pid
00003Er 1  B0 70            bcs @fail
000040r 1               
000040r 1  9D rr rr         sta proc_context,x
000043r 1               
000043r 1  AD rr rr         lda proc_alloc_entryL
000046r 1  9D rr rr         sta proc_entryL,x
000049r 1               
000049r 1  AD rr rr         lda proc_alloc_entryH
00004Cr 1  9D rr rr         sta proc_entryH,x
00004Fr 1               
00004Fr 1  AD rr rr         lda proc_alloc_parent_pid
000052r 1  9D rr rr         sta proc_parent_pid,x
000055r 1               
000055r 1  A9 FF            lda #$FF
000057r 1  9D rr rr         sta proc_sp,x
00005Ar 1               
00005Ar 1  A9 00            lda #WAIT_NONE
00005Cr 1  9D rr rr         sta wait_reason,x
00005Fr 1  9E rr rr         stz wait_object,x
000062r 1  9E rr rr         stz proc_signal_pending,x
000065r 1               
000065r 1  A9 00            lda #EXIT_OK
000067r 1  9D rr rr         sta proc_exit_code,x
00006Ar 1               
00006Ar 1  20 rr rr         jsr proc_clear_launch_state
00006Dr 1               
00006Dr 1  A9 00            lda #PROC_FLAG_NONE
00006Fr 1  9D rr rr         sta proc_flags,x
000072r 1               
