000000r 1               .import proc_gate_acquire
000000r 1               .import proc_gate_release
000000r 1               .import proc_gate_cancel_wait
000000r 1               .import proc_gate
000000r 1               .import proc_gate_owner
000000r 1               .import fd_init_process
000000r 1               .import fd_clear_process_slots
000000r 1               .import fd_close_process
000000r 1               .import file_io_gate_acquire
000000r 1               .import file_io_gate_release
000000r 1               .import file_io_gate_cancel_wait
000000r 1               .import file_io_gate
000000r 1               .import file_io_gate_owner
000000r 1               
000000r 1               .import active_pid
000000r 1               .import proc_state
000000r 1               .import proc_context
000000r 1               .import proc_sp
000000r 1               .import proc_entryL
000000r 1               .import proc_entryH
000000r 1               .import proc_flags
000000r 1               .import proc_parent_pid
000000r 1               .import proc_signal_pending
000000r 1               .import proc_exit_code
000000r 1               .import proc_launch_id
000000r 1               .import proc_launch_line_len
000000r 1               .import timer_free
