000000r 1               ; ============================================================
000000r 1               ; mailbox.asm
000000r 1               ; NEOX - RP2350 mailbox transport helpers
000000r 1               ;
000000r 1               ; Purpose:
000000r 1               ;   Provides only the low-level kernel-side mailbox transport
000000r 1               ;   used to communicate with the RP2350 co-processor.
000000r 1               ;
000000r 1               ; Architecture:
000000r 1               ;   - Request/result block lives in shared RAM at RP_REQ_BASE.
000000r 1               ;   - Doorbell register lives in shared I/O space.
000000r 1               ;   - rp_lock serializes mailbox ownership.
000000r 1               ;
000000r 1               ; Design rule:
000000r 1               ;   This file is mechanism only. Command-specific mailbox usage
000000r 1               ;   belongs in separate modules such as rp_console_io.asm.
000000r 1               ; ============================================================
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               
000000r 1               .include "bios.inc"
